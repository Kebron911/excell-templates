---
/**
 * EmailGate.astro — embeddable email capture form.
 *
 * Sub-export: @str/email-gate/EmailGate.astro
 *
 * The component renders a self-contained <form>. The caller is responsible
 * for wiring a server endpoint (e.g. /api/subscribe) that calls submit()
 * from @str/email-gate and returns JSON { ok, id } or { ok, error }.
 *
 * Props:
 *   siteId       — 'guests' | 'buyers' | 'host' | 'ops'
 *   listSegment  — audience segment label (e.g. "main", "waitlist")
 *   action       — form POST endpoint, default "/api/subscribe"
 *   source       — optional attribution tag forwarded to submit()
 *   heading      — optional heading text
 *   placeholder  — email input placeholder text
 *   cta          — submit button label
 *   successMsg   — message shown after successful submission
 */

export interface Props {
  siteId: 'guests' | 'buyers' | 'host' | 'ops';
  listSegment: string;
  action?: string;
  source?: string;
  heading?: string;
  placeholder?: string;
  cta?: string;
  successMsg?: string;
}

const {
  siteId,
  listSegment,
  action = '/api/subscribe',
  source = '',
  heading = 'Stay in the loop',
  placeholder = 'you@example.com',
  cta = 'Subscribe',
  successMsg = 'You\'re in! Check your inbox to confirm.',
} = Astro.props;
---

<div class="email-gate" data-site-id={siteId}>
  {/* Email gate paused — cluster lead-router (n8n) being wired this week.
      Revert this stub when STR_Cluster_Lead_Router is live + tested. */}
  <div class="email-gate__paused" style="border:1px solid rgba(0,0,0,.12); padding:12px 14px; border-radius:6px;">
    {heading && <p class="email-gate__heading" style="margin:0 0 6px 0; font-weight:600;">{heading}</p>}
    <p style="margin:0; font-size:.9rem; line-height:1.45;">
      Email signups are paused while we finish wiring delivery. Email
      <a href="mailto:hello@thestrledger.com">hello@thestrledger.com</a>
      if you want this resource now.
    </p>
  </div>
</div>

<script>
  // Progressive enhancement: submit via fetch, show inline feedback.
  // Falls back to a full page POST if JS is unavailable.
  document.querySelectorAll<HTMLFormElement>('[data-email-gate-form]').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const successEl = form.querySelector<HTMLElement>('.email-gate__success');
      const errorEl = form.querySelector<HTMLElement>('.email-gate__error');
      const btn = form.querySelector<HTMLButtonElement>('button[type="submit"]');

      if (!successEl || !errorEl) return;

      // Reset state
      successEl.hidden = true;
      errorEl.hidden = true;
      if (btn) btn.disabled = true;

      try {
        const res = await fetch(form.action, {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams(new FormData(form) as any).toString(),
        });

        const data: { ok: boolean; error?: string } = await res.json();

        if (data.ok) {
          successEl.hidden = false;
          form.reset();
        } else {
          errorEl.textContent = data.error ?? 'Something went wrong. Please try again.';
          errorEl.hidden = false;
          if (btn) btn.disabled = false;
        }
      } catch {
        errorEl.textContent = 'Network error. Please try again.';
        errorEl.hidden = false;
        if (btn) btn.disabled = false;
      }
    });
  });
</script>

<style>
  .email-gate {
    font-family: inherit;
  }

  .email-gate__heading {
    margin: 0 0 0.5rem;
    font-weight: 600;
  }

  .email-gate__row {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .email-gate__input {
    flex: 1 1 200px;
    padding: 0.5rem 0.75rem;
    border: 1px solid #d1d5db;
    border-radius: 0.375rem;
    font-size: 0.875rem;
  }

  .email-gate__btn {
    padding: 0.5rem 1rem;
    background: #2563eb;
    color: #fff;
    border: none;
    border-radius: 0.375rem;
    font-size: 0.875rem;
    cursor: pointer;
    white-space: nowrap;
  }

  .email-gate__btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .email-gate__success {
    margin-top: 0.5rem;
    color: #16a34a;
    font-size: 0.875rem;
  }

  .email-gate__error {
    margin-top: 0.5rem;
    color: #dc2626;
    font-size: 0.875rem;
  }
</style>

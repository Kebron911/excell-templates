---
import { loadCatalog } from '@str/catalog';
import CatalogToolCard from './CatalogToolCard.astro';
import { findCrossSiteRelated } from './catalog-queries.js';

interface Props {
  /** Source tool id (e.g. "guests.house-rules-pdf"). Used as the anchor. */
  toolId: string;
  heading?: string;
  /** Max tools shown. Default 4. */
  limit?: number;
}

const { toolId, heading = 'Related tools across the empire', limit = 4 } = Astro.props;

const { catalog } = loadCatalog();
const sitesById = new Map(catalog.sites.map((s) => [s.id, s] as const));
const candidates = findCrossSiteRelated(catalog, toolId, limit);
---

{candidates.length > 0 && (
  <section class="my-12">
    <h2 class="text-xl font-semibold mb-4">{heading}</h2>
    <ul class="grid gap-3 sm:grid-cols-2">
      {candidates.map((t) => {
        const site = sitesById.get(t.site)!;
        return (
          <li>
            <CatalogToolCard
              tool={t}
              site={site}
              crossSite={true}
              event="upsell_clicked"
            />
          </li>
        );
      })}
    </ul>
  </section>
)}

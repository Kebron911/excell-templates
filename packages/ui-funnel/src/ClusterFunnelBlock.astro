---
// ClusterFunnelBlock — cross-cluster funnel. Links to strbuyers / strhost /
// strops / strguests with one-line value props. Hides the matching site for
// the current cluster position.
// Per design spec section 18 (cluster bridge mechanism #5).
//
// Relocated from chrome/ to funnel/ (semantic: this is a conversion/funnel
// component, not a chrome/layout component).

import type { SiteConfig } from '@str/seo';

interface Props {
  siteConfig: SiteConfig;
  currentCluster: 'acquisition' | 'math' | 'operations' | 'guest-xp';
}

const { currentCluster } = Astro.props;

const clusters = [
  {
    id: 'acquisition',
    name: 'strbuyers.tools',
    blurb: 'Pre-buy: DSCR, market score, comp analysis.',
    href: 'https://strbuyers.tools',
  },
  {
    id: 'math',
    name: 'strhost.tools',
    blurb: 'Analyzing: profit, RevPAR, break-even.',
    href: 'https://strhost.tools',
  },
  {
    id: 'operations',
    name: 'strops.tools',
    blurb: 'Running: turnover, dispatch, smart locks.',
    href: 'https://strops.tools',
  },
  {
    id: 'guest-xp',
    name: 'strguests.tools',
    blurb: 'Optimizing: house rules, welcome books, AI replies.',
    href: 'https://strguests.tools',
  },
];

const others = clusters.filter(c => c.id !== currentCluster);
---
<section class="cluster-funnel-block bg-parchment-alt border-y border-rule">
  <div class="mx-auto max-w-6xl px-5 py-7">
    <p class="label text-navy">More tools across the STR cluster</p>
    <div class="mt-4 grid grid-cols-1 md:grid-cols-3 gap-4">
      {others.map(c => (
        <a
          href={c.href}
          class="group block rounded-md border border-rule bg-parchment-light p-4 no-underline hover:border-[color:var(--accent-500)] hover:shadow-card transition-all duration-std"
        >
          <p class="wordmark text-navy group-hover:text-[color:var(--accent-700)]">{c.name}</p>
          <p class="mt-2 text-small text-ink-2 leading-snug">{c.blurb}</p>
          <p class="mt-3 text-caption text-[color:var(--accent-700)] group-hover:text-[color:var(--accent-500)]">
            Visit
            <span class="inline-block transition-transform duration-std group-hover:translate-x-0.5" aria-hidden="true"> →</span>
          </p>
        </a>
      ))}
    </div>
  </div>
</section>

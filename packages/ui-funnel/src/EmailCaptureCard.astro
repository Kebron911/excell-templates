---
// EmailCaptureCard — inline content-styled card. Posts to ESP webhook from
// the static client. UTM-tagged by tool slug.
//
// One per page. Inline placement only — no popup, no exit-intent, no sticky.
// Reads as content, not as an ad break.
//
// Email-gate decoupling: accepts an `endpoint` prop so the consuming site
// provides the webhook URL. The payload shape is preserved for compatibility
// with existing ESP webhook handlers (email, magnet, source, tool, UTM fields, ts).

import type { SiteConfig } from '@str/seo';

interface Props {
  siteConfig: SiteConfig;
  /** ESP magnet identifier — tags the subscription on the ESP side. */
  magnet: string;
  /** Tool slug, embedded in UTM source/content for attribution. */
  toolSlug?: string;
  headline?: string;
  blurb?: string;
  cta?: string;
  /**
   * URL of the server endpoint that handles the email-capture POST.
   * Defaults to PUBLIC_ESP_WEBHOOK env var (client-side) for backward compat.
   * Pass an explicit URL to decouple from any specific ESP backend.
   */
  endpoint?: string;
}

const {
  siteConfig,
  magnet,
  toolSlug = 'unknown',
  headline = 'Free Welcome Book template — fill in once, print forever',
  blurb = "We'll email you the editable Welcome Book master template. Branded printable, 8 sections, no signup gymnastics.",
  cta = 'Email me the template',
  endpoint,
} = Astro.props;
---
<aside
  class="email-capture-card my-7 rounded-md border border-rule bg-parchment-light p-5 print:hidden"
  aria-label="Get free guest-XP templates by email"
  data-site-id={siteConfig.siteId}
>
  <div class="flex flex-col sm:flex-row sm:items-center gap-4">
    <div class="flex-1 min-w-0">
      <p class="font-serif text-h3 text-navy leading-snug">{headline}</p>
      <p class="mt-1 text-small text-ink-2 leading-snug">{blurb}</p>
    </div>

    <form
      class="flex flex-col sm:flex-row gap-2 sm:w-auto sm:items-stretch"
      data-email-capture
      data-magnet={magnet}
      data-tool={toolSlug}
      data-site={siteConfig.siteId}
      data-endpoint={endpoint ?? ''}
      method="post"
      novalidate
    >
      <label class="sr-only" for={`email-${magnet}`}>Email address</label>
      <input
        id={`email-${magnet}`}
        name="email"
        type="email"
        required
        autocomplete="email"
        placeholder="you@yourdomain.com"
        class="rounded-md border border-rule bg-parchment px-4 py-2 text-ui text-navy placeholder:text-ink-3 focus:outline-none focus:border-[color:var(--accent-500)] focus:shadow-focus"
      />
      <button
        type="submit"
        class="rounded-md bg-navy text-parchment px-5 py-2 text-ui hover:bg-navy-tint transition-colors duration-std focus:outline-none focus:shadow-focus"
      >
        {cta}
      </button>
    </form>
  </div>
  <p
    class="mt-3 text-caption text-ink-3 leading-snug"
    data-email-capture-status
    role="status"
    aria-live="polite"
  >
    No spam. One template per email. Unsubscribe anytime.
  </p>
</aside>

<script>
  // Resolve endpoint: prefer explicit data-endpoint, fall back to PUBLIC_ESP_WEBHOOK env var.
  // Payload shape is preserved for backward compat with existing ESP webhook handlers.
  document.querySelectorAll<HTMLFormElement>('form[data-email-capture]').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const input = form.querySelector<HTMLInputElement>('input[name="email"]');
      const status = form.parentElement?.querySelector<HTMLElement>('[data-email-capture-status]');
      const email = input?.value?.trim();
      const magnet = form.dataset.magnet ?? '';
      const tool = form.dataset.tool ?? '';
      const site = form.dataset.site ?? '';

      // Resolve webhook: explicit endpoint prop > env var fallback
      const webhook =
        form.dataset.endpoint ||
        (import.meta.env.PUBLIC_ESP_WEBHOOK as string | undefined) ||
        '';

      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        if (status) status.textContent = 'Please enter a valid email.';
        return;
      }

      // Payload shape preserved — ESP webhook handlers keep working at Task 8 wire-up.
      const payload = {
        email,
        magnet,
        source: site || 'strguests.tools',
        tool,
        utm_source: `${site || 'strguests'}-tools`,
        utm_medium: 'email-capture',
        utm_content: tool,
        ts: Date.now(),
      };

      try {
        if (webhook) {
          await fetch(webhook, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
            keepalive: true,
          });
        } else {
          console.warn('[EmailCaptureCard] No endpoint configured; payload:', payload);
        }
        (window as any).gtag?.('event', 'email_captured', { tool, magnet });
        if (status) status.textContent = 'Got it. Watch your inbox.';
        if (input) input.value = '';
      } catch (err) {
        if (status) status.textContent = 'Something went sideways. Try again in a minute.';
      }
    });
  });
</script>

---
import { loadCatalog, type SiteId, type ToolCategory } from '@str/catalog';
import CatalogToolCard from './CatalogToolCard.astro';
import { findSiteTools } from './catalog-queries.js';

interface Props {
  /** Site id to show tools for. Required when in-site rendering. */
  siteId: SiteId;
  /** Heading shown above the grid. Pass empty string to suppress. */
  heading?: string;
  /** Filter to a specific category. */
  category?: ToolCategory;
  /** Max number of tools to render. Default 12. */
  limit?: number;
  /** When true, links use full domain URLs. */
  crossSite?: boolean;
}

const {
  siteId,
  heading = 'All tools',
  category,
  limit = 12,
  crossSite = false,
} = Astro.props;

const { catalog } = loadCatalog();
const site = catalog.sites.find((s) => s.id === siteId);
const tools = findSiteTools(catalog, siteId, { category, limit });
---

{site && tools.length > 0 && (
  <section class="my-10">
    {heading && <h2 class="text-2xl font-semibold mb-5">{heading}</h2>}
    <ul class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {tools.map((t) => (
        <li>
          <CatalogToolCard tool={t} site={site} crossSite={crossSite} />
        </li>
      ))}
    </ul>
  </section>
)}

---
import type { Tool, Site } from '@str/catalog';

interface Props {
  tool: Tool;
  site: Site;
  /** Optional analytics event override (defaults to tool.ga4Event). */
  event?: string;
  /** Extra class names appended to the card root. */
  class?: string;
  /** When true, link uses the tool's absolute domain (https://...). */
  crossSite?: boolean;
}

const {
  tool,
  site,
  event,
  class: extraClass = '',
  crossSite = false,
} = Astro.props;

const href = crossSite ? `https://${site.domain}${tool.path}` : tool.path;
const tierBadge =
  tool.paidTier === 'paid' ? 'PAID' :
  tool.paidTier === 'pro' ? 'PRO' :
  tool.paidTier === 'lead-magnet' ? 'FREE' :
  null;
---
<a
  href={href}
  class={`block border rounded-lg p-4 hover:shadow-md transition ${extraClass}`}
  data-event={event ?? `tool_card_clicked`}
  data-tool-id={tool.id}
  data-tool-site={tool.site}
  data-tool-category={tool.category}
>
  <div class="flex items-start justify-between gap-2">
    <div class="text-xs uppercase tracking-wide text-gray-500">{site.displayName}</div>
    {tierBadge && (
      <span class="text-[10px] font-semibold px-1.5 py-0.5 rounded bg-gray-100 text-gray-700">
        {tierBadge}
      </span>
    )}
  </div>
  <div class="font-medium mt-1">{tool.shortTitle ?? tool.title}</div>
  <p class="text-sm text-gray-600 mt-1 line-clamp-2">{tool.description}</p>
</a>

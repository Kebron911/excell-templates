{
  "name": "@str/seo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "seo-sitemap-emit": "./dist/cli/sitemap-emit.js",
    "seo-cannibalization-check": "./dist/cli/cannibalization-check.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --project tsconfig.typecheck.json",
    "sitemap:emit": "node ./dist/cli/sitemap-emit.js",
    "cannibalization:check": "node ./dist/cli/cannibalization-check.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@str/catalog": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "typescript": "^5.5.3",
    "vitest": "^3.0.0"
  }
}

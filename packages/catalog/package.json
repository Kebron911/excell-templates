{
  "name": "@str/catalog",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "catalog-emit": "./dist/cli/emit.js",
    "catalog-validate": "./dist/cli/validate.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "default": "./dist/schema.js"
    },
    "./events": {
      "types": "./dist/events.d.ts",
      "default": "./dist/events.js"
    }
  },
  "files": ["dist", "src", "data"],
  "scripts": {
    "build": "tsc && node ./dist/cli/emit.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --project tsconfig.typecheck.json",
    "validate": "node ./dist/cli/validate.js",
    "emit": "node ./dist/cli/emit.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "typescript": "^5.5.3",
    "vitest": "^3.0.0"
  }
}

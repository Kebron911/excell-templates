---
// Sidebar — related nav links. Uses siteConfig.nav for related items.
// Accepts optional `current` prop to exclude the active page from the list.

import type { SiteConfig } from '@str/seo';

interface Props {
  siteConfig: SiteConfig;
  /** href of the current page — excluded from related links. */
  current?: string;
}

const { siteConfig, current } = Astro.props;

const others = siteConfig.nav
  .filter(item => item.href !== current)
  .slice(0, 6);
---
<aside class="related-generators" aria-label="Related pages">
  <p class="label text-navy">Related pages</p>

  <ul class="mt-4 space-y-3">
    {others.map(item => (
      <li>
        <a
          href={item.href}
          class="block group rounded-md border border-rule bg-parchment-light p-4 no-underline hover:border-[color:var(--accent-500)] hover:shadow-card transition-all duration-std"
        >
          <p class="text-ui text-navy group-hover:text-[color:var(--accent-700)] font-semibold">{item.label}</p>
        </a>
      </li>
    ))}
  </ul>
</aside>

---
// Header — primary site shell. Nav items from siteConfig.nav.
// Named slot: header-cta — replace default CTA area with site-specific content.

import type { SiteConfig } from '@str/seo';
import Wordmark from './Wordmark.astro';

interface Props {
  siteConfig: SiteConfig;
}

const { siteConfig } = Astro.props;
---
<header class="border-b border-rule bg-parchment">
  <div class="mx-auto max-w-6xl px-5 py-5 flex items-center justify-between gap-6">
    <Wordmark siteConfig={siteConfig} size="md" theme="navy" class="shrink-0" />

    <nav class="hidden lg:flex items-center gap-6" aria-label="Primary">
      {siteConfig.nav.map(item => (
        <a
          href={item.href}
          class="text-ui text-ink-2 no-underline hover:text-[color:var(--accent-700)] transition-colors duration-std whitespace-nowrap"
        >
          {item.label}
        </a>
      ))}
      <slot name="header-cta" />
    </nav>

    <details class="lg:hidden relative">
      <summary class="list-none cursor-pointer p-2 -mr-2" aria-label="Open menu">
        <svg width="22" height="22" viewBox="0 0 22 22" aria-hidden="true">
          <path d="M3 6h16M3 11h16M3 16h16" stroke="currentColor" stroke-width="1.5" fill="none" />
        </svg>
      </summary>
      <div class="absolute right-0 top-full mt-2 w-60 bg-parchment-light border border-rule rounded-md shadow-lifted py-2 z-10">
        {siteConfig.nav.map(item => (
          <a
            href={item.href}
            class="block px-4 py-2 text-ui text-ink-2 no-underline hover:bg-parchment-alt hover:text-[color:var(--accent-700)]"
          >
            {item.label}
          </a>
        ))}
      </div>
    </details>
  </div>
</header>

---
// Wordmark — brand identity component.
// Renders the wordmark using siteConfig.brand.wordmark as the main text.
// Treatment: font-serif medium reads as editorial/hospitality-warm.
// Per cluster style guide §1, hierarchy is {Brand Name} main + .tld trailing.

import type { SiteConfig } from '@str/seo';

interface Props {
  siteConfig: SiteConfig;
  /** Visual scale. */
  size?: 'sm' | 'md' | 'lg';
  /** Surface the wordmark sits on; controls main text color. */
  theme?: 'navy' | 'parchment';
  /** Render as a link to home (default true). When false, plain text. */
  asLink?: boolean;
  /** Optional href override (defaults to "/"). */
  href?: string;
  /** Class to extend the wrapping element. */
  class?: string;
}

const {
  siteConfig,
  size = 'md',
  theme = 'navy',
  asLink = true,
  href = '/',
  class: className = '',
} = Astro.props;

const sizes = {
  sm: { main: 'text-[20px]', tail: 'text-[10px]', track: 'tracking-[0.28em]' },
  md: { main: 'text-[28px]', tail: 'text-[12px]', track: 'tracking-[0.28em]' },
  lg: { main: 'text-[40px]', tail: 'text-[14px]', track: 'tracking-[0.28em]' },
};

const themes = {
  navy:      { main: 'text-[color:var(--accent-700)]', tail: 'text-ink-3',                dot: 'text-[color:var(--accent-500)]' },
  parchment: { main: 'text-[color:var(--accent-500)]', tail: 'text-parchment opacity-70', dot: 'text-parchment' },
};

const s = sizes[size];
const t = themes[theme];

// Derive tld suffix from canonical URL (e.g. "https://strguests.tools" → "tools")
const tld = siteConfig.url.canonical.split('.').pop() ?? 'tools';

const Tag = asLink ? 'a' : 'span';
const linkProps = asLink
  ? { href, 'aria-label': `${siteConfig.brand.name} — home`, class: 'no-underline' }
  : {};
---
<Tag
  {...linkProps}
  class:list={[
    'inline-flex items-baseline gap-1',
    className,
  ]}
>
  <span
    class:list={[
      'font-serif font-medium leading-none whitespace-nowrap',
      s.main,
      t.main,
    ]}
  >
    {siteConfig.brand.wordmark}
  </span>
  <span
    class:list={[
      'font-sans uppercase font-semibold leading-none',
      s.tail,
      s.track,
    ]}
    aria-hidden="true"
  >
    <span class={t.dot}>.</span><span class={t.tail}>{tld}</span>
  </span>
</Tag>

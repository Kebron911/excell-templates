---
// Footer — site shell bottom. Footer sections from siteConfig.footer.sections.
// Named slot: footer-extra — append site-specific content after footer grid.

import type { SiteConfig } from '@str/seo';
import Wordmark from './Wordmark.astro';

interface Props {
  siteConfig: SiteConfig;
}

const { siteConfig } = Astro.props;

const today = new Date();
const lastUpdated = today.toISOString().slice(0, 10);
---
<footer class="site-footer surface-navy mt-7">
  <div class="mx-auto max-w-6xl px-5 py-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 footer-nav">
      <div>
        <Wordmark siteConfig={siteConfig} size="md" theme="parchment" asLink={false} />
        <p class="mt-3 text-small text-parchment max-w-xs leading-snug">
          {siteConfig.brand.tagline}
        </p>
      </div>

      {siteConfig.footer.sections.map(section => (
        <div>
          <p class="label text-[color:var(--accent-500)]">{section.title}</p>
          <ul class="mt-3 space-y-2">
            {section.links.map(link => (
              <li>
                <a
                  href={link.href}
                  class="text-small text-parchment no-underline hover:underline hover:decoration-[color:var(--accent-500)] underline-offset-2"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <slot name="footer-extra" />

    <hr class="accent-rule full mt-7 border-0 h-px" style="background: var(--accent-500);" />

    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-3">
      <p class="text-caption text-parchment opacity-70">
        &copy; {today.getFullYear()} {siteConfig.brand.name}. Generated content is for informational purposes only — not legal or tax advice.
      </p>
      <p class="text-caption text-parchment opacity-70 font-mono">
        Last updated <time datetime={lastUpdated}>{lastUpdated}</time>
      </p>
    </div>
  </div>
</footer>

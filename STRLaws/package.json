{
  "name": "strlaws",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "typecheck": "astro check && tsc --noEmit && tsc -p server/tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test --project=chromium",
    "test:e2e": "playwright test --project=chromium",
    "e2e:install": "playwright install --with-deps chromium",
    "lint": "eslint --ext .ts,.tsx,.astro src tests server",
    "server:dev": "tsx watch server/index.ts",
    "server:build": "tsc -p server/tsconfig.json",
    "server:start": "node server/dist/index.js",
    "db:migrate": "tsx server/db/migrate.ts",
    "db:seed": "tsx scripts/seed-cities.ts",
    "scrape:once": "tsx scripts/scrape-once.ts",
    "extract:once": "tsx scripts/extract-once.ts"
  },
  "dependencies": {
    "@str/email-gate": "workspace:*",
    "@str/format": "workspace:*",
    "@str/seo": "workspace:*",
    "@str/ui-chrome": "workspace:*",
    "@str/url-state": "workspace:*",
    "@anthropic-ai/sdk": "^0.30.0",
    "@astrojs/mdx": "^5.0.4",
    "@astrojs/react": "^5.0.4",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/tailwind": "^6.0.2",
    "@resvg/resvg-js": "^2.6.2",
    "astro": "^6.2.2",
    "astro-seo": "^0.8.4",
    "cheerio": "^1.0.0",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "mysql2": "^3.10.0",
    "playwright": "^1.45.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^4.0.0",
    "satori": "^0.10.13",
    "sharp": "^0.33.4",
    "stripe": "^17.0.0",
    "tailwindcss": "^3.4.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "eslint": "^8.57.0",
    "eslint-plugin-astro": "^1.2.3",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}

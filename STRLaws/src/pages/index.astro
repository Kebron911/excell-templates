---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getAllStates } from '@/lib/city-data';
import { buildOrganizationSchema, buildWebSiteSchema } from '@/lib/seo';

const states = await getAllStates();
const schemas = [buildOrganizationSchema(), buildWebSiteSchema()];
---

<BaseLayout
  title="STRLaws — National Short-Term Rental Regulation Database"
  description="Current short-term rental regulations for all 50 US states and 500+ cities. Free permit costs, tax rates, occupancy caps, and ban status — verified and updated."
  schema={schemas}
>
  <section class="mx-auto max-w-6xl px-4 py-16 text-center">
    <h1 class="text-hero font-wordmark text-navy mb-6">
      US Short-Term Rental Laws
    </h1>
    <p class="text-lead text-ink-2 max-w-2xl mx-auto mb-8">
      Free, current regulation data for all 50 states. Permit costs, occupancy caps,
      tax rates, and ban status — verified weekly.
    </p>
    <a
      href="/alerts"
      class="inline-block bg-navy text-parchment px-6 py-3 rounded-md text-ui hover:bg-navy-tint"
    >
      Get alerts when your city's laws change
    </a>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-12">
    <h2 class="text-h2 font-wordmark text-navy mb-6">Browse by State</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3">
      {states.map((state) => (
        <a
          href={`/${state.slug}`}
          class="bg-white border border-rule rounded-md p-3 hover:border-accent hover:shadow-card transition-all"
        >
          <div class="text-body font-medium text-navy">{state.name}</div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

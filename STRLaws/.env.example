# STRLaws — environment variables
# Copy to .env.local for dev; production values live in Hostinger env panel.

# --- Database ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=strlaws
DB_PASSWORD=
DB_NAME=strlaws

# --- Anthropic (Claude with prompt caching) ---
ANTHROPIC_API_KEY=

# --- Stripe (premium billing) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_ANNUAL=

# --- Resend (transactional alerts) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=alerts@strlaws.com

# --- Influencersoft (marketing email + funnels + affiliates) ---
INFLUENCERSOFT_API_KEY=
INFLUENCERSOFT_LIST_ID_ALERTS=
INFLUENCERSOFT_BASE_URL=

# --- Firecrawl (fallback scraper) ---
FIRECRAWL_API_KEY=

# --- Admin gate ---
ADMIN_TOKEN=

# --- Slack (review queue notifications) ---
SLACK_WEBHOOK_URL=

# --- Public (build-time, exposed to client) ---
PUBLIC_GA4_ID=
PUBLIC_SITE_URL=https://strlaws.com

---
import Layout from '@/components/chrome/Layout.astro';
import ClusterFunnelBlock from '@/components/chrome/ClusterFunnelBlock.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { buildItemList, buildBreadcrumb } from '@/lib/seo';

const products = (await getCollection('products') as CollectionEntry<'products'>[])
  .sort((a, b) => a.data.sku.localeCompare(b.data.sku));

const itemList = buildItemList({
  name: 'The STR Ledger — workbook catalog',
  items: products.map((p) => ({
    name: p.data.title,
    url: `/products/${p.data.slug}/`,
  })),
});

const breadcrumb = buildBreadcrumb([
  { name: 'Home', url: '/' },
  { name: 'Products', url: '/products/' },
]);
---
<Layout
  title="Workbooks — The STR Ledger"
  description="Excel + PDF workbooks for short-term rental operators. Tax, ops, pricing, acquisition. Browse the full catalog."
  path="/products"
  jsonLd={[itemList, breadcrumb]}
>
  <section class="bg-parchment">
    <div class="mx-auto max-w-6xl px-5 pt-12 pb-7">
      <p class="label text-gold-deep">Catalog</p>
      <h1 class="mt-3 font-serif text-h1 text-navy max-w-3xl leading-tight">
        Workbooks<span class="period-gold">.</span>
      </h1>
      <p class="mt-4 text-lead text-ink-2 max-w-2xl">
        Excel + PDF templates for the math part of running a short-term rental portfolio. Schedule E-ready. Formula-tight. Built for 3-10 properties.
      </p>
    </div>
  </section>

  <section class="bg-parchment-light border-t border-rule">
    <div class="mx-auto max-w-6xl px-5 py-9">
      <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {products.map((p) => (
          <li>
            <a
              href={`/products/${p.data.slug}/`}
              class="group block h-full rounded-md border border-rule bg-parchment p-5 no-underline hover:border-gold hover:shadow-card transition-all"
            >
              <p class="font-mono text-caption text-gold-deep tracking-widest uppercase">{p.data.sku}</p>
              <p class="mt-2 font-serif text-h3 text-navy leading-snug">{p.data.title}</p>
              <p class="mt-2 text-small text-ink-2 leading-snug">{p.data.description}</p>
              <p class="mt-4 flex items-center justify-between">
                <span class="font-mono text-ui text-navy">${p.data.price}</span>
                <span class="text-caption text-gold-deep group-hover:text-gold">View →</span>
              </p>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <ClusterFunnelBlock />
</Layout>

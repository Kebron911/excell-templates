---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import Layout from '@/components/chrome/Layout.astro';
import { buildProduct, buildFAQPage, buildBreadcrumb } from '@/lib/seo';

export async function getStaticPaths() {
  const products = await getCollection('products') as CollectionEntry<'products'>[];
  return products.map((p) => ({
    params: { slug: p.data.slug },
    props: { product: p },
  }));
}

const { product } = Astro.props as { product: CollectionEntry<'products'> };
const { data } = product;
const { Content } = await render(product);

const productLd = buildProduct({
  name: data.title,
  description: data.description,
  slug: data.slug,
  sku: data.sku,
  price: data.price,
  image: data.image,
  gtin: data.gtin,
  category: data.category,
  availability: data.availability,
  aggregateRating: data.aggregateRating,
});

const faqLd = data.faqs.length > 0
  ? buildFAQPage(data.faqs.map((f: { q: string; a: string }) => ({ question: f.q, answer: f.a })))
  : null;

const breadcrumb = buildBreadcrumb([
  { name: 'Home', url: '/' },
  { name: 'Products', url: '/products/' },
  { name: data.title, url: `/products/${data.slug}/` },
]);

const lds: Array<Record<string, unknown>> = [productLd, breadcrumb];
if (faqLd) lds.push(faqLd);

const title = `${data.title} — ${data.sku} — The STR Ledger`;
---
<Layout
  title={title}
  description={data.description}
  path={`/products/${data.slug}`}
  jsonLd={lds}
>
  <section class="bg-parchment">
    <div class="mx-auto max-w-4xl px-5 pt-10 pb-7">
      <nav class="text-caption text-ink-3" aria-label="Breadcrumb">
        <a href="/" class="no-underline hover:underline">Home</a>
        <span aria-hidden="true"> / </span>
        <a href="/products/" class="no-underline hover:underline">Products</a>
        <span aria-hidden="true"> / </span>
        <span class="text-ink-2">{data.sku}</span>
      </nav>
      <p class="mt-5 font-mono text-caption text-gold-deep tracking-widest uppercase">{data.sku} · {data.category ?? 'Workbook'}</p>
      <h1 class="mt-2 font-serif text-h1 text-navy leading-tight">
        {data.title}<span class="period-gold">.</span>
      </h1>
      <p class="mt-4 text-lead text-ink-2 max-w-2xl">{data.description}</p>

      <div class="mt-7 flex flex-wrap items-center gap-4 border-t border-b border-rule py-5">
        <div>
          <p class="label text-gold-deep">Price</p>
          <p class="mt-1 font-mono text-h2 text-navy">${data.price}</p>
        </div>
        <div class="ml-auto flex flex-wrap gap-3">
          <a
            href="#buy"
            class="inline-flex items-center gap-2 bg-navy text-parchment px-5 py-3 rounded-md no-underline text-ui hover:bg-navy-tint transition-colors"
          >
            Get the workbook
            <span class="text-gold" aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <article class="bg-parchment">
    <div class="mx-auto max-w-3xl px-5 py-9 prose">
      <Content />

      {data.inside.length > 0 && (
        <section class="mt-7">
          <h2 class="font-serif text-h2 text-navy">What's inside</h2>
          <ul class="mt-3 space-y-2 list-disc pl-5 text-ink-2">
            {data.inside.map((item: string) => (<li>{item}</li>))}
          </ul>
        </section>
      )}

      {data.faqs.length > 0 && (
        <section class="mt-9">
          <h2 class="font-serif text-h2 text-navy">FAQ</h2>
          <dl class="mt-4 space-y-5">
            {data.faqs.map((f: { q: string; a: string }) => (
              <div>
                <dt class="font-serif text-h3 text-navy leading-snug">{f.q}</dt>
                <dd class="mt-2 text-body text-ink-2 leading-relaxed">{f.a}</dd>
              </div>
            ))}
          </dl>
        </section>
      )}

      <section id="buy" class="mt-9 border-t border-rule pt-7">
        <h2 class="font-serif text-h2 text-navy">Get the workbook</h2>
        <p class="mt-3 text-body text-ink-2 leading-relaxed">
          Format: Excel .xlsx + how-to PDF. Excel 2016+, Excel 365, Google Sheets compatible. Instant download after checkout. 14-day refund, no questions.
        </p>
        <a
          href={`mailto:hello@thestrledger.com?subject=Order%20${data.sku}`}
          class="mt-5 inline-flex items-center gap-2 bg-navy text-parchment px-5 py-3 rounded-md no-underline text-ui hover:bg-navy-tint transition-colors"
        >
          Order {data.sku} — ${data.price}
          <span class="text-gold" aria-hidden="true">→</span>
        </a>
      </section>
    </div>
  </article>
</Layout>

<style>
  .prose :global(h2) { font-family: var(--font-display); font-size: var(--t-h2-size, 36px); color: var(--brand-navy); margin-top: var(--sp-7); margin-bottom: var(--sp-3); line-height: 1.1; }
  .prose :global(p) { color: var(--fg-1); margin-bottom: var(--sp-3); line-height: 1.6; }
  .prose :global(strong) { color: var(--brand-navy); font-weight: 600; }
</style>

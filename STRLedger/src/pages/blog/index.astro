---
import Layout from '@/components/chrome/Layout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { buildBreadcrumb } from '@/lib/seo';

// Strategy decision (documented in STRLedger/DEPLOY-STATUS.md):
// Long-form blog lives at blog.thestrledger.com (Ghost). This /blog/
// landing exists primarily to (a) preserve any inbound links to the
// path and (b) point readers to the canonical Ghost subdomain.
//
// Any MDX files in src/content/blog/ still render at /blog/<slug>/ via
// [slug].astro - useful for cross-references, brand-voice samples, or
// posts that need to live in the static build (e.g., post-purchase
// thank-you reads).
const GHOST_URL = 'https://blog.thestrledger.com';

const posts = (await getCollection('blog') as CollectionEntry<'blog'>[])
  .sort((a, b) => (a.data.datePublished < b.data.datePublished ? 1 : -1));

const breadcrumb = buildBreadcrumb([
  { name: 'Home', url: '/' },
  { name: 'Blog', url: '/blog/' },
]);
---
<Layout
  title="Blog — The STR Ledger"
  description="Long-form essays for operators running real STR portfolios. Hosted on blog.thestrledger.com."
  path="/blog"
  jsonLd={breadcrumb}
>
  <section class="bg-parchment">
    <div class="mx-auto max-w-3xl px-5 pt-12 pb-7">
      <p class="label text-gold-deep">Notebook</p>
      <h1 class="mt-3 font-serif text-h1 text-navy leading-tight">
        Long-form lives on Ghost<span class="period-gold">.</span>
      </h1>
      <p class="mt-4 text-lead text-ink-2 max-w-2xl leading-relaxed">
        Essays, deep-dives, and operator interviews live at
        <a href={GHOST_URL} class="text-gold-deep hover:underline">blog.thestrledger.com</a>.
        Ghost has the comments, the RSS, the email newsletter, and the
        archive. The catalog and product detail live here on the main
        site.
      </p>
      <a
        href={GHOST_URL}
        class="mt-7 inline-flex items-center gap-2 bg-navy text-parchment px-5 py-3 rounded-md no-underline text-ui hover:bg-navy-tint transition-colors"
      >
        Read the blog on Ghost
        <span class="text-gold" aria-hidden="true">↗</span>
      </a>
    </div>
  </section>

  {posts.length > 0 && (
    <section class="bg-parchment-light border-t border-rule">
      <div class="mx-auto max-w-3xl px-5 py-9">
        <p class="label text-gold-deep">Also on this site</p>
        <p class="mt-2 text-small text-ink-2">
          A few posts live here on the main domain — usually onboarding
          notes or post-purchase reads tied to a specific workbook.
        </p>
        <ul class="mt-5 space-y-4">
          {posts.map((post) => {
            const slug = post.id.replace(/\.mdx$/, '');
            return (
              <li>
                <a
                  href={`/blog/${slug}/`}
                  class="group block rounded-md border border-rule bg-parchment p-5 no-underline hover:border-gold hover:shadow-card transition-all"
                >
                  <p class="font-mono text-caption text-gold-deep">{post.data.datePublished} · {post.data.readMinutes} min</p>
                  <p class="mt-2 font-serif text-h3 text-navy leading-snug">{post.data.title}</p>
                  <p class="mt-2 text-small text-ink-2 leading-snug">{post.data.description}</p>
                  <p class="mt-3 text-caption text-gold-deep group-hover:text-gold">Read →</p>
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    </section>
  )}
</Layout>

---
import Layout from '@/components/chrome/Layout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { buildBreadcrumb } from '@/lib/seo';

const posts = (await getCollection('blog') as CollectionEntry<'blog'>[])
  .sort((a, b) => (a.data.datePublished < b.data.datePublished ? 1 : -1));

const breadcrumb = buildBreadcrumb([
  { name: 'Home', url: '/' },
  { name: 'Blog', url: '/blog/' },
]);
---
<Layout
  title="Blog — The STR Ledger"
  description="Long-form notes from operators running real STR portfolios. Tax, ops, pricing, acquisition."
  path="/blog"
  jsonLd={breadcrumb}
>
  <section class="bg-parchment">
    <div class="mx-auto max-w-3xl px-5 pt-12 pb-7">
      <p class="label text-gold-deep">Notebook</p>
      <h1 class="mt-3 font-serif text-h1 text-navy leading-tight">
        From the notebook<span class="period-gold">.</span>
      </h1>
      <p class="mt-4 text-lead text-ink-2 max-w-2xl">
        Operators running real portfolios. Tax-season prep, turnover ops, pricing math, acquisition underwriting. No fluff.
      </p>
    </div>
  </section>

  <section class="bg-parchment-light border-t border-rule">
    <div class="mx-auto max-w-3xl px-5 py-9">
      <ul class="space-y-5">
        {posts.map((post) => {
          const slug = post.id.replace(/\.mdx$/, '');
          return (
            <li>
              <a
                href={`/blog/${slug}/`}
                class="group block rounded-md border border-rule bg-parchment p-5 no-underline hover:border-gold hover:shadow-card transition-all"
              >
                <p class="font-mono text-caption text-gold-deep">{post.data.datePublished} · {post.data.readMinutes} min</p>
                <p class="mt-2 font-serif text-h3 text-navy leading-snug">{post.data.title}</p>
                <p class="mt-2 text-small text-ink-2 leading-snug">{post.data.description}</p>
                <p class="mt-3 text-caption text-gold-deep group-hover:text-gold">Read →</p>
              </a>
            </li>
          );
        })}
      </ul>
    </div>
  </section>
</Layout>

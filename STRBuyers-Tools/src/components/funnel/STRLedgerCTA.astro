---
// STRLedgerCTA — one per page, copy varies by calculator, deep-links to the
// matching SKU on thestrledger.com with UTM tracking. Below the fold.

interface Props {
  /** Calculator slug (matches keys in src/data/tools.json). */
  tool: string;
  headline?: string;
  blurb?: string;
  cta?: string;
  skuPath?: string;
}

const { tool, headline, blurb, cta, skuPath } = Astro.props;

const defaults: Record<string, { headline: string; blurb: string; cta: string; skuPath: string }> = {
  'dscr-calculator': {
    headline: "Once you fund the loan, the P&L starts running.",
    blurb: 'The STR Ledger P&L workbook tracks revenue and expenses for the property the moment escrow closes.',
    cta: 'See the P&L workbook',
    skuPath: '/products/p-and-l-single-property',
  },
  'down-payment-calculator': {
    headline: 'Down payment was the easy part.',
    blurb: 'The STR Ledger Year-1 Cash workbook tracks every dollar from closing through the first 12 months of operation.',
    cta: 'See the year-1 workbook',
    skuPath: '/products/year-1-cash-workbook',
  },
  'comp-analyzer': {
    headline: "Comps tell you what others are charging — the workbook tells you what you're earning.",
    blurb: 'The STR Ledger Comp + Performance workbook benchmarks your property against your stated comps month-over-month.',
    cta: 'See the comp workbook',
    skuPath: '/products/comp-workbook',
  },
  'market-score': {
    headline: 'Market score signals demand. The P&L proves the property.',
    blurb: 'The STR Ledger P&L workbook tracks revenue and expenses for the property in this market.',
    cta: 'See the P&L workbook',
    skuPath: '/products/p-and-l-single-property',
  },
  'cash-on-cash': {
    headline: 'Cash-on-cash is the start. Track it monthly.',
    blurb: 'The STR Ledger P&L workbook computes cash-on-cash live as actuals replace projections.',
    cta: 'See the P&L workbook',
    skuPath: '/products/p-and-l-single-property',
  },
  'year-1-cash-needs': {
    headline: 'Year-1 cash projected — track it as it spends.',
    blurb: 'The STR Ledger Year-1 Cash workbook converts the projection into a live spending tracker.',
    cta: 'See the year-1 workbook',
    skuPath: '/products/year-1-cash-workbook',
  },
  'furnishing-budget': {
    headline: 'Furnishing budget set. Track it line by line.',
    blurb: 'The STR Ledger Furnishing Tracker captures every purchase, vendor, and depreciation timeline.',
    cta: 'See the furnishing tracker',
    skuPath: '/products/furnishing-tracker',
  },
};

const fallback = {
  headline: 'Track every property in The STR Ledger.',
  blurb: 'Excel templates and PDFs for short-term rental finance.',
  cta: 'Browse The STR Ledger',
  skuPath: '/',
};

const conf = defaults[tool] ?? fallback;
const finalHeadline = headline ?? conf.headline;
const finalBlurb = blurb ?? conf.blurb;
const finalCta = cta ?? conf.cta;
const finalSkuPath = skuPath ?? conf.skuPath;

const href = `https://thestrledger.com${finalSkuPath}?utm_source=strbuyers-tools&utm_medium=cta&utm_content=${encodeURIComponent(tool)}`;
---
<aside class="str-ledger-cta my-7 print:hidden" aria-label="Related product on The STR Ledger">
  <div class="rounded-md surface-navy p-6">
    <p class="label text-[color:var(--accent-500)]">From The STR Ledger</p>
    <p class="mt-3 font-serif text-h3 text-parchment max-w-2xl leading-snug">
      {finalHeadline}
    </p>
    <p class="mt-3 text-small text-parchment opacity-90 max-w-2xl leading-snug">
      {finalBlurb}
    </p>
    <a
      href={href}
      class="mt-5 inline-flex items-center gap-2 rounded-md text-navy px-5 py-2.5 text-ui no-underline transition-colors duration-std focus:outline-none focus:shadow-focus"
      style="background: var(--accent-500);"
      data-str-ledger-cta
      data-tool={tool}
    >
      {finalCta}
      <span aria-hidden="true">→</span>
    </a>
  </div>
</aside>

<script>
  document.querySelectorAll<HTMLAnchorElement>('a[data-str-ledger-cta]').forEach((a) => {
    a.addEventListener('click', () => {
      (window as any).gtag?.('event', 'str_ledger_cta_clicked', { tool: a.dataset.tool });
    });
  });
</script>

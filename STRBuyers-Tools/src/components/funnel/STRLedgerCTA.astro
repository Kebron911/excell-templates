---
// STRLedgerCTA — one per page, copy varies by tool, deep-links to the matching
// SKU on thestrledger.com with UTM tracking.
//
// Contextual cluster bridge. Below the fold, after value has been delivered.
// Single button, single link, no carousel.

interface Props {
  /** Tool slug (matches keys in src/data/tools.json). */
  tool: string;
  /** Override copy if needed. Defaults below. */
  headline?: string;
  blurb?: string;
  cta?: string;
  /** Override target SKU path if the default mapping isn't right. */
  skuPath?: string;
}

const { tool, headline, blurb, cta, skuPath } = Astro.props;

// Per-tool copy + STR Ledger SKU mapping. Editable here as catalog evolves.
const defaults: Record<string, { headline: string; blurb: string; cta: string; skuPath: string }> = {
  'dscr-calculator': {
    headline: 'Track DSCR in Excel as you scale.',
    blurb: 'The STR Ledger DSCR Tracker monitors debt-service-coverage across your portfolio month-over-month.',
    cta: 'See the DSCR tracker',
    skuPath: '/products/dscr-tracker',
  },
  'down-payment-calculator': {
    headline: 'Plan the down payment, in Excel.',
    blurb: 'The STR Ledger Acquisition Workbook captures down payment, closing costs, and reserves on one page.',
    cta: 'See the acquisition workbook',
    skuPath: '/products/acquisition-workbook',
  },
  'comp-analyzer': {
    headline: 'Track comp performance over time.',
    blurb: 'The STR Ledger Comp Tracker logs ADR, occupancy, and RevPAR for your comp set, monthly.',
    cta: 'See the comp tracker',
    skuPath: '/products/comp-tracker',
  },
  'market-score': {
    headline: 'Track market signals you bought into.',
    blurb: 'The STR Ledger Market Watch workbook tracks regulation changes, ADR drift, and saturation per market.',
    cta: 'See the market watch workbook',
    skuPath: '/products/market-watch',
  },
  'cash-on-cash': {
    headline: 'Track cash-on-cash year-over-year.',
    blurb: 'The STR Ledger Returns Workbook reconciles modeled vs. actual cash-on-cash return per property, annually.',
    cta: 'See the returns workbook',
    skuPath: '/products/returns-workbook',
  },
  'year-1-cash-needs': {
    headline: 'Plan Year 1 cash, in Excel.',
    blurb: 'The STR Ledger Year 1 Workbook lays out down payment, closing, furnish, and reserves on one tab.',
    cta: 'See the Year 1 workbook',
    skuPath: '/products/year-1-workbook',
  },
  'furnishing-budget': {
    headline: 'Track furnishing spend, in Excel.',
    blurb: 'The STR Ledger Furnishing Tracker logs every line item against your budget by room.',
    cta: 'See the furnishing tracker',
    skuPath: '/products/furnishing-tracker',
  },
};

const fallback = {
  headline: 'Track this for real in The STR Ledger.',
  blurb: 'Excel templates and PDFs that turn these calculators into your monthly bookkeeping rhythm.',
  cta: 'Browse The STR Ledger',
  skuPath: '/',
};

const conf = defaults[tool] ?? fallback;
const finalHeadline = headline ?? conf.headline;
const finalBlurb = blurb ?? conf.blurb;
const finalCta = cta ?? conf.cta;
const finalSkuPath = skuPath ?? conf.skuPath;

const href = `https://thestrledger.com${finalSkuPath}?utm_source=strbuyers-tools&utm_medium=cta&utm_content=${encodeURIComponent(tool)}`;
---
<aside class="str-ledger-cta my-7 print:hidden" aria-label="Related product on The STR Ledger">
  <div class="rounded-md surface-navy p-6">
    <p class="label text-gold">From The STR Ledger</p>
    <p class="mt-3 font-serif text-h3 text-parchment max-w-2xl leading-snug">
      {finalHeadline}
    </p>
    <p class="mt-3 text-small text-parchment opacity-90 max-w-2xl leading-snug">
      {finalBlurb}
    </p>
    <a
      href={href}
      class="mt-5 inline-flex items-center gap-2 rounded-md bg-gold text-navy px-5 py-2.5 text-ui no-underline hover:bg-gold-soft transition-colors duration-std focus:outline-none focus:shadow-focus"
      data-str-ledger-cta
      data-tool={tool}
    >
      {finalCta}
      <span aria-hidden="true">→</span>
    </a>
  </div>
</aside>

<script>
  document.querySelectorAll<HTMLAnchorElement>('a[data-str-ledger-cta]').forEach((a) => {
    a.addEventListener('click', () => {
      (window as any).gtag?.('event', 'str_ledger_cta_clicked', {
        tool: a.dataset.tool,
      });
    });
  });
</script>

---
import tools from '@/data/tools.json';
import Wordmark from './Wordmark.astro';

// Compact nav labels — all 7 buyer calculators visible inline at lg+. Header
// is the primary cross-tool nav once a visitor is deep in a calculator,
// so full coverage matters more than label space here.
const navLabels: Record<string, string> = {
  'dscr-calculator': 'DSCR',
  'down-payment-calculator': 'Down pmt',
  'comp-analyzer': 'Comps',
  'market-score': 'Market',
  'cash-on-cash': 'Cash-on-cash',
  'year-1-cash-needs': 'Year 1 cash',
  'furnishing-budget': 'Furnishing',
};

const allTools = Object.entries(tools);
---
<header class="border-b border-rule bg-parchment">
  <div class="mx-auto max-w-6xl px-5 py-5 flex items-center justify-between gap-6">
    <Wordmark size="md" theme="navy" class="shrink-0" />

    <nav class="hidden lg:flex items-center gap-6" aria-label="Primary">
      {allTools.map(([key, t]) => (
        <a
          href={t.path}
          class="text-ui text-ink-2 no-underline hover:text-accent transition-colors duration-std whitespace-nowrap"
        >
          {navLabels[key] ?? t.shortName}
        </a>
      ))}
      <a
        href="/blog"
        class="text-ui text-ink-2 no-underline hover:text-accent transition-colors duration-std"
      >
        Blog
      </a>
    </nav>

    <details class="lg:hidden relative">
      <summary class="list-none cursor-pointer p-2 -mr-2" aria-label="Open menu">
        <svg width="22" height="22" viewBox="0 0 22 22" aria-hidden="true">
          <path d="M3 6h16M3 11h16M3 16h16" stroke="currentColor" stroke-width="1.5" fill="none" />
        </svg>
      </summary>
      <div class="absolute right-0 top-full mt-2 w-60 bg-parchment-light border border-rule rounded-md shadow-lifted py-2 z-10">
        {allTools.map(([_key, t]) => (
          <a
            href={t.path}
            class="block px-4 py-2 text-ui text-ink-2 no-underline hover:bg-parchment-alt hover:text-accent"
          >
            {t.shortName}
          </a>
        ))}
        <hr class="my-2 border-rule" />
        <a href="/blog" class="block px-4 py-2 text-ui text-ink-2 no-underline hover:bg-parchment-alt hover:text-accent">Blog</a>
      </div>
    </details>
  </div>
</header>

---
// Cross-cluster funnel — links to strhost / strops / strguests with a one-line
// value prop each. Hides the matching site for the current cluster position.
// strbuyers.tools sits at the "acquisition" position in the cluster.

interface Props {
  currentCluster: 'acquisition' | 'math' | 'operations' | 'guest-xp';
}

const { currentCluster } = Astro.props;

const clusters = [
  {
    id: 'acquisition',
    name: 'strbuyers.tools',
    blurb: 'Pre-buy: DSCR, market score, comp analysis.',
    href: 'https://strbuyers.tools',
  },
  {
    id: 'math',
    name: 'strhost.tools',
    blurb: 'Analyzing: profit, RevPAR, break-even.',
    href: 'https://strhost.tools',
  },
  {
    id: 'operations',
    name: 'strops.tools',
    blurb: 'Running: turnover, dispatch, smart locks.',
    href: 'https://strops.tools',
  },
  {
    id: 'guest-xp',
    name: 'strguests.tools',
    blurb: 'Optimizing: house rules, welcome books, AI replies.',
    href: 'https://strguests.tools',
  },
];

const others = clusters.filter(c => c.id !== currentCluster);
---
<section class="cluster-funnel-block bg-parchment-alt border-y border-rule" data-testid="cluster-funnel-block">
  <div class="mx-auto max-w-6xl px-5 py-7">
    <p class="label text-navy">More tools across the STR cluster</p>
    <div class="mt-4 grid grid-cols-1 md:grid-cols-3 gap-4">
      {others.map(c => (
        <a
          href={c.href}
          class="group block rounded-md border border-rule bg-parchment-light p-4 no-underline hover:border-accent hover:shadow-card transition-all duration-std"
          data-cluster-link
          data-destination={c.id}
        >
          <p class="wordmark text-navy group-hover:text-accent">{c.name}</p>
          <p class="mt-2 text-small text-ink-2 leading-snug">{c.blurb}</p>
          <p class="mt-3 text-caption text-accent-tint group-hover:text-accent">
            Visit
            <span class="inline-block transition-transform duration-std group-hover:translate-x-0.5" aria-hidden="true"> →</span>
          </p>
        </a>
      ))}
    </div>
  </div>
</section>

<script>
  // Fire `cluster_click` on cross-site link click. Cross-domain linker
  // (configured in Layout.astro) carries the GA client_id across domains.
  document.querySelectorAll<HTMLAnchorElement>('a[data-cluster-link]').forEach((a) => {
    a.addEventListener('click', () => {
      const destination = a.dataset.destination ?? '';
      (window as any).gtag?.('event', 'cluster_click', { destination });
    });
  });
</script>

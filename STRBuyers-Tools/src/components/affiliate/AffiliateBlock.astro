---
// AffiliateBlock — renders 1–3 vendor cards filtered by `tool` (and optional
// `vendor` to surface a specific vendor first). Reads from src/data/affiliates.json.
// Click handler POSTs to /api/click with {vendor, tool, utm} payload.
// Inline FTC disclosure. Reads as content (vendor recommendation), not as an ad.

import affiliates from '@/data/affiliates.json';

interface Props {
  /** Optional: filter / prioritize a single vendor id from the registry. */
  vendor?: string;
  /** Optional: explicit ordered list of vendor ids to render (Phase 2). */
  vendorIds?: string[];
  /** Tool slug — used to filter vendors whose `tools` includes this slug. */
  tool: string;
  /** Override: cap the number of cards rendered (default 3, max 3). */
  limit?: number;
}

interface Vendor {
  id: string;
  name: string;
  category: string;
  tagline: string;
  ctaUrl: string;
  tools: string[];
}

const { vendor, vendorIds, tool, limit = 3 } = Astro.props;

const allVendors = (affiliates.vendors as Vendor[]) ?? [];

// Resolution order:
//   1. If vendorIds is given, render those in the listed order (skipping unknown ids).
//   2. Else filter by tool, then bump `vendor` to the front if specified.
let matched: Vendor[];
if (vendorIds && vendorIds.length > 0) {
  matched = vendorIds
    .map(id => allVendors.find(v => v.id === id))
    .filter((v): v is Vendor => v !== undefined);
} else {
  matched = allVendors.filter(v => v.tools.includes(tool));
  if (vendor) {
    const named = allVendors.find(v => v.id === vendor);
    if (named) {
      matched = [named, ...matched.filter(v => v.id !== vendor)];
    }
  }
}
const cards = matched.slice(0, Math.min(limit, 3));
---
<aside
  class="affiliate-block my-7"
  aria-label="Recommended vendors"
  data-tool={tool}
  data-testid="affiliate-block"
>
  <p class="label text-accent">Recommended for this calculator</p>
  <p class="mt-1 text-caption text-ink-3 leading-snug">
    These are partners we think can help. We may earn a commission if you sign up — costs you nothing extra.
    <a href="/disclosures" class="underline decoration-rule underline-offset-2 hover:text-accent">Full disclosure</a>.
  </p>

  <div class="mt-4 grid grid-cols-1 md:grid-cols-3 gap-4">
    {cards.map((v) => (
      <a
        class="affiliate-card group block rounded-md border border-rule bg-parchment-light p-4 no-underline hover:border-accent hover:shadow-card transition-all duration-std"
        href={v.ctaUrl}
        rel="sponsored noopener nofollow"
        target="_blank"
        data-affiliate-card
        data-vendor={v.id}
        data-tool={tool}
        data-category={v.category}
      >
        <p class="text-caption text-ink-3 uppercase tracking-widest">{v.category.replace(/-/g, ' ')}</p>
        <p class="mt-1 font-serif text-h3 text-navy group-hover:text-accent leading-snug">{v.name}</p>
        <p class="mt-2 text-small text-ink-2 leading-snug">{v.tagline}</p>
        <p class="mt-3 text-caption text-accent group-hover:text-accent-tint">
          Visit
          <span class="inline-block transition-transform duration-std group-hover:translate-x-0.5" aria-hidden="true"> →</span>
        </p>
      </a>
    ))}
  </div>
</aside>

<script>
  // POST a click ping to /api/click. Endpoint is built in Phase 4 — until then
  // the request will 404, which is fine; we still emit a GA4 event and follow
  // through to the affiliate URL in a new tab.
  document.querySelectorAll<HTMLAnchorElement>('a[data-affiliate-card]').forEach((a) => {
    a.addEventListener('click', () => {
      const vendor = a.dataset.vendor ?? '';
      const tool = a.dataset.tool ?? '';
      const category = a.dataset.category ?? '';
      const payload = {
        vendor,
        tool,
        category,
        utm_source: 'strbuyers-tools',
        utm_medium: 'affiliate',
        utm_content: tool,
        ts: Date.now(),
      };

      try {
        fetch('/api/click', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
          keepalive: true,
        }).catch(() => { /* swallow — endpoint may not exist yet */ });
      } catch (_err) { /* noop */ }

      (window as any).gtag?.('event', 'affiliate_click', { vendor, tool, category });
    });
  });
</script>

---
import Layout from '@/components/chrome/Layout.astro';
import Sidebar from '@/components/chrome/Sidebar.astro';
import ClusterFunnelBlock from '@/components/chrome/ClusterFunnelBlock.astro';
import AdSlot from '@/components/ads/AdSlot.astro';
import EmailCaptureCard from '@/components/funnel/EmailCaptureCard.astro';
import STRLedgerCTA from '@/components/funnel/STRLedgerCTA.astro';
import AffiliateBlock from '@/components/affiliate/AffiliateBlock.astro';
import CashOnCashCalculator from '@/components/calculators/CashOnCashCalculator.tsx';
import { Content as ToolCopy } from '@/content/tools/cash-on-cash.mdx';
import { buildWebApplication, buildFAQPage } from '@/lib/seo';
import tools from '@/data/tools.json';

const tool = tools['cash-on-cash'];
const faqs = [
  { question: 'What\'s a good cash-on-cash for an STR?', answer: 'Most experienced operators target 8–12% as their floor. Below 6% means you\'re betting on appreciation; above 15% usually means hidden risk or a non-replicable opportunity.' },
  { question: 'How is this different from cap rate?', answer: 'Cap rate uses NOI ÷ price (ignores financing). Cash-on-cash uses post-debt-service cash flow ÷ cash invested — captures the leverage effect.' },
  { question: 'Should I include appreciation?', answer: 'No. Cash-on-cash is a year-1 in-pocket return, not a total return. Track appreciation separately.' },
];
const jsonLd = [
  buildWebApplication({ name: 'Cash-on-Cash Return Calculator', description: 'Free cash-on-cash return calculator for STR investors.', toolPath: tool.path }),
  buildFAQPage(faqs),
];
---
<Layout title="Cash-on-Cash Return Calculator — strbuyers.tools" description="Free cash-on-cash return calculator for STR investors. See your year-1 in-pocket return as a percentage." path="/cash-on-cash" jsonLd={jsonLd}>
  <article class="calculator-page bg-parchment">
    <div class="mx-auto max-w-6xl px-5 pt-9 pb-7 grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-9">
      <div class="min-w-0">
        <header><h1 class="text-h1 font-serif text-navy leading-tight">Cash-on-Cash Return<span class="period-accent">.</span></h1><p class="mt-3 text-lead text-ink-2 max-w-2xl">What does the cash you put in actually earn?</p></header>
        <div class="mt-7"><CashOnCashCalculator client:load /></div>
        <AdSlot location="in-content" />
        <AffiliateBlock tool="cash-on-cash" headline="Tools the math depends on" />
        <div class="prose mt-7 max-w-2xl"><ToolCopy /></div>
        <EmailCaptureCard magnet="strbuyers-checklist" toolSlug="cash-on-cash" />
        <STRLedgerCTA tool="cash-on-cash" />
        <AdSlot location="footer" />
      </div>
      <Sidebar current="cash-on-cash" />
    </div>
    <ClusterFunnelBlock currentCluster="acquisition" />
  </article>
</Layout>
<style>
  .prose :global(h2) { font-family: var(--font-display); font-size: var(--t-h2-size); color: var(--brand-navy); margin-top: 1.6rem; margin-bottom: 0.6rem; }
  .prose :global(h3) { font-family: var(--font-display); color: var(--brand-navy); margin-top: 1.2rem; margin-bottom: 0.4rem; font-size: var(--t-h3-size); }
  .prose :global(p) { margin-bottom: 0.9rem; line-height: 1.65; color: var(--ink-2); }
</style>

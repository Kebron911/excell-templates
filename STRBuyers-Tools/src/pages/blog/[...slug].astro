---
import Layout from '@/components/chrome/Layout.astro';
import ClusterFunnelBlock from '@/components/chrome/ClusterFunnelBlock.astro';
import AdSlot from '@/components/ads/AdSlot.astro';
import AffiliateBlock from '@/components/affiliate/AffiliateBlock.astro';
import EmailCaptureCard from '@/components/funnel/EmailCaptureCard.astro';
import { getCollection, render } from 'astro:content';
import { buildArticle, buildFAQPage, buildBreadcrumbList } from '@/lib/seo';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.data.slug },
    props: { post, allPosts: posts },
  }));
}

type Post = Awaited<ReturnType<typeof getCollection<'blog'>>>[number];
interface Props { post: Post; allPosts: Post[]; }

const { post, allPosts } = Astro.props;
const { Content } = await render(post);

const CATEGORY_LABEL: Record<string, string> = {
  financing: 'Financing',
  markets: 'Markets',
  underwriting: 'Underwriting',
  operations: 'Operations',
  regulation: 'Regulation',
};

// Resolve related posts via slug match. Skip self.
const related = (post.data.relatedPosts ?? [])
  .map((slug) => allPosts.find((p) => p.data.slug === slug))
  .filter((p): p is Post => !!p && p.data.slug !== post.data.slug);

// Schema stack — Article + (FAQPage if faqs) + BreadcrumbList. Layout
// accepts a single object or an array; pass an array so all three emit
// as separate <script type="application/ld+json"> blocks.
const articleLd = buildArticle({
  headline: post.data.title,
  description: post.data.description,
  slug: post.data.slug,
  datePublished: post.data.datePublished,
  dateModified: post.data.dateModified,
});
const breadcrumbLd = buildBreadcrumbList([
  { name: 'Home', path: '/' },
  { name: 'Blog', path: '/blog' },
  { name: post.data.title, path: `/blog/${post.data.slug}` },
]);
const faqLd = post.data.faqs && post.data.faqs.length > 0
  ? buildFAQPage(post.data.faqs.map((f) => ({ question: f.q, answer: f.a })))
  : null;

const lds: Array<Record<string, unknown>> = [articleLd, breadcrumbLd];
if (faqLd) lds.push(faqLd);

// SERP page-title hygiene: drop the " — strbuyers.tools" suffix on long
// titles so Google's ~60-char (~580px) display budget isn't blown.
const SUFFIX = ' — strbuyers.tools';
const pageTitle = post.data.title.length + SUFFIX.length <= 60
  ? `${post.data.title}${SUFFIX}`
  : post.data.title;

const lastChar = post.data.title.slice(-1);
const titleEndsInPunctuation = ['.', '?', '!', ':'].includes(lastChar);
---
<Layout
  title={pageTitle}
  description={post.data.description}
  path={`/blog/${post.data.slug}`}
  ogImage="https://strbuyers.tools/og/default.png"
  jsonLd={lds}
>
  <article class="blog-post bg-parchment">
    <div class="mx-auto max-w-3xl px-5 pt-9 pb-7">
      <nav aria-label="Breadcrumb" class="text-caption text-ink-3 font-mono">
        <a href="/" class="text-ink-3 no-underline hover:text-accent">Home</a>
        <span class="mx-2" aria-hidden="true">/</span>
        <a href="/blog" class="text-ink-3 no-underline hover:text-accent">Blog</a>
        <span class="mx-2" aria-hidden="true">/</span>
        <span class="text-ink-2">{CATEGORY_LABEL[post.data.category] ?? post.data.category}</span>
      </nav>

      <header class="mt-3">
        <p class="label text-accent">
          Acquisition · {CATEGORY_LABEL[post.data.category] ?? post.data.category}
        </p>
        <h1 class="font-serif text-h1 text-navy mt-3 leading-tight">
          {post.data.title}{!titleEndsInPunctuation && <span class="period-accent">.</span>}
        </h1>
        <p class="mt-3 text-lead text-ink-2 max-w-2xl">
          {post.data.description}
        </p>
        <p class="mt-4 text-caption text-ink-3 font-mono">
          <time datetime={post.data.datePublished}>{post.data.datePublished}</time>
          <span class="mx-2">·</span>
          {post.data.readingTimeMin} min read
          {post.data.dateModified && (
            <>
              <span class="mx-2">·</span>
              Updated <time datetime={post.data.dateModified}>{post.data.dateModified}</time>
            </>
          )}
        </p>
      </header>

      {post.data.keyTakeaway && (
        <aside
          class="mt-7 rounded-md border-l-4 border-gold bg-parchment-light p-5"
          aria-label="Key takeaway"
        >
          <p class="label text-accent">The short answer</p>
          <p class="mt-2 text-ui text-ink-1 leading-relaxed">
            {post.data.keyTakeaway}
          </p>
        </aside>
      )}

      <section class="mt-9 prose max-w-none">
        <Content />
      </section>

      {post.data.relatedTool && (
        <aside class="mt-7 rounded-md border-l-4 border-accent bg-parchment-light p-4">
          <p class="label text-accent">Run the numbers</p>
          <p class="mt-1 text-ui text-ink-2">
            <a
              href={post.data.relatedTool}
              class="text-accent no-underline hover:underline"
            >
              Open the calculator → {post.data.relatedTool}
            </a>
          </p>
        </aside>
      )}

      {post.data.faqs && post.data.faqs.length > 0 && (
        <section class="mt-9" aria-label="Frequently asked questions">
          <h2 class="font-serif text-h2 text-navy">Frequently asked</h2>
          <div class="mt-5 space-y-3">
            {post.data.faqs.map((faq) => (
              <details class="group rounded-md border border-rule bg-parchment-light p-4">
                <summary class="cursor-pointer list-none font-serif text-h3 text-navy leading-snug">
                  <span class="mr-2 inline-block transition-transform group-open:rotate-90" aria-hidden="true">›</span>
                  {faq.q}
                </summary>
                <p class="mt-3 text-ui text-ink-2 leading-relaxed">{faq.a}</p>
              </details>
            ))}
          </div>
        </section>
      )}

      {related.length > 0 && (
        <section class="mt-9" aria-label="Related reading">
          <h2 class="font-serif text-h2 text-navy">Related reading</h2>
          <ul class="mt-5 grid grid-cols-1 gap-4 list-none p-0">
            {related.map((rel) => (
              <li class="rounded-md border border-rule bg-parchment-light p-4">
                <p class="text-caption text-ink-3 uppercase tracking-widest font-mono">
                  {CATEGORY_LABEL[rel.data.category] ?? rel.data.category}
                  <span class="mx-2">·</span>
                  {rel.data.readingTimeMin} min read
                </p>
                <p class="mt-1 font-serif text-h3 text-navy leading-snug">
                  <a
                    href={`/blog/${rel.data.slug}`}
                    class="text-navy no-underline hover:text-accent transition-colors duration-std"
                  >
                    {rel.data.title}
                  </a>
                </p>
                <p class="mt-1 text-small text-ink-2">{rel.data.description}</p>
              </li>
            ))}
          </ul>
        </section>
      )}

      {post.data.affiliateVendors && post.data.affiliateVendors.length > 0 && (
        <AffiliateBlock
          vendorIds={post.data.affiliateVendors}
          tool={`blog-${post.data.slug}`}
        />
      )}

      <AdSlot location="in-content" />

      <EmailCaptureCard
        magnet="str-buyer-playbook"
        toolSlug={`blog-${post.data.slug}`}
      />
    </div>

    <ClusterFunnelBlock currentCluster="acquisition" />
  </article>

  <script is:inline define:vars={{ slug: post.data.slug, category: post.data.category }}>
    (function () {
      function fire() {
        if (typeof window === 'undefined') return;
        if (typeof window.gtag !== 'function') return;
        try { window.gtag('event', 'blog_view', { slug: slug, category: category }); } catch (_e) {}
      }
      if (document.readyState === 'complete') fire();
      else window.addEventListener('load', fire, { once: true });
    })();
  </script>
</Layout>

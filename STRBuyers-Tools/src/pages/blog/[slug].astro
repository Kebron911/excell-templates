---
import Layout from '@/components/chrome/Layout.astro';
import ClusterFunnelBlock from '@/components/chrome/ClusterFunnelBlock.astro';
import { buildArticle, buildBreadcrumb } from '@/lib/seo';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const all = await getCollection('posts');
  const sorted = [...all].sort((a, b) =>
    a.data.datePublished < b.data.datePublished ? 1 : -1,
  );
  return sorted.map((post, i) => ({
    params: { slug: post.id.replace(/\.mdx$/, '') },
    props: {
      post,
      newer: i > 0 ? sorted[i - 1] : null,
      older: i < sorted.length - 1 ? sorted[i + 1] : null,
    },
  }));
}

const { post, newer, older } = Astro.props;
const slug = post.id.replace(/\.mdx$/, '');
const { Content } = await render(post);

const navLink = (p: typeof newer) =>
  p && {
    slug: p.id.replace(/\.mdx$/, ''),
    title: p.data.title,
    readMinutes: p.data.readMinutes,
  };
const newerLink = navLink(newer);
const olderLink = navLink(older);

const formatDate = (iso: string) =>
  new Date(iso + 'T12:00:00Z').toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' });

const categoryLabels: Record<string, string> = {
  financing: 'Financing',
  underwriting: 'Underwriting',
  regulation: 'Regulation',
  insurance: 'Insurance',
  'startup-costs': 'Startup Costs',
  'market-selection': 'Market Selection',
};

const articleLd = buildArticle({
  headline: post.data.title,
  description: post.data.description,
  slug,
  datePublished: post.data.datePublished,
  dateModified: post.data.dateModified ?? post.data.datePublished,
  authorName: post.data.author,
});

const breadcrumbLd = buildBreadcrumb([
  { name: 'Home', path: '/' },
  { name: 'Blog', path: '/blog' },
  { name: post.data.title },
]);
---
<Layout
  title={`${post.data.title} — strbuyers.tools`}
  description={post.data.description}
  path={`/blog/${slug}`}
  jsonLd={[articleLd, breadcrumbLd]}
>
  <article class="bg-parchment">
    <div class="mx-auto max-w-3xl px-5 pt-12 pb-7">
      <p class="label text-accent">
        <a href="/blog" class="no-underline hover:text-accent">← Back to all posts</a>
      </p>

      <div class="mt-3 flex items-center gap-3 text-caption text-ink-3">
        <span class="label text-accent">{categoryLabels[post.data.category] ?? post.data.category}</span>
        <span aria-hidden="true">·</span>
        <time datetime={post.data.datePublished} class="font-mono">{formatDate(post.data.datePublished)}</time>
        <span aria-hidden="true">·</span>
        <span class="font-mono">{post.data.readMinutes} min read</span>
      </div>

      <h1 class="mt-3 text-h1 font-serif text-navy leading-tight">
        {post.data.title}
      </h1>
      <p class="mt-4 text-lead text-ink-2">{post.data.description}</p>
    </div>

    <div class="mx-auto max-w-3xl px-5 prose">
      <Content />
    </div>

    {(newerLink || olderLink) && (
      <nav class="mx-auto max-w-3xl px-5 mt-9" aria-label="Other posts">
        <p class="label text-navy">Keep reading</p>
        <div class="mt-3 grid grid-cols-1 md:grid-cols-2 gap-3">
          {newerLink ? (
            <a
              href={`/blog/${newerLink.slug}/`}
              class="group block rounded-md border border-rule bg-parchment-light p-4 no-underline hover:border-accent hover:shadow-card transition-all"
            >
              <p class="text-caption text-accent">← Newer</p>
              <p class="mt-1 font-serif text-h3 text-navy leading-snug group-hover:text-accent">{newerLink.title}</p>
              <p class="mt-2 text-caption text-ink-3 font-mono">{newerLink.readMinutes} min read</p>
            </a>
          ) : <span aria-hidden="true" />}
          {olderLink ? (
            <a
              href={`/blog/${olderLink.slug}/`}
              class="group block rounded-md border border-rule bg-parchment-light p-4 no-underline hover:border-accent hover:shadow-card transition-all md:text-right"
            >
              <p class="text-caption text-accent">Older →</p>
              <p class="mt-1 font-serif text-h3 text-navy leading-snug group-hover:text-accent">{olderLink.title}</p>
              <p class="mt-2 text-caption text-ink-3 font-mono">{olderLink.readMinutes} min read</p>
            </a>
          ) : <span aria-hidden="true" />}
        </div>
      </nav>
    )}

    <ClusterFunnelBlock currentCluster="acquisition" />
  </article>
</Layout>

<style>
  .prose :global(h2) { font-family: var(--font-display); font-size: var(--t-h2-size); color: var(--brand-navy); margin-top: var(--sp-7); margin-bottom: var(--sp-3); line-height: 1.15; }
  .prose :global(h3) { font-family: var(--font-display); font-size: var(--t-h3-size); color: var(--brand-navy); margin-top: var(--sp-5); margin-bottom: var(--sp-2); }
  .prose :global(p) { color: var(--fg-1); margin-bottom: var(--sp-3); line-height: 1.65; font-size: 1.05rem; }
  .prose :global(ol), .prose :global(ul) { margin: var(--sp-3) 0 var(--sp-4); padding-left: var(--sp-5); }
  .prose :global(li) { margin-bottom: var(--sp-2); line-height: 1.6; }
  .prose :global(strong) { color: var(--brand-navy); font-weight: 600; }
  .prose :global(a) { color: var(--brand-navy); text-decoration: underline; text-decoration-color: var(--accent-500, currentColor); text-underline-offset: 3px; }
  .prose :global(table) { width: 100%; border-collapse: collapse; margin: var(--sp-4) 0; font-size: 0.95em; }
  .prose :global(th), .prose :global(td) { border-bottom: 1px solid var(--rule); text-align: left; padding: 0.5em 0.75em; }
  .prose :global(th) { font-family: var(--font-display); color: var(--brand-navy); font-weight: 600; background: var(--bg-2); }
  .prose :global(hr) { border: 0; border-top: 1px solid var(--rule); margin: var(--sp-6) 0; }
  .prose :global(blockquote) { border-left: 3px solid var(--brand-gold, currentColor); padding-left: var(--sp-4); color: var(--fg-2); font-style: italic; margin: var(--sp-4) 0; }
</style>

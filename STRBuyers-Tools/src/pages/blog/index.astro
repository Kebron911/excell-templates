---
import Layout from '@/components/chrome/Layout.astro';
import ClusterFunnelBlock from '@str/ui-funnel/ClusterFunnelBlock.astro';
import { getCollection } from 'astro:content';
import { siteConfig } from '@/data/site.config';

const all = await getCollection('posts');
const posts = all
  .map((p) => ({
    slug: p.id.replace(/\.mdx$/, ''),
    ...p.data,
  }))
  .sort((a, b) => (a.datePublished < b.datePublished ? 1 : -1));

const categoryLabels: Record<string, string> = {
  financing: 'Financing',
  underwriting: 'Underwriting',
  regulation: 'Regulation',
  insurance: 'Insurance',
  'startup-costs': 'Startup Costs',
  'market-selection': 'Market Selection',
};

const formatDate = (iso: string) =>
  new Date(iso + 'T12:00:00Z').toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', timeZone: 'UTC' });
---
<Layout
  title="Blog — strbuyers.tools"
  description="Honest pre-purchase analysis for short-term rental investors. Financing, underwriting, regulation, insurance, startup costs — written for buyers who'd rather wait six months than overpay."
  path="/blog"
>
  <section class="bg-parchment">
    <div class="mx-auto max-w-6xl px-5 pt-12 pb-9">
      <p class="label text-accent">From the notebook</p>
      <h1 class="mt-3 text-h1 font-serif text-navy max-w-3xl leading-tight">
        Buyer-side math, written down<span class="period-accent">.</span>
      </h1>
      <p class="mt-4 text-lead text-ink-2 max-w-2xl">
        Every post pairs a calculator or a city report with the underwriting logic behind it. No hot takes, no AI fluff, no popup that asks for your email before you've read a sentence.
      </p>
    </div>
  </section>

  <section class="bg-parchment-light border-t border-rule">
    <div class="mx-auto max-w-6xl px-5 py-9">
      {posts.length === 0 ? (
        <p class="text-body text-ink-2">No posts yet. New posts ship as the buyer-side calculators each get a paired explainer.</p>
      ) : (
        <ul class="grid grid-cols-1 md:grid-cols-2 gap-5">
          {posts.map((post) => (
            <li>
              <a
                href={`/blog/${post.slug}/`}
                class="group block h-full rounded-md border border-rule bg-parchment p-6 no-underline hover:border-accent hover:shadow-card transition-all"
              >
                <div class="flex items-center gap-3 text-caption text-ink-3">
                  <span class="label text-accent">{categoryLabels[post.category] ?? post.category}</span>
                  <span aria-hidden="true">·</span>
                  <time datetime={post.datePublished} class="font-mono">{formatDate(post.datePublished)}</time>
                  <span aria-hidden="true">·</span>
                  <span class="font-mono">{post.readMinutes} min read</span>
                </div>
                <p class="mt-3 font-serif text-h3 text-navy leading-snug group-hover:text-accent">
                  {post.title}
                </p>
                <p class="mt-2 text-small text-ink-2 leading-snug">{post.description}</p>
                <p class="mt-4 text-caption text-accent">Read →</p>
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>

  <ClusterFunnelBlock siteConfig={siteConfig} currentCluster="acquisition" />
</Layout>

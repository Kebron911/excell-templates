---
import Layout from '@/components/chrome/Layout.astro';
import Sidebar from '@/components/chrome/Sidebar.astro';
import ClusterFunnelBlock from '@/components/chrome/ClusterFunnelBlock.astro';
import AdSlot from '@/components/ads/AdSlot.astro';
import EmailCaptureCard from '@/components/funnel/EmailCaptureCard.astro';
import STRLedgerCTA from '@/components/funnel/STRLedgerCTA.astro';
import AffiliateBlock from '@/components/affiliate/AffiliateBlock.astro';
import CompAnalyzer from '@/components/calculators/CompAnalyzer.tsx';
import { Content as ToolCopy } from '@/content/tools/comp-analyzer.mdx';
import { buildWebApplication, buildFAQPage } from '@/lib/seo';
import tools from '@/data/tools.json';

const tool = tools['comp-analyzer'];
const faqs = [
  { question: 'Where do I find comp data?', answer: 'AirDNA, PriceLabs, and Mashvisor publish comp data by ZIP. You can also pull listings directly from Airbnb/Vrbo and use occupancy estimates from a paid data source.' },
  { question: 'What does "spread" mean?', answer: 'The percentage difference between the highest and lowest comp\'s annual revenue. Tight (<15%) means the comps agree; wide (>30%) means at least one outlier and you should investigate before trusting the average.' },
  { question: 'Why is cleaning fee separate?', answer: 'Cleaning fees scale with bookings, not with nightly rate. Modeling them separately gives a more accurate annual gross.' },
];
const jsonLd = [
  buildWebApplication({ name: 'STR Comp Analyzer', description: 'Free comp analyzer — paste 3 listings, see the annual revenue spread.', toolPath: tool.path }),
  buildFAQPage(faqs),
];
---
<Layout title="STR Comp Analyzer — strbuyers.tools" description="Free comp analyzer for STR buyers. Enter 3 listings; see annual revenue spread and confidence label." path="/comp-analyzer" jsonLd={jsonLd}>
  <article class="calculator-page bg-parchment">
    <div class="mx-auto max-w-6xl px-5 pt-9 pb-7 grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-9">
      <div class="min-w-0">
        <header><h1 class="text-h1 font-serif text-navy leading-tight">Comp Analyzer<span class="period-accent">.</span></h1><p class="mt-3 text-lead text-ink-2 max-w-2xl">Three listings, one shared URL, the spread you need to trust the comps.</p></header>
        <div class="mt-7"><CompAnalyzer client:load /></div>
        <AdSlot location="in-content" />
        <AffiliateBlock tool="comp-analyzer" headline="STR data sources" />
        <div class="prose mt-7 max-w-2xl"><ToolCopy /></div>
        <EmailCaptureCard magnet="strbuyers-checklist" toolSlug="comp-analyzer" />
        <STRLedgerCTA tool="comp-analyzer" />
        <AdSlot location="footer" />
      </div>
      <Sidebar current="comp-analyzer" />
    </div>
    <ClusterFunnelBlock currentCluster="acquisition" />
  </article>
</Layout>
<style>
  .prose :global(h2) { font-family: var(--font-display); font-size: var(--t-h2-size); color: var(--brand-navy); margin-top: 1.6rem; margin-bottom: 0.6rem; }
  .prose :global(h3) { font-family: var(--font-display); color: var(--brand-navy); margin-top: 1.2rem; margin-bottom: 0.4rem; font-size: var(--t-h3-size); }
  .prose :global(p) { margin-bottom: 0.9rem; line-height: 1.65; color: var(--ink-2); }
</style>

---
import Layout from '@/components/chrome/Layout.astro';
import ClusterFunnelBlock from '@str/ui-funnel/ClusterFunnelBlock.astro';
import AdSlot from '@str/ui-funnel/AdSlot.astro';
import DisclosureBanner from '@/components/affiliate/DisclosureBanner.astro';
import PageHero from '@/components/PageHero.astro';
import tools from '@/data/tools.json';
import { siteConfig } from '@/data/site.config';
import { getCollection } from 'astro:content';

const toolsList = Object.entries(tools);

const latestPosts = (await getCollection('posts'))
  .map((p: any) => ({
    slug: p.id.replace(/\.mdx$/, ''),
    title: p.data.title,
    description: p.data.description,
    datePublished: p.data.datePublished,
    readMinutes: p.data.readMinutes,
    category: p.data.category,
    heroImage: p.data.heroImage,
    heroAlt: p.data.heroAlt,
  }))
  .sort((a: { datePublished: string }, b: { datePublished: string }) =>
    a.datePublished < b.datePublished ? 1 : -1
  )
  .slice(0, 3);

const categoryLabels: Record<string, string> = {
  financing: 'Financing',
  underwriting: 'Underwriting',
  regulation: 'Regulation',
  insurance: 'Insurance',
  'startup-costs': 'Startup costs',
  'market-selection': 'Market selection',
};

// Featured high-intent markets surfaced from the 219-city corpus.
const featuredCities = [
  { slug: 'austin-tx', name: 'Austin, TX' },
  { slug: 'nashville-tn', name: 'Nashville, TN' },
  { slug: 'scottsdale-az', name: 'Scottsdale, AZ' },
  { slug: 'asheville-nc', name: 'Asheville, NC' },
  { slug: 'park-city-ut', name: 'Park City, UT' },
  { slug: 'joshua-tree-ca', name: 'Joshua Tree, CA' },
];
---
<Layout
  title="strbuyers.tools — free calculators for short-term rental investors"
  description="Seven free calculators for STR property buyers — DSCR loan qualifier, down payment, comp analyzer, market score, cash-on-cash, Year 1 cash, furnishing budget. Plus 219 city market reports."
  path="/"
>
  <DisclosureBanner />

  {/* Hero */}
  <section class="mx-auto max-w-6xl px-5 py-12 lg:py-16">
    <p class="label text-accent">STR Buyers<span class="text-ink-3">·tools</span></p>
    <h1 class="font-serif text-h1 text-navy mt-3 leading-tight max-w-3xl">
      Free tools for short-term rental investors<span class="period-accent">.</span>
    </h1>
    <p class="mt-5 text-lead text-ink-2 max-w-2xl leading-snug">
      Seven calculators that walk you through the buy decision — financing, market, returns,
      Year 1 cash, and furnishing — plus market reports on 219 STR cities. No accounts,
      no popups, no paywalls.
    </p>
    <PageHero slug="homepage" alt="strbuyers.tools - free calculators for short-term rental investors" />

    <div class="mt-7 flex flex-wrap gap-3">
      <a
        href="#tools"
        class="rounded-md bg-accent text-parchment px-5 py-3 text-ui hover:bg-accent-tint transition-colors duration-std focus:outline-none focus:shadow-focus"
      >
        Browse calculators
      </a>
      <a
        href="/cities"
        class="rounded-md border border-rule bg-parchment-light text-navy px-5 py-3 text-ui hover:border-accent hover:text-accent transition-all duration-std focus:outline-none focus:shadow-focus"
      >
        See city data
      </a>
    </div>
  </section>

  {/* Tools grid */}
  <section id="tools" class="mx-auto max-w-6xl px-5 pb-12">
    <div class="flex items-baseline justify-between mb-6">
      <h2 class="font-serif text-h2 text-navy">The seven calculators</h2>
      <p class="text-caption text-ink-3">All free · all client-side · all printable</p>
    </div>
    <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {toolsList.map(([_key, t]) => (
        <li>
          <a
            href={t.path}
            class="block rounded-md border border-rule bg-parchment-light p-5 hover:border-accent hover:shadow-card transition-all duration-std no-underline"
          >
            <p class="text-caption text-ink-3 uppercase tracking-widest">{t.category}</p>
            <p class="mt-1 font-serif text-h3 text-navy leading-snug">{t.name}</p>
            <p class="mt-2 text-small text-ink-2 leading-snug">{t.tagline}</p>
            <p class="mt-3 text-caption text-accent">
              Open tool
              <span class="inline-block transition-transform duration-std" aria-hidden="true"> →</span>
            </p>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <AdSlot siteConfig={siteConfig} location="in-content" />

  {/* Cities highlight */}
  <section class="mx-auto max-w-6xl px-5 py-12">
    <p class="label text-accent">Market data</p>
    <h2 class="mt-3 font-serif text-h2 text-navy max-w-2xl leading-tight">
      Researched 219 STR markets across 50 states. See where to invest<span class="period-accent">.</span>
    </h2>
    <p class="mt-3 text-body text-ink-2 max-w-2xl leading-snug">
      Each market report covers regulation status, average daily rate, occupancy, saturation tier,
      and a buyer-friendly score. Updated annually.
    </p>
    <ul class="mt-7 grid grid-cols-2 sm:grid-cols-3 gap-3">
      {featuredCities.map((c) => (
        <li>
          <a
            href={`/cities/${c.slug}`}
            class="block rounded-md border border-rule bg-parchment-light px-4 py-3 hover:border-accent hover:text-accent transition-all duration-std no-underline"
          >
            <span class="text-ui text-navy">{c.name}</span>
            <span class="block text-caption text-ink-3">Market report →</span>
          </a>
        </li>
      ))}
    </ul>
    <p class="mt-5">
      <a href="/cities" class="text-ui text-accent hover:text-accent-tint">
        Browse all 219 markets →
      </a>
    </p>
  </section>

  {/* Why we built this */}
  <section class="mx-auto max-w-6xl px-5 py-12">
    <h2 class="font-serif text-h2 text-navy">Why we built this</h2>
    <ul class="mt-6 grid grid-cols-1 md:grid-cols-3 gap-5">
      <li class="rounded-md border border-rule bg-parchment-light p-5">
        <p class="font-serif text-h3 text-navy">Pre-purchase math is hardest</p>
        <p class="mt-2 text-small text-ink-2 leading-snug">
          Most STR calculators assume you already own the property. We focus on the buy decision —
          DSCR qualifying, down payment by loan type, Year 1 reserves — before you sign anything.
        </p>
      </li>
      <li class="rounded-md border border-rule bg-parchment-light p-5">
        <p class="font-serif text-h3 text-navy">City data, hand-checked</p>
        <p class="mt-2 text-small text-ink-2 leading-snug">
          219 markets reviewed by humans, not scraped. Regulation status updated annually,
          ADR + saturation reasoned through, not pulled from a stale API.
        </p>
      </li>
      <li class="rounded-md border border-rule bg-parchment-light p-5">
        <p class="font-serif text-h3 text-navy">No upsell</p>
        <p class="mt-2 text-small text-ink-2 leading-snug">
          We surface vendor recommendations on results pages with FTC disclosure. We never sell
          your email or gate calculators behind a signup. Use the tool, leave when done.
        </p>
      </li>
    </ul>
  </section>

  {latestPosts.length > 0 && (
    <section class="bg-parchment border-t border-rule">
      <div class="mx-auto max-w-6xl px-5 py-9">
        <div class="flex items-end justify-between gap-4">
          <div>
            <p class="label text-accent">From the notebook</p>
            <p class="mt-3 font-serif text-h2 text-navy leading-tight">
              Pair the calculator with the math<span class="period-accent">.</span>
            </p>
          </div>
          <a
            href="/blog"
            class="hidden sm:inline-flex items-center gap-1 text-ui text-navy no-underline hover:text-navy-tint group whitespace-nowrap"
          >
            All posts
            <span class="text-accent inline-block transition-transform duration-std group-hover:translate-x-0.5" aria-hidden="true">→</span>
          </a>
        </div>

        <ul class="mt-6 grid grid-cols-1 md:grid-cols-3 gap-4">
          {latestPosts.map((post) => {
            const thumbSrc = post.heroImage
              ? post.heroImage.replace(/\/hero\.webp$/, '/thumb.webp')
              : null;
            return (
            <li>
              <a
                href={`/blog/${post.slug}`}
                class="group block h-full rounded-md border border-rule bg-parchment-light no-underline hover:border-accent hover:shadow-card transition-all duration-std focus:outline-none focus:shadow-focus overflow-hidden"
              >
                {thumbSrc && (
                  <div class="aspect-[1200/630] overflow-hidden bg-parchment-alt border-b border-rule">
                    <img
                      src={thumbSrc}
                      alt={post.heroAlt ?? post.title}
                      width="600"
                      height="315"
                      loading="lazy"
                      decoding="async"
                      class="w-full h-full object-cover transition-transform duration-std group-hover:scale-[1.02]"
                    />
                  </div>
                )}
                <div class="p-5">
                  <div class="flex items-center gap-2 text-caption text-ink-3">
                    <span class="label text-accent">{categoryLabels[post.category] ?? post.category}</span>
                    <span aria-hidden="true">·</span>
                    <span class="font-mono">{post.readMinutes} min</span>
                  </div>
                  <p class="mt-3 font-serif text-h3 text-navy leading-snug group-hover:text-navy-tint">{post.title}</p>
                  <p class="mt-2 text-small text-ink-2 leading-snug">{post.description}</p>
                  <p class="mt-4 text-caption text-accent group-hover:text-accent-tint flex items-center gap-1">
                    Read
                    <span class="inline-block transition-transform duration-std group-hover:translate-x-0.5" aria-hidden="true">→</span>
                  </p>
                </div>
              </a>
            </li>
            );
          })}
        </ul>
      </div>
    </section>
  )}

  <ClusterFunnelBlock siteConfig={siteConfig} currentCluster="acquisition" />

  <AdSlot siteConfig={siteConfig} location="footer" />
</Layout>

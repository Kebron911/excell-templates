---
import Layout from '@/components/chrome/Layout.astro';
import ClusterFunnelBlock from '@/components/chrome/ClusterFunnelBlock.astro';

const today = new Date().toISOString().slice(0, 10);
---
<Layout
  title="Terms — strbuyers.tools"
  description="Terms of use for strbuyers.tools. Free calculators and city reports, provided as-is, not financial advice."
  path="/terms"
>
  <article class="mx-auto max-w-3xl px-5 py-12 prose">
    <header>
      <p class="label text-accent">Legal</p>
      <h1 class="mt-2 font-serif text-h1 text-navy">Terms<span class="period-accent">.</span></h1>
      <p class="mt-3 text-caption text-ink-3 font-mono">
        Last updated <time datetime={today}>{today}</time>
      </p>
    </header>

    <section class="mt-7">
      <h2 class="font-serif text-h2 text-navy">Use of the site</h2>
      <p class="mt-3 text-body text-ink-2 leading-relaxed">
        strbuyers.tools is operated by The STR Ledger. The calculators and
        city market reports are provided free of charge. You may use them
        for personal, research, or business purposes. Do not abuse, scrape
        at high volume, or attempt to disrupt the service.
      </p>
    </section>

    <section class="mt-7">
      <h2 class="font-serif text-h2 text-navy">Not financial advice</h2>
      <p class="mt-3 text-body text-ink-2 leading-relaxed">
        Every tool on this site is for informational purposes only. The
        DSCR loan, down payment, cash-on-cash, market score, and furnishing
        calculators produce estimates from inputs you supply — they are not
        underwriting decisions, appraisals, or investment recommendations.
        Verify every number with a qualified lender, accountant, and local
        STR-regulation authority before purchasing property.
      </p>
    </section>

    <section class="mt-7">
      <h2 class="font-serif text-h2 text-navy">City data accuracy</h2>
      <p class="mt-3 text-body text-ink-2 leading-relaxed">
        City pages reflect hand-compiled regulation and market data accurate
        as of the publication date shown on each page. STR rules change
        often — re-verify any city's current ordinance with the municipality
        before making a buy decision. We disclaim liability for outdated or
        incorrect city-level data.
      </p>
    </section>

    <section class="mt-7">
      <h2 class="font-serif text-h2 text-navy">Affiliate relationships</h2>
      <p class="mt-3 text-body text-ink-2 leading-relaxed">
        Some outbound links are affiliate links — we may earn a commission
        at no extra cost to you. Affiliate relationships do not influence
        which vendors appear in calculator output or how city reports are
        scored. Full detail at <a href="/disclosures" class="text-accent">/disclosures</a>.
      </p>
    </section>

    <section class="mt-7">
      <h2 class="font-serif text-h2 text-navy">Changes to these terms</h2>
      <p class="mt-3 text-body text-ink-2 leading-relaxed">
        We may update these terms. Material changes will be reflected by an
        updated "Last updated" date at the top of this page.
      </p>
    </section>
  </article>

  <ClusterFunnelBlock currentCluster="acquisition" />
</Layout>

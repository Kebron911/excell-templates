---
import Layout from '@/components/chrome/Layout.astro';
import ClusterFunnelBlock from '@str/ui-funnel/ClusterFunnelBlock.astro';
import STRLedgerCTA from '@str/ui-funnel/STRLedgerCTA.astro';
import { siteConfig } from '@/data/site.config';
---
<Layout
  title="About — strbuyers.tools"
  description="strbuyers.tools is a free calculator + city-data site for short-term rental property buyers. Built by the team behind The STR Ledger."
  path="/about"
>
  <article class="mx-auto max-w-3xl px-5 py-12 prose">
    <header>
      <p class="label text-accent">About</p>
      <h1 class="mt-2 font-serif text-h1 text-navy">
        Free tools for the buy decision<span class="period-accent">.</span>
      </h1>
      <p class="mt-3 text-lead text-ink-2 max-w-2xl leading-snug">
        strbuyers.tools is a small free-tools site for short-term rental investors
        deciding whether (and where) to buy. Seven calculators, 219 city market
        reports, no signup, no popups.
      </p>
    </header>

    <section class="mt-9">
      <h2 class="font-serif text-h2 text-navy">Who builds this</h2>
      <p class="mt-3 text-body text-ink-2 leading-relaxed">
        strbuyers.tools is built by the team behind
        <a href="https://thestrledger.com" class="text-accent">The STR Ledger</a> —
        a small studio making Excel and Notion templates for short-term rental
        finance. We host properties ourselves; everything on this site exists
        because we wanted it before we bought.
      </p>
      <p class="mt-3 text-body text-ink-2 leading-relaxed">
        strbuyers.tools is the first stop in a four-site cluster covering the
        full STR host lifecycle:
        strbuyers.tools (acquisition),
        <a href="https://strhost.tools" class="text-accent">strhost.tools</a> (math),
        <a href="https://strops.tools" class="text-accent">strops.tools</a> (operations), and
        <a href="https://strguests.tools" class="text-accent">strguests.tools</a> (guest XP).
        Each site is deliberately specialized so the tools stay sharp.
      </p>
    </section>

    <section class="mt-9">
      <h2 class="font-serif text-h2 text-navy">What we won't do</h2>
      <ul class="mt-4 space-y-3 text-body text-ink-2 leading-relaxed">
        <li><strong class="text-navy">Sell your email.</strong> We use email captures for our buyer playbook and product launches, nothing else. Unsubscribe link in every email.</li>
        <li><strong class="text-navy">Run popups, exit-intent modals, or sticky ads.</strong> Use the calculator, leave when you're done.</li>
        <li><strong class="text-navy">Hide formulas behind a paywall.</strong> Every calculator's math is documented on its page.</li>
        <li><strong class="text-navy">Quietly take affiliate money.</strong> Vendor recommendations are flagged with FTC-compliant
          <a href="/disclosures" class="text-accent">disclosures</a> on every page they appear.</li>
      </ul>
    </section>

    <section class="mt-9">
      <h2 class="font-serif text-h2 text-navy">What we will do</h2>
      <ul class="mt-4 space-y-3 text-body text-ink-2 leading-relaxed">
        <li><strong class="text-navy">Verify city data annually.</strong> Each of the 219 city reports has a <code>lastVerified</code> ISO date. Regulation status, ADR, and saturation re-checked each year.</li>
        <li><strong class="text-navy">Add tools as we hear what buyers need.</strong> The seven launch calculators cover the highest-volume buy-decision questions. New tools land when there's a clear demand signal.</li>
        <li><strong class="text-navy">Listen to bug reports.</strong> If a calculator gives wrong math or a city report goes stale, message us — we fix it within a week.</li>
      </ul>
    </section>

    <section class="mt-9">
      <h2 class="font-serif text-h2 text-navy">How we make money</h2>
      <p class="mt-3 text-body text-ink-2 leading-relaxed">
        We earn affiliate commissions when you sign up with a recommended DSCR
        lender, STR data provider, or insurance broker through our links. We
        only recommend vendors we'd use ourselves; the
        <a href="/disclosures" class="text-accent">disclosures page</a> spells out
        who pays us, how much, and how it affects what we recommend.
      </p>
    </section>

    <STRLedgerCTA siteConfig={siteConfig} tool="strbuyers" />
  </article>

  <ClusterFunnelBlock siteConfig={siteConfig} currentCluster="acquisition" />
</Layout>

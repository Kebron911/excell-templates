---
import Layout from '@/components/chrome/Layout.astro';
import Sidebar from '@/components/chrome/Sidebar.astro';
import ClusterFunnelBlock from '@/components/chrome/ClusterFunnelBlock.astro';
import AdSlot from '@/components/ads/AdSlot.astro';
import EmailCaptureCard from '@/components/funnel/EmailCaptureCard.astro';
import STRLedgerCTA from '@/components/funnel/STRLedgerCTA.astro';
import AffiliateBlock from '@/components/affiliate/AffiliateBlock.astro';
import FurnishingCalculator from '@/components/calculators/FurnishingCalculator.tsx';
import { Content as ToolCopy } from '@/content/tools/furnishing-budget.mdx';
import { buildWebApplication, buildFAQPage } from '@/lib/seo';
import tools from '@/data/tools.json';

const tool = tools['furnishing-budget'];
const faqs = [
  { question: 'How much should I spend on furnishing?', answer: 'For a 2-bedroom mid-tier STR, plan $18–22k. Basic comes in around $11k; luxury $35k+. Don\'t skimp on the photo-driving items: living-room sofa, primary bedroom, kitchen.' },
  { question: 'Should I use a turnkey furniture package?', answer: 'Stage by Hand and Minoan deliver everything in 2–3 weeks for ~10–15% premium over DIY. Worth it when speed matters; skip when you have time and design taste.' },
  { question: 'What are the must-have items for STR photos?', answer: 'Living room sofa + accent chairs, primary bed with headboard, dining table, kitchen styling, primary bath linens, and outdoor seating if applicable. These drive 80% of booking decisions.' },
];
const jsonLd = [
  buildWebApplication({ name: 'Furnishing Budget Calculator', description: 'Free furnishing budget calculator for STR property setup.', toolPath: tool.path }),
  buildFAQPage(faqs),
];
---
<Layout title="STR Furnishing Budget Calculator — strbuyers.tools" description="Free furnishing budget calculator for STR investors. By bedroom count and tier — basic, mid, or luxury." path="/furnishing-budget" jsonLd={jsonLd}>
  <article class="calculator-page bg-parchment">
    <div class="mx-auto max-w-6xl px-5 pt-9 pb-7 grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-9">
      <div class="min-w-0">
        <header><h1 class="text-h1 font-serif text-navy leading-tight">Furnishing Budget<span class="period-accent">.</span></h1><p class="mt-3 text-lead text-ink-2 max-w-2xl">Studio to 4-bedroom. Three tiers. Real numbers.</p></header>
        <div class="mt-7"><FurnishingCalculator client:load /></div>
        <AdSlot location="in-content" />
        <AffiliateBlock tool="furnishing-budget" headline="Furniture & turnkey packages" />
        <div class="prose mt-7 max-w-2xl"><ToolCopy /></div>
        <EmailCaptureCard magnet="strbuyers-checklist" toolSlug="furnishing-budget" />
        <STRLedgerCTA tool="furnishing-budget" />
        <AdSlot location="footer" />
      </div>
      <Sidebar current="furnishing-budget" />
    </div>
    <ClusterFunnelBlock currentCluster="acquisition" />
  </article>
</Layout>
<style>
  .prose :global(h2) { font-family: var(--font-display); font-size: var(--t-h2-size); color: var(--brand-navy); margin-top: 1.6rem; margin-bottom: 0.6rem; }
  .prose :global(h3) { font-family: var(--font-display); color: var(--brand-navy); margin-top: 1.2rem; margin-bottom: 0.4rem; font-size: var(--t-h3-size); }
  .prose :global(p) { margin-bottom: 0.9rem; line-height: 1.65; color: var(--ink-2); }
</style>

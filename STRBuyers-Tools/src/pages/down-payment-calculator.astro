---
import Layout from '@/components/chrome/Layout.astro';
import Sidebar from '@/components/chrome/Sidebar.astro';
import ClusterFunnelBlock from '@/components/chrome/ClusterFunnelBlock.astro';
import AdSlot from '@/components/ads/AdSlot.astro';
import EmailCaptureCard from '@/components/funnel/EmailCaptureCard.astro';
import STRLedgerCTA from '@/components/funnel/STRLedgerCTA.astro';
import AffiliateBlock from '@/components/affiliate/AffiliateBlock.astro';
import DownPaymentCalculator from '@/components/calculators/DownPaymentCalculator.tsx';
import { Content as ToolCopy } from '@/content/tools/down-payment-calculator.mdx';
import { buildWebApplication, buildFAQPage } from '@/lib/seo';
import tools from '@/data/tools.json';

const tool = tools['down-payment-calculator'];
const faqs = [
  { question: 'How much down for a DSCR loan?', answer: 'Typically 20–25% for the best rates. Some lenders fund 80% LTV (20% down); others cap at 75% LTV (25% down) on STRs specifically.' },
  { question: 'Can I use FHA for an STR?', answer: 'Only if you live in the property as your primary residence. House-hack scenarios where you STR a portion of your primary home work; pure investment-only STRs do not qualify for FHA.' },
  { question: 'What is the second-home loan?', answer: 'A non-primary, non-investment loan with the lowest down (~10%). The property must be reasonable distance from your primary and used as a second home — most lenders cap STR rentals on second-home loans.' },
];
const jsonLd = [
  buildWebApplication({ name: 'STR Down Payment Calculator', description: 'Free down-payment calculator for STR property purchase.', toolPath: tool.path }),
  buildFAQPage(faqs),
];
---
<Layout title="STR Down Payment Calculator — strbuyers.tools" description="See your down payment, loan amount, and estimated monthly P&I across loan types — conventional, DSCR, second-home, FHA." path="/down-payment-calculator" jsonLd={jsonLd}>
  <article class="calculator-page bg-parchment">
    <div class="mx-auto max-w-6xl px-5 pt-9 pb-7 grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-9">
      <div class="min-w-0">
        <header><h1 class="text-h1 font-serif text-navy leading-tight">Down Payment Calculator<span class="period-accent">.</span></h1><p class="mt-3 text-lead text-ink-2 max-w-2xl">Down, loan amount, monthly P&I — by loan type.</p></header>
        <div class="mt-7"><DownPaymentCalculator client:load /></div>
        <AdSlot location="in-content" />
        <AffiliateBlock tool="down-payment-calculator" headline="Lenders we've vetted" />
        <div class="prose mt-7 max-w-2xl"><ToolCopy /></div>
        <EmailCaptureCard magnet="strbuyers-checklist" toolSlug="down-payment-calculator" />
        <STRLedgerCTA tool="down-payment-calculator" />
        <AdSlot location="footer" />
      </div>
      <Sidebar current="down-payment-calculator" />
    </div>
    <ClusterFunnelBlock currentCluster="acquisition" />
  </article>
</Layout>
<style>
  .prose :global(h2) { font-family: var(--font-display); font-size: var(--t-h2-size); color: var(--brand-navy); margin-top: 1.6rem; margin-bottom: 0.6rem; }
  .prose :global(h3) { font-family: var(--font-display); color: var(--brand-navy); margin-top: 1.2rem; margin-bottom: 0.4rem; font-size: var(--t-h3-size); }
  .prose :global(p) { margin-bottom: 0.9rem; line-height: 1.65; color: var(--ink-2); }
</style>

---
import Layout from '@/components/chrome/Layout.astro';
import Sidebar from '@/components/chrome/Sidebar.astro';
import ClusterFunnelBlock from '@/components/chrome/ClusterFunnelBlock.astro';
import AdSlot from '@/components/ads/AdSlot.astro';
import EmailCaptureCard from '@/components/funnel/EmailCaptureCard.astro';
import STRLedgerCTA from '@/components/funnel/STRLedgerCTA.astro';
import AffiliateBlock from '@/components/affiliate/AffiliateBlock.astro';
import MarketScoreCalculator from '@/components/calculators/MarketScoreCalculator.tsx';
import { Content as ToolCopy } from '@/content/tools/market-score.mdx';
import { buildWebApplication, buildFAQPage } from '@/lib/seo';
import tools from '@/data/tools.json';

const tool = tools['market-score'];
const faqs = [
  { question: 'How is the score calculated?', answer: 'A weighted heuristic: ADR (30 pts), occupancy (30 pts), regulation status (20 pts), saturation (20 pts). Banned regulation zeroes the total.' },
  { question: 'What counts as restrictive regulation?', answer: 'Cities/counties with active permit caps, primary-residence requirements, registration fees, or stay-length limits. Restrictive doesn\'t kill the deal but adds compliance burden and risk.' },
  { question: 'How do I find regulation status?', answer: 'Check the city/county short-term rental ordinance directly. Many cities maintain a public STR registry. AirDNA\'s "Regulation" tab summarizes status by ZIP.' },
];
const jsonLd = [
  buildWebApplication({ name: 'STR Market Score Tool', description: 'Free market score for STR investors — combines ADR, occupancy, regulation, and saturation.', toolPath: tool.path }),
  buildFAQPage(faqs),
];
---
<Layout title="STR Market Score — strbuyers.tools" description="Free market scoring tool for STR investors. ADR, occupancy, regulation, and saturation combined into a 0–100 score." path="/market-score" jsonLd={jsonLd}>
  <article class="calculator-page bg-parchment">
    <div class="mx-auto max-w-6xl px-5 pt-9 pb-7 grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-9">
      <div class="min-w-0">
        <header><h1 class="text-h1 font-serif text-navy leading-tight">Market Score Tool<span class="period-accent">.</span></h1><p class="mt-3 text-lead text-ink-2 max-w-2xl">Is this market worth your time? One score, four inputs.</p></header>
        <div class="mt-7"><MarketScoreCalculator client:load /></div>
        <AdSlot location="in-content" />
        <AffiliateBlock tool="market-score" headline="Market data" />
        <div class="prose mt-7 max-w-2xl"><ToolCopy /></div>
        <EmailCaptureCard magnet="strbuyers-checklist" toolSlug="market-score" />
        <STRLedgerCTA tool="market-score" />
        <AdSlot location="footer" />
      </div>
      <Sidebar current="market-score" />
    </div>
    <ClusterFunnelBlock currentCluster="acquisition" />
  </article>
</Layout>
<style>
  .prose :global(h2) { font-family: var(--font-display); font-size: var(--t-h2-size); color: var(--brand-navy); margin-top: 1.6rem; margin-bottom: 0.6rem; }
  .prose :global(h3) { font-family: var(--font-display); color: var(--brand-navy); margin-top: 1.2rem; margin-bottom: 0.4rem; font-size: var(--t-h3-size); }
  .prose :global(p) { margin-bottom: 0.9rem; line-height: 1.65; color: var(--ink-2); }
</style>

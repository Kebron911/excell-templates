# strbuyers.tools — environment variables
# Copy to .env (gitignored) and fill in. Server reads these at boot.

# --- MySQL (Hostinger managed) ---
# Phase 4 server bootstraps the pool LAZILY — missing creds don't crash
# `pnpm server:dev`; only the first /api/click insert will fail.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=
DB_PASS=
DB_NAME=strbuyers

# --- Click endpoint hardening ---
# Salt for sha256(IP + salt). If unset, the server picks a per-process
# random salt at boot (rotates on restart, which is fine for click logs).
IP_HASH_SALT=

# --- Server runtime ---
PORT=3301
CORS_ORIGIN=https://strbuyers.tools

# --- Public (build-time, baked into dist) ---
# ESP webhook for lead capture (EmailCaptureCard). When unset, the form
# logs to console and shows a dev-mode thank-you.
PUBLIC_ESP_WEBHOOK=
# GA4 measurement ID — Phase 5 wires this into Layout.
PUBLIC_GA4_ID=

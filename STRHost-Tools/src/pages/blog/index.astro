---
import Layout from '@/components/chrome/Layout.astro';
import ClusterFunnelBlock from '@/components/chrome/ClusterFunnelBlock.astro';
import EmailCaptureCard from '@/components/funnel/EmailCaptureCard.astro';
import STRLedgerCTA from '@/components/funnel/STRLedgerCTA.astro';
import { getCollection } from 'astro:content';

// Posts collection — sorted newest first.
const all = await getCollection('posts');
const posts = all
  .map((p) => ({
    slug: p.id.replace(/\.mdx$/, ''),
    ...p.data,
  }))
  .sort((a, b) => (a.datePublished < b.datePublished ? 1 : -1));

const categoryLabels: Record<string, string> = {
  math: 'Math',
  operations: 'Operations',
  tax: 'Tax',
  'guest-xp': 'Guest XP',
  acquisition: 'Acquisition',
};

const formatDate = (iso: string) =>
  new Date(iso + 'T12:00:00Z').toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', timeZone: 'UTC' });
---

<Layout
  title="Blog — STR Host Tools"
  description="Honest, formula-first writing for short-term rental hosts. Profit, RevPAR, break-even, cleaning fees, lodging tax, and co-host splits — without the fluff."
  path="/blog"
>
  <section class="bg-parchment">
    <div class="mx-auto max-w-6xl px-5 pt-12 pb-9">
      <p class="label text-gold-deep">The Ledger Notebook</p>
      <h1 class="mt-3 text-h1 font-serif text-navy max-w-3xl leading-tight">
        STR math, written down<span class="period-gold">.</span>
      </h1>
      <p class="mt-4 text-lead text-ink-2 max-w-2xl">
        Every post pairs a calculator with a 1,500-word breakdown of the math behind it. No hot takes, no AI fluff, no popup that asks for your email before you've read a sentence.
      </p>
    </div>
  </section>

  <section class="bg-parchment-light border-t border-rule">
    <div class="mx-auto max-w-6xl px-5 py-9">
      <ul class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {posts.map((post) => (
          <li>
            <a
              href={`/blog/${post.slug}`}
              class="group block h-full rounded-md border border-rule bg-parchment p-6 no-underline hover:border-gold hover:shadow-card transition-all duration-std focus:outline-none focus:shadow-focus"
            >
              <div class="flex items-center gap-3 text-caption text-ink-3">
                <span class="label text-gold-deep">{categoryLabels[post.category] ?? post.category}</span>
                <span aria-hidden="true">·</span>
                <time datetime={post.datePublished} class="font-mono">{formatDate(post.datePublished)}</time>
                <span aria-hidden="true">·</span>
                <span class="font-mono">{post.readMinutes} min read</span>
              </div>
              <p class="mt-3 font-serif text-h3 text-navy leading-snug group-hover:text-navy-tint">
                {post.title}
              </p>
              <p class="mt-2 text-small text-ink-2 leading-snug">{post.description}</p>
              <p class="mt-4 text-caption text-gold-deep group-hover:text-gold flex items-center gap-1">
                Read
                <span class="inline-block transition-transform duration-std group-hover:translate-x-0.5" aria-hidden="true">→</span>
              </p>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="bg-parchment border-t border-rule">
    <div class="mx-auto max-w-6xl px-5 py-9">
      <EmailCaptureCard
        magnet="str-host-income-report-2026"
        toolSlug="blog-index"
      />
    </div>
  </section>

  <section class="bg-parchment-light border-t border-rule">
    <div class="mx-auto max-w-6xl px-5 py-9">
      <STRLedgerCTA tool="profit-calculator" />
    </div>
  </section>

  <ClusterFunnelBlock currentCluster="math" />
</Layout>

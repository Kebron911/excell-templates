---
import Layout from '@/components/AppLayout.astro';
import Sidebar from '@str/ui-chrome/AppSidebar.astro';
import ClusterFunnelBlock from '@str/ui-funnel/ClusterFunnelBlock.astro';
import AdSlot from '@str/ui-funnel/AdSlot.astro';
import EmailCaptureCard from '@str/ui-funnel/EmailCaptureCard.astro';
import STRLedgerCTA from '@str/ui-funnel/STRLedgerCTA.astro';
import RelatedPosts from '@/components/funnel/RelatedPosts.astro';
import ProfitCalculator from '@/components/calculators/ProfitCalculator.tsx';
import { Content as ToolCopy } from '@/content/tools/profit-calculator.mdx';
import { buildWebApplication, buildFAQPage } from '@str/seo';
import { siteConfig } from '@/data/site.config';
import { sidebarItems } from '@/data/sidebar-items';
import tools from '@/data/tools.json';

const tool = tools['profit-calculator'];

const faqs = [
  {
    question: 'Should I include my own labor as a cost?',
    answer:
      "If you self-manage and self-clean, no. Set management fee rate = 0 and cleaning per turnover = your actual supplies cost. If you want to value your time, set a reasonable management fee rate (10–20%) and net profit becomes 'what's left after paying yourself.'",
  },
  {
    question: 'How do I model multiple properties?',
    answer:
      "Run the calculator once per property. The numbers don't combine cleanly because mortgage and tax differ per property.",
  },
  {
    question: 'What about depreciation?',
    answer:
      'Not modeled — depreciation is a tax concept, not a cash-flow concept. For tax planning, see The STR Ledger depreciation tracker.',
  },
  {
    question: 'Why is my profit margin so low?',
    answer:
      "STR margins typically run 15–35% net. If you're under 10%, the usual culprits are: mortgage too high relative to ADR, occupancy assumption too aggressive, or hidden costs (capex, vacancy reserve) you haven't itemized.",
  },
  {
    question: 'Is this tax advice?',
    answer:
      'No. This is a cash-flow model. For tax planning — material participation, cost segregation, Schedule E vs. C — consult a CPA.',
  },
];

const jsonLd = [
  buildWebApplication(siteConfig, {
    name: 'STR Profit Calculator',
    description:
      'Free short-term rental profit calculator. Itemize revenue, variable costs, and fixed costs to see net profit and margin in one view.',
    toolPath: tool.path,
  }),
  buildFAQPage(faqs),
];
---

<Layout siteConfig={siteConfig}
  title="STR Profit Calculator — STR Host Tools"
  description="Free short-term rental profit calculator. Enter ADR, occupancy, and itemized costs to see your real net profit and margin."
  path="/profit-calculator"
  jsonLd={jsonLd}
>
  <article class="calculator-page bg-parchment">
    <div class="mx-auto max-w-6xl px-5 pt-9 pb-7 grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-9">
      <div class="min-w-0">
        <header>
          <h1 class="text-h1 font-serif text-navy leading-tight">
            STR Profit Calculator<span class="period-gold">.</span>
          </h1>
          <p class="mt-3 text-lead text-ink-2 max-w-2xl">
            Itemize revenue, variable costs, and fixed costs. See your real net profit and margin — no spreadsheet required.
          </p>
        
    </header>

        <div class="mt-7">
          <ProfitCalculator client:load />
        </div>

        <AdSlot siteConfig={siteConfig} location="in-content" />

        <div class="prose mt-7 max-w-2xl">
          <ToolCopy />
        </div>

        <RelatedPosts toolKey="profit-calculator" />

        <EmailCaptureCard siteConfig={siteConfig}
          magnet="str-host-income-report-2026"
          toolSlug="profit-calculator"
        />

        <STRLedgerCTA siteConfig={siteConfig} tool="profit-calculator" />

        <AdSlot siteConfig={siteConfig} location="footer" />
      </div>

      <Sidebar siteConfig={siteConfig} items={sidebarItems} current="profit-calculator" />
    </div>

    <ClusterFunnelBlock siteConfig={siteConfig} currentCluster="math" />
  </article>
</Layout>

<style>
  .prose :global(h2) {
    font-family: var(--font-display);
    font-size: var(--t-h2-size);
    color: var(--brand-navy);
    margin-top: var(--sp-7);
    margin-bottom: var(--sp-3);
    line-height: 1.1;
  }
  .prose :global(h3) {
    font-family: var(--font-display);
    font-size: var(--t-h3-size);
    color: var(--brand-navy);
    margin-top: var(--sp-5);
    margin-bottom: var(--sp-2);
  }
  .prose :global(p) {
    color: var(--fg-1);
    margin-bottom: var(--sp-3);
    line-height: 1.6;
  }
  .prose :global(ol),
  .prose :global(ul) {
    margin: var(--sp-3) 0 var(--sp-4);
    padding-left: var(--sp-5);
  }
  .prose :global(li) { margin-bottom: var(--sp-2); line-height: 1.55; }
  .prose :global(strong) { color: var(--brand-navy); font-weight: 600; }
  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: var(--bg-2);
    padding: 0 0.3em;
    border-radius: var(--r-1);
  }
  .prose :global(a) {
    color: var(--brand-navy);
    text-decoration: underline;
    text-decoration-color: var(--brand-gold);
    text-underline-offset: 3px;
  }
</style>

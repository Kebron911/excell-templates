---
import Layout from '@str/ui-chrome/Layout.astro';
import { siteConfig } from '@/data/site.config';
---

<Layout siteConfig={siteConfig}
  title="Terms of Use — STR Host Tools"
  description="Terms of use for strhost.tools. Calculators are informational, not financial or tax advice."
  path="/terms"
>
  <section class="bg-parchment">
    <div class="mx-auto max-w-3xl px-5 pt-12 pb-9">
      <p class="label text-gold-deep">Legal</p>
      <h1 class="mt-3 text-h1 font-serif text-navy leading-tight">
        Terms of Use<span class="period-gold">.</span>
      </h1>
      <p class="mt-4 text-lead text-ink-2">
        Full terms are in development. The short version: the calculators on strhost.tools are informational, free to use, and not a substitute for professional financial, accounting, or tax advice.
      </p>
    </div>
  </section>

  <section class="bg-parchment-light border-t border-rule">
    <div class="mx-auto max-w-3xl px-5 py-9 prose">
      <h2 class="font-serif text-h2 text-navy">No advice</h2>
      <p class="mt-3 text-body text-ink-2 leading-snug">
        Outputs are estimates based on inputs you provide and assumptions documented on each page. Verify with a CPA, attorney, or other licensed professional before making financial or legal decisions.
      </p>

      <h2 class="mt-7 font-serif text-h2 text-navy">No warranty</h2>
      <p class="mt-3 text-body text-ink-2 leading-snug">
        The site is provided "as is." We work to keep rates and formulas accurate (lodging-tax data is reviewed annually), but we make no guarantee of accuracy, completeness, or fitness for any purpose.
      </p>

      <h2 class="mt-7 font-serif text-h2 text-navy">Acceptable use</h2>
      <p class="mt-3 text-body text-ink-2 leading-snug">
        Use the calculators for your own host operations or share scenarios with partners. Don't scrape the site at high volume, embed without attribution, or republish the underlying data as your own.
      </p>

      <p class="mt-7 text-caption text-ink-3 italic">
        Last updated: this stub is a placeholder. See <a href="/privacy" class="text-navy">Privacy</a> and <a href="/disclosures" class="text-navy">Disclosures</a>.
      </p>
    </div>
  </section>
</Layout>

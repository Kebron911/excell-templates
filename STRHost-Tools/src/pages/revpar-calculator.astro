---
import Layout from '@/components/chrome/Layout.astro';
import Sidebar from '@/components/chrome/Sidebar.astro';
import ClusterFunnelBlock from '@/components/chrome/ClusterFunnelBlock.astro';
import AdSlot from '@/components/ads/AdSlot.astro';
import EmailCaptureCard from '@/components/funnel/EmailCaptureCard.astro';
import STRLedgerCTA from '@/components/funnel/STRLedgerCTA.astro';
import RelatedPosts from '@/components/funnel/RelatedPosts.astro';
import RevparCalculator from '@/components/calculators/RevparCalculator.tsx';
import { Content as ToolCopy } from '@/content/tools/revpar-calculator.mdx';
import { buildWebApplication, buildFAQPage } from '@/lib/seo';
import tools from '@/data/tools.json';

const tool = tools['revpar-calculator'];

const faqs = [
  { question: 'Should revenue be gross or net?', answer: 'Use gross — that is the industry convention. Subtracting fees first gives you "Net ADR" / "Net RevPAR" which don\'t compare cleanly to AirDNA, Mashvisor, or hotel-industry benchmarks.' },
  { question: 'What counts as "available"?', answer: 'Nights you actively listed and were willing to accept bookings. Blocked owner-use, maintenance, or seasonal closure nights are NOT available.' },
  { question: 'Why does RevPAR matter more than occupancy?', answer: 'Occupancy is a vanity metric. A 95%-occupied property at $50/night earns less per available night than a 50%-occupied property at $200/night. RevPAR exposes that.' },
  { question: 'Does this work for a multi-unit portfolio?', answer: 'Yes. For a 5-unit portfolio over 30 days, nights available = 150. Sum revenue across units. The result is blended portfolio RevPAR.' },
  { question: 'How do I improve RevPAR?', answer: 'Two levers: raise ADR without tanking occupancy, or raise occupancy without tanking ADR. The break-even calculator shows the floor; the profit calculator helps you optimize.' },
];

const jsonLd = [
  buildWebApplication({
    name: 'Occupancy + ADR + RevPAR Calculator',
    description: 'Free calculator for the hospitality-industry trio: occupancy rate, average daily rate (ADR), and revenue per available night (RevPAR).',
    toolPath: tool.path,
  }),
  buildFAQPage(faqs),
];
---

<Layout
  title="Occupancy, ADR + RevPAR Calculator — STR Host Tools"
  description="Free RevPAR calculator. Enter nights available, nights booked, and revenue to see occupancy, ADR, and RevPAR — the three numbers hotel pros use."
  path="/revpar-calculator"
  jsonLd={jsonLd}
>
  <article class="calculator-page bg-parchment">
    <div class="mx-auto max-w-6xl px-5 pt-9 pb-7 grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-9">
      <div class="min-w-0">
        <header>
          <h1 class="text-h1 font-serif text-navy leading-tight">
            Occupancy, ADR + RevPAR Calculator<span class="period-gold">.</span>
          </h1>
          <p class="mt-3 text-lead text-ink-2 max-w-2xl">
            The hospitality-industry trio. Three inputs, three numbers: occupancy, ADR, RevPAR.
          </p>
        </header>

        <div class="mt-7">
          <RevparCalculator client:visible />
        </div>

        <AdSlot location="in-content" />

        <div class="prose mt-7 max-w-2xl">
          <ToolCopy />
        </div>

        <RelatedPosts toolKey="revpar-calculator" />

        <EmailCaptureCard
          magnet="str-host-income-report-2026"
          toolSlug="revpar-calculator"
        />

        <STRLedgerCTA tool="revpar-calculator" />

        <AdSlot location="footer" />
      </div>

      <Sidebar current="revpar-calculator" />
    </div>

    <ClusterFunnelBlock currentCluster="math" />
  </article>
</Layout>

<style>
  .prose :global(h2) { font-family: var(--font-display); font-size: var(--t-h2-size); color: var(--brand-navy); margin-top: var(--sp-7); margin-bottom: var(--sp-3); line-height: 1.1; }
  .prose :global(h3) { font-family: var(--font-display); font-size: var(--t-h3-size); color: var(--brand-navy); margin-top: var(--sp-5); margin-bottom: var(--sp-2); }
  .prose :global(p) { color: var(--fg-1); margin-bottom: var(--sp-3); line-height: 1.6; }
  .prose :global(ol), .prose :global(ul) { margin: var(--sp-3) 0 var(--sp-4); padding-left: var(--sp-5); }
  .prose :global(li) { margin-bottom: var(--sp-2); line-height: 1.55; }
  .prose :global(strong) { color: var(--brand-navy); font-weight: 600; }
  .prose :global(code) { font-family: var(--font-mono); font-size: 0.9em; background: var(--bg-2); padding: 0 0.3em; border-radius: var(--r-1); }
  .prose :global(a) { color: var(--brand-navy); text-decoration: underline; text-decoration-color: var(--brand-gold); text-underline-offset: 3px; }
</style>

---
import Layout from '@/components/AppLayout.astro';
import Sidebar from '@str/ui-chrome/AppSidebar.astro';
import ClusterFunnelBlock from '@str/ui-funnel/ClusterFunnelBlock.astro';
import AdSlot from '@str/ui-funnel/AdSlot.astro';
import EmailCaptureCard from '@str/ui-funnel/EmailCaptureCard.astro';
import STRLedgerCTA from '@str/ui-funnel/STRLedgerCTA.astro';
import RelatedPosts from '@/components/funnel/RelatedPosts.astro';
import CleaningFeeCalculator from '@/components/calculators/CleaningFeeCalculator.tsx';
import { Content as ToolCopy } from '@/content/tools/cleaning-fee-calculator.mdx';
import { buildWebApplication, buildFAQPage } from '@str/seo';
import { siteConfig } from '@/data/site.config';
import { sidebarItems } from '@/data/sidebar-items';
import tools from '@/data/tools.json';

const tool = tools['cleaning-fee-calculator'];

const faqs = [
  {
    question: 'What should be included in cleaning fees?',
    answer:
      "The cleaner's full labor (turnover + linens + restocking + pre-arrival), all consumable supplies, laundry, and a small buffer for damage or surprise tasks. Don't include capex, utilities, or your own management time — those belong in overhead.",
  },
  {
    question: 'How do I price cleaning fees fairly?',
    answer:
      "Bottom-up from actual costs (this calculator). Top-down from competitor fees leads to undercharging because most competitors also undercharge.",
  },
  {
    question: 'Per-night vs per-stay — which does Airbnb show?',
    answer:
      "Airbnb shows the cleaning fee as a separate line on the booking. Guests see the total. The per-night view is for your analysis — it shows how the fee distributes across the typical stay.",
  },
  {
    question: 'How many hours should a turnover take?',
    answer:
      "A clean 2BR/2BA STR with light usage takes 2.5–4 hours. Larger properties, hot tubs, or complex setups push to 5–7 hours. Anything under 2 hours is a wipe-down, not a turnover.",
  },
  {
    question: "What's a fair supplies budget per turnover?",
    answer:
      "$8–$15 for a typical STR (toiletries, paper goods, coffee pods, dishwasher tabs, trash bags). Add $3–$5 for extras like tea or fresh sponges.",
  },
];

const jsonLd = [
  buildWebApplication(siteConfig, {
    name: 'Airbnb Cleaning Fee Calculator',
    description:
      'Free Airbnb cleaning fee calculator. Build a defensible cleaning fee bottom-up from labor, supplies, laundry, and buffer.',
    toolPath: tool.path,
  }),
  buildFAQPage(faqs),
];
---

<Layout siteConfig={siteConfig}
  title="Airbnb Cleaning Fee Calculator — STR Host Tools"
  description="Free Airbnb cleaning fee calculator. Build a defensible fee from cleaner labor, supplies, laundry, and buffer — see what's fair without losing the booking."
  path="/cleaning-fee-calculator"
  jsonLd={jsonLd}
>
  <article class="calculator-page bg-parchment">
    <div class="mx-auto max-w-6xl px-5 pt-9 pb-7 grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-9">
      <div class="min-w-0">
        <header>
          <h1 class="text-h1 font-serif text-navy leading-tight">
            Airbnb Cleaning Fee Calculator<span class="period-gold">.</span>
          </h1>
          <p class="mt-3 text-lead text-ink-2 max-w-2xl">
            Build a defensible cleaning fee from the bottom up. Labor + supplies + laundry + buffer — see what's fair without losing the booking.
          </p>
        
    </header>

        <div class="mt-7">
          <CleaningFeeCalculator client:load />
        </div>

        <AdSlot siteConfig={siteConfig} location="in-content" />

        <div class="prose mt-7 max-w-2xl">
          <ToolCopy />
        </div>

        <RelatedPosts toolKey="cleaning-fee-calculator" />

        <EmailCaptureCard siteConfig={siteConfig}
          magnet="str-host-income-report-2026"
          toolSlug="cleaning-fee-calculator"
        />

        <STRLedgerCTA siteConfig={siteConfig} tool="cleaning-fee-calculator" />

        <AdSlot siteConfig={siteConfig} location="footer" />
      </div>

      <Sidebar siteConfig={siteConfig} items={sidebarItems} current="cleaning-fee-calculator" />
    </div>

    <ClusterFunnelBlock siteConfig={siteConfig} currentCluster="math" />
  </article>
</Layout>

<style>
  .prose :global(h2) { font-family: var(--font-display); font-size: var(--t-h2-size); color: var(--brand-navy); margin-top: var(--sp-7); margin-bottom: var(--sp-3); line-height: 1.1; }
  .prose :global(h3) { font-family: var(--font-display); font-size: var(--t-h3-size); color: var(--brand-navy); margin-top: var(--sp-5); margin-bottom: var(--sp-2); }
  .prose :global(p) { color: var(--fg-1); margin-bottom: var(--sp-3); line-height: 1.6; }
  .prose :global(ol), .prose :global(ul) { margin: var(--sp-3) 0 var(--sp-4); padding-left: var(--sp-5); }
  .prose :global(li) { margin-bottom: var(--sp-2); line-height: 1.55; }
  .prose :global(strong) { color: var(--brand-navy); font-weight: 600; }
  .prose :global(code) { font-family: var(--font-mono); font-size: 0.9em; background: var(--bg-2); padding: 0 0.3em; border-radius: var(--r-1); }
  .prose :global(a) { color: var(--brand-navy); text-decoration: underline; text-decoration-color: var(--brand-gold); text-underline-offset: 3px; }
</style>

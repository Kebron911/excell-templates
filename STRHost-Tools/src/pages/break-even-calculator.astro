---
import Layout from '@/components/AppLayout.astro';
import Sidebar from '@str/ui-chrome/AppSidebar.astro';
import ClusterFunnelBlock from '@str/ui-funnel/ClusterFunnelBlock.astro';
import AdSlot from '@str/ui-funnel/AdSlot.astro';
import EmailCaptureCard from '@str/ui-funnel/EmailCaptureCard.astro';
import STRLedgerCTA from '@str/ui-funnel/STRLedgerCTA.astro';
import RelatedPosts from '@/components/funnel/RelatedPosts.astro';
import BreakEvenCalculator from '@/components/calculators/BreakEvenCalculator.tsx';
import { Content as ToolCopy } from '@/content/tools/break-even-calculator.mdx';
import { buildWebApplication, buildFAQPage } from '@str/seo';
import { siteConfig } from '@/data/site.config';
import { sidebarItems } from '@/data/sidebar-items';
import tools from '@/data/tools.json';
import PageHero from '@/components/PageHero.astro';

const tool = tools['break-even-calculator'];

const faqs = [
  { question: 'Why divide by 30?', answer: 'Assumes a 30-day month for simplicity. For seasonal analysis, run it multiple times — break-even in low season may be 70% while high season is 40%.' },
  { question: 'Should I include my own labor in fixed costs?', answer: 'Only if you are paying yourself. For break-even, focus on actual cash outflows; the profit calculator handles management fees if you want to value your time.' },
  { question: 'What if I have multiple properties?', answer: 'Run break-even per property. Portfolio break-even does not generalize cleanly — one property might subsidize another and you want to know which.' },
  { question: 'My break-even is 35 nights — does that mean I am broken?', answer: 'Means the deal cannot break even in a 30-day month at your current ADR. Fixes: raise ADR, lower fixed costs, or raise minimum-night stay to spread cleaning across more nights.' },
  { question: 'Why is my net per night negative?', answer: 'Cleaning + fees + variable costs are eating more than 100% of nightly revenue. Raise the minimum-night requirement, raise ADR, or both.' },
];

const jsonLd = [
  buildWebApplication(siteConfig, {
    name: 'Break-even Occupancy Calculator',
    description: 'Free Airbnb break-even occupancy calculator. Find the minimum occupancy rate to cover your monthly fixed costs.',
    toolPath: tool.path,
  }),
  buildFAQPage(faqs),
];
---

<Layout siteConfig={siteConfig}
  title="Break-even Occupancy Calculator — STR Host Tools"
  description="Free Airbnb break-even calculator. Find the minimum nights or occupancy rate you need each month to cover fixed costs at your current ADR."
  path="/break-even-calculator"
  jsonLd={jsonLd}
>
  <article class="calculator-page bg-parchment">
    <div class="mx-auto max-w-6xl px-5 pt-9 pb-7 grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-9">
      <div class="min-w-0">
        <header>
          <h1 class="text-h1 font-serif text-navy leading-tight">
            Break-even Occupancy Calculator<span class="period-gold">.</span>
          </h1>
          <p class="mt-3 text-lead text-ink-2 max-w-2xl">
            What occupancy do you need to keep the lights on? Enter fixed costs and per-night economics; see the floor.
          </p>
        
      <PageHero slug="break-even-calculator" alt="Break-even occupancy calculator - What occupancy do you need to keep the lights on?" />
    </header>

        <div class="mt-7">
          <BreakEvenCalculator client:visible />
        </div>

        <AdSlot siteConfig={siteConfig} location="in-content" />

        <div class="prose mt-7 max-w-2xl">
          <ToolCopy />
        </div>

        <RelatedPosts toolKey="break-even-calculator" />

        <EmailCaptureCard siteConfig={siteConfig}
          magnet="str-host-income-report-2026"
          toolSlug="break-even-calculator"
        />

        <STRLedgerCTA siteConfig={siteConfig} tool="break-even-calculator" />

        <AdSlot siteConfig={siteConfig} location="footer" />
      </div>

      <Sidebar siteConfig={siteConfig} items={sidebarItems} current="break-even-calculator" />
    </div>

    <ClusterFunnelBlock siteConfig={siteConfig} currentCluster="math" />
  </article>
</Layout>

<style>
  .prose :global(h2) { font-family: var(--font-display); font-size: var(--t-h2-size); color: var(--brand-navy); margin-top: var(--sp-7); margin-bottom: var(--sp-3); line-height: 1.1; }
  .prose :global(h3) { font-family: var(--font-display); font-size: var(--t-h3-size); color: var(--brand-navy); margin-top: var(--sp-5); margin-bottom: var(--sp-2); }
  .prose :global(p) { color: var(--fg-1); margin-bottom: var(--sp-3); line-height: 1.6; }
  .prose :global(ol), .prose :global(ul) { margin: var(--sp-3) 0 var(--sp-4); padding-left: var(--sp-5); }
  .prose :global(li) { margin-bottom: var(--sp-2); line-height: 1.55; }
  .prose :global(strong) { color: var(--brand-navy); font-weight: 600; }
  .prose :global(code) { font-family: var(--font-mono); font-size: 0.9em; background: var(--bg-2); padding: 0 0.3em; border-radius: var(--r-1); }
  .prose :global(a) { color: var(--brand-navy); text-decoration: underline; text-decoration-color: var(--brand-gold); text-underline-offset: 3px; }
</style>

---
import Layout from '@/components/AppLayout.astro';
import Sidebar from '@str/ui-chrome/AppSidebar.astro';
import ClusterFunnelBlock from '@str/ui-funnel/ClusterFunnelBlock.astro';
import AdSlot from '@str/ui-funnel/AdSlot.astro';
import EmailCaptureCard from '@str/ui-funnel/EmailCaptureCard.astro';
import STRLedgerCTA from '@str/ui-funnel/STRLedgerCTA.astro';
import RelatedPosts from '@/components/funnel/RelatedPosts.astro';
import AirbnbFeeCalculator from '@/components/calculators/AirbnbFeeCalculator.tsx';
import { Content as ToolCopy } from '@/content/tools/airbnb-fee-calculator.mdx';
import { buildWebApplication, buildFAQPage } from '@str/seo';
import { siteConfig } from '@/data/site.config';
import { sidebarItems } from '@/data/sidebar-items';
import tools from '@/data/tools.json';
import PageHero from '@/components/PageHero.astro';

const tool = tools['airbnb-fee-calculator'];

const faqs = [
  {
    question: 'What is the Airbnb host service fee?',
    answer:
      "Most hosts pay 3% of the booking subtotal under the host-only fee structure that Airbnb made the default in late 2020. A few legacy listings still see the older split-fee structure (~14–16% host fee, ~6% guest fee).",
  },
  {
    question: 'What is the Airbnb guest service fee?',
    answer:
      "Guests typically pay around 14% of the booking subtotal, varying by trip length, total amount, and other factors Airbnb doesn't fully disclose.",
  },
  {
    question: 'Does the cleaning fee count toward the service fees?',
    answer:
      'Yes. Both the host fee and the guest service fee apply to the subtotal, which includes the cleaning fee.',
  },
  {
    question: 'Are these rates exact?',
    answer:
      "They're typical defaults. Your account may differ, especially if you're on the legacy split fee or have negotiated terms. Adjust the inputs to match your actual rates.",
  },
  {
    question: 'Is this tax advice?',
    answer:
      'No. This calculator only models Airbnb’s platform fees. For state lodging and occupancy tax, see the lodging tax calculator. For income or self-employment tax, consult a CPA.',
  },
];

const jsonLd = [
  buildWebApplication(siteConfig, {
    name: 'Airbnb Fee Calculator',
    description:
      'Free Airbnb fee calculator. See the host fee, guest service fee, and your real payout — instantly.',
    toolPath: tool.path,
  }),
  buildFAQPage(faqs),
];
---

<Layout siteConfig={siteConfig}
  title="Airbnb Fee Calculator — STR Host Tools"
  description="Free Airbnb fee calculator. Enter nightly rate, nights, and cleaning fee — see what the guest pays, what Airbnb takes, and what you really receive."
  path="/airbnb-fee-calculator"
  jsonLd={jsonLd}
>
  <article class="calculator-page bg-parchment">
    <div class="mx-auto max-w-6xl px-5 pt-9 pb-7 grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-9">
      <div class="min-w-0">
        {/* 1. H1 + lede */}
        <header>
          <h1 class="text-h1 font-serif text-navy leading-tight">
            Airbnb Fee Calculator<span class="period-gold">.</span>
          </h1>
          <p class="mt-3 text-lead text-ink-2 max-w-2xl">
            See exactly what Airbnb takes from a booking — and what you really keep. Live updates, shareable URL, clean print.
          </p>
        
      <PageHero slug="airbnb-fee-calculator" alt="Airbnb fee calculator - What Airbnb really takes from your booking." />
    </header>

        {/* 2. Calculator above the fold */}
        <div class="mt-7">
          <AirbnbFeeCalculator client:load />
        </div>

        {/* 3. In-content ad */}
        <AdSlot siteConfig={siteConfig} location="in-content" />

        {/* 4 + 6 + 7. How it works / How to use / FAQ — content from MDX */}
        <div class="prose mt-7 max-w-2xl">
          <ToolCopy />
        </div>

        <RelatedPosts toolKey="airbnb-fee-calculator" />

        {/* 5. Email capture */}
        <EmailCaptureCard siteConfig={siteConfig}
          magnet="str-host-income-report-2026"
          toolSlug="airbnb-fee-calculator"
        />

        {/* 8. STR Ledger CTA */}
        <STRLedgerCTA siteConfig={siteConfig} tool="airbnb-fee-calculator" />

        {/* 9. Footer ad */}
        <AdSlot siteConfig={siteConfig} location="footer" />
      </div>

      {/* 10. Related calculators (Sidebar) — desktop right rail, mobile collapses below */}
      <Sidebar siteConfig={siteConfig} items={sidebarItems} current="airbnb-fee-calculator" />
    </div>

    {/* 11. Cluster funnel band */}
    <ClusterFunnelBlock siteConfig={siteConfig} currentCluster="math" />
  </article>
</Layout>

<style>
  /* Tailwind doesn't ship a default .prose; light-touch styling here so the
     MDX content renders with editorial rhythm. */
  .prose :global(h2) {
    font-family: var(--font-display);
    font-size: var(--t-h2-size);
    color: var(--brand-navy);
    margin-top: var(--sp-7);
    margin-bottom: var(--sp-3);
    line-height: 1.1;
  }
  .prose :global(h3) {
    font-family: var(--font-display);
    font-size: var(--t-h3-size);
    color: var(--brand-navy);
    margin-top: var(--sp-5);
    margin-bottom: var(--sp-2);
  }
  .prose :global(p) {
    color: var(--fg-1);
    margin-bottom: var(--sp-3);
    line-height: 1.6;
  }
  .prose :global(ol),
  .prose :global(ul) {
    margin: var(--sp-3) 0 var(--sp-4);
    padding-left: var(--sp-5);
  }
  .prose :global(li) {
    margin-bottom: var(--sp-2);
    line-height: 1.55;
  }
  .prose :global(strong) { color: var(--brand-navy); font-weight: 600; }
  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: var(--bg-2);
    padding: 0 0.3em;
    border-radius: var(--r-1);
  }
  .prose :global(a) {
    color: var(--brand-navy);
    text-decoration: underline;
    text-decoration-color: var(--brand-gold);
    text-underline-offset: 3px;
  }
</style>

---
import Layout from '@str/ui-chrome/Layout.astro';
import Sidebar from '@str/ui-chrome/Sidebar.astro';
import ClusterFunnelBlock from '@str/ui-funnel/ClusterFunnelBlock.astro';
import AdSlot from '@str/ui-funnel/AdSlot.astro';
import EmailCaptureCard from '@str/ui-funnel/EmailCaptureCard.astro';
import STRLedgerCTA from '@str/ui-funnel/STRLedgerCTA.astro';
import RelatedPosts from '@/components/funnel/RelatedPosts.astro';
import CohostSplitCalculator from '@/components/calculators/CohostSplitCalculator.tsx';
import { Content as ToolCopy } from '@/content/tools/cohost-split-calculator.mdx';
import { buildWebApplication, buildFAQPage } from '@str/seo';
import { siteConfig } from '@/data/site.config';
import tools from '@/data/tools.json';

const tool = tools['cohost-split-calculator'];

const faqs = [
  { question: "What's a fair cohost percentage?", answer: 'Industry typical is 20–25% of net for full management. Lower (10–15%) for just-the-comms; higher (25–30%) for properties needing significant operational lift.' },
  { question: 'Should the split be on gross or net?', answer: 'Net (gross minus pass-through costs) is fair. A cohost should not earn on cleaning fees that pass straight to the cleaner.' },
  { question: 'Why can owner share clamp to 0?', answer: 'If flat-fee cohost charges exceed net revenue in a slow month, the calculator clamps owner at 0 instead of showing negative. That means the flat-fee structure isn\'t sustainable at this volume — renegotiate.' },
  { question: 'Does this handle multiple cohosts or tiered splits?', answer: 'No. For tiered or multi-party splits, use The STR Ledger commission split workbook which handles tiers, bonuses, and reconciliation.' },
  { question: 'What about lodging tax in the split?', answer: 'Include lodging tax as a pass-through cost. It is remitted to the state and should not appear in net revenue the cohost earns on.' },
];

const jsonLd = [
  buildWebApplication(siteConfig, {
    name: 'Co-host Split Calculator',
    description: 'Free Airbnb cohost split calculator. Model percent-of-net or flat-fee splits. See cohost share and owner share with effective percentages.',
    toolPath: tool.path,
  }),
  buildFAQPage(faqs),
];
---

<Layout siteConfig={siteConfig}
  title="Co-host Split Calculator — STR Host Tools"
  description="Free Airbnb cohost split calculator. Model percent-of-net or flat-fee splits. See cohost share and owner share — fair, transparent, sharable."
  path="/cohost-split-calculator"
  jsonLd={jsonLd}
>
  <article class="calculator-page bg-parchment">
    <div class="mx-auto max-w-6xl px-5 pt-9 pb-7 grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-9">
      <div class="min-w-0">
        <header>
          <h1 class="text-h1 font-serif text-navy leading-tight">
            Co-host Split Calculator<span class="period-gold">.</span>
          </h1>
          <p class="mt-3 text-lead text-ink-2 max-w-2xl">
            Fair, transparent revenue splits between cohosts and owners. Percent of net or flat fees, sharable URL.
          </p>
        </header>

        <div class="mt-7">
          <CohostSplitCalculator client:visible />
        </div>

        <AdSlot siteConfig={siteConfig} location="in-content" />

        <div class="prose mt-7 max-w-2xl">
          <ToolCopy />
        </div>

        <RelatedPosts toolKey="cohost-split-calculator" />

        <EmailCaptureCard siteConfig={siteConfig}
          magnet="str-host-income-report-2026"
          toolSlug="cohost-split-calculator"
        />

        <STRLedgerCTA siteConfig={siteConfig} tool="cohost-split-calculator" />

        <AdSlot siteConfig={siteConfig} location="footer" />
      </div>

      <Sidebar siteConfig={siteConfig} current="cohost-split-calculator" />
    </div>

    <ClusterFunnelBlock siteConfig={siteConfig} currentCluster="math" />
  </article>
</Layout>

<style>
  .prose :global(h2) { font-family: var(--font-display); font-size: var(--t-h2-size); color: var(--brand-navy); margin-top: var(--sp-7); margin-bottom: var(--sp-3); line-height: 1.1; }
  .prose :global(h3) { font-family: var(--font-display); font-size: var(--t-h3-size); color: var(--brand-navy); margin-top: var(--sp-5); margin-bottom: var(--sp-2); }
  .prose :global(p) { color: var(--fg-1); margin-bottom: var(--sp-3); line-height: 1.6; }
  .prose :global(ol), .prose :global(ul) { margin: var(--sp-3) 0 var(--sp-4); padding-left: var(--sp-5); }
  .prose :global(li) { margin-bottom: var(--sp-2); line-height: 1.55; }
  .prose :global(strong) { color: var(--brand-navy); font-weight: 600; }
  .prose :global(code) { font-family: var(--font-mono); font-size: 0.9em; background: var(--bg-2); padding: 0 0.3em; border-radius: var(--r-1); }
  .prose :global(a) { color: var(--brand-navy); text-decoration: underline; text-decoration-color: var(--brand-gold); text-underline-offset: 3px; }
</style>

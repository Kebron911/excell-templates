---
import Layout from '@/components/chrome/Layout.astro';
import tools from '@/data/tools.json';

const toolsList = Object.values(tools);
---

<Layout
  title="Page not found — STR Host Tools"
  description="The page you're looking for has moved or never existed. Pick a calculator below."
  path="/404"
  noIndex={true}
>
  <section class="bg-parchment">
    <div class="mx-auto max-w-3xl px-5 pt-12 pb-9">
      <p class="label text-gold-deep">404</p>
      <h1 class="mt-3 text-h1 font-serif text-navy leading-tight">
        Page not found<span class="period-gold">.</span>
      </h1>
      <p class="mt-4 text-lead text-ink-2">
        The page you wanted has moved, been retired, or never existed. Try a calculator instead.
      </p>
    </div>
  </section>

  <section class="bg-parchment-light border-t border-rule">
    <div class="mx-auto max-w-6xl px-5 py-9">
      <p class="label text-gold-deep">Calculators</p>
      <ul class="mt-4 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {toolsList.map((t) => (
          <li>
            <a
              href={t.path}
              class="group block h-full rounded-md border border-rule bg-parchment p-5 no-underline hover:border-gold hover:shadow-card transition-all duration-std focus:outline-none focus:shadow-focus"
            >
              <p class="font-serif text-h3 text-navy leading-snug">{t.shortName}</p>
              <p class="mt-2 text-small text-ink-2 leading-snug">{t.tagline}</p>
              <p class="mt-4 text-caption text-gold-deep group-hover:text-gold flex items-center gap-1">
                Open
                <span class="inline-block transition-transform duration-std group-hover:translate-x-0.5" aria-hidden="true">→</span>
              </p>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="bg-parchment border-t border-rule">
    <div class="mx-auto max-w-6xl px-5 py-9 grid grid-cols-1 sm:grid-cols-2 gap-4">
      <a
        href="/blog"
        class="group block rounded-md border border-rule bg-parchment-light p-5 no-underline hover:border-gold hover:shadow-card transition-all duration-std focus:outline-none focus:shadow-focus"
      >
        <p class="font-serif text-h3 text-navy leading-snug">Blog</p>
        <p class="mt-2 text-small text-ink-2 leading-snug">STR math, written down. Profit, RevPAR, break-even, cleaning fees.</p>
      </a>
      <a
        href="/lodging-tax"
        class="group block rounded-md border border-rule bg-parchment-light p-5 no-underline hover:border-gold hover:shadow-card transition-all duration-std focus:outline-none focus:shadow-focus"
      >
        <p class="font-serif text-h3 text-navy leading-snug">Lodging tax — 50 states + DC</p>
        <p class="mt-2 text-small text-ink-2 leading-snug">State-by-state lodging tax rates and source citations.</p>
      </a>
    </div>
  </section>
</Layout>

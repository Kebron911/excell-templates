---
// STRLedgerCTA — one per page, copy varies by tool, deep-links to the matching
// SKU on thestrledger.com with UTM tracking.
//
// Per design spec section 10 & 18: contextual cluster bridge. Below the fold,
// after value has been delivered. Single button, single link, no carousel.

interface Props {
  /** Tool slug (matches keys in src/data/tools.json). */
  tool: string;
  /** Override copy if needed. Defaults below. */
  headline?: string;
  blurb?: string;
  cta?: string;
  /** Override target SKU path if the default mapping isn't right. */
  skuPath?: string;
}

const { tool, headline, blurb, cta, skuPath } = Astro.props;

// Per-tool copy + STR Ledger SKU mapping. Editable here as catalog evolves.
const defaults: Record<string, { headline: string; blurb: string; cta: string; skuPath: string }> = {
  'airbnb-fee-calculator': {
    headline: 'Track every fee for real, in Excel.',
    blurb: 'The STR Ledger P&L workbook captures Airbnb host fees, cleaning fees, and lodging tax line-by-line.',
    cta: 'See the P&L workbook',
    skuPath: '/products/p-and-l-single-property',
  },
  'profit-calculator': {
    headline: 'Stop guessing — track this for real.',
    blurb: 'The STR Ledger P&L workbook tracks every income and expense line, monthly, with year-over-year benchmarks.',
    cta: 'See the P&L workbook',
    skuPath: '/products/p-and-l-single-property',
  },
  'cleaning-fee-calculator': {
    headline: 'Track cleaning costs vs. fees collected.',
    blurb: 'The STR Ledger Cleaning Cost Tracker shows margin per turnover and where fee math drifts from reality.',
    cta: 'See the cleaning tracker',
    skuPath: '/products/cleaning-cost-per-turnover',
  },
  'revpar-calculator': {
    headline: 'Compare RevPAR year-over-year.',
    blurb: 'The STR Ledger YoY Comparison Workbook lets you see RevPAR, ADR, and occupancy month-by-month against last year.',
    cta: 'See the YoY workbook',
    skuPath: '/products/yoy-comparison-workbook',
  },
  'break-even-calculator': {
    headline: 'See break-even live, every month.',
    blurb: 'The STR Ledger Break-Even Workbook updates as you log expenses, so you always know where the line is.',
    cta: 'See the break-even workbook',
    skuPath: '/products/break-even-occupancy',
  },
  'cohost-split-calculator': {
    headline: 'Pay co-hosts cleanly, every month.',
    blurb: 'The STR Ledger Commission Split Calculator handles tiered splits and reconciles against actual revenue.',
    cta: 'See the commission tracker',
    skuPath: '/products/commission-split-calculator',
  },
  'lodging-tax': {
    headline: 'Calculate lodging tax, then track filings.',
    blurb: 'The STR Ledger TOT Filing Calendar reminds you of due dates and tracks paid amounts state-by-state.',
    cta: 'See the TOT filing tracker',
    skuPath: '/products/tot-filing-calendar',
  },
};

const fallback = {
  headline: 'Track this for real in The STR Ledger.',
  blurb: 'Excel templates and PDFs that turn these calculators into your monthly bookkeeping rhythm.',
  cta: 'Browse The STR Ledger',
  skuPath: '/',
};

const conf = defaults[tool] ?? fallback;
const finalHeadline = headline ?? conf.headline;
const finalBlurb = blurb ?? conf.blurb;
const finalCta = cta ?? conf.cta;
const finalSkuPath = skuPath ?? conf.skuPath;

const href = `https://thestrledger.com${finalSkuPath}?utm_source=strhost-tools&utm_medium=cta&utm_content=${encodeURIComponent(tool)}`;
---
<aside class="str-ledger-cta my-7 print:hidden" aria-label="Related product on The STR Ledger">
  <div class="rounded-md surface-navy p-6">
    <p class="label text-gold">From The STR Ledger</p>
    <p class="mt-3 font-serif text-h3 text-parchment max-w-2xl leading-snug">
      {finalHeadline}
    </p>
    <p class="mt-3 text-small text-parchment opacity-90 max-w-2xl leading-snug">
      {finalBlurb}
    </p>
    <a
      href={href}
      class="mt-5 inline-flex items-center gap-2 rounded-md bg-gold text-navy px-5 py-2.5 text-ui no-underline hover:bg-gold-soft transition-colors duration-std focus:outline-none focus:shadow-focus"
      data-str-ledger-cta
      data-tool={tool}
    >
      {finalCta}
      <span aria-hidden="true">→</span>
    </a>
  </div>
</aside>

<script>
  document.querySelectorAll<HTMLAnchorElement>('a[data-str-ledger-cta]').forEach((a) => {
    a.addEventListener('click', () => {
      (window as any).gtag?.('event', 'str_ledger_cta_clicked', {
        tool: a.dataset.tool,
      });
    });
  });
</script>

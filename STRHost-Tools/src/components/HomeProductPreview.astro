---
// HomeProductPreview — three mini calculator-output cards that preview
// the real numbers strhost.tools spits out. Pure HTML/CSS — no images.
// Replaces the generic interior hero image on the homepage.
---

<div class="mx-auto max-w-6xl px-5 mt-7 mb-3">
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
    {/* Airbnb fee calculator */}
    <div class="rounded-md border border-rule bg-parchment p-5 shadow-card">
      <p class="label text-gold-deep">Airbnb fee calculator</p>
      <p class="mt-2 font-serif text-h3 text-navy leading-snug">Per booking, after fees</p>
      <dl class="mt-3 space-y-1.5 text-small">
        <div class="flex justify-between"><dt class="text-ink-2">Gross nightly × 5</dt><dd class="font-mono text-navy">$1,225</dd></div>
        <div class="flex justify-between"><dt class="text-ink-2">Cleaning fee</dt><dd class="font-mono text-navy">+ $145</dd></div>
        <div class="flex justify-between"><dt class="text-ink-2">Airbnb host fee 3%</dt><dd class="font-mono text-ink-3">– $41</dd></div>
        <div class="flex justify-between border-t border-rule pt-1.5 mt-1.5"><dt class="text-navy font-semibold">Net payout</dt><dd class="font-mono text-navy font-semibold">$1,329</dd></div>
      </dl>
    </div>

    {/* Profit calculator */}
    <div class="rounded-md border border-rule bg-parchment-light p-5 shadow-card">
      <p class="label text-gold-deep">Profit calculator</p>
      <p class="mt-2 font-serif text-h3 text-navy leading-snug">Monthly cash flow</p>
      <dl class="mt-3 space-y-1.5 text-small">
        <div class="flex justify-between"><dt class="text-ink-2">ADR</dt><dd class="font-mono text-navy">$245</dd></div>
        <div class="flex justify-between"><dt class="text-ink-2">Occupancy</dt><dd class="font-mono text-navy">68%</dd></div>
        <div class="flex justify-between"><dt class="text-ink-2">Operating cost</dt><dd class="font-mono text-ink-3">– $3,168</dd></div>
        <div class="flex justify-between border-t border-rule pt-1.5 mt-1.5"><dt class="text-navy font-semibold">Net / month</dt><dd class="font-mono text-navy font-semibold">$1,827</dd></div>
      </dl>
    </div>

    {/* Break-even calculator */}
    <div class="rounded-md border border-rule bg-parchment p-5 shadow-card">
      <p class="label text-gold-deep">Break-even calculator</p>
      <p class="mt-2 font-serif text-h3 text-navy leading-snug">Keep the lights on</p>
      <p class="mt-3 text-small text-ink-2 leading-snug">
        With your mortgage, taxes, and ops at <span class="font-mono text-navy">$5,000/mo</span> and an ADR of <span class="font-mono text-navy">$245</span>, you need:
      </p>
      <p class="mt-3 font-serif text-3xl text-gold-deep leading-none">52%</p>
      <p class="mt-1 text-caption text-ink-3">occupancy to break even</p>
    </div>
  </div>
</div>

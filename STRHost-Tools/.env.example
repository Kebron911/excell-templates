# strhost.tools — environment variables
# Copy to `.env` for local dev. None of these are required to build the site.
# All `PUBLIC_*` vars are exposed to client-side code at build time.

# ---- Public client envs (Astro reads PUBLIC_* at build time) -----------------

# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX).
# When unset, no gtag script is emitted and analytics helpers are no-ops.
PUBLIC_GA4_ID=

# AdSense gating — set to "1" to render the AdSense bootstrap on tool pages.
PUBLIC_ADSENSE_ENABLED=
PUBLIC_ADSENSE_CLIENT=

# Email service provider endpoint that the lead-magnet forms POST to.
# Leave empty to fall back to the GET-based magnet flow.
PUBLIC_ESP_ENDPOINT=

# ============================================================
# listingaudit.tools — local development env
# Copy to `.env.local` and fill in. Never commit the filled file.
# ============================================================

# ----- Anthropic (Phase 3 — audit scoring) -----
# Used by server/lib/ai/anthropic.ts. Sonnet 4.5 + Haiku 4.5 mix with prompt caching.
ANTHROPIC_API_KEY=

# ----- Apify (Phase 2 — listing scrape) -----
# Used by server/lib/scrape/apify.ts. Apify Airbnb actor.
APIFY_TOKEN=
APIFY_AIRBNB_ACTOR=tri_angle/airbnb-scraper

# ----- Admin (Phase 2 — debug scrape endpoint) -----
# Random 32+ byte string. Sent as x-admin-token header on POST /api/scrape.
ADMIN_TOKEN=

# ----- MySQL (Phase 1 — audit_runs + rate limits + email verifies) -----
# Hostinger Business shared MySQL in production. Local dev uses local MySQL.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=strlistingaudit

# ----- Email verification + IP hashing (Phase 4 — email gate + rate limit) -----
# 32+ byte random strings. EMAIL_VERIFY_SECRET signs HMAC verify-tokens; IP_HASH_SALT
# is mixed into sha256(ip) so we never store raw IPs.
EMAIL_VERIFY_SECRET=
IP_HASH_SALT=

# ----- Email delivery (Phase 4) -----
# 'console' (default) logs verify links to stdout — fine for local dev.
# 'webhook' POSTs to PUBLIC_ESP_WEBHOOK for ESP-side send.
EMAIL_PROVIDER=console
PUBLIC_ESP_WEBHOOK=

# ----- Analytics (Phase 6) -----
# Gated in @str/ui-chrome/Layout.astro — leave empty in CI / dev.
PUBLIC_GA4_ID=

# ----- API base URL (Phase 6) -----
# Empty = same-origin (local dev: Astro on :4321 with Vite proxy, or hand-managed).
# Production: https://api.listingaudit.tools (Express server on n8n VPS via Traefik).
PUBLIC_API_BASE=

# ----- CORS (server-side, prod only) -----
# Origin the static site loads from. Server sets Access-Control-Allow-Origin to this.
# Defaults to '*' if unset; production should set https://listingaudit.tools.
ALLOWED_ORIGIN=

# ----- Server port (Phase 1) -----
PORT=3002

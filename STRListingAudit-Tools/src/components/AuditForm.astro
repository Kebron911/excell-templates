---
// AuditForm — client-island. Validates URL, POSTs to /api/audit, redirects
// to /audit/?id=ABC123 on success. Surfaces rate-limit and validation errors.
//
// Server-rendered shell + small client script. No React island needed for v0.1
// (lighter bundle, no hydration cost).
---

<form id="audit-form" class="mx-auto max-w-2xl flex flex-col sm:flex-row gap-3">
  <input
    type="url"
    name="url"
    id="audit-url"
    required
    placeholder="https://www.airbnb.com/rooms/..."
    aria-label="Listing URL"
    class="flex-1 rounded-md border border-rule bg-white px-4 py-3 text-body text-ink-1 placeholder:text-ink-3 focus:outline-none focus:border-[color:var(--accent-500)] focus:shadow-focus"
  />
  <button
    type="submit"
    id="audit-submit"
    class="rounded-md bg-[color:var(--accent-500)] text-white font-medium px-6 py-3 hover:bg-[color:var(--accent-700)] transition-colors duration-std focus:outline-none focus:shadow-focus disabled:opacity-60 disabled:cursor-wait"
  >
    Audit listing →
  </button>
</form>
<p id="audit-error" class="mt-3 text-small text-error min-h-[1.5em]" role="alert" aria-live="polite"></p>
<p class="mt-1 text-caption text-ink-3">
  Free. 3 audits per hour. Verify your email for 20/day.
</p>

<script>
  const form = document.getElementById('audit-form') as HTMLFormElement | null;
  const input = document.getElementById('audit-url') as HTMLInputElement | null;
  const submit = document.getElementById('audit-submit') as HTMLButtonElement | null;
  const errorEl = document.getElementById('audit-error');
  if (form && input && submit && errorEl) {
    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      const url = input.value.trim();
      errorEl.textContent = '';
      if (!url || !/^https?:\/\/(www\.)?(airbnb|vrbo)\.[^/]+\/.+/i.test(url)) {
        errorEl.textContent = 'Paste a public Airbnb or Vrbo property URL to start the audit.';
        return;
      }
      submit.disabled = true;
      submit.textContent = 'Starting…';
      try {
        const res = await fetch('/api/audit', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ url }),
          credentials: 'same-origin',
        });
        if (res.status === 429) {
          const body = await res.json().catch(() => ({}));
          errorEl.textContent =
            body?.upgradeHint ?? 'You hit the free audit limit for this hour. Try again later.';
          submit.disabled = false;
          submit.textContent = 'Audit listing →';
          return;
        }
        if (!res.ok) {
          const body = await res.json().catch(() => ({}));
          errorEl.textContent = body?.detail
            ? `That URL didn't work: ${typeof body.detail === 'string' ? body.detail : body.error ?? 'unknown error'}.`
            : (body?.error ?? `Could not start audit (${res.status}). Try again in a moment.`);
          submit.disabled = false;
          submit.textContent = 'Audit listing →';
          return;
        }
        const data = await res.json();
        if (!data?.id) {
          errorEl.textContent = 'Audit started but no id came back. Refresh and try again.';
          submit.disabled = false;
          submit.textContent = 'Audit listing →';
          return;
        }
        // Send the visitor to the result page; it polls /api/audit/:id/status.
        window.location.href = `/audit/?id=${encodeURIComponent(data.id)}`;
      } catch (err) {
        errorEl.textContent =
          'Could not reach the audit service. Check your connection and try again.';
        submit.disabled = false;
        submit.textContent = 'Audit listing →';
      }
    });
  }
</script>

---
import Layout from '@/components/AppLayout.astro';
import { siteConfig } from '@/data/site.config';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort((a: any, b: any) =>
  a.data.datePublished < b.data.datePublished ? 1 : -1,
);
---

<Layout
  siteConfig={siteConfig}
  title="Listing-audit playbooks · Listing Audit Tools"
  description="Short reads on what makes Airbnb and Vrbo listings convert — title, description, photos, amenities, reviews."
  path="/blog/"
>
  <section class="bg-parchment">
    <div class="mx-auto max-w-3xl px-5 pt-12 pb-16">
      <p class="label text-[color:var(--accent-700)]">Playbooks</p>
      <h1 class="mt-3 font-serif text-h1 text-navy leading-tight">
        Short reads, no fluff<span class="period-accent">.</span>
      </h1>
      <ul class="mt-9 space-y-5">
        {posts.map((p: any) => (
          <li>
            <a
              href={`/blog/${p.id.replace(/\.md$/, '')}/`}
              class="group block rounded-md border border-rule bg-white p-6 no-underline hover:border-[color:var(--accent-500)] hover:shadow-card transition-all duration-std focus:outline-none focus:shadow-focus"
            >
              <p class="label text-[color:var(--accent-700)]">{p.data.category} · {p.data.readMinutes} min</p>
              <p class="mt-2 font-serif text-h3 text-navy leading-snug">{p.data.title}</p>
              <p class="mt-2 text-body text-ink-2 leading-snug">{p.data.description}</p>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
</Layout>

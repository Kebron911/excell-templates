---
import Layout from '@/components/AppLayout.astro';
import { siteConfig } from '@/data/site.config';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((p: any) => ({
    params: { slug: p.id.replace(/\.md$/, '') },
    props: { post: p },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout
  siteConfig={siteConfig}
  title={`${post.data.title} · Listing Audit Tools`}
  description={post.data.description}
  path={`/blog/${post.id.replace(/\.md$/, '')}/`}
>
  <article class="bg-parchment">
    <div class="mx-auto max-w-3xl px-5 pt-12 pb-16">
      <p class="label text-[color:var(--accent-700)]">{post.data.category} · {post.data.readMinutes} min · {post.data.datePublished}</p>
      <h1 class="mt-3 font-serif text-h1 text-navy leading-tight">{post.data.title}</h1>
      <p class="mt-5 text-lead text-ink-2 max-w-2xl">{post.data.description}</p>
      <div class="mt-9 prose prose-lg max-w-none text-ink-1 leading-relaxed
                  prose-headings:font-serif prose-headings:text-navy
                  prose-h2:text-h2 prose-h2:mt-12 prose-h2:mb-4
                  prose-h3:text-h3 prose-h3:mt-8 prose-h3:mb-3
                  prose-p:text-body prose-p:text-ink-2 prose-p:leading-snug
                  prose-li:text-ink-2 prose-li:leading-snug
                  prose-strong:text-navy prose-strong:font-semibold
                  prose-a:text-navy prose-a:underline prose-a:decoration-[color:var(--accent-500)] prose-a:underline-offset-2
                  prose-code:bg-parchment-deep prose-code:px-1 prose-code:rounded prose-code:text-graphite">
        <Content />
      </div>

      <div class="mt-14 rounded-md border border-rule bg-[color:var(--bg-result-tile)] p-7">
        <p class="font-serif text-h3 text-navy">Run the audit</p>
        <p class="mt-2 text-body text-ink-2 leading-snug">
          Free. 30 seconds. The scoring rubrics in this post are how the audit grades your actual listing.
        </p>
        <p class="mt-4">
          <a href="/" class="rounded-md bg-[color:var(--accent-500)] text-white font-medium px-5 py-2.5 no-underline hover:bg-[color:var(--accent-700)] transition-colors duration-std inline-block">
            Start an audit →
          </a>
        </p>
      </div>
    </div>
  </article>
</Layout>

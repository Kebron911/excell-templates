---
import Layout from '@/components/AppLayout.astro';
import AuditForm from '@/components/AuditForm.astro';
import { siteConfig } from '@/data/site.config';
import { cities, type CityEntry } from '@/data/cities';

export function getStaticPaths() {
  return cities.map((c) => ({
    params: { slug: c.slug },
    props: { city: c },
  }));
}

interface Props {
  city: CityEntry;
}

const { city } = Astro.props;
---

<Layout
  siteConfig={siteConfig}
  title={`Audit your ${city.name} Airbnb · Listing Audit Tools`}
  description={city.hook}
  path={`/audit/cities/${city.slug}/`}
>
  <section class="bg-parchment">
    <div class="mx-auto max-w-4xl px-5 pt-12 pb-12 text-center">
      <p class="label text-[color:var(--accent-700)]">{city.region} · STR audit</p>
      <h1 class="mt-3 font-serif text-h1 text-navy leading-tight">
        Audit your {city.name} listing in 30 seconds<span class="period-accent">.</span>
      </h1>
      <p class="mt-5 text-lead text-ink-2 max-w-2xl mx-auto">
        {city.hook}
      </p>
      <div class="mt-9">
        <AuditForm />
      </div>
    </div>
  </section>

  <section class="bg-parchment-light border-t border-rule">
    <div class="mx-auto max-w-3xl px-5 py-12">
      <p class="label text-[color:var(--accent-700)]">Local pattern to watch for</p>
      <p class="mt-3 font-serif text-h2 text-navy leading-tight">
        {city.watchOut}
      </p>
    </div>
  </section>

  <section class="bg-parchment border-t border-rule">
    <div class="mx-auto max-w-3xl px-5 py-12">
      <p class="label text-[color:var(--accent-700)]">Amenities that move the needle in {city.name}</p>
      <ul class="mt-4 flex flex-wrap gap-2">
        {city.marketAmenities.map((a) => (
          <li class="rounded-pill border border-[color:var(--accent-500)] text-[color:var(--accent-700)] text-ui px-4 py-1.5">
            {a}
          </li>
        ))}
      </ul>
      <p class="mt-5 text-body text-ink-2 leading-snug">
        Listings in {city.name} that surface these amenities in both their title and amenity
        checklist consistently outscore ones that don't. Run the audit to see which you're missing.
      </p>
    </div>
  </section>

  <section class="bg-parchment-light border-t border-rule">
    <div class="mx-auto max-w-2xl px-5 py-12 text-center">
      <p class="label text-[color:var(--accent-700)]">Ready?</p>
      <p class="mt-2 font-serif text-h2 text-navy">Paste your URL above and the scorecard renders in about 20 seconds.</p>
      <p class="mt-4">
        <a href="/audit/cities/" class="text-ui text-navy no-underline hover:text-[color:var(--accent-700)]">← All cities</a>
      </p>
    </div>
  </section>
</Layout>

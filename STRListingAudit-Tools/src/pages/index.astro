---
import Layout from '@/components/AppLayout.astro';
import AuditForm from '@/components/AuditForm.astro';
import { siteConfig } from '@/data/site.config';
---

<Layout
  siteConfig={siteConfig}
  title="Listing Audit — AI scorecard for your Airbnb or Vrbo in 30 seconds"
  description="Paste your Airbnb or Vrbo listing URL and get an instant 0-100 scorecard with the top 5 fixes ranked by impact. Free, no signup."
  path="/"
>
  <section class="bg-parchment">
    <div class="mx-auto max-w-4xl px-5 pt-16 pb-12 text-center">
      <p class="label text-[color:var(--accent-700)]">A diagnostic tool by The STR Ledger</p>
      <h1 class="mt-4 font-serif text-h1 text-navy leading-tight">
        Audit any listing in 30 seconds<span class="period-accent">.</span>
      </h1>
      <p class="mt-5 text-lead text-ink-2 max-w-2xl mx-auto">
        Paste an Airbnb or Vrbo URL. Get a 0-100 scorecard across five dimensions
        plus the five highest-impact fixes ranked by priority. No signup. No sales pitch.
      </p>

      <div class="mt-9">
        <AuditForm />
      </div>
    </div>
  </section>

  <section class="bg-parchment-light border-t border-rule">
    <div class="mx-auto max-w-5xl px-5 py-12 grid grid-cols-1 md:grid-cols-3 gap-7">
      <div>
        <p class="label text-[color:var(--accent-700)]">Step 1</p>
        <p class="mt-3 font-serif text-h3 text-navy leading-snug">Paste your URL.</p>
        <p class="mt-2 text-small text-ink-2 leading-snug">
          Works on any public Airbnb or Vrbo listing. We pull your title,
          description, photos, amenities, and recent reviews.
        </p>
      </div>
      <div>
        <p class="label text-[color:var(--accent-700)]">Step 2</p>
        <p class="mt-3 font-serif text-h3 text-navy leading-snug">We score five dimensions.</p>
        <p class="mt-2 text-small text-ink-2 leading-snug">
          Title, description, photos, amenities, and reviews — each rated 0-100
          against the patterns that drive bookings.
        </p>
      </div>
      <div>
        <p class="label text-[color:var(--accent-700)]">Step 3</p>
        <p class="mt-3 font-serif text-h3 text-navy leading-snug">Get five prioritized fixes.</p>
        <p class="mt-2 text-small text-ink-2 leading-snug">
          Each fix is ranked by expected booking impact. Take a screenshot, share
          the result, or download the full PDF (email gated).
        </p>
      </div>
    </div>
  </section>

  <section class="bg-parchment border-t border-rule">
    <div class="mx-auto max-w-3xl px-5 py-12">
      <p class="label text-[color:var(--accent-700)]">FAQ</p>
      <dl class="mt-5 space-y-7">
        <div>
          <dt class="font-serif text-h3 text-navy">Is it really free?</dt>
          <dd class="mt-2 text-body text-ink-2 leading-snug">
            Yes. Three audits per hour without an email. Verify your email and you get
            twenty audits per day. The paid tier with AI-rewritten copy and competitive
            analysis lands in v0.2 — opt-in only.
          </dd>
        </div>
        <div>
          <dt class="font-serif text-h3 text-navy">Where does the data come from?</dt>
          <dd class="mt-2 text-body text-ink-2 leading-snug">
            Public listing pages. We never log into your host account, never see your
            booking history, never ask for credentials. The scorecard reflects what a
            potential guest sees.
          </dd>
        </div>
        <div>
          <dt class="font-serif text-h3 text-navy">How is the scorecard built?</dt>
          <dd class="mt-2 text-body text-ink-2 leading-snug">
            Five dimensions: title, description, photos (metadata in v0.1), amenities,
            and reviews. Each is scored 0-100 by an LLM against a rubric tuned to what
            drives bookings on Airbnb and Vrbo. A synthesizer picks the top five fixes
            ranked by impact × inverse effort.
          </dd>
        </div>
      </dl>
    </div>
  </section>
</Layout>

---
import { formatDateTime } from '@/lib/format';

interface Props {
  source: string;
  lastRefresh?: string | Date | null;
  nextRefresh?: string;
  notes?: string;
}
const { source, lastRefresh, nextRefresh, notes } = Astro.props;
---
<footer class="mt-6 flex flex-wrap items-center gap-x-4 gap-y-1 text-xs"
        style="color: rgb(var(--c-muted))"
        aria-label="Data source">
  <span><strong>Source:</strong> {source}</span>
  {lastRefresh && <span>last refresh: {formatDateTime(lastRefresh)}</span>}
  {nextRefresh && <span>next: {nextRefresh}</span>}
  {notes && <span class="opacity-80">· {notes}</span>}
</footer>

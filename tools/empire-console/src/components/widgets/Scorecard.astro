---
interface Props {
  label: string;
  value: string | number;
  hint?: string;
  tooltip?: string;
  tone?: 'ok' | 'warn' | 'bad' | 'neutral';
  /** 3-tier visual hierarchy: critical = red border-left, notable = amber, reference = muted bg */
  tier?: 'critical' | 'notable' | 'reference' | 'normal';
}
const { label, value, hint, tooltip, tone = 'neutral', tier = 'normal' } = Astro.props;
const toneColor = {
  ok: 'rgb(var(--c-ok))',
  warn: 'rgb(var(--c-warn))',
  bad: 'rgb(var(--c-bad))',
  neutral: 'rgb(var(--c-ink))',
}[tone];
const tierClass =
  tier === 'critical' ? 'card card-critical' :
  tier === 'notable' ? 'card card-notable' :
  tier === 'reference' ? 'card card-reference' :
  'card';
---
<div class={tierClass} role="group" aria-label={label}>
  <div class="text-xs uppercase tracking-wide" style="color: rgb(var(--c-muted))">
    {tooltip ? (
      <span class="tooltip" data-tooltip={tooltip} tabindex="0">{label}</span>
    ) : label}
  </div>
  <div class="mt-2 font-display text-3xl font-semibold tabular-nums" style={`color: ${toneColor}`}>
    {value}
  </div>
  {hint && <div class="mt-1 text-xs" style="color: rgb(var(--c-muted))">{hint}</div>}
</div>

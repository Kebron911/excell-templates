---
import { computeNextAction } from '@/lib/data/next-action';
const action = await computeNextAction();
const tier = action.priority === 'P0' ? 'critical' : action.priority === 'P1' ? 'notable' : 'reference';
const tierClass = `card card-${tier}`;
const isAllClear = action.source === 'all-clear';
---
<div class={tierClass} role="region" aria-label="Next action">
  <div class="flex items-baseline gap-3">
    <span class="text-xs uppercase tracking-wide" style="color: rgb(var(--c-muted))">
      Next 60 minutes
    </span>
    {!isAllClear && <span class:list={['badge', `badge-${action.priority.toLowerCase()}`]}>{action.priority}</span>}
  </div>
  <p class="mt-3 font-display text-2xl font-semibold leading-snug">
    {action.message}
  </p>
  <div class="mt-3 flex items-center gap-3 text-sm">
    {action.ctaLabel && action.ctaHref && (
      <a href={action.ctaHref}
         class="inline-block rounded border px-4 py-2 no-underline"
         style={`border-color: rgb(var(--c-${action.priority === 'P0' ? 'bad' : 'accent'})); color: rgb(var(--c-${action.priority === 'P0' ? 'bad' : 'accent'}))`}>
        {action.ctaLabel} →
      </a>
    )}
    <span class="text-xs" style="color: rgb(var(--c-muted))">from {action.source}</span>
  </div>
</div>

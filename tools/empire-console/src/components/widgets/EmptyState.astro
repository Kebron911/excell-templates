---
interface Props {
  title: string;
  body?: string;
  yamlPath?: string;       // path to the file the user should edit
  exampleCommand?: string; // optional shell command to demonstrate
  ctaHref?: string;
  ctaLabel?: string;
}
const { title, body, yamlPath, exampleCommand, ctaHref, ctaLabel } = Astro.props;
---
<div class="empty-state">
  <h3 class="font-display text-xl font-semibold">{title}</h3>
  {body && <p class="mt-2 text-sm" style="color: rgb(var(--c-muted))">{body}</p>}
  {yamlPath && (
    <p class="mt-3 text-sm">
      Edit <code>{yamlPath}</code> to add your first entry.
    </p>
  )}
  {exampleCommand && (
    <pre class="mx-auto mt-3 inline-block rounded px-3 py-2 text-left text-xs"
         style="background: rgb(var(--c-surface)); border: 1px solid rgb(var(--c-border))">{exampleCommand}</pre>
  )}
  {ctaHref && ctaLabel && (
    <p class="mt-4">
      <a href={ctaHref} class="inline-block rounded border px-4 py-2 text-sm no-underline"
         style="border-color: rgb(var(--c-accent)); color: rgb(var(--c-accent))">
        {ctaLabel} →
      </a>
    </p>
  )}
</div>

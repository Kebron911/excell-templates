---
/**
 * Wrap any reader-driven section. If the reader throws (e.g., malformed YAML),
 * renders a recovery message instead of crashing the whole page.
 *
 * Usage in a page frontmatter:
 *
 *   let report;
 *   let error: Error | null = null;
 *   try { report = await readSomething(); }
 *   catch (e) { error = e instanceof Error ? e : new Error(String(e)); }
 *
 * Then in the template:
 *
 *   {error ? <ErrorBoundary error={error} sourcePath="ops/foo.yaml" /> : <NormalView />}
 */
interface Props {
  error: Error;
  sourcePath?: string;
  recovery?: string;
}
const { error, sourcePath, recovery } = Astro.props;
---
<div class="card card-critical">
  <h2 class="font-display text-xl font-semibold">Something went wrong reading this section</h2>
  {sourcePath && (
    <p class="mt-2 text-sm">
      Source: <code>{sourcePath}</code>
    </p>
  )}
  <details class="mt-3">
    <summary class="cursor-pointer text-sm" style="color: rgb(var(--c-muted))">
      Show error message
    </summary>
    <pre class="mt-2 max-h-48 overflow-auto rounded p-3 text-xs"
         style="background: rgb(var(--c-surface-2)); color: rgb(var(--c-bad))">{error.message}</pre>
  </details>
  <p class="mt-3 text-sm">
    {recovery ?? `Most often this is a YAML/JSON parse error. Open the source file, run \`pnpm validate:ops\`, fix the offending entry.`}
  </p>
  <div class="mt-4 flex gap-2 text-xs">
    <a href="/inbox" class="rounded border px-3 py-1.5 no-underline"
       style="border-color: rgb(var(--c-border))">Capture this issue (i)</a>
    <a href="javascript:location.reload()" class="rounded border px-3 py-1.5 no-underline"
       style="border-color: rgb(var(--c-border))">Reload page</a>
  </div>
</div>

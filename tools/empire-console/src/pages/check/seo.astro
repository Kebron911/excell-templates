---
import Layout from '@/components/chrome/Layout.astro';
import Scorecard from '@/components/widgets/Scorecard.astro';

// Phase 3 — wired when nightly-refresh pulls Search Console + CrUX/PSI.
const stub = {
  gsc: {
    impressions: 0,
    clicks: 0,
    ctr: 0,
    avgPosition: 0,
    indexingErrors: 0,
  },
  cwv: {
    pagesGood: 0,
    pagesNeedsImprovement: 0,
    pagesPoor: 0,
  },
  topQueries: [] as Array<{ query: string; impressions: number; clicks: number; position: number; deltaPosition: number }>,
  strikingDistance: [] as Array<{ query: string; position: number; impressions: number }>,
};
---
<Layout title="Check · SEO" section="check">
  <header class="mb-6 flex items-baseline justify-between">
    <div>
      <h1 class="font-display text-3xl font-semibold">SEO</h1>
      <p class="text-sm" style="color: rgb(var(--c-muted))">
        Search Console performance + Core Web Vitals + indexing health
        across thestrledger.com + 4 sister sites. Phase 3 wires live data.
      </p>
    </div>
    <span class="badge badge-p2">Phase 3 stub</span>
  </header>

  <section class="mb-8 grid grid-cols-1 gap-4 md:grid-cols-4">
    <Scorecard label="Impressions (28d)" value={stub.gsc.impressions} />
    <Scorecard label="Clicks (28d)" value={stub.gsc.clicks} hint={`${(stub.gsc.ctr * 100).toFixed(2)}% CTR`} />
    <Scorecard label="Avg position" value={stub.gsc.avgPosition.toFixed(1)} />
    <Scorecard
      label="Indexing errors"
      value={stub.gsc.indexingErrors}
      tone={stub.gsc.indexingErrors > 0 ? 'bad' : 'ok'}
    />
  </section>

  <section class="mb-8 card">
    <h2 class="mb-3 text-sm font-semibold uppercase tracking-wide" style="color: rgb(var(--c-muted))">
      Core Web Vitals
    </h2>
    <div class="grid grid-cols-3 gap-4 text-center text-sm">
      <div>
        <div class="font-display text-2xl font-semibold" style="color: rgb(var(--c-ok))">{stub.cwv.pagesGood}</div>
        <div style="color: rgb(var(--c-muted))">Good</div>
      </div>
      <div>
        <div class="font-display text-2xl font-semibold" style="color: rgb(var(--c-warn))">{stub.cwv.pagesNeedsImprovement}</div>
        <div style="color: rgb(var(--c-muted))">Needs improvement</div>
      </div>
      <div>
        <div class="font-display text-2xl font-semibold" style="color: rgb(var(--c-bad))">{stub.cwv.pagesPoor}</div>
        <div style="color: rgb(var(--c-muted))">Poor</div>
      </div>
    </div>
    <p class="mt-4 text-xs" style="color: rgb(var(--c-muted))">
      Source: PageSpeed Insights / CrUX dataset. The n8n <code>cwv-watch</code> flow fires
      a P1 if any cluster page exits "Good" thresholds (LCP &lt;2.5s · INP &lt;200ms · CLS &lt;0.1).
    </p>
  </section>

  <section class="mb-8">
    <h2 class="mb-3 text-sm font-semibold uppercase tracking-wide" style="color: rgb(var(--c-muted))">
      Top queries (28d)
    </h2>
    <div class="card">
      {stub.topQueries.length === 0 ? (
        <p class="text-sm" style="color: rgb(var(--c-muted))">
          Will populate from Search Console API in Phase 3 (nightly-refresh).
          Weekly digest fires Mon 08:00 as P2 with position deltas.
        </p>
      ) : (
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b text-left text-xs uppercase tracking-wide"
                style="color: rgb(var(--c-muted)); border-color: rgb(var(--c-border))">
              <th class="py-2">Query</th>
              <th class="text-right">Impr</th>
              <th class="text-right">Clicks</th>
              <th class="text-right">Pos</th>
              <th class="text-right">Δ</th>
            </tr>
          </thead>
          <tbody>
            {stub.topQueries.map((q) => (
              <tr class="border-b" style="border-color: rgb(var(--c-border))">
                <td class="py-2">{q.query}</td>
                <td class="text-right font-mono">{q.impressions}</td>
                <td class="text-right font-mono">{q.clicks}</td>
                <td class="text-right font-mono">{q.position.toFixed(1)}</td>
                <td class="text-right font-mono">{q.deltaPosition > 0 ? '↑' : '↓'}{Math.abs(q.deltaPosition).toFixed(1)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </div>
  </section>

  <section class="mb-8">
    <h2 class="mb-3 text-sm font-semibold uppercase tracking-wide" style="color: rgb(var(--c-muted))">
      Striking-distance queries (positions 5–20)
    </h2>
    <div class="card">
      <p class="text-sm" style="color: rgb(var(--c-muted))">
        These are the queries closest to ranking — content gap candidates feed
        into <a href="/promote/keywords">Promote → Keyword opportunities</a> (Phase 4).
      </p>
    </div>
  </section>

  <section class="card" style="background: rgb(var(--c-surface-2))">
    <h3 class="mb-2 text-sm font-semibold uppercase tracking-wide" style="color: rgb(var(--c-muted))">
      AI search visibility (manual log)
    </h3>
    <p class="text-sm">
      Programmatic checks for ChatGPT Search / Perplexity / Google AI Overviews are unstable
      (Phase 5+). For now, log monthly spot-checks at <code>ops/ai-visibility-log.md</code>:
      ask each tool the cluster's beachhead queries and record citation status.
    </p>
  </section>
</Layout>

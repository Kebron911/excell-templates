---
import Layout from '@/components/chrome/Layout.astro';
import Scorecard from '@/components/widgets/Scorecard.astro';
import SourceFooter from '@/components/widgets/SourceFooter.astro';
import { readContacts } from '@/lib/data/contacts';

const c = await readContacts();
const maxStage = c.funnel[0]?.count || 1;
function pct(n: number, d: number) { return d > 0 ? ((n / d) * 100) : 0; }
const bounceTone = c.health.bounceRate > 2 ? 'bad' : 'ok';
const complaintTone = c.health.complaintRate > 0.1 ? 'bad' : 'ok';
---
<Layout title="Check · Contacts" section="check">
  <header class="mb-6 flex items-baseline justify-between">
    <div>
      <h1 class="font-display text-3xl font-semibold">Contacts (funnel)</h1>
      <p class="text-sm" style="color: rgb(var(--c-muted))">
        Source: Influencersoft (cached). The middle of the chain — between
        <a href="/check/traffic">Traffic</a> (who's coming) and
        <a href="/check/money">Money</a> (who paid).
      </p>
    </div>
    {c.isCacheReady
      ? <span class="badge badge-ok">live</span>
      : <span class="badge badge-p2">awaiting n8n nightly-refresh</span>}
  </header>

  {!c.isCacheReady && (
    <div class="mb-6 card" style="background: rgb(var(--c-surface-2))">
      <p class="text-sm">
        <strong>No cache yet.</strong> <code>ops/cache/contacts.json</code> is written by the
        n8n <code>nightly-refresh</code> flow (Influencersoft API → atomic JSON write).
      </p>
    </div>
  )}

  <section class="mb-8 grid grid-cols-2 gap-4 md:grid-cols-4">
    <Scorecard label="Total list" value={c.list.total} />
    <Scorecard
      label="New (7d)"
      value={c.list.new7d}
      hint={c.list.new7dDelta >= 0 ? `+${c.list.new7dDelta} vs avg` : `${c.list.new7dDelta} vs avg`}
      tone={c.list.new7dDelta < 0 ? 'warn' : 'ok'}
    />
    <Scorecard
      label="Engaged (30d)"
      value={c.list.engaged30d}
      hint={c.list.total > 0 ? `${pct(c.list.engaged30d, c.list.total).toFixed(0)}% of list` : '—'}
    />
    <Scorecard
      label="Cold (90d+)"
      value={c.list.cold90d}
      hint="re-engage candidates"
      tone={c.list.cold90d > 0 ? 'warn' : 'ok'}
    />
  </section>

  <section class="mb-8">
    <h2 class="mb-3 text-sm font-semibold uppercase tracking-wide" style="color: rgb(var(--c-muted))">
      Funnel conversion (28d)
    </h2>
    <div class="card">
      {c.funnel.map((stage, i) => {
        const prev = i > 0 ? c.funnel[i - 1].count : null;
        const stagePct = prev !== null && prev > 0 ? pct(stage.count, prev) : null;
        const overallPct = i > 0 ? pct(stage.count, maxStage) : 100;
        const barWidth = Math.min(100, overallPct);
        return (
          <div class="mb-3 last:mb-0">
            <div class="flex items-baseline justify-between text-sm">
              <span class="font-medium">{stage.label}</span>
              <span class="font-mono">
                {stage.count}
                {stagePct !== null && (
                  <span class="ml-2 text-xs" style="color: rgb(var(--c-muted))">
                    ({stagePct.toFixed(1)}% of {c.funnel[i - 1].label.toLowerCase()})
                  </span>
                )}
              </span>
            </div>
            <div class="mt-1 h-2 w-full overflow-hidden rounded" style="background: rgb(var(--c-surface-2))">
              <div class="h-full rounded" style={`width: ${barWidth}%; background: rgb(var(--c-accent))`}></div>
            </div>
          </div>
        );
      })}
    </div>
  </section>

  <section class="mb-8">
    <h2 class="mb-3 text-sm font-semibold uppercase tracking-wide" style="color: rgb(var(--c-muted))">
      Drop-out — where the leak is (28d)
    </h2>
    <div class="card">
      {c.funnel.length < 2 ? (
        <p class="text-sm" style="color: rgb(var(--c-muted))">No data yet.</p>
      ) : (
        <ul class="space-y-2 text-sm">
          {c.funnel.slice(1).map((stage, i) => {
            const prev = c.funnel[i].count;
            const lossPct = prev > 0 ? 100 - pct(stage.count, prev) : 0;
            return (
              <li class="flex items-center justify-between">
                <span>{c.funnel[i].label} → {stage.label}</span>
                <span class="font-mono" style={lossPct > 80 ? 'color: rgb(var(--c-bad))' : ''}>
                  {lossPct.toFixed(1)}% leak
                </span>
              </li>
            );
          })}
        </ul>
      )}
      <p class="mt-3 text-xs" style="color: rgb(var(--c-muted))">
        n8n <code>funnel-dropout-watch</code> sends a P2 weekly digest;
        escalates to P1 if any stage drops &gt;50% week-over-week.
      </p>
    </div>
  </section>

  <section class="mb-8">
    <h2 class="mb-3 text-sm font-semibold uppercase tracking-wide" style="color: rgb(var(--c-muted))">
      Top sign-up sources (28d)
    </h2>
    <div class="card">
      {c.topSources.length === 0 ? (
        <p class="text-sm" style="color: rgb(var(--c-muted))">
          Will populate from IS form-of-origin on first nightly-refresh. Each lead magnet across
          the cluster has its own form ID — that's the attribution key.
        </p>
      ) : (
        <table class="w-full text-sm">
          <tbody>
            {c.topSources.map((s) => (
              <tr class="border-b last:border-0" style="border-color: rgb(var(--c-border))">
                <td class="py-2">{s.source}</td>
                <td class="py-2 text-right font-mono">{s.signups}</td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </div>
  </section>

  <section class="mb-8">
    <h2 class="mb-3 text-sm font-semibold uppercase tracking-wide" style="color: rgb(var(--c-muted))">
      List health (rolling 30d)
    </h2>
    <div class="grid grid-cols-2 gap-4 md:grid-cols-5">
      <Scorecard label="Bounce rate" value={`${c.health.bounceRate.toFixed(2)}%`} tone={bounceTone}
                 hint=">2% fires P0" />
      <Scorecard label="Unsub rate" value={`${c.health.unsubRate.toFixed(2)}%`} />
      <Scorecard label="Complaint rate" value={`${c.health.complaintRate.toFixed(2)}%`} tone={complaintTone}
                 hint=">0.1% fires P0" />
      <Scorecard label="Avg open" value={`${c.health.avgOpen.toFixed(0)}%`} />
      <Scorecard label="Avg click" value={`${c.health.avgClick.toFixed(1)}%`} />
    </div>
  </section>

  <section class="mb-8">
    <h2 class="mb-3 text-sm font-semibold uppercase tracking-wide" style="color: rgb(var(--c-muted))">
      Sequence performance (28d)
    </h2>
    <div class="card">
      {c.sequences.length === 0 ? (
        <p class="text-sm" style="color: rgb(var(--c-muted))">
          5 IS sequences drafted (welcome · review-request · refund-recovery · win-back · abandoned-cart).
          Drill-in to IS UI for full message-level data.
        </p>
      ) : (
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b text-left text-xs uppercase tracking-wide"
                style="color: rgb(var(--c-muted)); border-color: rgb(var(--c-border))">
              <th class="py-2">Sequence</th>
              <th>Metric</th>
              <th class="text-right">Value</th>
            </tr>
          </thead>
          <tbody>
            {c.sequences.map((s) => (
              <tr class="border-b" style="border-color: rgb(var(--c-border))">
                <td class="py-2 font-medium">{s.name}</td>
                <td>{s.metric}</td>
                <td class="text-right font-mono">{s.value}</td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </div>
  </section>

  <section class="card" style="background: rgb(var(--c-surface-2))">
    <h3 class="mb-2 text-sm font-semibold uppercase tracking-wide" style="color: rgb(var(--c-muted))">
      What this module does NOT do
    </h3>
    <ul class="space-y-1 text-sm">
      <li>• <strong>No per-contact records.</strong> That's the Influencersoft UI.
        Console shows aggregates and drill-out links.</li>
      <li>• <strong>No manual tagging.</strong> IS owns tags; console reads them.</li>
      <li>• <strong>No direct email sends.</strong> All sends go through n8n → IS webhook.</li>
    </ul>
  </section>

  <SourceFooter source="ops/cache/contacts.json (n8n nightly-refresh)"
                lastRefresh={c.generatedAt ?? null}
                notes="Influencersoft API" />
</Layout>

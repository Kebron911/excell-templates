---
import Layout from '@/components/chrome/Layout.astro';
import Scorecard from '@/components/widgets/Scorecard.astro';
import SourceFooter from '@/components/widgets/SourceFooter.astro';
import { readMoney } from '@/lib/data/money';

const m = await readMoney();
---
<Layout title="Check · Money" section="check">
  <header class="mb-6 flex items-baseline justify-between">
    <div>
      <h1 class="font-display text-3xl font-semibold">Money</h1>
      <p class="text-sm" style="color: rgb(var(--c-muted))">
        Operational revenue & burn. <strong>Not bookkeeping.</strong>
        Books of record: Wave / QuickBooks (PROGRESS §P9.2).
      </p>
    </div>
    {m.isCacheReady
      ? <span class="badge badge-ok">live</span>
      : <span class="badge badge-p2">awaiting n8n nightly-refresh</span>}
  </header>

  {!m.isCacheReady && (
    <div class="mb-6 card" style="background: rgb(var(--c-surface-2))">
      <p class="text-sm">
        <strong>No cache yet.</strong> <code>ops/cache/money.json</code> is written by the
        n8n <code>nightly-refresh</code> flow (Stripe + Etsy + Gumroad → atomic JSON write).
        Once that flow runs, this page populates automatically.
        See <a href="/maintain/automations">/maintain/automations</a>.
      </p>
    </div>
  )}

  <section class="mb-6 card border-2" style="border-color: rgb(var(--c-accent))">
    <div class="flex items-baseline justify-between">
      <div>
        <div class="text-xs uppercase tracking-wide" style="color: rgb(var(--c-muted))">
          Above the line (MTD)
        </div>
        <div class="mt-1 font-display text-4xl font-semibold">
          ${m.mtd.revenue.toFixed(0)}
          <span class="text-2xl" style="color: rgb(var(--c-muted))">
            / ${m.mtd.burn.toFixed(0)} burn
          </span>
        </div>
      </div>
      <div class="text-right">
        <div class="text-xs uppercase tracking-wide" style="color: rgb(var(--c-muted))">Ratio</div>
        <div class="mt-1 font-display text-3xl font-semibold">
          {m.aboveTheLineRatio === null ? '—' : `${m.aboveTheLineRatio.toFixed(1)}×`}
        </div>
        <div class="text-xs" style="color: rgb(var(--c-muted))">
          {m.aboveTheLineRatio === null
            ? 'set burn to compute'
            : m.aboveTheLineRatio >= 1 ? 'above the line' : 'below the line'}
        </div>
      </div>
    </div>
  </section>

  <section class="mb-8 grid grid-cols-1 gap-4 md:grid-cols-3">
    <Scorecard label="Yesterday revenue" value={`$${m.yesterday.revenue.toFixed(0)}`}
               hint={`${m.yesterday.orders} orders, ${m.yesterday.refunds} refunds`} />
    <Scorecard label="This week" value={`$${m.week.revenue.toFixed(0)}`}
               hint={`${m.week.orders} orders, ${m.week.refunds} refunds`} />
    <Scorecard label="MTD orders" value={m.mtd.orders}
               hint={`${m.mtd.refunds} refunds MTD`} />
  </section>

  {m.refundSpikes.length > 0 && (
    <section class="mb-8">
      <h2 class="mb-3 text-sm font-semibold uppercase tracking-wide" style="color: rgb(var(--c-muted))">
        Refund spikes (24h)
      </h2>
      <div class="card border-2" style="border-color: rgb(var(--c-danger, var(--c-accent)))">
        <ul class="space-y-2">
          {m.refundSpikes.map((s) => (
            <li class="flex items-baseline justify-between text-sm">
              <span class="font-mono">{s.sku}</span>
              <span>
                {s.refundCount24h} refunds · {(s.refundRate24h * 100).toFixed(1)}% rate
                <span class="ml-2 text-xs" style="color: rgb(var(--c-muted))">
                  triggered {new Date(s.triggerAt).toLocaleString()}
                </span>
              </span>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <section class="mb-8">
    <h2 class="mb-3 text-sm font-semibold uppercase tracking-wide" style="color: rgb(var(--c-muted))">
      Revenue by channel (MTD)
    </h2>
    <div class="card">
      {m.channels.length === 0 ? (
        <p class="text-sm" style="color: rgb(var(--c-muted))">
          Will populate from Stripe + Etsy + Gumroad on first nightly-refresh.
        </p>
      ) : m.channels.map((c) => (
        <div class="mb-3 last:mb-0">
          <div class="flex items-baseline justify-between text-sm">
            <span class="font-medium">{c.name}</span>
            <span class="font-mono">
              ${c.amount.toFixed(0)} ({(c.share * 100).toFixed(0)}%)
              <span class="ml-2 text-xs" style="color: rgb(var(--c-muted))">
                {c.orders} orders · {c.refunds} refunds
              </span>
            </span>
          </div>
          <div class="mt-1 h-2 w-full overflow-hidden rounded" style="background: rgb(var(--c-surface-2))">
            <div class="h-full rounded"
                 style={`width: ${(c.share * 100).toFixed(0)}%; background: rgb(var(--c-accent))`}></div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="mb-8">
    <h2 class="mb-3 text-sm font-semibold uppercase tracking-wide" style="color: rgb(var(--c-muted))">
      Top SKUs (MTD)
    </h2>
    <div class="card">
      {m.topSkus.length === 0 ? (
        <p class="text-sm" style="color: rgb(var(--c-muted))">
          Top SKUs by revenue land here once nightly-refresh has data.
        </p>
      ) : (
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b text-left text-xs uppercase tracking-wide"
                style="color: rgb(var(--c-muted)); border-color: rgb(var(--c-border))">
              <th class="py-2">SKU</th>
              <th>Title</th>
              <th class="text-right">Revenue</th>
              <th class="text-right">Orders</th>
              <th class="text-right">Refund rate</th>
            </tr>
          </thead>
          <tbody>
            {m.topSkus.map((s) => (
              <tr class="border-b" style="border-color: rgb(var(--c-border))">
                <td class="py-2 font-mono">
                  <a href={`/check/catalog/${s.sku}`}>{s.sku}</a>
                </td>
                <td class="text-xs" style="color: rgb(var(--c-muted))">{s.title ?? '—'}</td>
                <td class="text-right font-mono">${s.revenue.toFixed(0)}</td>
                <td class="text-right font-mono">{s.orders}</td>
                <td class="text-right font-mono">{(s.refundRate * 100).toFixed(1)}%</td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </div>
  </section>

  {m.killSkuCandidates.length > 0 && (
    <section class="mb-8">
      <h2 class="mb-3 text-sm font-semibold uppercase tracking-wide" style="color: rgb(var(--c-muted))">
        Kill-SKU candidates
      </h2>
      <div class="card">
        <p class="mb-2 text-xs" style="color: rgb(var(--c-muted))">
          Underperformers from <a href="/check/kill-sku">/check/kill-sku</a> (CVR&lt;1%, 0 sales 90d).
        </p>
        <ul class="space-y-1 text-sm">
          {m.killSkuCandidates.slice(0, 5).map((s) => (
            <li class="font-mono">{s.sku} — ${s.revenue.toFixed(0)} · {s.orders} orders</li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <section class="card" style="background: rgb(var(--c-surface-2))">
    <h3 class="mb-2 text-sm font-semibold uppercase tracking-wide" style="color: rgb(var(--c-muted))">
      Books of record
    </h3>
    <p class="text-sm">
      Tax-grade P&L, journal entries, depreciation, and 1099-K reconciliation live in
      <a href="https://waveapps.com" target="_blank" rel="noopener noreferrer">Wave Apps</a>
      (or QuickBooks — pending §9 decision). The console intentionally does <em>not</em> own the books;
      it shows the operational view between closes.
    </p>
  </section>

  <SourceFooter source="ops/cache/money.json (n8n nightly-refresh)"
                lastRefresh={m.generatedAt ?? null}
                notes="Stripe + Etsy + Gumroad" />
</Layout>

---
import Layout from '@/components/chrome/Layout.astro';
import EmptyState from '@/components/widgets/EmptyState.astro';
import SourceFooter from '@/components/widgets/SourceFooter.astro';
import { readNearMisses } from '@/lib/data/near-misses';
import { formatDateTime } from '@/lib/format';

const entries = await readNearMisses(100);
const last30d = entries.filter((e) => Date.now() - new Date(e.ts).getTime() < 30 * 86_400_000).length;
---
<Layout title="Near-misses" section="maintain">
  <header class="mb-6">
    <h1 class="font-display text-3xl font-semibold">Near-misses log</h1>
    <p class="mt-1 text-sm" style="color: rgb(var(--c-muted))">
      "Almost broke" moments. Cheaper than incidents but worth the same lesson.
      Source: <code>ops/near-misses.ndjson</code>.
    </p>
  </header>

  <section class="mb-6 grid grid-cols-2 gap-4 md:grid-cols-3">
    <div class="card">
      <div class="text-xs uppercase tracking-wide" style="color: rgb(var(--c-muted))">Total</div>
      <div class="mt-1 font-display text-2xl font-semibold tabular-nums">{entries.length}</div>
    </div>
    <div class="card">
      <div class="text-xs uppercase tracking-wide" style="color: rgb(var(--c-muted))">Last 30d</div>
      <div class="mt-1 font-display text-2xl font-semibold tabular-nums">{last30d}</div>
    </div>
    <div class="card card-reference">
      <div class="text-xs uppercase tracking-wide" style="color: rgb(var(--c-muted))">Why this exists</div>
      <p class="mt-1 text-sm">Patterns in near-misses tell you where the next real incident comes from.</p>
    </div>
  </section>

  {entries.length === 0 ? (
    <EmptyState
      title="No near-misses logged"
      body="Log every 'that almost broke us' moment. Capture: what happened, what fixed it, what prevents recurrence."
      yamlPath="ops/near-misses.ndjson"
    />
  ) : (
    <ul class="space-y-3">
      {entries.map((e) => (
        <li class="card">
          <div class="flex items-baseline justify-between gap-3">
            <h3 class="font-display text-lg font-semibold">{e.title}</h3>
            <span class="text-xs" style="color: rgb(var(--c-muted))">{formatDateTime(e.ts)}</span>
          </div>
          <div class="mt-3 grid grid-cols-1 gap-3 md:grid-cols-3">
            <div>
              <div class="text-xs font-semibold uppercase tracking-wide" style="color: rgb(var(--c-warn))">What happened</div>
              <p class="mt-1 text-sm">{e.what}</p>
            </div>
            {e.fix && (
              <div>
                <div class="text-xs font-semibold uppercase tracking-wide" style="color: rgb(var(--c-ok))">Fix</div>
                <p class="mt-1 text-sm">{e.fix}</p>
              </div>
            )}
            {e.prevention && (
              <div>
                <div class="text-xs font-semibold uppercase tracking-wide" style="color: rgb(var(--c-accent))">Prevention</div>
                <p class="mt-1 text-sm">{e.prevention}</p>
              </div>
            )}
          </div>
          {e.tags.length > 0 && (
            <div class="mt-3 flex gap-2">
              {e.tags.map((t) => <span class="badge badge-p2">#{t}</span>)}
            </div>
          )}
        </li>
      ))}
    </ul>
  )}

  <SourceFooter source="ops/near-misses.ndjson" lastRefresh={new Date()} />
</Layout>

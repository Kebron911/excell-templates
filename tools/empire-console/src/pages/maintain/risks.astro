---
import Layout from '@/components/chrome/Layout.astro';
import Scorecard from '@/components/widgets/Scorecard.astro';
import EmptyState from '@/components/widgets/EmptyState.astro';
import SourceFooter from '@/components/widgets/SourceFooter.astro';
import { readRisks, type EnrichedRisk } from '@/lib/data/risks';
import { formatDate } from '@/lib/format';

const report = await readRisks();

const tierClass: Record<EnrichedRisk['tier'], string> = {
  critical: 'card card-critical',
  high: 'card card-notable',
  medium: 'card',
  low: 'card card-reference',
};
const tierBadge: Record<EnrichedRisk['tier'], string> = {
  critical: 'badge-p0',
  high: 'badge-p1',
  medium: 'badge-p2',
  low: 'badge-p2',
};
---
<Layout title="Risks" section="maintain">
  <header class="mb-6 flex items-baseline justify-between">
    <div>
      <h1 class="font-display text-3xl font-semibold">Risk register</h1>
      <p class="mt-1 text-sm" style="color: rgb(var(--c-muted))">
        Single-points-of-failure for the empire. Score = likelihood × impact (1–25).
        Source: <code>ops/risks.yaml</code>. Review quarterly.
      </p>
    </div>
    <a href="/maintain" class="text-xs">← back to Run</a>
  </header>

  {report.risks.length === 0 ? (
    <EmptyState
      title="No risks tracked"
      body="What could end this business? Write the list before something happens."
      yamlPath="ops/risks.yaml"
    />
  ) : (
    <>
      <section class="mb-8 grid grid-cols-2 gap-4 md:grid-cols-5">
        <Scorecard label="Critical (≥16)" value={report.critical} tone={report.critical > 0 ? 'bad' : 'ok'}
                   tier={report.critical > 0 ? 'critical' : 'normal'}
                   tooltip="Likelihood × impact ≥ 16. Mitigate or contingency-plan now." />
        <Scorecard label="High (10–15)"   value={report.high}     tone={report.high > 0 ? 'warn' : 'ok'} />
        <Scorecard label="Medium (5–9)"   value={report.medium} />
        <Scorecard label="Low (<5)"       value={report.low} />
        <Scorecard label="Stale (>180d)"  value={report.staleCount} tone={report.staleCount > 0 ? 'warn' : 'ok'} />
      </section>

      <ul class="space-y-4">
        {report.risks.map((r) => (
          <li class={tierClass[r.tier]}>
            <div class="flex flex-wrap items-baseline justify-between gap-3">
              <h3 class="font-display text-lg font-semibold">{r.title}</h3>
              <div class="flex items-center gap-2 text-xs">
                <span class="badge badge-p2">{r.category}</span>
                <span class:list={['badge', tierBadge[r.tier]]}>{r.tier}</span>
                <span class="font-mono">L{r.likelihood} × I{r.impact} = {r.score}</span>
              </div>
            </div>
            {r.mitigation && (
              <div class="mt-3">
                <div class="text-xs font-semibold uppercase tracking-wide" style="color: rgb(var(--c-muted))">Mitigation</div>
                <p class="mt-1 text-sm">{r.mitigation}</p>
              </div>
            )}
            {r.contingency && (
              <div class="mt-3">
                <div class="text-xs font-semibold uppercase tracking-wide" style="color: rgb(var(--c-muted))">If it happens</div>
                <p class="mt-1 text-sm">{r.contingency}</p>
              </div>
            )}
            <div class="mt-3 flex flex-wrap items-center gap-3 text-xs" style="color: rgb(var(--c-muted))">
              {r.owner && <span>Owner: {r.owner}</span>}
              <span>
                Last reviewed: {r.last_reviewed ? formatDate(r.last_reviewed) : '—'}
                {r.daysSinceReview !== null && <> ({r.daysSinceReview}d ago)</>}
                {r.isStale && <span class="ml-1 badge badge-p1">stale</span>}
              </span>
            </div>
          </li>
        ))}
      </ul>
    </>
  )}

  <section class="mt-8 card" style="background: rgb(var(--c-surface-2))">
    <h3 class="mb-2 text-sm font-semibold uppercase tracking-wide" style="color: rgb(var(--c-muted))">
      Score guide
    </h3>
    <ul class="space-y-1 text-sm">
      <li><strong>Likelihood (1–5):</strong> 1 = very unlikely · 3 = possible · 5 = expected within a year</li>
      <li><strong>Impact (1–5):</strong> 1 = nuisance · 3 = costly setback · 5 = ends the business</li>
      <li><strong>Critical (≥16):</strong> mitigate or contingency-plan immediately. Review monthly.</li>
      <li><strong>High (10–15):</strong> documented mitigation required. Review quarterly.</li>
      <li><strong>Medium / low:</strong> awareness only. Review annually.</li>
    </ul>
  </section>

  <SourceFooter source="ops/risks.yaml" lastRefresh={new Date()} />
</Layout>

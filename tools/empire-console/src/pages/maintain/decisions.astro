---
import Layout from '@/components/chrome/Layout.astro';
import Scorecard from '@/components/widgets/Scorecard.astro';
import EmptyState from '@/components/widgets/EmptyState.astro';
import SourceFooter from '@/components/widgets/SourceFooter.astro';
import { readDecisions } from '@/lib/data/decisions';
import { formatDate } from '@/lib/format';

const decisions = await readDecisions(200);
const counts = decisions.reduce<Record<string, number>>((acc, d) => {
  acc[d.category] = (acc[d.category] ?? 0) + 1; return acc;
}, {});
const last90d = decisions.filter((d) => Date.now() - new Date(d.ts).getTime() < 90 * 86_400_000).length;
---
<Layout title="Decisions" section="maintain">
  <header class="mb-6 flex items-baseline justify-between">
    <div>
      <h1 class="font-display text-3xl font-semibold">Decisions log</h1>
      <p class="mt-1 text-sm" style="color: rgb(var(--c-muted))">
        Lightweight ADRs — what was decided, why, and what alternatives were considered.
        Source: <code>ops/decisions.ndjson</code> (append-only).
      </p>
    </div>
    <a href="/inbox" class="text-xs">capture quick decisions via inbox →</a>
  </header>

  <section class="mb-6 grid grid-cols-2 gap-3 md:grid-cols-5">
    <Scorecard label="Total decisions"   value={decisions.length} />
    <Scorecard label="Last 90d"          value={last90d} />
    <Scorecard label="Strategic"         value={counts.strategic ?? 0} />
    <Scorecard label="Tech"              value={counts.tech ?? 0} />
    <Scorecard label="Product+Marketing" value={(counts.product ?? 0) + (counts.marketing ?? 0)} />
  </section>

  {decisions.length === 0 ? (
    <EmptyState
      title="No decisions logged"
      body="Capture each non-trivial decision as you make it. Six months from now you'll thank yourself."
      yamlPath="ops/decisions.ndjson"
    />
  ) : (
    <ul class="space-y-4">
      {decisions.map((d) => (
        <li class="card">
          <div class="flex flex-wrap items-baseline justify-between gap-3">
            <h3 class="font-display text-lg font-semibold">{d.title}</h3>
            <div class="flex items-center gap-2 text-xs">
              <span class="badge badge-p2">{d.category}</span>
              <span style="color: rgb(var(--c-muted))">{formatDate(d.ts)}</span>
            </div>
          </div>
          {d.context && (
            <div class="mt-3">
              <div class="text-xs font-semibold uppercase tracking-wide" style="color: rgb(var(--c-muted))">Context</div>
              <p class="mt-1 text-sm">{d.context}</p>
            </div>
          )}
          {d.alternatives.length > 0 && (
            <div class="mt-3">
              <div class="text-xs font-semibold uppercase tracking-wide" style="color: rgb(var(--c-muted))">Alternatives considered</div>
              <ul class="mt-1 list-disc pl-5 text-sm">
                {d.alternatives.map((a) => <li>{a}</li>)}
              </ul>
            </div>
          )}
          <div class="mt-3">
            <div class="text-xs font-semibold uppercase tracking-wide" style="color: rgb(var(--c-muted))">Decision</div>
            <p class="mt-1 text-sm font-medium">{d.decision}</p>
          </div>
          {d.rationale && (
            <div class="mt-3">
              <div class="text-xs font-semibold uppercase tracking-wide" style="color: rgb(var(--c-muted))">Why</div>
              <p class="mt-1 text-sm">{d.rationale}</p>
            </div>
          )}
          {d.tags.length > 0 && (
            <div class="mt-3 flex gap-2">
              {d.tags.map((t) => <span class="badge badge-p2">#{t}</span>)}
            </div>
          )}
        </li>
      ))}
    </ul>
  )}

  <SourceFooter source="ops/decisions.ndjson" lastRefresh={new Date()} />
</Layout>

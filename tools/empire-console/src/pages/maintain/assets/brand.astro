---
import Layout from '@/components/chrome/Layout.astro';
import Scorecard from '@/components/widgets/Scorecard.astro';
import EmptyState from '@/components/widgets/EmptyState.astro';
import SourceFooter from '@/components/widgets/SourceFooter.astro';
import { readAssetsByType } from '@/lib/data/assets';
import { readFile } from 'node:fs/promises';
import { join } from 'node:path';
import { paths } from '@/lib/paths';
import { formatDate } from '@/lib/format';

const items = await readAssetsByType('brand-asset');

// Try to load palette tokens from design-system if present
let paletteCss: string | null = null;
try {
  paletteCss = await readFile(join(paths.root, 'design-system', 'tokens.css'), 'utf8');
} catch { /* ignore */ }

// Extract brand-decisions excerpt
let brandDecisions: string | null = null;
try {
  const raw = await readFile(join(paths.root, 'brand', 'brand-decisions.md'), 'utf8');
  brandDecisions = raw.split(/\r?\n/).slice(0, 60).join('\n');
} catch { /* ignore */ }

const categories: Record<string, string> = {
  logo: 'Logo + wordmark',
  palette: 'Color palette',
  font: 'Typography',
  template: 'Template (OG, etc.)',
  kit: 'Kits + bundles',
};

const grouped: Record<string, typeof items> = {};
for (const a of items) {
  const cat = String(a.raw.category ?? 'uncategorized');
  (grouped[cat] ??= []).push(a);
}
---
<Layout title="Brand assets" section="maintain">
  <header class="mb-6 flex items-baseline justify-between">
    <div>
      <h1 class="font-display text-3xl font-semibold">Brand assets</h1>
      <p class="mt-1 text-sm" style="color: rgb(var(--c-muted))">
        Logo · palette · fonts · OG templates · kits. Source: <code>ops/assets/brand-assets.yaml</code>.
      </p>
    </div>
    <a href="/maintain/assets" class="text-xs">← back to registry</a>
  </header>

  <section class="mb-8 grid grid-cols-2 gap-4 md:grid-cols-4">
    <Scorecard label="Total" value={items.length} />
    <Scorecard label="Categories" value={Object.keys(grouped).length} />
    <Scorecard label="Logos" value={grouped.logo?.length ?? 0} />
    <Scorecard label="Templates" value={grouped.template?.length ?? 0} />
  </section>

  {brandDecisions && (
    <section class="mb-8 card">
      <h2 class="mb-3 text-sm font-semibold uppercase tracking-wide" style="color: rgb(var(--c-muted))">
        Brand decisions (top of file)
      </h2>
      <pre class="max-h-72 overflow-auto whitespace-pre-wrap text-xs"
           style="font-family: inherit; line-height: 1.5">{brandDecisions}</pre>
      <p class="mt-2 text-xs font-mono" style="color: rgb(var(--c-muted))">
        brand/brand-decisions.md
      </p>
    </section>
  )}

  {paletteCss && (
    <section class="mb-8 card">
      <h2 class="mb-3 text-sm font-semibold uppercase tracking-wide" style="color: rgb(var(--c-muted))">
        Palette tokens (live)
      </h2>
      <div class="grid grid-cols-2 gap-2 sm:grid-cols-4 md:grid-cols-6">
        {Object.entries({
          'paper': 'rgb(var(--c-paper))',
          'ink': 'rgb(var(--c-ink))',
          'muted': 'rgb(var(--c-muted))',
          'accent': 'rgb(var(--c-accent))',
          'ok': 'rgb(var(--c-ok))',
          'warn': 'rgb(var(--c-warn))',
          'bad': 'rgb(var(--c-bad))',
          'surface': 'rgb(var(--c-surface))',
          'surface-2': 'rgb(var(--c-surface-2))',
          'surface-3': 'rgb(var(--c-surface-3))',
          'border': 'rgb(var(--c-border))',
          'border-strong': 'rgb(var(--c-border-strong))',
        }).map(([name, value]) => (
          <div>
            <div class="h-12 w-full rounded border"
                 style={`background: ${value}; border-color: rgb(var(--c-border))`}></div>
            <div class="mt-1 text-xs font-mono">{name}</div>
          </div>
        ))}
      </div>
      <p class="mt-3 text-xs font-mono" style="color: rgb(var(--c-muted))">
        design-system/tokens.css (~{(paletteCss.length / 1024).toFixed(1)}KB)
      </p>
    </section>
  )}

  {items.length === 0 ? (
    <EmptyState title="No brand assets" yamlPath="ops/assets/brand-assets.yaml" />
  ) : (
    Object.entries(grouped).map(([cat, list]) => (
      <section class="mb-6">
        <h2 class="mb-3 text-xs font-semibold uppercase tracking-wide" style="color: rgb(var(--c-muted))">
          {categories[cat] ?? cat} ({list.length})
        </h2>
        <ul class="space-y-2">
          {list.map((a) => (
            <li class="card card-tight">
              <div class="flex items-baseline justify-between gap-3">
                <div class="min-w-0 flex-1">
                  <div class="font-medium">{a.name}</div>
                  <div class="mt-1 text-xs font-mono" style="color: rgb(var(--c-muted))">
                    {String(a.raw.location ?? '—')}
                  </div>
                </div>
                <div class="flex items-center gap-2 text-xs">
                  <span class="badge badge-p2">{String(a.raw.format ?? '—')}</span>
                  <span class="font-mono" style="color: rgb(var(--c-muted))">
                    {a.last_updated ? formatDate(a.last_updated) : '—'}
                  </span>
                </div>
              </div>
              {a.raw.notes && (
                <p class="mt-2 text-xs" style="color: rgb(var(--c-muted))">{String(a.raw.notes)}</p>
              )}
            </li>
          ))}
        </ul>
      </section>
    ))
  )}

  <SourceFooter source="ops/assets/brand-assets.yaml + brand/ + design-system/tokens.css" lastRefresh={new Date()} />
</Layout>

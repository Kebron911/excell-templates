---
import Layout from '@/components/chrome/Layout.astro';
import Scorecard from '@/components/widgets/Scorecard.astro';
import EmptyState from '@/components/widgets/EmptyState.astro';
import SourceFooter from '@/components/widgets/SourceFooter.astro';
import { readNetwork } from '@/lib/data/network';
import { formatDate } from '@/lib/format';

const r = await readNetwork();

const askDebtBadge: Record<string, string> = {
  'me-owes': 'badge-p0',
  'them-owes': 'badge-p1',
  'balanced': 'badge-ok',
};
---
<Layout title="Network" section="maintain">
  <header class="mb-6 flex items-baseline justify-between">
    <div>
      <h1 class="font-display text-3xl font-semibold">Network</h1>
      <p class="mt-1 text-sm" style="color: rgb(var(--c-muted))">
        Mentors · advisors · peers · partners. Source: <code>ops/network.yaml</code>.
        Cold = no contact in &gt;90d.
      </p>
    </div>
  </header>

  <section class="mb-8 grid grid-cols-2 gap-4 md:grid-cols-4">
    <Scorecard label="Total people" value={r.total} />
    <Scorecard label="Cold (>90d)" value={r.cold}
               tone={r.cold > 0 ? 'warn' : 'ok'} hint="reach out" />
    <Scorecard label="I owe a follow-up" value={r.meOwesCount}
               tone={r.meOwesCount > 0 ? 'warn' : 'ok'}
               tier={r.meOwesCount > 0 ? 'notable' : 'normal'} />
    <Scorecard label="Mentors / advisors"
               value={(r.byRole.mentor ?? 0) + (r.byRole.advisor ?? 0)} />
  </section>

  {r.people.length === 0 ? (
    <EmptyState
      title="Network is empty"
      body="Track the people whose context affects empire decisions. Personal social belongs in Cowork OS."
      yamlPath="ops/network.yaml"
    />
  ) : (
    <ul class="space-y-3">
      {r.people.map((p) => (
        <li class={`card ${p.ask_debt === 'me-owes' ? 'card-notable' : ''}`}>
          <div class="flex flex-wrap items-baseline justify-between gap-3">
            <div>
              <h3 class="font-display text-lg font-semibold">{p.name}</h3>
              {p.contact && <span class="text-xs font-mono" style="color: rgb(var(--c-muted))">{p.contact}</span>}
            </div>
            <div class="flex items-center gap-2 text-xs">
              <span class="badge badge-p2">{p.role}</span>
              {p.category && <span class="badge badge-p2">{p.category}</span>}
              {p.ask_debt && <span class:list={['badge', askDebtBadge[p.ask_debt]]}>{p.ask_debt}</span>}
              {p.isCold && <span class="badge badge-p1">cold</span>}
            </div>
          </div>
          {p.context && <p class="mt-3 text-sm">{p.context}</p>}
          {p.notes && <p class="mt-2 text-xs" style="color: rgb(var(--c-muted))">{p.notes}</p>}
          <div class="mt-3 text-xs" style="color: rgb(var(--c-muted))">
            Last contact: {p.last_contact ? formatDate(p.last_contact) : '—'}
            {p.daysSinceContact !== null && <> ({p.daysSinceContact}d ago)</>}
          </div>
        </li>
      ))}
    </ul>
  )}

  <SourceFooter source="ops/network.yaml" lastRefresh={new Date()} />
</Layout>

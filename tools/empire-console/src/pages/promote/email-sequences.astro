---
import Layout from '@/components/chrome/Layout.astro';
import Scorecard from '@/components/widgets/Scorecard.astro';
import EmptyState from '@/components/widgets/EmptyState.astro';
import SourceFooter from '@/components/widgets/SourceFooter.astro';
import { readEmailSequences } from '@/lib/data/email-sequences';
import { formatDate } from '@/lib/format';

const r = await readEmailSequences();
---
<Layout title="Email sequences" section="promote">
  <header class="mb-6">
    <h1 class="font-display text-3xl font-semibold">Email sequences</h1>
    <p class="text-sm" style="color: rgb(var(--c-muted))">
      IS sequence drafts in <code>copy/email-sequences/</code> — welcome flows,
      post-purchase, review-request, refund-recovery, win-back, abandoned-cart,
      bundle cross-sell.
    </p>
  </header>

  <section class="mb-8 grid grid-cols-2 gap-4 md:grid-cols-3">
    <Scorecard label="Sequences" value={r.totalSequences} />
    <Scorecard label="Total messages" value={r.totalMessages} />
    <Scorecard label="Avg per sequence"
               value={r.totalSequences ? Math.round(r.totalMessages / r.totalSequences) : 0} />
  </section>

  {r.sequences.length === 0 ? (
    <EmptyState title="No sequences" body="Drop drafts in copy/email-sequences/<slug>/*.md" yamlPath="copy/email-sequences/" />
  ) : (
    <ul class="space-y-3">
      {r.sequences.map((seq) => (
        <li>
          <details class="card">
            <summary class="cursor-pointer">
              <span class="font-display text-lg font-semibold">{seq.slug}</span>
              <span class="ml-3 font-mono text-xs" style="color: rgb(var(--c-muted))">
                {seq.messages.length} message{seq.messages.length === 1 ? '' : 's'}
              </span>
            </summary>
            <ol class="mt-3 space-y-3">
              {seq.messages.map((m, i) => (
                <li class="rounded border p-3" style="border-color: rgb(var(--c-border))">
                  <div class="flex items-baseline justify-between gap-3">
                    <span class="font-mono text-xs" style="color: rgb(var(--c-muted))">#{i + 1}</span>
                    <span class="font-mono text-xs" style="color: rgb(var(--c-muted))">{formatDate(m.mtime)}</span>
                  </div>
                  {m.subject && <div class="mt-1 font-medium">📧 {m.subject}</div>}
                  {m.preheader && (
                    <div class="mt-1 text-xs italic" style="color: rgb(var(--c-muted))">↳ {m.preheader}</div>
                  )}
                  {m.bodyExcerpt && (
                    <p class="mt-2 text-sm line-clamp-3">{m.bodyExcerpt}…</p>
                  )}
                  <div class="mt-2 text-xs font-mono" style="color: rgb(var(--c-muted))">{m.path}</div>
                </li>
              ))}
            </ol>
          </details>
        </li>
      ))}
    </ul>
  )}

  <SourceFooter source="copy/email-sequences/**/*.md" lastRefresh={new Date()} />
</Layout>

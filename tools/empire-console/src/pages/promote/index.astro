---
import Layout from '@/components/chrome/Layout.astro';
import { readNewsletter } from '@/lib/data/newsletter';
import { readCitations } from '@/lib/data/citations';
import { readSocialAnswers } from '@/lib/data/social-answers';
import { readPinterest } from '@/lib/data/pinterest';
import { readIndexNow } from '@/lib/data/indexnow';
import { readCustomerEmbeds } from '@/lib/data/customer-embeds';

const [newsletter, citations, social, pinterest, indexnow, embeds] = await Promise.all([
  readNewsletter(),
  readCitations(),
  readSocialAnswers(),
  readPinterest(),
  readIndexNow(),
  readCustomerEmbeds(),
]);

interface Tile {
  href: string; title: string; desc: string;
  signal?: string; tone?: 'ok' | 'warn' | 'bad'; disabled?: boolean;
}

const groups: Array<{ title: string; subtitle?: string; tiles: Tile[] }> = [
  {
    title: 'Traffic Engines',
    subtitle: 'Where visits come from now. Free or near-free; no reputation prerequisite. See docs/backlink-automation-plan.md.',
    tiles: [
      { href: '/promote/citations', title: 'Citations', desc: 'Free profile + directory backlinks (Phase 0 sprints).',
        signal: `${citations.counts.live}/${citations.counts.total} live`,
        tone: citations.counts.pending > 5 ? 'warn' : 'ok' },
      { href: '/promote/pinterest', title: 'Pinterest perf', desc: 'Pin volume · impressions · top performers · outbound clicks. (W15 + W44)',
        signal: pinterest.isCacheReady
          ? `${pinterest.outbound_clicks_30d.toLocaleString()} clicks/30d`
          : 'cache pending',
        tone: pinterest.isCacheReady ? 'ok' : 'warn' },
      { href: '/promote/social-answers', title: 'Reddit / Quora answers', desc: 'Questions surfaced + answered + traffic earned. (W41)',
        signal: `${social.answered7d}/${social.surfaced7d} answered (7d)`,
        tone: social.surfaced7d > 0 && social.answered7d === 0 ? 'warn' : 'ok' },
      { href: '/promote/etsy-referral', title: 'Etsy referral', desc: 'Etsy → site visits, share of all traffic, per-listing attribution.' },
      { href: '/check/seo', title: 'IndexNow + GSC submit', desc: 'Fast indexing across Bing/Yandex/Pinterest/GSC. (W43)',
        signal: `${indexnow.submissions_7d}/7d · ${indexnow.errors_7d} err`,
        tone: indexnow.errors_7d > 0 ? 'warn' : 'ok' },
      { href: '/promote/customer-embeds', title: 'Customer embeds', desc: 'Free attribution badges on customers’ own sites. (W45)',
        signal: `${embeds.active.length} active`,
        tone: embeds.active.length > 0 ? 'ok' : 'ok' },
    ],
  },
  {
    title: 'Content',
    subtitle: 'What feeds the engines.',
    tiles: [
      { href: '/promote/newsletter', title: 'Newsletter', desc: 'Subscribers · cadence · per-send performance.',
        signal: newsletter.daysSinceLastSend !== null
          ? `last send ${newsletter.daysSinceLastSend}d ago`
          : 'no sends yet',
        tone: newsletter.isCadenceStale ? 'warn' : 'ok' },
      { href: '/promote/atomization',     title: 'Atomization decks', desc: 'Source Topic → 11 platform artifacts.' },
      { href: '/promote/copy',            title: 'Copy library',      desc: 'All copy/ assets — Etsy · email · blog · Pinterest · FB.' },
      { href: '/promote/email-sequences', title: 'Email sequences',   desc: 'IS sequence drafts (welcome · post-purchase · win-back · etc.).' },
      { href: '#', title: 'Pin generator', desc: 'Hoists STRGuests pin code to shared lib.', disabled: true },
      { href: '#', title: 'Broadcast queue', desc: 'IS YAML → import webhook (the send action).', disabled: true },
      { href: '#', title: 'Lifecycle preview', desc: 'IS automated sequence viewer.', disabled: true },
    ],
  },
  {
    title: 'Long Game (deferred)',
    subtitle: 'Reactivate when reputation built. See trigger conditions in docs/backlink-automation-plan.md.',
    tiles: [
      { href: '/promote/backlinks',    title: 'Backlinks (outreach)',    desc: 'Direct outreach pursuit. Deferred — needs first placements.',
        signal: 'Deferred · MRR > $3k', tone: 'warn' },
      { href: '/promote/press',        title: 'Press / PR',   desc: 'Podcasts + HARO + guest posts. Deferred — needs prior credibility.',
        signal: 'Deferred · Mo 4–6+', tone: 'warn' },
      { href: '/promote/influencers',  title: 'Influencers',  desc: 'Influencer partnerships. Deferred — needs MRR.',
        signal: 'Deferred · MRR > $3k', tone: 'warn' },
      { href: '/promote/affiliates',   title: 'Affiliates',   desc: 'Leaderboard + payouts due. Active — every affiliate page = a link.' },
      { href: '/promote/partnerships', title: 'Partnerships', desc: 'PMS integrations + co-marketing. Deferred — needs 50+ buyers/mo.', disabled: true },
      { href: '/promote/paid',         title: 'Paid',         desc: 'Promoted Listings · Pinterest · Meta. Optional accelerant.' },
      { href: '/promote/competitors',   title: 'Competitor watch', desc: 'Direct · adjacent · aspirational players.' },
    ],
  },
  {
    title: 'Service',
    tiles: [
      { href: '/promote/voice', title: 'Customer voice', desc: 'Quotes · pain · feature-asks · objections · churn reasons.' },
      { href: '/promote/feature-requests', title: 'Feature requests', desc: 'Clustered view of feature-asks (3+ = strong signal).' },
      { href: '/promote/onboarding', title: 'Onboarding flow', desc: 'First-100 buyer white-glove follow-through.' },
      { href: '#', title: 'Customer support', desc: 'Etsy convos + Gumroad + email queue.', disabled: true },
      { href: '#', title: 'Reviews & reputation', desc: 'Etsy + Gumroad rating + 1-2 star alerts.', disabled: true },
      { href: '#', title: 'Promotions', desc: 'Coupon ladder + A/B tests.', disabled: true },
    ],
  },
];
---
<Layout title="Grow" section="promote">
  <header class="mb-8">
    <h1 class="font-display text-4xl font-semibold">Grow</h1>
    <p class="text-sm" style="color: rgb(var(--c-muted))">
      Traffic-first. Distribution &gt; acquisition for new brands.
      Plan: <code>docs/backlink-automation-plan.md</code>.
    </p>
  </header>

  {groups.map((group) => (
    <section class="mb-10">
      <h2 class="mb-1 text-sm font-semibold uppercase tracking-wide" style="color: rgb(var(--c-muted))">
        {group.title}
      </h2>
      {group.subtitle && (
        <p class="mb-4 text-xs" style="color: rgb(var(--c-muted))">{group.subtitle}</p>
      )}
      <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
        {group.tiles.map((t) => (
          <a href={t.disabled ? '#' : t.href}
             class="card no-underline transition hover:shadow-md"
             style={t.disabled ? 'opacity: 0.55; cursor: not-allowed' : ''}
             aria-disabled={t.disabled ? 'true' : undefined}>
            <div class="flex items-baseline justify-between gap-3">
              <h3 class="font-display text-base font-semibold">{t.title}</h3>
              {t.signal && <span class:list={['badge', `badge-${t.tone === 'bad' ? 'p0' : t.tone === 'warn' ? 'p1' : 'ok'}`, 'shrink-0', 'text-[10px]']}>{t.signal}</span>}
            </div>
            <p class="mt-1 text-sm" style="color: rgb(var(--c-muted))">{t.desc}</p>
          </a>
        ))}
      </div>
    </section>
  ))}
</Layout>

---
import Layout from '@/components/chrome/Layout.astro';
import Scorecard from '@/components/widgets/Scorecard.astro';
import EmptyState from '@/components/widgets/EmptyState.astro';
import SourceFooter from '@/components/widgets/SourceFooter.astro';
import { readCompetitors } from '@/lib/data/competitors';
import { formatDate } from '@/lib/format';

const r = await readCompetitors();
---
<Layout title="Competitors" section="promote">
  <header class="mb-6 flex items-baseline justify-between">
    <div>
      <h1 class="font-display text-3xl font-semibold">Competitor watch</h1>
      <p class="mt-1 text-sm" style="color: rgb(var(--c-muted))">
        Direct / adjacent / aspirational players. Source: <code>ops/competitors.yaml</code>.
        Review weekly during Tuesday or Wednesday session.
      </p>
    </div>
  </header>

  <section class="mb-8 grid grid-cols-2 gap-4 md:grid-cols-4">
    <Scorecard label="Direct" value={r.byTier.direct} hint="competes for same dollars" />
    <Scorecard label="Adjacent" value={r.byTier.adjacent} hint="adjacent niche" />
    <Scorecard label="Aspirational" value={r.byTier.aspirational} hint="role models" />
    <Scorecard
      label="Stale (>30d)"
      value={r.staleCount}
      tone={r.staleCount > 0 ? 'warn' : 'ok'}
    />
  </section>

  {r.competitors.length === 0 ? (
    <EmptyState
      title="No competitors tracked"
      body="Add 3–5 direct + 2–3 adjacent competitors. Review their pricing, copy, listings monthly."
      yamlPath="ops/competitors.yaml"
    />
  ) : (
    <ul class="space-y-4">
      {r.competitors.map((c) => (
        <li class={`card ${c.isStale ? 'card-notable' : ''}`}>
          <div class="flex flex-wrap items-baseline justify-between gap-3">
            <div>
              <h3 class="font-display text-lg font-semibold">{c.name}</h3>
              {c.url && <a href={c.url} target="_blank" rel="noopener noreferrer" class="text-xs">{c.url} ↗</a>}
            </div>
            <div class="flex items-center gap-2 text-xs">
              <span class="badge badge-p2">{c.tier}</span>
              {c.category && <span class="badge badge-p2">{c.category}</span>}
              {c.pricing && <span class="font-mono">{c.pricing}</span>}
            </div>
          </div>

          <div class="mt-3 grid grid-cols-1 gap-3 md:grid-cols-2">
            {c.strengths.length > 0 && (
              <div>
                <div class="text-xs font-semibold uppercase tracking-wide" style="color: rgb(var(--c-ok))">Strengths</div>
                <ul class="mt-1 list-disc pl-5 text-sm">
                  {c.strengths.map((s) => <li>{s}</li>)}
                </ul>
              </div>
            )}
            {c.weaknesses.length > 0 && (
              <div>
                <div class="text-xs font-semibold uppercase tracking-wide" style="color: rgb(var(--c-bad))">Weaknesses</div>
                <ul class="mt-1 list-disc pl-5 text-sm">
                  {c.weaknesses.map((w) => <li>{w}</li>)}
                </ul>
              </div>
            )}
          </div>

          {c.moves.length > 0 && (
            <div class="mt-3">
              <div class="text-xs font-semibold uppercase tracking-wide" style="color: rgb(var(--c-muted))">Recent moves</div>
              <ul class="mt-1 list-disc pl-5 text-sm">
                {c.moves.map((m) => <li>{m}</li>)}
              </ul>
            </div>
          )}

          <div class="mt-3 flex items-baseline justify-between text-xs" style="color: rgb(var(--c-muted))">
            <span>
              Last checked: {c.last_checked ? formatDate(c.last_checked) : '—'}
              {c.daysSinceCheck !== null && <> ({c.daysSinceCheck}d ago)</>}
            </span>
            {c.isStale && <span class="badge badge-p1">stale — review</span>}
          </div>
        </li>
      ))}
    </ul>
  )}

  <SourceFooter source="ops/competitors.yaml" lastRefresh={new Date()}
                notes="Update strengths/weaknesses/pricing/moves when reviewing" />
</Layout>

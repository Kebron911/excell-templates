---
import Layout from '@/components/chrome/Layout.astro';
---
<Layout title="Promote · Partnerships" section="promote">
  <header class="mb-6 flex items-baseline justify-between">
    <div>
      <h1 class="font-display text-3xl font-semibold">Partnerships</h1>
      <p class="text-sm" style="color: rgb(var(--c-muted))">
        PMS integrations + co-marketing swap calendar + cross-promo opportunities.
      </p>
    </div>
    <span class="badge badge-p2">Phase 5 stub</span>
  </header>

  <section class="mb-8 card" style="background: rgb(var(--c-surface-2))">
    <h3 class="mb-2 text-sm font-semibold uppercase tracking-wide" style="color: rgb(var(--c-muted))">
      Phase 5 scope
    </h3>
    <ul class="space-y-1 text-sm">
      <li>• <strong>PMS integrations:</strong> Hostfully · Guesty · Hospitable · Lodgify · Smoobu — pitch each as a "templates partner" co-marketing.</li>
      <li>• <strong>Swap calendar:</strong> trade newsletter mentions / blog cross-posts / podcast guesting with adjacent STR brands.</li>
      <li>• <strong>Cross-promo opportunities:</strong> products that complement (not compete) — STR-specific accounting tools, photographers, cleaning marketplaces.</li>
    </ul>
    <p class="mt-3 text-sm" style="color: rgb(var(--c-muted))">
      Lands in Phase 5 if Phases 1–4 hit on time. Earlier if a partnership opportunity arrives unsolicited.
    </p>
  </section>
</Layout>

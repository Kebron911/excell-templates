---
import Layout from '@/components/chrome/Layout.astro';
import { readAtlas, type AtlasItemKind } from '@/lib/data/atlas';
import { listSites } from '@/lib/data/site-atlas';

const [report, sites] = await Promise.all([
  readAtlas(),
  listSites(),
]);

const kindMeta: Record<AtlasItemKind, { label: string; cssClass: string; isExternal: boolean }> = {
  internal: { label: 'page',    cssClass: 'badge-ok', isExternal: false },
  external: { label: 'tool ↗',  cssClass: 'badge-p1', isExternal: true  },
  doc:      { label: 'doc',     cssClass: 'badge-p2', isExternal: false },
  runbook:  { label: 'runbook', cssClass: 'badge-p2', isExternal: false },
  yaml:     { label: 'yaml',    cssClass: 'badge-p2', isExternal: false },
  code:     { label: 'code',    cssClass: 'badge-p2', isExternal: false },
};
---
<Layout title="Atlas" section="today">
  <header class="mb-6">
    <h1 class="font-display text-4xl font-semibold">Atlas</h1>
    <p class="mt-1 text-sm" style="color: rgb(var(--c-muted))">
      The empire's directory of everything. <strong>{report.totals.items}</strong> entries across <strong>{report.totals.sections}</strong> sections.
      Press <kbd class="rounded border px-1.5 py-0.5 text-xs" style="border-color: rgb(var(--c-border))">/</kbd> to focus search,
      or <kbd class="rounded border px-1.5 py-0.5 text-xs" style="border-color: rgb(var(--c-border))">⌘K</kbd> anywhere in the console.
    </p>
  </header>

  {sites.length > 0 && (
    <section class="mb-8">
      <h2 class="mb-3 text-xs font-semibold uppercase tracking-wide" style="color: rgb(var(--c-muted))">
        Per-site atlases
      </h2>
      <div class="grid grid-cols-2 gap-3 md:grid-cols-3 lg:grid-cols-5">
        {sites.map((s) => (
          <a href={`/atlas/${s.id}`}
             class="card no-underline transition hover:shadow-md"
             style="padding: 0.75rem 1rem">
            <div class="font-display text-base font-semibold">{s.name}</div>
            <div class="mt-0.5 text-xs" style="color: rgb(var(--c-muted))">{s.role ?? 'site'}</div>
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="mb-4 sticky top-0 -mx-6 px-6 pb-3 pt-3"
           style="background: rgb(var(--c-paper)); z-index: 10; border-bottom: 1px solid rgb(var(--c-border))">
    <div class="flex flex-col gap-3 md:flex-row md:items-center">
      <input
        id="atlas-filter"
        type="search"
        placeholder='Filter — type any text. Try "stripe", "runbook", "newsletter"…'
        class="flex-1 rounded-lg border px-4 py-2.5 text-sm"
        style="background: rgb(var(--c-surface)); border-color: rgb(var(--c-border)); color: rgb(var(--c-ink))"
        autocomplete="off"
      />
      <div class="flex flex-wrap gap-2 text-xs">
        <button data-kind="all"      class="atlas-kind-btn badge badge-ok" type="button">all</button>
        <button data-kind="internal" class="atlas-kind-btn badge"          type="button">page · {report.totals.byKind.internal}</button>
        <button data-kind="external" class="atlas-kind-btn badge"          type="button">tool ↗ · {report.totals.byKind.external}</button>
        <button data-kind="doc"      class="atlas-kind-btn badge"          type="button">doc · {report.totals.byKind.doc}</button>
        <button data-kind="runbook"  class="atlas-kind-btn badge"          type="button">runbook · {report.totals.byKind.runbook}</button>
        <button data-kind="yaml"     class="atlas-kind-btn badge"          type="button">yaml · {report.totals.byKind.yaml}</button>
        <button data-kind="code"     class="atlas-kind-btn badge"          type="button">code · {report.totals.byKind.code}</button>
      </div>
    </div>
    <div class="mt-2 flex items-center justify-between text-xs" style="color: rgb(var(--c-muted))">
      <span>
        <span id="atlas-result-count">{report.totals.items}</span> of {report.totals.items} shown
        <button id="atlas-clear" type="button"
                class="ml-3 hidden rounded border px-2 py-0.5"
                style="border-color: rgb(var(--c-border))">clear filters</button>
      </span>
      <button id="atlas-toggle-all" type="button"
              class="rounded border px-2 py-0.5"
              style="border-color: rgb(var(--c-border))">expand all</button>
    </div>
  </section>

  <section id="atlas-pinned" class="hidden mb-8" aria-label="Pinned favorites">
    <h2 class="mb-3 text-xs font-semibold uppercase tracking-wide" style="color: rgb(var(--c-warn))">
      ★ Pinned
    </h2>
    <ul id="atlas-pinned-list" class="space-y-1"></ul>
    <p class="mt-2 text-xs" style="color: rgb(var(--c-muted))">
      Pin items via <kbd class="rounded border px-1" style="border-color: rgb(var(--c-border))">⌘K</kbd> →
      <kbd class="rounded border px-1" style="border-color: rgb(var(--c-border))">⇧↵</kbd>.
    </p>
  </section>

  <div id="atlas-content">
    {report.sections.map((section) => (
      <details class="atlas-section mb-4"
               data-section-id={section.id}
               open={section.expanded}>
        <summary class="cursor-pointer rounded px-3 py-2 hover:bg-[rgb(var(--c-surface-2))]">
          <span class="font-display text-xl font-semibold">{section.label}</span>
          <span class="ml-2 text-xs" style="color: rgb(var(--c-muted))">
            {section.groups.reduce((s, g) => s + g.items.length, 0)} items
          </span>
        </summary>
        <div class="mt-2 pl-3">
          {section.groups.map((group) => (
            <div class="atlas-group mb-4">
              {group.label && (
                <h3 class="mb-2 text-xs font-semibold uppercase tracking-wide" style="color: rgb(var(--c-muted))">
                  {group.label}
                </h3>
              )}
              <ul class="space-y-1">
                {group.items.map((item) => {
                  const meta = kindMeta[item.kind];
                  const target = meta.isExternal ? '_blank' : undefined;
                  const rel = meta.isExternal ? 'noopener noreferrer' : undefined;
                  const isPlaceholder = item.status === 'placeholder';
                  const hasUrl = item.url && item.url.length > 0;
                  return (
                    <li class="atlas-item rounded px-3 py-2 hover:bg-[rgb(var(--c-surface-2))]"
                        data-name={item.name.toLowerCase()}
                        data-section={section.label.toLowerCase()}
                        data-kind={item.kind}
                        data-note={(item.note ?? '').toLowerCase()}>
                      <div class="flex flex-wrap items-baseline justify-between gap-x-3 gap-y-1">
                        <div class="min-w-0 flex-1">
                          {hasUrl ? (
                            <a href={item.url} target={target} rel={rel}
                               class="font-medium no-underline hover:underline"
                               style={isPlaceholder ? 'opacity: 0.6' : ''}>
                              {item.name}
                            </a>
                          ) : (
                            <span class="font-medium" style="opacity: 0.6">{item.name}</span>
                          )}
                          {item.note && (
                            <span class="ml-2 text-xs" style="color: rgb(var(--c-muted))">— {item.note}</span>
                          )}
                          {isPlaceholder && (
                            <span class="ml-2 badge badge-p2">placeholder</span>
                          )}
                        </div>
                        <span class:list={['badge', meta.cssClass, 'shrink-0']}>{meta.label}</span>
                      </div>
                      {hasUrl && (
                        <div class="mt-1 truncate text-xs" style="color: rgb(var(--c-muted))">
                          <code>{item.url}</code>
                        </div>
                      )}
                    </li>
                  );
                })}
              </ul>
            </div>
          ))}
        </div>
      </details>
    ))}
  </div>

  <div id="atlas-empty" class="hidden card mt-6 text-center"
       style="background: rgb(var(--c-surface-2))">
    <p class="text-sm">No matches.</p>
    <p class="mt-1 text-xs" style="color: rgb(var(--c-muted))">
      Try clearing the kind filter, or shorten your search query.
    </p>
  </div>
</Layout>

<script is:inline>
  (function () {
    const input = document.getElementById('atlas-filter');
    const items = Array.from(document.querySelectorAll('.atlas-item'));
    const groups = Array.from(document.querySelectorAll('.atlas-group'));
    const sections = Array.from(document.querySelectorAll('.atlas-section'));
    const empty = document.getElementById('atlas-empty');
    const buttons = Array.from(document.querySelectorAll('.atlas-kind-btn'));
    const countEl = document.getElementById('atlas-result-count');
    const clearBtn = document.getElementById('atlas-clear');
    const toggleAllBtn = document.getElementById('atlas-toggle-all');
    const totalItems = items.length;

    // Remember initial expanded state per section so we can restore on clear.
    const initialExpanded = new Map();
    sections.forEach((s) => initialExpanded.set(s, s.hasAttribute('open')));

    let activeKind = 'all';
    let activeQuery = '';
    let allExpanded = false;

    function readUrlState() {
      const params = new URLSearchParams(location.search);
      activeQuery = params.get('q') || '';
      activeKind = params.get('kind') || 'all';
      input.value = activeQuery;
      buttons.forEach((b) => {
        b.classList.toggle('badge-ok', b.getAttribute('data-kind') === activeKind);
      });
    }

    function writeUrlState() {
      const params = new URLSearchParams();
      if (activeQuery) params.set('q', activeQuery);
      if (activeKind !== 'all') params.set('kind', activeKind);
      const newUrl = params.toString() ? `?${params}` : location.pathname;
      history.replaceState({}, '', newUrl);
    }

    function applyFilter() {
      const q = activeQuery.trim().toLowerCase();
      const isFiltering = q.length > 0 || activeKind !== 'all';
      let visibleCount = 0;

      items.forEach((el) => {
        const name = el.getAttribute('data-name') || '';
        const note = el.getAttribute('data-note') || '';
        const section = el.getAttribute('data-section') || '';
        const kind = el.getAttribute('data-kind') || '';
        const matchesKind = activeKind === 'all' || activeKind === kind;
        const matchesQuery = !q || name.includes(q) || note.includes(q) || section.includes(q);
        const visible = matchesKind && matchesQuery;
        el.classList.toggle('hidden', !visible);
        if (visible) visibleCount++;
      });
      groups.forEach((g) => {
        const anyVisible = g.querySelectorAll('.atlas-item:not(.hidden)').length > 0;
        g.classList.toggle('hidden', !anyVisible);
      });
      sections.forEach((s) => {
        const anyVisible = s.querySelectorAll('.atlas-item:not(.hidden)').length > 0;
        s.classList.toggle('hidden', !anyVisible);
        // Auto-expand any section that contains matches when filtering.
        if (isFiltering && anyVisible) {
          s.setAttribute('open', '');
        } else if (!isFiltering) {
          // Restore initial expanded state on clear.
          if (initialExpanded.get(s)) s.setAttribute('open', '');
          else s.removeAttribute('open');
        }
      });

      countEl.textContent = String(visibleCount);
      empty.classList.toggle('hidden', visibleCount > 0);
      clearBtn.classList.toggle('hidden', !isFiltering);
    }

    function setKind(kind) {
      activeKind = kind;
      buttons.forEach((b) => {
        b.classList.toggle('badge-ok', b.getAttribute('data-kind') === kind);
      });
      writeUrlState();
      applyFilter();
    }

    function clearFilters() {
      activeQuery = '';
      activeKind = 'all';
      input.value = '';
      buttons.forEach((b) => {
        b.classList.toggle('badge-ok', b.getAttribute('data-kind') === 'all');
      });
      writeUrlState();
      applyFilter();
    }

    input.addEventListener('input', (e) => {
      activeQuery = e.target.value;
      writeUrlState();
      applyFilter();
    });
    buttons.forEach((b) => {
      b.addEventListener('click', () => setKind(b.getAttribute('data-kind') || 'all'));
    });
    clearBtn.addEventListener('click', clearFilters);
    toggleAllBtn.addEventListener('click', () => {
      allExpanded = !allExpanded;
      sections.forEach((s) => {
        if (allExpanded) s.setAttribute('open', '');
        else if (!initialExpanded.get(s)) s.removeAttribute('open');
      });
      toggleAllBtn.textContent = allExpanded ? 'collapse all' : 'expand all';
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === '/' && document.activeElement !== input && !e.ctrlKey && !e.metaKey) {
        e.preventDefault();
        input.focus();
      }
      if (e.key === 'Escape' && document.activeElement === input) {
        clearFilters();
        input.blur();
      }
    });

    readUrlState();
    applyFilter();

    // Pinned section — sync from Cmd+K favorites in localStorage
    function renderPinned() {
      const pinned = document.getElementById('atlas-pinned');
      const list = document.getElementById('atlas-pinned-list');
      let favs;
      try { favs = new Set(JSON.parse(localStorage.getItem('empire-cmdk-favs') || '[]')); }
      catch { favs = new Set(); }
      if (favs.size === 0) { pinned.classList.add('hidden'); return; }

      const matches = items
        .filter((it) => favs.has(it.getAttribute('data-favkey') || ''))
        .slice(0, 12);
      if (matches.length === 0) { pinned.classList.add('hidden'); return; }
      list.innerHTML = matches.map((it) => it.outerHTML.replace('atlas-item', 'atlas-item-pinned')).join('');
      pinned.classList.remove('hidden');
    }
    renderPinned();
    window.addEventListener('storage', renderPinned);
  })();
</script>

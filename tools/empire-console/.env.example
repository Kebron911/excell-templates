# Empire Console — environment variables
#
# Copy to .env (gitignored) for local dev. GitHub Actions reads matching
# repo secrets at deploy time and inlines them into the static build
# before rsync to Hostinger.
#
# Astro convention: PUBLIC_* vars are inlined into the static build and
# visible to the browser. Anything sensitive must NOT be PUBLIC_*.

# ─── Phase 4 capture persistence ──────────────────────────────────
# Base URL of the n8n capture-receiver webhook. Console POSTs to:
#   ${PUBLIC_N8N_WEBHOOK_BASE}/empire-capture
# Leave blank to fall back to localStorage paste-flow.
PUBLIC_N8N_WEBHOOK_BASE=

# ─── Public site URL ──────────────────────────────────────────────
# Used for canonical links and Telegram deep-links from n8n flows.
# In dev: http://localhost:4327
# In prod: https://dashboard.thestrledger.com
PUBLIC_CONSOLE_BASE_URL=http://localhost:4327

    {
      "id": "w11-n12",
      "name": "Log Refund Alert",
      "type": "n8n-nodes-base.airtable",
      "typeVersion": 2.1,
      "position": [1500, 200],
      "onError": "continueErrorOutput",
      "parameters": {
        "operation": "create",
        "base": { "__rl": true, "value": "BASE_ID_PLACEHOLDER", "mode": "id" },
        "table": { "__rl": true, "value": "TABLE_ID_ERRORS", "mode": "id" },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "Timestamp": "={{ $json.received_at }}",
            "Workflow": "W11-threshold-alerts",
            "Node": "={{ $json.alert_type }}",
            "Error message": "={{ 'Threshold breach: ' + $json.metric_name + ' = ' + $json.last_value_label + ' (target ' + $json.target + ')' }}",
            "Payload": "={{ JSON.stringify({ metric_name: $json.metric_name, value: $json.value, date: $json.date, channel: $json.channel }) }}",
            "Status": "Alert"
          },
          "schema": []
        }
      },
      "credentials": {
        "airtableTokenApi": { "id": "1", "name": "Airtable account" }
      }
    },

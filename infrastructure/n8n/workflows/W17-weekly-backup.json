        "jsCode": "const data = $input.first().json;\nconst folders = data.files || [];\nconst now = new Date();\nconst ms30Days = 30 * 24 * 60 * 60 * 1000;\nconst ms12Months = 365 * 24 * 60 * 60 * 1000;\n\n// Track which month-year combinations we've kept\nconst keptMonths = new Set();\nconst toDelete = [];\n\n// Sort folders newest first for month-keeping logic\nconst sorted = [...folders].sort((a, b) => new Date(b.createdTime) - new Date(a.createdTime));\n\nfor (const folder of sorted) {\n  const created = new Date(folder.createdTime);\n  const ageMs = now - created;\n  const monthKey = `${created.getFullYear()}-${String(created.getMonth() + 1).padStart(2, '0')}`;\n\n  if (ageMs < ms30Days) {\n    // Keep all backups from last 30 days\n    continue;\n  } else if (ageMs < ms12Months) {\n    // Keep only first (newest) backup of each month\n    if (!keptMonths.has(monthKey)) {\n      keptMonths.add(monthKey);\n    } else {\n      toDelete.push(folder.id);\n    }\n  } else {\n    // Older than 12 months — delete\n    toDelete.push(folder.id);\n  }\n}\n\nreturn toDelete.map(id => ({ json: { folder_id: id } }));"
      }
    },

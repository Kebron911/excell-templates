{
  "name": "W17 — Weekly Backup",
  "nodes": [
    {
      "id": "w17-n01",
      "name": "Weekly Schedule",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [250, 300],
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 2 * * 0"
            }
          ]
        }
      }
    },
    {
      "id": "w17-n02",
      "name": "Generate Backup Metadata",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [500, 300],
      "parameters": {
        "jsCode": "const now = new Date();\nconst dateStr = now.toISOString().slice(0, 10);\nreturn [{ json: {\n  backup_date: dateStr,\n  backup_folder: `backup-${dateStr}`,\n  timestamp: now.toISOString(),\n  tables: ['Products', 'Customers', 'Orders', 'Content', 'Metrics', 'Errors']\n}}];"
      }
    },
    {
      "id": "w17-n03",
      "name": "Fetch Products",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [750, 200],
      "onError": "continueErrorOutput",
      "parameters": {
        "method": "GET",
        "url": "={{ 'https://api.airtable.com/v0/' + $env.AIRTABLE_BASE_ID + '/Products?pageSize=100' }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "={{ 'Bearer ' + $env.AIRTABLE_API_KEY }}" }
          ]
        }
      }
    },
    {
      "id": "w17-n04",
      "name": "Products to CSV",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1000, 200],
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst records = data.records || [];\nif (!records.length) return [{ json: { table: 'Products', csv: 'SKU,Name,Status,Tier\\n', row_count: 0 } }];\n\nconst fields = Object.keys(records[0].fields);\nconst header = fields.map(f => `\"${f.replace(/\"/g, '\"\"')}\"`).join(',');\nconst rows = records.map(r => fields.map(f => {\n  const v = r.fields[f];\n  if (v === null || v === undefined) return '';\n  if (Array.isArray(v)) return `\"${v.map(i => i.name || i.id || i).join(';').replace(/\"/g, '\"\"')}\"`;\n  return `\"${String(v).replace(/\"/g, '\"\"')}\"`;\n}).join(','));\n\nreturn [{ json: { table: 'Products', csv: [header, ...rows].join('\\n'), row_count: records.length } }];"
      }
    },
    {
      "id": "w17-n05",

        "method": "POST",
        "url": "={{ $env.N8N_BASE_URL + '/webhook/product-resync' }}",
        "sendBody": true,
        "contentType": "json",
        "body": "={{ JSON.stringify({ platform: 'is', product_record_id: $json.product_record_id, reason: 'w18-minor-drift', mismatches: $json.mismatches }) }}"
      }

    {
      "id": "w18-n15",
      "name": "Compare Gumroad Product",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1500, 400],
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst remote = response.product || response;\nconst local = $node['Split Gumroad Products'].json.fields;\nconst recordId = $node['Split Gumroad Products'].json.id;\n\nconst mismatches = [];\nlet severity = 'none';\n\nif ((remote.name || '').trim() !== (local['Name'] || '').trim()) {\n  mismatches.push({ field: 'name', local: local['Name'], remote: remote.name });\n  severity = 'major';\n}\n\nif ((remote.description || '').replace(/<[^>]+>/g, '').trim() !== (local['Description'] || '').trim()) {\n  mismatches.push({ field: 'description', local: (local['Description'] || '').slice(0, 100), remote: (remote.description || '').slice(0, 100) });\n  if (severity !== 'major') severity = 'minor';\n}\n\n// Gumroad price stored in cents\nconst localPriceCents = Math.round(parseFloat(local['Price (USD)'] || 0) * 100);\nconst remotePriceCents = parseInt(remote.price || 0);\nif (Math.abs(localPriceCents - remotePriceCents) > 1) {\n  mismatches.push({ field: 'price_cents', local: localPriceCents, remote: remotePriceCents });\n  if (severity !== 'major') severity = 'minor';\n}\n\n// Published flag\nif (local['Live on Gumroad'] === true && remote.published === false) {\n  mismatches.push({ field: 'published', local: true, remote: false });\n  severity = 'major';\n}\n\nreturn [{ json: {\n  platform: 'gumroad',\n  product_record_id: recordId,\n  product_sku: local['SKU'],\n  product_name: local['Name'],\n  has_mismatch: mismatches.length > 0,\n  severity,\n  mismatches,\n  mismatch_summary: mismatches.map(m => `${m.field}: local=${m.local} | remote=${m.remote}`).join(' || ')\n}}];"
      }
    },

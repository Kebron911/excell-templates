      "type": "n8n-nodes-base.airtable",
      "typeVersion": 2.1,
      "position": [1000, 800],
      "onError": "continueErrorOutput",
      "parameters": {
        "operation": "search",
        "base": { "__rl": true, "value": "BASE_ID_PLACEHOLDER", "mode": "id" },
        "table": { "__rl": true, "value": "TABLE_ID_ORDERS", "mode": "id" },
        "filterByFormula": "={{ \"AND({Platform} = 'is', IS_AFTER({Timestamp}, '\" + $node['Init Run Context'].json.prior_day_iso + \" 00:00:00'), IS_BEFORE({Timestamp}, '\" + $node['Init Run Context'].json.prior_day_iso + \" 23:59:59'))\" }}",
        "options": {}

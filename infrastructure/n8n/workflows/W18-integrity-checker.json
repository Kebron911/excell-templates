        "channel": { "__rl": true, "value": "#str-platform-alerts", "mode": "name" },
        "text": "={{ '⚠️ W18 MAJOR drift on IS product ' + $json.product_sku + ' (' + $json.product_name + ')\\nFields: ' + $json.mismatch_summary + '\\nHuman review required.' }}",
        "otherOptions": {}
      },
      "credentials": {
        "slackApi": { "id": "3", "name": "Slack account" }
      }
    },

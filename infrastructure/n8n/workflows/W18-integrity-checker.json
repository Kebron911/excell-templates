{
  "name": "W18 — Integrity Checker",
  "nodes": [
    {
      "id": "w18-n01",
      "name": "Daily 03:00 ET Schedule",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [250, 400],
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 3 * * *"
            }
          ]
        }
      }
    },
    {
      "id": "w18-n02",
      "name": "Init Run Context",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [500, 400],
      "parameters": {
        "jsCode": "const now = new Date();\nconst yesterday = new Date(now.getTime() - 24 * 60 * 60 * 1000);\nconst startOfYesterday = new Date(yesterday.getFullYear(), yesterday.getMonth(), yesterday.getDate(), 0, 0, 0);\nconst endOfYesterday = new Date(yesterday.getFullYear(), yesterday.getMonth(), yesterday.getDate(), 23, 59, 59);\nreturn [{ json: {\n  run_id: `w18-${now.toISOString().slice(0,10)}`,\n  run_started_at: now.toISOString(),\n  prior_day_iso: yesterday.toISOString().slice(0, 10),\n  prior_day_start_unix: Math.floor(startOfYesterday.getTime() / 1000),\n  prior_day_end_unix: Math.floor(endOfYesterday.getTime() / 1000),\n  mismatches_minor: 0,\n  mismatches_major: 0,\n  total_checks: 0\n}}];"
      }
    },
    {
      "id": "w18-n03",
      "name": "List IS-Live Products",
      "type": "n8n-nodes-base.airtable",
      "typeVersion": 2.1,
      "position": [750, 200],
      "onError": "continueErrorOutput",
      "parameters": {
        "operation": "search",
        "base": { "__rl": true, "value": "BASE_ID_PLACEHOLDER", "mode": "id" },
        "table": { "__rl": true, "value": "TABLE_ID_PRODUCTS", "mode": "id" },
        "filterByFormula": "={{ \"AND({Live on IS} = TRUE(), {IS product ID} != '')\" }}",
        "options": {}
      },
      "credentials": {
        "airtableTokenApi": { "id": "1", "name": "Airtable account" }
      }
    },
    {
      "id": "w18-n04",
      "name": "Split IS Products",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [1000, 200],
      "parameters": {
        "batchSize": 1,
        "options": {}
      }
    },
    {
      "id": "w18-n05",
      "name": "IS API Get Product",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1250, 200],
      "onError": "continueErrorOutput",
      "parameters": {
        "method": "GET",
        "url": "={{ $env.IS_API_BASE_URL + '/api/products/' + $json.fields['IS product ID'] }}",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "httpHeaderAuth",
        "options": {
          "timeout": 30000
        }
      },
      "credentials": {
        "httpHeaderAuth": { "id": "2", "name": "IS API Key" }
      }
    },
    {
      "id": "w18-n06",
      "name": "Compare IS Product",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1500, 200],
      "parameters": {
        "jsCode": "const crypto = require('crypto');\nconst remote = $input.first().json;\nconst local = $node['Split IS Products'].json.fields;\nconst recordId = $node['Split IS Products'].json.id;\n\nconst mismatches = [];\nlet severity = 'none';\n\n// Name check (major)\nif ((remote.name || '').trim() !== (local['Name'] || '').trim()) {\n  mismatches.push({ field: 'name', local: local['Name'], remote: remote.name });\n  severity = 'major';\n}\n\n// Description check (minor)\nif ((remote.description || '').trim() !== (local['Description'] || '').trim()) {\n  mismatches.push({ field: 'description', local: (local['Description'] || '').slice(0, 100), remote: (remote.description || '').slice(0, 100) });\n  if (severity !== 'major') severity = 'minor';\n}\n\n// Price check (minor — fixable via resync)\nconst localPrice = parseFloat(local['Price (USD)'] || 0);\nconst remotePrice = parseFloat(remote.price || 0);\nif (Math.abs(localPrice - remotePrice) > 0.01) {\n  mismatches.push({ field: 'price', local: localPrice, remote: remotePrice });\n  if (severity !== 'major') severity = 'minor';\n}\n\n// File hash check (major)\nconst localHash = local['File hash'] || '';\nconst remoteHash = remote.file_hash || (remote.file_url ? crypto.createHash('sha256').update(remote.file_url).digest('hex') : '');\nif (localHash && remoteHash && localHash !== remoteHash) {\n  mismatches.push({ field: 'file_hash', local: localHash, remote: remoteHash });\n  severity = 'major';\n}\n\nreturn [{ json: {\n  platform: 'is',\n  product_record_id: recordId,\n  product_sku: local['SKU'],\n  product_name: local['Name'],\n  has_mismatch: mismatches.length > 0,\n  severity,\n  mismatches,\n  mismatch_summary: mismatches.map(m => `${m.field}: local=${m.local} | remote=${m.remote}`).join(' || ')\n}}];"
      }
    },
    {
      "id": "w18-n07",
      "name": "IF IS Mismatch",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.2,
      "position": [1750, 200],
      "parameters": {
        "rules": {
          "values": [
            {
              "outputKey": "minor",
              "conditions": {
                "options": { "caseSensitive": true, "leftValue": "" },
                "conditions": [
                  {
                    "leftValue": "={{ $json.has_mismatch }}",
                    "rightValue": true,
                    "operator": { "type": "boolean", "operation": "equals" }
                  },
                  {
                    "leftValue": "={{ $json.severity }}",
                    "rightValue": "minor",
                    "operator": { "type": "string", "operation": "equals" }
                  }
                ],
                "combinator": "and"
              }
            },
            {
              "outputKey": "major",
              "conditions": {
                "options": { "caseSensitive": true, "leftValue": "" },
                "conditions": [
                  {
                    "leftValue": "={{ $json.has_mismatch }}",
                    "rightValue": true,
                    "operator": { "type": "boolean", "operation": "equals" }
                  },
                  {
                    "leftValue": "={{ $json.severity }}",
                    "rightValue": "major",
                    "operator": { "type": "string", "operation": "equals" }
                  }
                ],
                "combinator": "and"
              }
            }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "w18-n08",
      "name": "Log IS Drift to Errors",
      "type": "n8n-nodes-base.airtable",
      "typeVersion": 2.1,
      "position": [2000, 100],
      "onError": "continueErrorOutput",
      "parameters": {
        "operation": "create",
        "base": { "__rl": true, "value": "BASE_ID_PLACEHOLDER", "mode": "id" },
        "table": { "__rl": true, "value": "TABLE_ID_ERRORS", "mode": "id" },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "Timestamp": "={{ new Date().toISOString() }}",
            "Workflow": "W18-integrity-checker",
            "Node": "={{ 'IS drift on ' + $json.product_sku }}",
            "Error message": "={{ 'IS drift (' + $json.severity + '): ' + $json.mismatch_summary }}",
            "Payload": "={{ JSON.stringify($json).slice(0, 500) }}",
            "Status": "Open"
          },
          "schema": []
        }
      },
      "credentials": {
        "airtableTokenApi": { "id": "1", "name": "Airtable account" }
      }
    },
    {
      "id": "w18-n09",
      "name": "Trigger W06 Resync (Minor)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2250, 50],
      "onError": "continueErrorOutput",

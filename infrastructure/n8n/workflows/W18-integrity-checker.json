    {
      "id": "w18-n30",
      "name": "Reconcile Stripe vs Airtable",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1250, 800],
      "parameters": {
        "jsCode": "const stripeData = $node['Stripe Charges Prior Day'].json;\nconst airtableItems = $node['List Airtable IS Orders Prior Day'].all();\n\nconst stripeCount = (stripeData.data || []).filter(c => c.status === 'succeeded' && !c.refunded).length;\nconst airtableCount = airtableItems.length;\nconst delta = stripeCount - airtableCount;\nconst hasMismatch = Math.abs(delta) > 0;\n\nreturn [{ json: {\n  prior_day: $node['Init Run Context'].json.prior_day_iso,\n  stripe_count: stripeCount,\n  airtable_count: airtableCount,\n  delta,\n  has_mismatch: hasMismatch,\n  summary: `Stripe ${stripeCount} vs Airtable ${airtableCount} (delta ${delta})`\n}}];"
      }
    },
    {
      "id": "w18-n31",
      "name": "IF Stripe Mismatch",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.2,
      "position": [1500, 800],
      "parameters": {
        "rules": {
          "values": [
            {
              "outputKey": "mismatch",
              "conditions": {
                "options": { "caseSensitive": true, "leftValue": "" },
                "conditions": [
                  {
                    "leftValue": "={{ $json.has_mismatch }}",
                    "rightValue": true,
                    "operator": { "type": "boolean", "operation": "equals" }
                  }
                ],
                "combinator": "and"
              }
            }
          ]
        },
        "options": {}
      }
    },

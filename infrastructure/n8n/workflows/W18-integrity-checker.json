            "Workflow": "W18-integrity-checker",
            "Node": "Stripe vs Airtable reconciliation",
            "Error message": "={{ 'Stripe/Airtable order count mismatch on ' + $json.prior_day + ': ' + $json.summary }}",
            "Payload": "={{ JSON.stringify($json).slice(0, 500) }}",
            "Status": "Open"
          },
          "schema": []
        }

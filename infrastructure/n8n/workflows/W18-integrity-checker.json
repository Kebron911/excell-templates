    {
      "id": "w18-n24",
      "name": "Compare Contact Tags",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1500, 600],
      "parameters": {
        "jsCode": "const remote = $input.first().json;\nconst local = $node['Split Customers'].json.fields;\nconst recordId = $node['Split Customers'].json.id;\n\nconst remoteTags = (remote.tags || []).map(t => (t.name || t).toLowerCase()).sort();\n\n// Build expected tags from local purchase history\nconst purchasedSKUs = local['Purchased SKUs'] || [];\nconst expectedTags = new Set();\nfor (const sku of (Array.isArray(purchasedSKUs) ? purchasedSKUs : [purchasedSKUs])) {\n  if (sku) expectedTags.add('product:' + String(sku).toLowerCase());\n}\nexpectedTags.add('platform:is');\nif ((local['LTV (USD)'] || 0) >= 97) expectedTags.add('persona:sarah');\nelse if ((local['LTV (USD)'] || 0) > 0) expectedTags.add('persona:sam');\n\nconst expectedArr = [...expectedTags].sort();\nconst missing = expectedArr.filter(t => !remoteTags.includes(t));\nconst extra = remoteTags.filter(t => t.startsWith('product:') && !expectedArr.includes(t));\n\nconst hasMismatch = missing.length > 0 || extra.length > 0;\n\nreturn [{ json: {\n  customer_record_id: recordId,\n  email: local['Email'],\n  has_mismatch: hasMismatch,\n  missing_tags: missing,\n  extra_tags: extra,\n  mismatch_summary: hasMismatch ? `missing=[${missing.join(',')}] extra=[${extra.join(',')}]` : 'ok'\n}}];"
      }
    },
    {
      "id": "w18-n25",
      "name": "IF Contact Mismatch",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.2,
      "position": [1750, 600],
      "parameters": {
        "rules": {
          "values": [
            {
              "outputKey": "mismatch",
              "conditions": {

                      "id":  "node-get-tokens",
                      "name":  "Get Etsy tokens",
                      "type":  "n8n-nodes-base.executeWorkflow",
                      "typeVersion":  1.2,
                      "position":  [
                                       460,
                                       300
                                   ]
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "// Receipt poll window. Consumes W31 - Etsy Token Manager output:\n//   { Authorization, \"x-api-key\", access_token, shop_id, expires_at, refreshed }\n// Passes auth headers through verbatim; downstream Etsy node uses them as-is.\n\nconst sd = $getWorkflowStaticData(\u0027global\u0027);\nconst nowSec = Math.floor(Date.now() / 1000);\nconst defaultBackfillSec = 24 * 60 * 60;\nconst lastPollSec = sd.last_poll_sec || (nowSec - defaultBackfillSec);\n\nconst tokens = $input.first().json;\nif (!tokens.access_token) throw new Error(\u0027W31 returned no access_token\u0027);\nif (!tokens.shop_id) throw new Error(\u0027W31 returned no shop_id\u0027);\nif (!tokens.Authorization) throw new Error(\u0027W31 returned no Authorization header\u0027);\nif (!tokens[\u0027x-api-key\u0027]) throw new Error(\u0027W31 returned no x-api-key header\u0027);\n\nreturn [{\n  json: {\n    authorization:   tokens.Authorization,\n    x_api_key:       tokens[\u0027x-api-key\u0027],\n    shop_id:         tokens.shop_id,\n    min_created_sec: lastPollSec,\n    now_sec:         nowSec,\n  },\n}];"
                                     },
                      "id":  "node-window",
                      "name":  "Compute poll window",
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       680,
                                       300
                                   ]
                  },
                  {
                      "parameters":  {
                                         "method":  "GET",
                                         "url":  "=https://openapi.etsy.com/v3/application/shops/{{ $json.shop_id }}/receipts",
                                         "sendQuery":  true,
                                         "queryParameters":  {
                                                                 "parameters":  [
                                                                                    {
                                                                                        "name":  "min_created",
                                                                                        "value":  "={{ $json.min_created_sec }}"
                                                                                    },
                                                                                    {
                                                                                        "name":  "was_paid",
                                                                                        "value":  "true"
                                                                                    },
                                                                                    {
                                                                                        "name":  "limit",
                                                                                        "value":  "100"
                                                                                    }
                                                                                ]
                                                             },
                                         "sendHeaders":  true,
                                         "headerParameters":  {
                                                                  "parameters":  [
                                                                                     {
                                                                                         "value":  "={{ $json.authorization }}",
                                                                                         "name":  "Authorization"
                                                                                     },
                                                                                     {
                                                                                         "value":  "={{ $json.x_api_key }}",
                                                                                         "name":  "x-api-key"
                                                                                     }
                                                                                 ]
                                                              },
                                         "options":  {
                                                         "timeout":  20000
                                                     }
                                     },
                      "id":  "node-fetch-receipts",
                      "name":  "Etsy GET /receipts",
                      "type":  "n8n-nodes-base.httpRequest",
                      "typeVersion":  4.2,
                      "position":  [
                                       900,
                                       300
                                   ]
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "// Flatten Etsy receipts payload into individual buyer-tagging items.\n// Etsy receipt shape (v3):\n//   {\n//     receipt_id, buyer_email, buyer_user_id, name,\n//     transactions: [ { listing_id, sku, product_id, quantity, ... } ],\n//     ...\n//   }\n//\n// We emit one item per RECEIPT (not per transaction); the SKUs are passed as an array\n// for the inner per-SKU loop downstream.\n\nconst resp = $input.first().json;\nconst receipts = (resp.results || []).filter((r) =\u003e r.buyer_email);\n\nif (receipts.length === 0) {\n  return [];  // Nothing to do - next node won\u0027t fire, but staticData update below still needs to run.\n}\n\nreturn receipts.map((r) =\u003e {\n  const skus = (r.transactions || [])\n    .map((t) =\u003e t.sku || (t.product_data \u0026\u0026 t.product_data.sku) || String(t.listing_id))\n    .filter(Boolean);\n  return {\n    json: {\n      email: r.buyer_email,\n      buyer_name: r.name || null,\n      receipt_id: r.receipt_id,\n      skus,\n      grandtotal_amount: r.grandtotal \u0026\u0026 r.grandtotal.amount,\n      grandtotal_currency: r.grandtotal \u0026\u0026 r.grandtotal.currency_code,\n      created_at: r.create_timestamp ? new Date(r.create_timestamp * 1000).toISOString() : null,\n    },\n  };\n});\n"
                                     },

                                         "jsCode":  "// Persist the new last_poll_sec so the next run only picks up receipts AFTER this run.\n// Runs once at end of workflow (no split-batches context).\n\nconst sd = $getWorkflowStaticData(\u0027global\u0027);\nsd.last_poll_sec = Math.floor(Date.now() / 1000);\nsd.last_run_at = new Date().toISOString();\n\nreturn [{ json: { last_poll_sec: sd.last_poll_sec, last_run_at: sd.last_run_at } }];\n"
                                     },

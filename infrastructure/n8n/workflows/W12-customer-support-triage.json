      "name": "Sales Inquiry to SupportDrafts",
      "type": "n8n-nodes-base.airtable",
      "typeVersion": 2.1,
      "position": [1550, 720],
      "onError": "continueErrorOutput",
      "parameters": {
        "operation": "create",
        "base": { "__rl": true, "value": "BASE_ID_PLACEHOLDER", "mode": "id" },
        "table": { "__rl": true, "value": "TABLE_ID_SUPPORT_DRAFTS", "mode": "id" },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "Message ID": "={{ $json.message_id }}",
            "Received at": "={{ $json.received_at }}",
            "From email": "={{ $json.from_email }}",
            "From name": "={{ $json.from_name }}",
            "Subject": "={{ $json.subject }}",
            "Body": "={{ $json.body }}",

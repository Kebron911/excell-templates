      }
    },
    {
      "id": "w12-n12",
      "name": "Refund Platform Switch",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.2,
      "position": [2200, 240],
      "parameters": {
        "rules": {
          "values": [
            {
              "outputKey": "is",
              "conditions": {
                "options": { "caseSensitive": true, "leftValue": "" },
                "conditions": [
                  { "leftValue": "={{ $json.platform }}", "rightValue": "is", "operator": { "type": "string", "operation": "equals" } }
                ],
                "combinator": "and"
              }
            },
            {
              "outputKey": "gumroad",
              "conditions": {
                "options": { "caseSensitive": true, "leftValue": "" },
                "conditions": [
                  { "leftValue": "={{ $json.platform }}", "rightValue": "gumroad", "operator": { "type": "string", "operation": "equals" } }
                ],
                "combinator": "and"
              }
            }
          ]
        },
        "options": {}
      }
    },
    {

                  {
                      "parameters":  {
                                         "jsCode":  "const sd = $getWorkflowStaticData(\u0027global\u0027);\nconst resp = $input.first().json;\n\nif (!resp.access_token || !resp.refresh_token) {\n  throw new Error(\u0027Refresh response missing tokens: \u0027 + JSON.stringify(resp).slice(0, 200));\n}\n\nsd.access_token  = String(resp.access_token);\nsd.refresh_token = String(resp.refresh_token);\nsd.expires_at    = Date.now() + (Number(resp.expires_in || 3600) - 60) * 1000;\nsd.last_refresh  = new Date().toISOString();\n\nreturn [{\n  json: {\n    refreshed: true,\n    access_token: sd.access_token,\n    keystring: sd.keystring,\n    shared_secret: sd.shared_secret,\n    shop_id: sd.shop_id,\n    expires_at: sd.expires_at,\n    expires_at_iso: new Date(sd.expires_at).toISOString(),\n  }\n}];"
                                     },

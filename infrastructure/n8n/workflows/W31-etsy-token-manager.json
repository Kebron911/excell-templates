                  {
                      "parameters":  {
                                         "jsCode":  "// Etsy Token Manager - single source of truth for current access_token + shop_id.\n// State lives in workflow static data ($getWorkflowStaticData(\u0027global\u0027))\n// which n8n persists across workflow runs.\n\nconst sd = $getWorkflowStaticData(\u0027global\u0027);\nconst input = $input.first()?.json || {};\n\n// One-time init from Manual Trigger input\nif (input.init_refresh_token) {\n  sd.refresh_token = String(input.init_refresh_token).trim();\n  sd.keystring     = String(input.init_keystring || \u0027\u0027).trim();\n  sd.shared_secret = String(input.init_shared_secret || \u0027\u0027).trim();\n  sd.expires_at    = 0;\n  console.log(\u0027Initialized static data from input\u0027);\n}\n\n// shop_id sourced from env (preferred) or literal fallback. Single-shop instance.\nif (!sd.shop_id) {\n  sd.shop_id = String($env.ETSY_SHOP_ID || \u002765957104\u0027);\n}\n\nif (!sd.refresh_token || !sd.keystring || !sd.shared_secret) {\n  throw new Error(\u0027Token manager not initialized. Run the Manual Trigger with { init_refresh_token, init_keystring, init_shared_secret } in the input first.\u0027);\n}\n\nconst now = Date.now();\nconst expiresAt = Number(sd.expires_at) || 0;\nconst BUFFER_MS = 5 * 60 * 1000;\nconst needsRefresh = (expiresAt - now) \u003c BUFFER_MS;\n\nreturn [{\n  json: {\n    needs_refresh: needsRefresh,\n    refresh_token: sd.refresh_token,\n    keystring: sd.keystring,\n    shared_secret: sd.shared_secret,\n    shop_id: sd.shop_id,\n    current_access_token: sd.access_token || null,\n    current_expires_at: expiresAt,\n    now,\n  }\n}];"
                                     },

# strguests.tools — environment variables
# Copy to .env (Astro/static) and .env.local (server) and fill in.

# ---- MySQL (server only) -----------------------------------------------------
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=strguests

# ---- OpenAI (server only) — required from Phase 3 onward ---------------------
# claude-haiku-4-5 is currently the cheapest path for the AI generators; OpenAI
# GPT-4o-mini is the fallback. Either way the key lives only on the server.
OPENAI_API_KEY=

# ---- Server secrets ----------------------------------------------------------
# Used to sign HMAC tokens emailed for email-verify. 32+ random bytes recommended.
EMAIL_VERIFY_SECRET=
# Mixed into sha256(IP) so we never store raw IPs in rate_limits.
IP_HASH_SALT=

# ---- Public client envs (Astro reads PUBLIC_* at build time) -----------------
# ESP webhook the EmailCaptureCard + PdfDownloadButton modal post into.
PUBLIC_ESP_WEBHOOK=
# Base URL for the API server (e.g. https://strguests.tools). Empty = same origin.
PUBLIC_API_BASE=
# Set to "true" once AdSense is approved.
PUBLIC_ADSENSE_ENABLED=false
PUBLIC_ADSENSE_CLIENT=
# GA4 measurement ID; empty disables GA4 entirely.
PUBLIC_GA4_ID=

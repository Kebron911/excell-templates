# strhost.tools — Apache/LiteSpeed config shipped with every deploy.
#
# Goals:
# 1. Don't cache HTML aggressively (so new posts/pages don't 404 from
#    LSCache after a deploy — see DEPLOY.md "LiteSpeed cache" section).
# 2. Cache static assets (CSS/JS/images/fonts) for a year — they have
#    content hashes in their filenames, so the URL changes when the file
#    changes; safe to cache forever.
# 3. Send a clean 404 page when something genuinely doesn't exist.

# ---------- Cache headers ----------

<IfModule mod_headers.c>
  # HTML — short cache, must revalidate so we never serve a stale page
  # for routes that have moved or been added (the /blog 404 incident).
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "public, max-age=300, must-revalidate"
  </FilesMatch>

  # Sitemaps + robots — short cache so search engines see updates fast.
  <FilesMatch "\.(xml|txt)$">
    Header set Cache-Control "public, max-age=600"
  </FilesMatch>

  # Hashed asset bundles in /_assets — content-addressed, cache forever.
  <FilesMatch "\.(css|js|woff2|woff|ttf|eot|png|jpg|jpeg|gif|svg|webp|avif|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

# ---------- LiteSpeed cache hints ----------
# Mirror the above for LSCache so Hostinger's edge respects the same TTLs.

<IfModule LiteSpeed>
  CacheLookup public on
  RewriteEngine On
  # Never cache HTML at the edge — origin serves it fast enough and
  # post-deploy stale-content is the bigger risk than re-fetching.
  RewriteRule \.(html|htm)$ - [E=Cache-Control:no-cache]
</IfModule>

# ---------- Compression ----------

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml application/rss+xml image/svg+xml
</IfModule>

# ---------- Pretty URLs ----------
# Astro emits /<route>/index.html. Apache directory-index handles this for
# requests with trailing slash. Add a rewrite so /blog → /blog/ etc., and
# the canonical URL stays consistent across crawlers.

<IfModule mod_rewrite.c>
  RewriteEngine On
  # Don't rewrite real files or real directories.
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  # Append trailing slash if missing AND a directory exists at that path.
  RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI}/ -d
  RewriteRule ^(.*)$ /$1/ [R=301,L]
</IfModule>

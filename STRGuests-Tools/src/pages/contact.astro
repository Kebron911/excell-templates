---
import Layout from '@/components/AppLayout.astro';
import ClusterFunnelBlock from '@str/ui-funnel/ClusterFunnelBlock.astro';
import { siteConfig } from '@/data/site.config';
---
<Layout
  siteConfig={siteConfig}
  title="Contact â€” strguests.tools"
  description="Bug reports, feature requests, and partnership inquiries for strguests.tools. We read every message."
  path="/contact"
>
  <article class="mx-auto max-w-3xl px-5 py-12 prose">
    <header>
      <p class="label text-[color:var(--accent-700)]">Contact</p>
      <h1 class="mt-2 font-serif text-h1 text-navy">
        hello@strguests.tools<span class="period-accent">.</span>
      </h1>
      <p class="mt-3 text-lead text-ink-2 max-w-2xl leading-snug">
        Bug reports, feature requests, partnership inquiries â€” we read every
        message. We don't promise instant replies, but we promise a real one.
      </p>
    </header>

    <section class="mt-9">
      <h2 class="font-serif text-h2 text-navy">Best ways to reach us</h2>
      <dl class="mt-4 space-y-5">
        <div>
          <dt class="font-serif text-h3 text-navy">Bug reports</dt>
          <dd class="mt-1 text-body text-graphite leading-relaxed">
            Email <a href="mailto:hello@strguests.tools?subject=Bug+report" class="text-[color:var(--accent-700)]">hello@strguests.tools</a>
            with the page URL, your browser + OS, and the steps to reproduce.
            We typically fix high-impact bugs within a week.
          </dd>
        </div>
        <div>
          <dt class="font-serif text-h3 text-navy">Generator requests</dt>
          <dd class="mt-1 text-body text-graphite leading-relaxed">
            New PDF or AI tool you'd like? Email
            <a href="mailto:hello@strguests.tools?subject=Generator+request" class="text-[color:var(--accent-700)]">hello@strguests.tools</a>
            with the host scenario you'd want it for. We collect requests and
            ship the highest-demand ones quarterly.
          </dd>
        </div>
        <div>
          <dt class="font-serif text-h3 text-navy">Template suggestions</dt>
          <dd class="mt-1 text-body text-graphite leading-relaxed">
            We add 5â€“10 new templates per month. If there's a guest scenario
            we don't cover, send us the situation + the message you actually
            sent. Good submissions get credited in the template's MDX
            narrative.
          </dd>
        </div>
        <div>
          <dt class="font-serif text-h3 text-navy">Press / partnerships</dt>
          <dd class="mt-1 text-body text-graphite leading-relaxed">
            For press inquiries or partnership pitches, email
            <a href="mailto:hello@strguests.tools?subject=Press+inquiry" class="text-[color:var(--accent-700)]">hello@strguests.tools</a>.
          </dd>
        </div>
      </dl>
    </section>

    <section class="mt-9">
      <h2 class="font-serif text-h2 text-navy">What we don't take</h2>
      <ul class="mt-4 space-y-3 text-body text-graphite leading-relaxed">
        <li><strong class="text-navy">Affiliate pitches.</strong> We have a small set of partner programs already; cold pitches won't get a reply.</li>
        <li><strong class="text-navy">"Sponsored content."</strong> The generators are free; we don't run sponsored copy.</li>
        <li><strong class="text-navy">Guest-blog requests.</strong> Site is generator-first. Maybe in the future.</li>
      </ul>
    </section>
  </article>

  <ClusterFunnelBlock siteConfig={siteConfig} currentCluster="guest-xp" />
</Layout>

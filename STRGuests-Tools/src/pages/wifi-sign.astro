---
import Layout from '@/components/chrome/Layout.astro';
import Sidebar from '@/components/chrome/Sidebar.astro';
import AdSlot from '@/components/ads/AdSlot.astro';
import EmailCaptureCard from '@/components/funnel/EmailCaptureCard.astro';
import STRLedgerCTA from '@/components/funnel/STRLedgerCTA.astro';
import RelatedPosts from '@/components/funnel/RelatedPosts.astro';
import PdfDownloadButton from '@/components/generator/PdfDownloadButton.astro';
import PinterestPinButton from '@/components/generator/PinterestPinButton.astro';
import ClusterFunnelBlock from '@/components/chrome/ClusterFunnelBlock.astro';
import WifiSignGenerator from '@/components/generators/WifiSignGenerator.tsx';
import { buildWebApplication, buildFAQPage } from '@/lib/seo';
import tools from '@/data/tools.json';

const tool = tools['wifi-sign'];
const path = tool.path;

const webApp = buildWebApplication({
  name: tool.name,
  description: tool.tagline,
  toolPath: path,
});
const faq = buildFAQPage([
  {
    question: 'What QR format does the sign use?',
    answer: 'Standard WIFI:T:WPA;S:...;P:...;; — recognized by iOS 11+, Android 10+, and modern Linux/macOS camera apps.',
  },
  {
    question: 'Does it work for hidden networks?',
    answer: 'The underlying QR generator supports the hidden flag; the form does not yet expose it. Contact us if you need it.',
  },
  {
    question: 'Why is the QR navy instead of black?',
    answer: 'Brand consistency. Navy reads as cleanly as black on parchment-tinted paper and matches the rest of the strguests cluster.',
  },
  {
    question: 'Can I print on cardstock?',
    answer: 'Yes — recommended. 80–110 lb cardstock holds up to kitchen splashes; standard printer paper warps near sinks.',
  },
]);
---
<Layout
  title={`${tool.name} — strguests.tools`}
  description={tool.tagline}
  path={path}
  jsonLd={[webApp, faq]}
>
  <article class="generator-page mx-auto max-w-6xl px-5 py-8">
    <header>
      <p class="label text-[color:var(--accent-700)]">Free generator · No signup</p>
      <h1 class="mt-2 font-serif text-h1 text-navy">
        Wi-Fi Sign Generator<span class="period-accent">.</span>
      </h1>
      <p class="mt-3 text-lead text-ink-2 max-w-2xl leading-snug">
        {tool.tagline} Three template designs. Standard WIFI-QR format that works
        on every modern smartphone OS.
      </p>
    </header>

    <section class="mt-7">
      <WifiSignGenerator client:visible />
    </section>

    <div class="mt-5 flex flex-wrap gap-3">
      <PdfDownloadButton
        toolSlug="wifi-sign"
        filename="wifi-sign"
        magnet="wifi-sign"
        label="Download PDF"
      />
      <PinterestPinButton toolSlug="wifi-sign" description="Free Airbnb wifi sign template — printable QR + credentials" />
    </div>

    <AdSlot location="in-content" />

    <section class="mt-9 prose">
      <h2 class="font-serif text-h2 text-navy">The first thing every guest does</h2>
      <p class="mt-3 text-body text-graphite leading-relaxed">
        Connects to the wifi. A printed sign with a QR code is the difference between
        "let me find the password" and "we're online." Most modern phones scan the
        QR straight from the camera app and connect on tap — no app, no typing.
      </p>
    </section>

    <section class="mt-9">
      <h2 class="font-serif text-h2 text-navy">How to use the printable</h2>
      <ul class="mt-4 space-y-3 text-body text-graphite leading-relaxed">
        <li><strong class="text-navy">Frame it.</strong> A 5x7 frame on the kitchen counter beats a Sharpie note every time.</li>
        <li><strong class="text-navy">Print on cardstock.</strong> Standard paper warps near sinks; 80–110 lb cardstock holds up.</li>
        <li><strong class="text-navy">Test the QR before printing.</strong> Open the PDF on one phone, scan with another, confirm it joins.</li>
        <li><strong class="text-navy">Re-print after every password rotation.</strong> Best practice: rotate annually and after any incident.</li>
      </ul>
    </section>

    <RelatedPosts toolKey="wifi-sign" />

    <EmailCaptureCard
      magnet="wifi-sign"
      toolSlug="wifi-sign"
      headline="Get the printable Cluster Pack"
      blurb="One email gets you a bundle: house rules, welcome book, wifi sign, and check-in instructions templates — all editable, all branded to your property."
      cta="Email me the cluster pack"
    />

    <section class="mt-9">
      <h2 class="font-serif text-h2 text-navy">Frequently asked</h2>
      <dl class="mt-4 space-y-5">
        <div>
          <dt class="font-serif text-h3 text-navy">What QR format?</dt>
          <dd class="mt-1 text-body text-graphite leading-relaxed">
            Standard <code>WIFI:T:WPA;S:...;P:...;;</code> — recognized by iOS 11+, Android 10+, and modern macOS/Linux camera apps.
          </dd>
        </div>
        <div>
          <dt class="font-serif text-h3 text-navy">Does it support hidden networks?</dt>
          <dd class="mt-1 text-body text-graphite leading-relaxed">
            The QR generator supports the hidden flag; the form doesn't expose it yet.
          </dd>
        </div>
        <div>
          <dt class="font-serif text-h3 text-navy">Why is the QR navy?</dt>
          <dd class="mt-1 text-body text-graphite leading-relaxed">
            Brand consistency. Navy reads cleanly on parchment paper and matches the cluster.
          </dd>
        </div>
      </dl>
    </section>

    <STRLedgerCTA tool="wifi-sign" />

    <AdSlot location="footer" />

    <Sidebar current="wifi-sign" />
  </article>

  <ClusterFunnelBlock currentCluster="guest-xp" />
</Layout>

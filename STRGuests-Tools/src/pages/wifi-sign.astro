---
import Layout from '@/components/chrome/Layout.astro';
import Sidebar from '@/components/chrome/Sidebar.astro';
import ClusterFunnelBlock from '@/components/chrome/ClusterFunnelBlock.astro';
import AdSlot from '@/components/ads/AdSlot.astro';
import EmailCaptureCard from '@/components/funnel/EmailCaptureCard.astro';
import STRLedgerCTA from '@/components/funnel/STRLedgerCTA.astro';
import PdfDownloadButton from '@/components/generator/PdfDownloadButton.astro';
import PinterestPinButton from '@/components/generator/PinterestPinButton.astro';
import WifiSignForm from '@/components/generator/WifiSignForm.tsx';
import { Content as ToolCopy } from '@/content/tools/wifi-sign.mdx';
import { buildWebApplication, buildFAQPage } from '@/lib/seo';
import tools from '@/data/tools.json';

const tool = tools['wifi-sign'];

const faqs = [
  {
    question: 'Does this generator produce a QR code?',
    answer:
      'Not in v1. QR support is on the roadmap. The PDF is plain text — works universally, no app required.',
  },
  {
    question: 'Can I print this on cardstock?',
    answer:
      'Yes. The single-page Letter design prints cleanly on most home printer cardstocks. For a glossy finish, take the PDF to a local print shop — usually under $5.',
  },
  {
    question: 'Will my Wi-Fi password be saved or transmitted?',
    answer:
      'No. Generation is client-side only. The PDF is built in your browser; nothing is uploaded.',
  },
  {
    question: 'Can I customize the colors?',
    answer:
      'Not in v1. The three templates lock to our hospitality-warm palette. Custom branding arrives with the v2 welcome book editor.',
  },
];

const jsonLd = [
  buildWebApplication({
    name: 'Airbnb Wi-Fi Sign Generator',
    description:
      'Free Airbnb Wi-Fi sign generator. Three frame-ready printable templates with your SSID and password.',
    toolPath: tool.path,
  }),
  buildFAQPage(faqs),
];
---

<Layout
  title="Airbnb Wi-Fi Sign Generator — strguests.tools"
  description="Free Airbnb Wi-Fi sign generator. Frame-ready printable PDF with your SSID and password. Three design templates. Built in your browser."
  path="/wifi-sign"
  jsonLd={jsonLd}
>
  <article class="generator-page bg-parchment">
    <div class="mx-auto max-w-6xl px-5 pt-9 pb-7 grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-9">
      <div class="min-w-0">
        <header>
          <h1 class="text-h1 font-serif text-navy leading-tight">
            Airbnb Wi-Fi Sign Generator<span class="period-gold">.</span>
          </h1>
          <p class="mt-3 text-lead text-ink-2 max-w-2xl">
            Frame-ready printable Wi-Fi card. Three designs to match your property. Built in your browser.
          </p>
        </header>

        <div class="mt-7">
          <WifiSignForm client:load />
        </div>

        <div class="flex flex-wrap gap-3 items-center">
          <PdfDownloadButton
            toolSlug="wifi-sign"
            filename="wifi-sign"
            magnet="wifi-sign-pdf"
          />
          <PinterestPinButton
            toolSlug="wifi-sign"
            description="Free Airbnb Wi-Fi sign generator. Frame-ready printable PDF, three design templates. No signup. strguests.tools"
          />
        </div>

        <AdSlot location="in-content" />

        <div class="prose mt-7 max-w-2xl">
          <ToolCopy />
        </div>

        <EmailCaptureCard
          magnet="strguests-newsletter"
          toolSlug="wifi-sign"
        />

        <STRLedgerCTA tool="wifi-sign" />

        <AdSlot location="footer" />
      </div>

      <Sidebar current="wifi-sign" />
    </div>

    <ClusterFunnelBlock currentCluster="guest-xp" />
  </article>
</Layout>

<style>
  .prose :global(h2) { font-family: var(--font-display); font-size: var(--t-h2-size); color: var(--brand-navy); margin-top: 1.6rem; margin-bottom: 0.6rem; }
  .prose :global(h3) { font-family: var(--font-display); color: var(--brand-navy); margin-top: 1.2rem; margin-bottom: 0.4rem; font-size: var(--t-h3-size); }
  .prose :global(p) { margin-bottom: 0.9rem; line-height: 1.65; color: var(--ink-2); }
</style>

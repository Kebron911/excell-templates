---
import Layout from '@/components/chrome/Layout.astro';
import EmailCaptureCard from '@/components/funnel/EmailCaptureCard.astro';
import STRLedgerCTA from '@/components/funnel/STRLedgerCTA.astro';
import RelatedPosts from '@/components/funnel/RelatedPosts.astro';
import ClusterFunnelBlock from '@/components/chrome/ClusterFunnelBlock.astro';
import tools from '@/data/tools.json';

const tool = tools['guest-messages'];
const path = tool.path;
---
<Layout
  title="Airbnb Guest Message Generator — Free AI Tool · strguests.tools"
  description="Booking confirmation, pre-arrival, mid-stay, and post-checkout messages — AI-customized for your property and tone. Coming when the serverless layer ships."
  path={path}
>
  <article class="generator-page mx-auto max-w-3xl px-5 py-12">
    <header>
      <p class="label text-[color:var(--accent-700)]">AI generator · Coming soon</p>
      <h1 class="mt-2 font-serif text-h1 text-navy">
        Guest Message Generator<span class="period-accent">.</span>
      </h1>
      <p class="mt-3 text-lead text-ink-2 max-w-2xl leading-snug">
        Booking confirmation, pre-arrival, mid-stay, check-out, post-checkout —
        AI-customized from the 26 hand-written templates in our library, in
        your property's voice. Coming when the serverless layer ships.
      </p>
      <p class="mt-3 text-body text-ink-2 leading-snug">
        Until then, browse the
        <a href="/templates/" class="text-[color:var(--accent-700)] hover:underline">26 hand-written templates</a>
        directly — searchable, filterable, with example inputs and outputs.
      </p>
    </header>

    <section class="mt-8 rounded-md surface-gen p-6">
      <p class="label text-[color:var(--accent-700)]">What it will do</p>
      <ul class="mt-3 space-y-2 text-body text-graphite leading-relaxed list-disc pl-5">
        <li>Pick a scenario (late-checkout, noise complaint, cancellation, etc.) — 26 scenarios in the library.</li>
        <li>Customizes the template with your property name, host name, and tone.</li>
        <li>Tone toggles: warm, professional, brief, apologetic.</li>
        <li>Rate-limited — 5/hour without email, 50/day verified.</li>
      </ul>
    </section>

    <section class="mt-9">
      <EmailCaptureCard
        magnet="message-template-bundle"
        toolSlug="guest-messages"
        headline="Email me when the message generator ships"
        blurb="One email when the AI generator goes live. You'll also get the editable bundle of all 26 templates — same list, no spam."
        cta="Email me when it ships"
      />
    </section>

    <RelatedPosts toolKey="guest-messages" />

    <STRLedgerCTA tool="guest-messages" />
  </article>

  <ClusterFunnelBlock currentCluster="guest-xp" />
</Layout>

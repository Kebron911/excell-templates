---
import Layout from '@/components/AppLayout.astro';
import Sidebar from '@str/ui-chrome/AppSidebar.astro';
import { sidebarItems } from '@/data/sidebar-items';
import AdSlot from '@str/ui-funnel/AdSlot.astro';
import EmailCaptureCard from '@str/ui-funnel/EmailCaptureCard.astro';
import STRLedgerCTA from '@str/ui-funnel/STRLedgerCTA.astro';
import RelatedPosts from '@/components/funnel/RelatedPosts.astro';
import ClusterFunnelBlock from '@str/ui-funnel/ClusterFunnelBlock.astro';
import AiRateLimitNotice from '@/components/generator/AiRateLimitNotice.astro';
import GuestMessageGenerator from '@/components/generators/GuestMessageGenerator.tsx';
import { buildWebApplication, buildFAQPage } from '@str/seo';
import { siteConfig } from '@/data/site.config';
import tools from '@/data/tools.json';

const tool = tools['guest-messages'];
const path = tool.path;

const webApp = buildWebApplication(siteConfig, { name: tool.name, description: tool.tagline, toolPath: path });
const faq = buildFAQPage([
  {
    question: 'Why are there {{guestFirstName}} placeholders in the output?',
    answer: 'They\'re Mustache-style placeholders the host swaps when pasting into Airbnb / VRBO. Same convention as our 26 starter templates at /templates — lets you reuse the message across multiple bookings without re-editing.',
  },
  {
    question: 'Does it match the four-moment cadence (booking, pre-arrival, mid-stay, post-checkout)?',
    answer: 'Yes — those are the stage toggles. The pre-arrival stage assumes a 2–3 day lead time; mid-stay assumes day 2 of the booking. Tweak the context field if your cadence differs.',
  },
  {
    question: 'Can I use this for scenario messages like late checkout requests or refund replies?',
    answer: 'For the four core moments, this generator is faster. For scenario edge cases (late checkout, noise complaint, broken item, refund request), use the scenario library at /templates — those are hand-curated.',
  },
]);
---
<Layout
  siteConfig={siteConfig}
  title={`${tool.name} — strguests.tools`}
  description={tool.tagline}
  path={path}
  jsonLd={[webApp, faq]}
>
  <article class="generator-page mx-auto max-w-6xl px-5 py-8">
    <header>
      <p class="label text-[color:var(--accent-700)]">AI generator · gpt-4o-mini</p>
      <h1 class="mt-2 font-serif text-h1 text-navy">
        Guest Message Templates<span class="period-accent">.</span>
      </h1>
      <p class="mt-3 text-lead text-ink-2 max-w-2xl leading-snug">
        {tool.tagline} Under 120 words, with placeholder names you can swap per booking.
      </p>
    
    </header>

    <AiRateLimitNotice toolSlug="guest-messages" />

    <section class="mt-7">
      <GuestMessageGenerator client:load />
    </section>

    <AdSlot siteConfig={siteConfig} location="in-content" />

    <section class="mt-9 prose">
      <h2 class="font-serif text-h2 text-navy">Why the four-moment cadence works</h2>
      <p class="mt-3 text-body text-graphite leading-relaxed">
        Booking confirmation, pre-arrival, mid-stay, post-checkout — four moments where a single short message dramatically lifts review scores without crossing into "over-communicating." See <a href="/blog/guest-message-cadence-pre-arrival-to-checkout">the cadence essay</a> for the timing rationale.
      </p>
    </section>

    <RelatedPosts toolKey="guest-messages" />

    <EmailCaptureCard
      siteConfig={siteConfig}
      magnet="guest-messages"
      toolSlug="guest-messages"
      headline="Manage multiple properties?"
      blurb="Verify your email for 50 generations/day instead of 5/hour. Speeds up the booking-confirmation flow across a portfolio."
      cta="Send the verify link"
    />

    <STRLedgerCTA siteConfig={siteConfig} tool="guest-messages" />

    <AdSlot siteConfig={siteConfig} location="footer" />

    <Sidebar siteConfig={siteConfig} items={sidebarItems} current="guest-messages" />
  </article>

  <ClusterFunnelBlock siteConfig={siteConfig} currentCluster="guest-xp" />
</Layout>

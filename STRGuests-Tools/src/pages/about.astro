---
import Layout from '@/components/chrome/Layout.astro';
import ClusterFunnelBlock from '@/components/chrome/ClusterFunnelBlock.astro';
import STRLedgerCTA from '@/components/funnel/STRLedgerCTA.astro';
---
<Layout
  title="About — strguests.tools"
  description="strguests.tools is a free generator + template library for short-term rental hosts who want to delight their guests. Built by the team behind The STR Ledger."
  path="/about"
>
  <article class="mx-auto max-w-3xl px-5 py-12 prose">
    <header>
      <p class="label text-[color:var(--accent-700)]">About</p>
      <h1 class="mt-2 font-serif text-h1 text-navy">
        Free generators. No upsell<span class="period-accent">.</span>
      </h1>
      <p class="mt-3 text-lead text-ink-2 max-w-2xl leading-snug">
        strguests.tools is a small free-tools site for short-term rental hosts.
        Four PDF generators, three AI generators, and a hand-written message
        template library. No signup, no popups.
      </p>
    </header>

    <section class="mt-9">
      <h2 class="font-serif text-h2 text-navy">Who builds this</h2>
      <p class="mt-3 text-body text-graphite leading-relaxed">
        strguests.tools is built by the team behind <a href="https://thestrledger.com" class="text-[color:var(--accent-700)]">The STR Ledger</a> —
        a small studio making Excel and Notion templates for short-term rental
        finance. We host properties ourselves; everything on this site exists
        because we needed it.
      </p>
      <p class="mt-3 text-body text-graphite leading-relaxed">
        strguests.tools is the fourth site in a four-site cluster
        (<a href="https://strbuyers.tools" class="text-[color:var(--accent-700)]">strbuyers.tools</a>,
        <a href="https://strhost.tools" class="text-[color:var(--accent-700)]">strhost.tools</a>,
        <a href="https://strops.tools" class="text-[color:var(--accent-700)]">strops.tools</a>, and
        strguests.tools) covering the full STR host lifecycle. Each site is
        deliberately specialized so the tools stay sharp.
      </p>
    </section>

    <section class="mt-9">
      <h2 class="font-serif text-h2 text-navy">What we won't do</h2>
      <ul class="mt-4 space-y-3 text-body text-graphite leading-relaxed">
        <li><strong class="text-navy">Sell your email.</strong> We use email captures for the lead magnet and product launches, nothing else. Unsubscribe link in every email.</li>
        <li><strong class="text-navy">Run popups, exit-intent modals, or sticky ads.</strong> Use the tool, leave when you're done.</li>
        <li><strong class="text-navy">Hide formulas behind a paywall.</strong> Everything the generators do is documented on each tool's page.</li>
        <li><strong class="text-navy">Upload your data.</strong> PDF generation runs in your browser. Property details never leave your laptop. The AI generators (when they ship) call our server, but only with the prompt — we don't store the output.</li>
      </ul>
    </section>

    <section class="mt-9">
      <h2 class="font-serif text-h2 text-navy">What we will do</h2>
      <ul class="mt-4 space-y-3 text-body text-graphite leading-relaxed">
        <li><strong class="text-navy">Verify content annually.</strong> Each template has a <code>lastVerified</code> ISO date. We re-check copy against current host-coaching guidance every year.</li>
        <li><strong class="text-navy">Add tools as we hear what hosts need.</strong> The seven launch tools cover the highest-volume guest-XP scenarios. New tools land when there's a clear demand signal.</li>
        <li><strong class="text-navy">Listen to bug reports.</strong> If a calculator gives wrong math or a PDF rendering breaks, message us — we fix it within a week.</li>
      </ul>
    </section>

    <STRLedgerCTA tool="welcome-book" />
  </article>

  <ClusterFunnelBlock currentCluster="guest-xp" />
</Layout>

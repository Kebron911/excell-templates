---
import Layout from '@/components/AppLayout.astro';
import Sidebar from '@/components/AppSidebar.astro';
import AdSlot from '@str/ui-funnel/AdSlot.astro';
import EmailCaptureCard from '@str/ui-funnel/EmailCaptureCard.astro';
import STRLedgerCTA from '@str/ui-funnel/STRLedgerCTA.astro';
import RelatedPosts from '@/components/funnel/RelatedPosts.astro';
import ClusterFunnelBlock from '@str/ui-funnel/ClusterFunnelBlock.astro';
import AiRateLimitNotice from '@/components/generator/AiRateLimitNotice.astro';
import ListingDescriptionGenerator from '@/components/generators/ListingDescriptionGenerator.tsx';
import { buildWebApplication, buildFAQPage } from '@str/seo';
import { siteConfig } from '@/data/site.config';
import tools from '@/data/tools.json';

const tool = tools['listing-description'];
const path = tool.path;

const webApp = buildWebApplication(siteConfig, { name: tool.name, description: tool.tagline, toolPath: path });
const faq = buildFAQPage([
  {
    question: 'Will the AI invent amenities I don\'t have?',
    answer: 'No — the system prompt explicitly forbids inventing amenities not in your input. The output draws only from the property type, location, amenities list, and unique features you provide.',
  },
  {
    question: 'How many free generations do I get?',
    answer: '5 per hour without an email, 50 per day if you verify your email. The verify link unlocks the higher tier in under a minute.',
  },
  {
    question: 'Can I edit the output?',
    answer: 'Yes — the output is a starting draft. Most hosts polish 15–20% of the language to fit their voice. Use the Regenerate button to try variations before editing.',
  },
]);
---
<Layout
  siteConfig={siteConfig}
  title={`${tool.name} — strguests.tools`}
  description={tool.tagline}
  path={path}
  jsonLd={[webApp, faq]}
>
  <article class="generator-page mx-auto max-w-6xl px-5 py-8">
    <header>
      <p class="label text-[color:var(--accent-700)]">AI generator · gpt-4o-mini</p>
      <h1 class="mt-2 font-serif text-h1 text-navy">
        Listing Description Generator<span class="period-accent">.</span>
      </h1>
      <p class="mt-3 text-lead text-ink-2 max-w-2xl leading-snug">
        {tool.tagline} Four-section output (headline, the space, guest access, other things to note) drawn only from what you tell it.
      </p>
    </header>

    <AiRateLimitNotice toolSlug="listing-description" />

    <section class="mt-7">
      <ListingDescriptionGenerator client:load />
    </section>

    <AdSlot siteConfig={siteConfig} location="in-content" />

    <section class="mt-9 prose">
      <h2 class="font-serif text-h2 text-navy">Why structured fields beat freeform prompts</h2>
      <p class="mt-3 text-body text-graphite leading-relaxed">
        Hosts who write a freeform "describe my place" prompt get generic copy — the model fills the gaps with cliché. Structured inputs (property type + location + listed amenities + a vibe toggle) constrain the model to facts you provided, which is the difference between "a charming retreat" and "a 2BR cabin in Asheville with a hot tub deck overlooking the ridge."
      </p>
    </section>

    <RelatedPosts toolKey="listing-description" />

    <EmailCaptureCard
      siteConfig={siteConfig}
      magnet="listing-description"
      toolSlug="listing-description"
      headline="Want 50 generations/day instead of 5/hour?"
      blurb="Verify your email to unlock the higher rate-limit tier — same generator, ten times the budget."
      cta="Send the verify link"
    />

    <STRLedgerCTA siteConfig={siteConfig} tool="listing-description" />

    <AdSlot siteConfig={siteConfig} location="footer" />

    <Sidebar siteConfig={siteConfig} current="listing-description" />
  </article>

  <ClusterFunnelBlock siteConfig={siteConfig} currentCluster="guest-xp" />
</Layout>

---
import Layout from '@/components/chrome/Layout.astro';
import EmailCaptureCard from '@/components/funnel/EmailCaptureCard.astro';
import STRLedgerCTA from '@/components/funnel/STRLedgerCTA.astro';
import RelatedPosts from '@/components/funnel/RelatedPosts.astro';
import ClusterFunnelBlock from '@/components/chrome/ClusterFunnelBlock.astro';
import tools from '@/data/tools.json';

const tool = tools['listing-description'];
const path = tool.path;
---
<Layout
  title="Airbnb Listing Description Generator — Free AI Tool · strguests.tools"
  description="AI-written Airbnb listing copy in your voice. Style toggles for warm, premium, family-focused, or amenity-led tone. Free, coming when the serverless layer ships."
  path={path}
>
  <article class="generator-page mx-auto max-w-3xl px-5 py-12">
    <header>
      <p class="label text-[color:var(--accent-700)]">AI generator · Coming soon</p>
      <h1 class="mt-2 font-serif text-h1 text-navy">
        Listing Description Generator<span class="period-accent">.</span>
      </h1>
      <p class="mt-3 text-lead text-ink-2 max-w-2xl leading-snug">
        AI-written Airbnb listing copy in your voice. Toggle warmth, premium
        framing, family appeal, and amenity-led structure. We're wiring the
        serverless layer (Claude Haiku 4.5) — drop your email below to hear
        the moment it ships.
      </p>
    </header>

    <section class="mt-8 rounded-md surface-gen p-6">
      <p class="label text-[color:var(--accent-700)]">What it will do</p>
      <ul class="mt-3 space-y-2 text-body text-graphite leading-relaxed list-disc pl-5">
        <li>Generate a full listing description (headline + body) from a short property brief.</li>
        <li>Style toggles: warm, premium, family-focused, amenity-led, minimal.</li>
        <li>Keyword-aware output (city, property type, distinctive features).</li>
        <li>Rate-limited — 5 generations/hour/IP without email, 50/day verified.</li>
      </ul>
    </section>

    <section class="mt-9">
      <EmailCaptureCard
        magnet="listing-description-launch"
        toolSlug="listing-description"
        headline="Email me when the listing generator ships"
        blurb="One email when the AI generator goes live. We'll also send the free Guest Message Template Pack — same list, no spam."
        cta="Email me when it ships"
      />
    </section>

    <RelatedPosts toolKey="listing-description" />

    <STRLedgerCTA tool="listing-description" />
  </article>

  <ClusterFunnelBlock currentCluster="guest-xp" />
</Layout>

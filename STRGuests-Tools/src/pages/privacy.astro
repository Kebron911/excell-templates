---
import Layout from '@/components/chrome/Layout.astro';
import ClusterFunnelBlock from '@/components/chrome/ClusterFunnelBlock.astro';

const today = new Date().toISOString().slice(0, 10);
---
<Layout
  title="Privacy — strguests.tools"
  description="How strguests.tools handles email addresses, analytics, and the soft-gate lead-magnet flow. Plain English, short."
  path="/privacy"
>
  <article class="mx-auto max-w-3xl px-5 py-12 prose">
    <header>
      <p class="label text-[color:var(--accent-700)]">Legal</p>
      <h1 class="mt-2 font-serif text-h1 text-navy">Privacy<span class="period-accent">.</span></h1>
      <p class="mt-3 text-caption text-ink-3 font-mono">
        Last updated <time datetime={today}>{today}</time>
      </p>
    </header>

    <section class="mt-7">
      <h2 class="font-serif text-h2 text-navy">What we collect</h2>
      <p class="mt-3 text-body text-graphite leading-relaxed">
        strguests.tools is operated by The STR Ledger. The site is a static set
        of free generators; we collect only what is necessary to deliver the
        tools and the optional lead-magnet email follow-ups.
      </p>
      <ul class="mt-3 text-body text-graphite leading-relaxed list-disc pl-5">
        <li><strong class="text-navy">Email address</strong> — only when you submit one through the soft email gate or a newsletter signup. Stored with our email provider and used to send the requested template pack or notification.</li>
        <li><strong class="text-navy">Analytics</strong> — Google Analytics 4 records anonymized pageviews and aggregated tool usage. No personally identifying information is sent.</li>
        <li><strong class="text-navy">PDF inputs</strong> — values you type into a generator never leave your browser. PDF generation runs entirely client-side via pdf-lib.</li>
      </ul>
    </section>

    <section class="mt-7">
      <h2 class="font-serif text-h2 text-navy">What we don't do</h2>
      <p class="mt-3 text-body text-graphite leading-relaxed">
        We do not sell, rent, or share email addresses. We do not run third-party
        retargeting pixels. We do not require an account to use any generator.
      </p>
    </section>

    <section class="mt-7">
      <h2 class="font-serif text-h2 text-navy">Removal requests</h2>
      <p class="mt-3 text-body text-graphite leading-relaxed">
        Every email we send includes an unsubscribe link. To remove an email
        address from our list outside the unsubscribe flow, contact us at
        <a href="/contact" class="text-[color:var(--accent-700)]">/contact</a>.
      </p>
    </section>
  </article>

  <ClusterFunnelBlock currentCluster="guest-xp" />
</Layout>

---
import Layout from '@/components/chrome/Layout.astro';
import ClusterFunnelBlock from '@/components/chrome/ClusterFunnelBlock.astro';
import tools from '@/data/tools.json';

const toolsList = Object.values(tools);
const pdfTools = toolsList.filter((t: any) => t.kind === 'pdf');
---
<Layout
  title="Page not found — strguests.tools"
  description="The page you're looking for doesn't exist. Try a free generator, browse the 26-template Airbnb message library, or grab the Pinterest pin pack."
  path="/404"
>
  <section class="bg-parchment">
    <div class="mx-auto max-w-3xl px-5 pt-12 pb-9">
      <p class="label text-[color:var(--accent-700)]">404 — Page not found</p>
      <h1 class="mt-3 text-h1 font-serif text-navy max-w-2xl leading-tight">
        That page doesn't exist<span class="period-accent">.</span>
      </h1>
      <p class="mt-4 text-lead text-ink-2 max-w-2xl">
        The URL you followed is broken or the page has moved. Here are the
        most useful entry points on strguests.tools — pick the one you
        came in for.
      </p>
    </div>
  </section>

  <section class="bg-parchment-light border-t border-rule">
    <div class="mx-auto max-w-5xl px-5 py-9">
      <p class="label text-[color:var(--accent-700)]">PDF generators</p>
      <h2 class="mt-2 font-serif text-h2 text-navy">Free printables, in your browser.</h2>
      <ul class="mt-5 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {pdfTools.map((t: any) => (
          <li>
            <a
              href={t.path}
              class="group block h-full rounded-md border border-rule bg-parchment p-5 no-underline hover:border-[color:var(--accent-500)] hover:shadow-card transition-all duration-std focus:outline-none focus:shadow-focus"
            >
              <p class="font-serif text-h3 text-navy leading-snug">{t.shortName}</p>
              <p class="mt-2 text-small text-ink-2 leading-snug">{t.tagline}</p>
              <p class="mt-4 text-caption text-[color:var(--accent-700)] group-hover:text-[color:var(--accent-500)] flex items-center gap-1">
                Open
                <span class="inline-block transition-transform duration-std group-hover:translate-x-0.5" aria-hidden="true">→</span>
              </p>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="bg-parchment border-t border-rule">
    <div class="mx-auto max-w-5xl px-5 py-9">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        <a
          href="/templates/"
          class="group block rounded-md border border-rule bg-parchment-light p-5 no-underline hover:border-[color:var(--accent-500)] hover:shadow-card transition-all duration-std focus:outline-none focus:shadow-focus"
        >
          <p class="label text-[color:var(--accent-700)]">Library</p>
          <p class="mt-2 font-serif text-h3 text-navy leading-snug">26 message templates</p>
          <p class="mt-2 text-small text-ink-2 leading-snug">
            Searchable, filterable — pre-arrival, problem-resolution, cancellations, anniversaries.
          </p>
          <p class="mt-4 text-caption text-[color:var(--accent-700)] group-hover:text-[color:var(--accent-500)]">
            Browse <span aria-hidden="true">→</span>
          </p>
        </a>
        <a
          href="/get-the-templates"
          class="group block rounded-md border border-rule bg-parchment-light p-5 no-underline hover:border-[color:var(--accent-500)] hover:shadow-card transition-all duration-std focus:outline-none focus:shadow-focus"
        >
          <p class="label text-[color:var(--accent-700)]">Lead magnet</p>
          <p class="mt-2 font-serif text-h3 text-navy leading-snug">Free template pack</p>
          <p class="mt-2 text-small text-ink-2 leading-snug">
            Editable bundle of all 26 templates — sent the day the AI generator ships.
          </p>
          <p class="mt-4 text-caption text-[color:var(--accent-700)] group-hover:text-[color:var(--accent-500)]">
            Get the pack <span aria-hidden="true">→</span>
          </p>
        </a>
        <a
          href="/blog"
          class="group block rounded-md border border-rule bg-parchment-light p-5 no-underline hover:border-[color:var(--accent-500)] hover:shadow-card transition-all duration-std focus:outline-none focus:shadow-focus"
        >
          <p class="label text-[color:var(--accent-700)]">From the notebook</p>
          <p class="mt-2 font-serif text-h3 text-navy leading-snug">Field-tested guides</p>
          <p class="mt-2 text-small text-ink-2 leading-snug">
            House rules, welcome books, review responses, message cadence — by hosts, for hosts.
          </p>
          <p class="mt-4 text-caption text-[color:var(--accent-700)] group-hover:text-[color:var(--accent-500)]">
            Read the blog <span aria-hidden="true">→</span>
          </p>
        </a>
      </div>
    </div>
  </section>

  <section class="bg-parchment-light border-t border-rule">
    <div class="mx-auto max-w-3xl px-5 py-9">
      <p class="text-body text-ink-2 leading-snug">
        Or head back to the <a href="/" class="text-[color:var(--accent-700)] hover:underline">homepage</a>
        to pick a generator from the full list.
      </p>
    </div>
  </section>

  <ClusterFunnelBlock currentCluster="guest-xp" />
</Layout>

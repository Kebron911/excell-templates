---
import Layout from '@/components/chrome/Layout.astro';
import Sidebar from '@/components/chrome/Sidebar.astro';
import AdSlot from '@/components/ads/AdSlot.astro';
import EmailCaptureCard from '@/components/funnel/EmailCaptureCard.astro';
import STRLedgerCTA from '@/components/funnel/STRLedgerCTA.astro';
import PinterestPinButton from '@/components/generator/PinterestPinButton.astro';
import AiRateLimitNotice from '@/components/generator/AiRateLimitNotice.astro';
import ClusterFunnelBlock from '@/components/chrome/ClusterFunnelBlock.astro';
import ReviewResponseGenerator from '@/components/generators/ReviewResponseGenerator.tsx';
import { buildWebApplication, buildFAQPage } from '@/lib/seo';
import tools from '@/data/tools.json';

const tool = tools['review-response'];
const path = tool.path;

const webApp = buildWebApplication({
  name: tool.name,
  description: tool.tagline,
  toolPath: path,
});
const faq = buildFAQPage([
  {
    question: 'Should I respond to every review?',
    answer:
      "Yes — every review, every time. Future guests scan responses to see how you handle feedback. A blank response history reads worse than an awkward reply.",
  },
  {
    question: 'How fast should I reply to a bad review?',
    answer:
      "Within 24-48 hours, but not in the heat of the moment. Sleep on it, draft the response (or have the AI draft it), then read it once more before posting.",
  },
  {
    question: 'Can I dispute a factually wrong review?',
    answer:
      "Through Airbnb's review-removal process, yes — but only if it violates content policy. The public response is for everyone else; the dispute is between you and Airbnb.",
  },
  {
    question: 'Should I offer a refund in the response?',
    answer:
      "No. Refunds happen in the Resolution Center, not in public. The AI prompt explicitly avoids any money language for that reason.",
  },
]);
---
<Layout
  title={`${tool.name} — strguests.tools`}
  description={tool.tagline}
  path={path}
  jsonLd={[webApp, faq]}
>
  <article class="generator-page mx-auto max-w-6xl px-5 py-8">
    <header>
      <p class="label text-[color:var(--accent-700)]">AI generator · Free with email</p>
      <h1 class="mt-2 font-serif text-h1 text-navy">
        Review Response Generator<span class="period-accent">.</span>
      </h1>
      <p class="mt-3 text-lead text-ink-2 max-w-2xl leading-snug">
        {tool.tagline} Paste the review, pick the goal, get a draft tuned to read well to FUTURE
        guests browsing your reviews. Capped at 90 words — Airbnb best practice.
      </p>
    </header>

    <AiRateLimitNotice toolSlug="review-response" />

    <section class="mt-7">
      <ReviewResponseGenerator client:load />
    </section>

    <div class="mt-5 flex flex-wrap gap-3">
      <PinterestPinButton toolSlug="review-response" description="Free Airbnb review response generator" />
    </div>

    <AdSlot location="in-content" />

    <section class="mt-9 prose">
      <h2 class="font-serif text-h2 text-navy">Why review responses matter more than the review</h2>
      <p class="mt-3 text-body text-graphite leading-relaxed">
        Future guests aren't reading reviews to decide if they like the property — they're reading
        to decide if they trust the host. A 4-star review with a thoughtful host response converts
        better than a 5-star review with no reply. This generator is tuned to write for the audience
        that hasn't booked yet.
      </p>
    </section>

    <section class="mt-9">
      <h2 class="font-serif text-h2 text-navy">Three rules the AI follows</h2>
      <ul class="mt-4 space-y-3 text-body text-graphite leading-relaxed">
        <li><strong class="text-navy">Never argue.</strong> Public spaces are not where you win factual disputes.</li>
        <li><strong class="text-navy">Never offer refunds in writing.</strong> All money movement goes through the Resolution Center.</li>
        <li><strong class="text-navy">Cap at 90 words.</strong> Long defensive responses are worse than short gracious ones.</li>
      </ul>
    </section>

    <EmailCaptureCard
      magnet="ai-tools-launch"
      toolSlug="review-response"
      headline="Get the full AI generator pack"
      blurb="Listing copy, review responses, and message templates — three AI tools in one launch alert."
      cta="Notify me at launch"
    />

    <STRLedgerCTA tool="review-response" />

    <AdSlot location="footer" />

    <Sidebar current="review-response" />
  </article>

  <ClusterFunnelBlock currentCluster="guest-xp" />
</Layout>

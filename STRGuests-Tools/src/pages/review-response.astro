---
import Layout from '@/components/chrome/Layout.astro';
import EmailCaptureCard from '@/components/funnel/EmailCaptureCard.astro';
import STRLedgerCTA from '@/components/funnel/STRLedgerCTA.astro';
import RelatedPosts from '@/components/funnel/RelatedPosts.astro';
import ClusterFunnelBlock from '@/components/chrome/ClusterFunnelBlock.astro';
import tools from '@/data/tools.json';

const tool = tools['review-response'];
const path = tool.path;
---
<Layout
  title="Airbnb Review Response Generator — Free AI Tool · strguests.tools"
  description="Thoughtful AI-written replies for 5-star, 4-star, and bad reviews. Tone-matched, defensive-free, future-host-friendly. Coming when the serverless layer ships."
  path={path}
>
  <article class="generator-page mx-auto max-w-3xl px-5 py-12">
    <header>
      <p class="label text-[color:var(--accent-700)]">AI generator · Coming soon</p>
      <h1 class="mt-2 font-serif text-h1 text-navy">
        Review Response Generator<span class="period-accent">.</span>
      </h1>
      <p class="mt-3 text-lead text-ink-2 max-w-2xl leading-snug">
        Replies that read like a human host wrote them — 5-star thanks, 4-star
        recoveries, and the hard bad-review responses that don't sound
        defensive. Coming when the serverless layer ships. Drop your email and
        we'll let you know.
      </p>
    </header>

    <section class="mt-8 rounded-md surface-gen p-6">
      <p class="label text-[color:var(--accent-700)]">What it will do</p>
      <ul class="mt-3 space-y-2 text-body text-graphite leading-relaxed list-disc pl-5">
        <li>5-star: gracious thanks that future guests will read.</li>
        <li>4-star: acknowledges the gap, addresses the specific issue, doesn't grovel.</li>
        <li>Bad review: defuses without arguing, signals improvement, protects the listing.</li>
        <li>Mode toggle for "first-time host" vs "experienced host" voice.</li>
      </ul>
    </section>

    <section class="mt-9">
      <EmailCaptureCard
        magnet="review-response-launch"
        toolSlug="review-response"
        headline="Email me when the review generator ships"
        blurb="One email when the AI generator goes live. We'll also send the free Guest Message Template Pack — same list, no spam."
        cta="Email me when it ships"
      />
    </section>

    <RelatedPosts toolKey="review-response" />

    <STRLedgerCTA tool="review-response" />
  </article>

  <ClusterFunnelBlock currentCluster="guest-xp" />
</Layout>

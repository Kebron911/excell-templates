---
import Layout from '@/components/AppLayout.astro';
import Sidebar from '@str/ui-chrome/AppSidebar.astro';
import { sidebarItems } from '@/data/sidebar-items';
import AdSlot from '@str/ui-funnel/AdSlot.astro';
import EmailCaptureCard from '@str/ui-funnel/EmailCaptureCard.astro';
import STRLedgerCTA from '@str/ui-funnel/STRLedgerCTA.astro';
import RelatedPosts from '@/components/funnel/RelatedPosts.astro';
import ClusterFunnelBlock from '@str/ui-funnel/ClusterFunnelBlock.astro';
import AiRateLimitNotice from '@/components/generator/AiRateLimitNotice.astro';
import ReviewResponseGenerator from '@/components/generators/ReviewResponseGenerator.tsx';
import { buildWebApplication, buildFAQPage } from '@str/seo';
import { siteConfig } from '@/data/site.config';
import tools from '@/data/tools.json';
import PageHero from '@/components/PageHero.astro';

const tool = tools['review-response'];
const path = tool.path;

const webApp = buildWebApplication(siteConfig, { name: tool.name, description: tool.tagline, toolPath: path });
const faq = buildFAQPage([
  {
    question: 'Does the bad-review response sound defensive?',
    answer: 'No — the system prompt explicitly forbids defensive language for bad reviews. The output leads with empathy ("I\'m sorry that…"), proposes a concrete remedy, and avoids contradiction-by-tone.',
  },
  {
    question: 'Will it ask the reviewer to change their rating?',
    answer: 'Never. The prompt forbids fishing for rating changes — that\'s an Airbnb policy violation and reads as desperate to future guests.',
  },
  {
    question: 'Can I add context the AI should know but the public response shouldn\'t?',
    answer: 'Yes — the "Host context" field informs the response\'s tone but doesn\'t appear verbatim. Useful for "the guest actually broke the rule we have posted" type situations.',
  },
]);
---
<Layout
  siteConfig={siteConfig}
  title={`${tool.name} — strguests.tools`}
  description={tool.tagline}
  path={path}
  jsonLd={[webApp, faq]}
>
  <article class="generator-page mx-auto max-w-6xl px-5 py-8">
    <header>
      <p class="label text-[color:var(--accent-700)]">AI generator · gpt-4o-mini</p>
      <h1 class="mt-2 font-serif text-h1 text-navy">
        Review Response Generator<span class="period-accent">.</span>
      </h1>
      <p class="mt-3 text-lead text-ink-2 max-w-2xl leading-snug">
        {tool.tagline} Under 90 words, empathy-first on bad reviews, no defensiveness.
      </p>
    
      <PageHero slug="review-response" alt="Review Response Generator — Thoughtful replies for 5-star, 4-star, and bad reviews." />
    </header>

    <AiRateLimitNotice toolSlug="review-response" />

    <section class="mt-7">
      <ReviewResponseGenerator client:load />
    </section>

    <AdSlot siteConfig={siteConfig} location="in-content" />

    <section class="mt-9 prose">
      <h2 class="font-serif text-h2 text-navy">The response is for future guests, not the reviewer</h2>
      <p class="mt-3 text-body text-graphite leading-relaxed">
        Public review responses are read by the next ten bookers, not by the person who left the review. The prompt is tuned for that audience — concise, calm, factual, and ending on a forward-looking note instead of a defensive correction.
      </p>
    </section>

    <RelatedPosts toolKey="review-response" />

    <EmailCaptureCard
      siteConfig={siteConfig}
      magnet="review-response"
      toolSlug="review-response"
      headline="50 review responses per day"
      blurb="Verify your email to unlock 50 generations/day instead of 5/hour. Useful if you manage multiple properties."
      cta="Send the verify link"
    />

    <STRLedgerCTA siteConfig={siteConfig} tool="review-response" />

    <AdSlot siteConfig={siteConfig} location="footer" />

    <Sidebar siteConfig={siteConfig} items={sidebarItems} current="review-response" />
  </article>

  <ClusterFunnelBlock siteConfig={siteConfig} currentCluster="guest-xp" />
</Layout>

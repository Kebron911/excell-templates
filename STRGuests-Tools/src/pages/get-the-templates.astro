---
import Layout from '@/components/AppLayout.astro';
import EmailCaptureCard from '@str/ui-funnel/EmailCaptureCard.astro';
import STRLedgerCTA from '@str/ui-funnel/STRLedgerCTA.astro';
import ClusterFunnelBlock from '@str/ui-funnel/ClusterFunnelBlock.astro';
import { siteConfig } from '@/data/site.config';
---
<Layout
  siteConfig={siteConfig}
  title="Get the free Guest Message Template Pack — strguests.tools"
  description="Drop your email and we'll send the editable bundle of all 26 hand-written Airbnb host message templates the day the AI generator ships. Free, no spam."
  path="/get-the-templates"
>
  <article class="mx-auto max-w-3xl px-5 py-12">
    <header>
      <p class="label text-[color:var(--accent-700)]">Free lead magnet · Coming soon</p>
      <h1 class="mt-2 font-serif text-h1 text-navy">
        The Guest Message Template Pack<span class="period-accent">.</span>
      </h1>
      <p class="mt-3 text-lead text-ink-2 max-w-2xl leading-snug">
        26 hand-written Airbnb host message templates — pre-arrival, check-in,
        problem-resolution, cancellations, anniversaries — packaged as an
        editable doc with the AI generator that customizes them per property.
        Drop your email; we'll send the day it ships.
      </p>
    </header>

    <section class="mt-8 grid grid-cols-1 md:grid-cols-3 gap-5">
      <div class="rounded-md surface-gen p-5">
        <p class="label text-[color:var(--accent-700)]">What's in it</p>
        <p class="mt-2 font-serif text-h3 text-navy leading-snug">26 templates, 10 categories</p>
        <p class="mt-2 text-small text-ink-2 leading-snug">
          Pre-arrival, check-in, mid-stay, check-out, post-checkout, problem-
          resolution, review-request, repeat-guest, cancellation, special-occasion.
        </p>
      </div>
      <div class="rounded-md surface-gen p-5">
        <p class="label text-[color:var(--accent-700)]">How it ships</p>
        <p class="mt-2 font-serif text-h3 text-navy leading-snug">Editable doc + generator</p>
        <p class="mt-2 text-small text-ink-2 leading-snug">
          Plain text + Notion / Google Doc versions, plus access to the AI
          generator at <a href="/guest-messages" class="text-[color:var(--accent-700)]">/guest-messages</a>
          when it goes live.
        </p>
      </div>
      <div class="rounded-md surface-gen p-5">
        <p class="label text-[color:var(--accent-700)]">No spam</p>
        <p class="mt-2 font-serif text-h3 text-navy leading-snug">One email, that's it</p>
        <p class="mt-2 text-small text-ink-2 leading-snug">
          We email when it ships. No newsletter, no drip, no upsell. Unsubscribe
          link in every email. We don't sell or share email addresses.
        </p>
      </div>
    </section>

    <section class="mt-9">
      <EmailCaptureCard
        siteConfig={siteConfig}
        magnet="message-template-bundle"
        toolSlug="get-the-templates"
        headline="Email me the template pack"
        blurb="One email when it ships. We'll also let you know about the next two AI generators (listing description, review responses) as they go live."
        cta="Email me when it ships"
      />
    </section>

    <section class="mt-9 prose">
      <h2 class="font-serif text-h2 text-navy">Why a template pack and not a paid product?</h2>
      <p class="mt-3 text-body text-graphite leading-relaxed">
        Hosts who pay for this kind of content already do — Hostfully, Touch Stay, Tinker tape solutions
        all pitch some version of "guest communication done for you" at $20–$60/month per property.
        That's fine for hosts running 5+ properties; it's overkill for the 1–2 property hosts who make
        up the long tail.
      </p>
      <p class="mt-3 text-body text-graphite leading-relaxed">
        The free pack is the on-ramp. The paid bridge is The STR Ledger workbooks — Excel templates that
        track the back-office side (income, expenses, occupancy, P&L) the message templates can't touch.
        If the templates are useful, the workbooks probably are too.
      </p>
    </section>

    <section class="mt-9">
      <STRLedgerCTA siteConfig={siteConfig} tool="guest-messages" />
    </section>
  </article>

  <ClusterFunnelBlock siteConfig={siteConfig} currentCluster="guest-xp" />
</Layout>

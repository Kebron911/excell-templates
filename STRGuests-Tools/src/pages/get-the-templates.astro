---
import Layout from '@/components/chrome/Layout.astro';
import ClusterFunnelBlock from '@/components/chrome/ClusterFunnelBlock.astro';
---

<Layout
  title="Free Welcome Book master template — strguests.tools"
  description="Get the editable Welcome Book master PDF — branded printable, 8 sections, no signup gymnastics. Email it once, edit forever."
  path="/get-the-templates"
>
  <article class="bg-parchment">
    <div class="mx-auto max-w-3xl px-5 pt-12 pb-9">
      <header>
        <p class="label text-[color:var(--accent-700)]">Free download</p>
        <h1 class="mt-3 text-h1 font-serif text-navy leading-tight">
          The Welcome Book master template<span class="period-gold">.</span>
        </h1>
        <p class="mt-3 text-lead text-ink-2 max-w-2xl">
          Editable, branded, 8 pre-built sections. The same template our team uses for every
          property we host. One email, lifetime access — including the seasonal updates.
        </p>
      </header>

      <section class="mt-7 rounded-md border border-rule bg-parchment-light p-6 max-w-2xl">
        <p class="font-serif text-h3 text-navy">What's inside</p>
        <ul class="mt-3 space-y-2 text-body text-ink-2">
          <li>· Cover page with your property name, photo placeholder, and host bio</li>
          <li>· Wi-Fi card (large, scannable from across the room)</li>
          <li>· Getting in / lockbox / parking section</li>
          <li>· House notes (quiet hours, trash day, heat & A/C)</li>
          <li>· Local picks template (coffee, casual dinner, special occasion, outdoor, rainy-day)</li>
          <li>· Emergency contacts page</li>
          <li>· Checkout reminders</li>
          <li>· Empty section template you can duplicate</li>
        </ul>
      </section>

      <section class="mt-7 max-w-2xl">
        <form
          class="flex flex-col gap-3"
          data-magnet-form
          aria-labelledby="magnet-form-heading"
        >
          <label class="block">
            <span class="block text-small text-ink-2 mb-1" id="magnet-form-heading">Your email</span>
            <input
              type="email"
              name="email"
              autocomplete="email"
              required
              placeholder="you@yourdomain.com"
              class="w-full rounded-md border border-rule bg-parchment-light px-4 py-3 text-ui text-navy placeholder:text-ink-3 focus:outline-none focus:border-[color:var(--accent-500)] focus:shadow-focus"
            />
          </label>
          <button
            type="submit"
            class="self-start rounded-md text-parchment px-5 py-3 text-ui transition-colors duration-std hover:opacity-90"
            style="background: var(--accent-500);"
          >
            Send me the template
          </button>
          <p class="text-caption text-ink-2 leading-snug max-w-md">
            One email per drop, ~1×/month. Unsubscribe anytime. We never sell or share your email.
          </p>
        </form>

        <div data-magnet-success hidden class="mt-4 rounded-md border border-[color:var(--accent-500)] bg-parchment-light p-5 text-body text-navy">
          <p class="font-serif text-h3 text-navy">Check your inbox.</p>
          <p class="mt-2 text-body text-ink-2">
            We've sent the master template to your email. If it doesn't arrive within five minutes,
            check spam — sometimes the first message lands there.
          </p>
        </div>
      </section>

      <section class="prose mt-9 max-w-2xl">
        <h2>Why this and not the in-browser builder?</h2>
        <p>
          The <a href="/welcome-book">Welcome Book Builder</a> generates a one-shot PDF — great
          when you want a polished result fast. The master template is the editable source: you fill
          it in once, then duplicate the file for each new property and tweak the property-specific
          bits. Hosts who scale beyond 1–2 listings prefer the master template.
        </p>

        <h2>What you'll get next</h2>
        <p>
          Every month or so, a new template ships — door-hangers, departure cards, mid-stay
          surveys. Subscribers see them first, and unsubscribe is one click.
        </p>
      </section>
    </div>

    <ClusterFunnelBlock currentCluster="guest-xp" />
  </article>
</Layout>

<script>
  const webhook = (import.meta.env.PUBLIC_ESP_WEBHOOK as string | undefined) ?? '';

  const form = document.querySelector<HTMLFormElement>('form[data-magnet-form]');
  const success = document.querySelector<HTMLDivElement>('[data-magnet-success]');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = (form.querySelector('input[name="email"]') as HTMLInputElement)?.value?.trim();
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) return;

    const payload = {
      email,
      magnet: 'welcome-book-master',
      source: 'strguests.tools',
      tool: 'lead-magnet',
      utm_source: 'strguests-tools',
      utm_medium: 'lead-magnet',
      utm_content: 'welcome-book-master',
      ts: Date.now(),
    };

    try {
      if (webhook) {
        await fetch(webhook, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
          keepalive: true,
        });
      } else {
        console.warn('[lead-magnet] PUBLIC_ESP_WEBHOOK not set; payload:', payload);
      }
      (window as any).gtag?.('event', 'lead_magnet_submit', { magnet: 'welcome-book-master' });
    } catch (err) {
      console.warn('[lead-magnet] capture failed', err);
    } finally {
      form.hidden = true;
      if (success) success.hidden = false;
    }
  });
</script>

<style>
  .prose :global(h2) { font-family: var(--font-display); font-size: var(--t-h2-size); color: var(--brand-navy); margin-top: 1.6rem; margin-bottom: 0.6rem; }
  .prose :global(p) { margin-bottom: 0.9rem; line-height: 1.65; color: var(--ink-2); }
  .prose :global(a) { color: var(--accent-700); text-decoration: underline; }
</style>

---
import Layout from '@/components/chrome/Layout.astro';
import AdSlot from '@/components/ads/AdSlot.astro';
import EmailCaptureCard from '@/components/funnel/EmailCaptureCard.astro';
import STRLedgerCTA from '@/components/funnel/STRLedgerCTA.astro';
import RelatedPosts from '@/components/funnel/RelatedPosts.astro';
import ClusterFunnelBlock from '@/components/chrome/ClusterFunnelBlock.astro';
import CopyButton from '@/components/templates/CopyButton.tsx';
import { buildScenarioArticle, buildBreadcrumb } from '@str/seo';
import { siteConfig } from '@/data/site.config';
import templatesData from '@/data/templates.json';

interface TemplateEntry {
  name: string;
  category: string;
  scenario: string;
  exampleInput: string;
  exampleOutput: string;
  lastVerified: string;
}

interface TemplatesFile {
  categories: string[];
  templates: Record<string, TemplateEntry>;
}

const data = templatesData as unknown as TemplatesFile;

// Eager-load any per-scenario narrative MDX files that exist under
// src/content/templates/. The pattern matches the scenario key.
const narrativeMdx = import.meta.glob<{ default: any }>('/src/content/templates/*.mdx', { eager: true });

export async function getStaticPaths() {
  const data = (templatesData as unknown as TemplatesFile);
  return Object.entries(data.templates).map(([scenario, entry]) => ({
    params: { scenario },
    props: { scenario, entry },
  }));
}

interface Props {
  scenario: string;
  entry: TemplateEntry;
}

const { scenario, entry } = Astro.props as Props;

const narrativePath = `/src/content/templates/${scenario}.mdx`;
const NarrativeModule = narrativeMdx[narrativePath];
const Narrative = NarrativeModule?.default;

// Related templates: 3 from the same category, excluding this scenario.
const related = Object.entries(data.templates)
  .filter(([k, v]) => k !== scenario && v.category === entry.category)
  .slice(0, 3);

const path = `/templates/${scenario}`;
const articleLd = buildScenarioArticle(siteConfig, {
  headline: `${entry.name} — Airbnb message template`,
  description: entry.scenario,
  slug: scenario,
  datePublished: entry.lastVerified,
});
const breadcrumbLd = buildBreadcrumb(siteConfig, [
  { name: 'Home', url: '/' },
  { name: 'Templates', url: '/templates/' },
  { name: entry.name, url: path },
]);

const categoryLabel = entry.category.replace(/-/g, ' ');
---
<Layout
  title={`${entry.name} — Airbnb message template · strguests.tools`}
  description={entry.scenario}
  path={path}
  jsonLd={[articleLd, breadcrumbLd]}
>
  <article class="generator-page mx-auto max-w-3xl px-5 py-8">
    <header>
      <p class="label text-[color:var(--accent-700)]">
        <a href="/templates/" class="no-underline hover:underline">Templates</a>
        <span class="mx-1 text-ink-3" aria-hidden="true">›</span>
        <a href={`/templates/?cat=${entry.category}`} class="no-underline hover:underline capitalize">{categoryLabel}</a>
      </p>
      <h1 class="mt-2 font-serif text-h1 text-navy">
        {entry.name}<span class="period-accent">.</span>
      </h1>
      <p class="mt-3 text-lead text-ink-2 leading-snug">{entry.scenario}</p>
      <p class="mt-1 text-caption text-ink-3 font-mono">
        Last verified <time datetime={entry.lastVerified}>{entry.lastVerified}</time>
      </p>
    </header>

    <section class="mt-7" aria-labelledby="example-input-label">
      <div class="flex items-end justify-between gap-3">
        <h2 id="example-input-label" class="label text-navy">Example input</h2>
      </div>
      <p class="mt-2 surface-gen p-4 text-ui text-graphite">{entry.exampleInput}</p>
    </section>

    <section class="mt-7" aria-labelledby="example-output-label">
      <div class="flex items-end justify-between gap-3">
        <h2 id="example-output-label" class="label text-navy">Example output</h2>
        <CopyButton client:idle text={entry.exampleOutput} label="Copy template" />
      </div>
      <pre class="mt-2 surface-gen p-5 text-ui text-graphite whitespace-pre-wrap font-sans leading-relaxed">{entry.exampleOutput}</pre>
      <p class="mt-2 text-caption text-ink-3">
        Mustache placeholders (<code>{'{{guestFirstName}}'}</code>, <code>{'{{propertyName}}'}</code>) mark the values you'll swap in for the actual stay.
      </p>
    </section>

    <aside class="mt-8 rounded-md surface-navy p-6 print:hidden">
      <p class="label text-[color:var(--accent-500)]">Make it yours</p>
      <p class="mt-2 font-serif text-h3 text-parchment leading-snug">
        Customize this template for your property automatically.
      </p>
      <a
        href={`/guest-messages?scenario=${encodeURIComponent(scenario)}`}
        class="mt-4 inline-flex items-center gap-2 rounded-md text-navy px-5 py-2.5 text-ui no-underline hover:opacity-90 transition-opacity duration-std"
        style="background: var(--accent-500);"
      >
        Customize in the message generator <span aria-hidden="true">→</span>
      </a>
    </aside>

    {Narrative && (
      <section class="mt-9 prose">
        <Narrative />
      </section>
    )}

    <AdSlot location="in-content" />

    {related.length > 0 && (
      <section class="mt-9" aria-labelledby="related-label">
        <h2 id="related-label" class="label text-navy">More <span class="capitalize">{categoryLabel}</span> templates</h2>
        <ul class="mt-4 space-y-3 list-none p-0">
          {related.map(([key, t]) => (
            <li>
              <a
                href={`/templates/${key}`}
                class="block group rounded-md border border-rule bg-parchment-light p-4 no-underline hover:border-[color:var(--accent-500)] hover:shadow-card transition-all duration-std"
              >
                <p class="text-ui text-navy group-hover:text-[color:var(--accent-700)] font-semibold">{t.name}</p>
                <p class="mt-1 text-caption text-ink-2 leading-snug">{t.scenario}</p>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <RelatedPosts toolKey="guest-messages" />

    <EmailCaptureCard
      magnet="message-template-bundle"
      toolSlug="guest-messages"
      headline="Get the full Guest Message Template Pack"
      blurb="The 26 templates here, plus the AI generator that customizes them for your property. One email gets you the editable bundle when it ships."
      cta="Email me the template pack"
    />

    <STRLedgerCTA tool="guest-messages" />

    <AdSlot location="footer" />
  </article>

  <ClusterFunnelBlock currentCluster="guest-xp" />
</Layout>

---
import Layout from '@/components/AppLayout.astro';
import Sidebar from '@/components/AppSidebar.astro';
import AdSlot from '@str/ui-funnel/AdSlot.astro';
import EmailCaptureCard from '@str/ui-funnel/EmailCaptureCard.astro';
import STRLedgerCTA from '@str/ui-funnel/STRLedgerCTA.astro';
import RelatedPosts from '@/components/funnel/RelatedPosts.astro';
import PdfDownloadButton from '@/components/generator/PdfDownloadButton.astro';
import PinterestPinButton from '@/components/generator/PinterestPinButton.astro';
import ClusterFunnelBlock from '@str/ui-funnel/ClusterFunnelBlock.astro';
import WelcomeBookBuilder from '@/components/generators/WelcomeBookBuilder.tsx';
import { buildWebApplication, buildFAQPage } from '@str/seo';
import { siteConfig } from '@/data/site.config';
import tools from '@/data/tools.json';

const tool = tools['welcome-book'];
const path = tool.path;

const webApp = buildWebApplication(siteConfig, {
  name: tool.name,
  description: tool.tagline,
  toolPath: path,
});
const faq = buildFAQPage([
  {
    question: 'How many pages does the welcome book get?',
    answer: 'Anywhere from 1 (cover only) to 6 (cover + all five sections). Most hosts ship 4–5 page books.',
  },
  {
    question: 'Can I add photos to the welcome book?',
    answer: "Not in this version — text-only. The Check-in Instructions generator supports image upload for door photos and parking maps.",
  },
  {
    question: 'Does the PDF work on guest phones?',
    answer: 'Yes — it is a standard PDF, opens fine in iOS/Android viewers and most messaging apps.',
  },
  {
    question: 'Can I remove the strguests.tools brand line at the bottom?',
    answer: 'Open the downloaded PDF in Preview, Acrobat, or Word and edit the footer. Direct opt-out is on the roadmap.',
  },
]);
---
<Layout
  siteConfig={siteConfig}
  title={`${tool.name} — strguests.tools`}
  description={tool.tagline}
  path={path}
  jsonLd={[webApp, faq]}
>
  <article class="generator-page mx-auto max-w-6xl px-5 py-8">
    <header>
      <p class="label text-[color:var(--accent-700)]">Free generator · No signup</p>
      <h1 class="mt-2 font-serif text-h1 text-navy">
        Welcome Book Builder<span class="period-accent">.</span>
      </h1>
      <p class="mt-3 text-lead text-ink-2 max-w-2xl leading-snug">
        {tool.tagline} Toggle sections, fill in details, and download a multi-page
        guidebook PDF. Generates in your browser — nothing uploaded.
      </p>
    </header>

    <section class="mt-7">
      <WelcomeBookBuilder client:visible />
    </section>

    <div class="mt-5 flex flex-wrap gap-3">
      <PdfDownloadButton
        toolSlug="welcome-book"
        filename="welcome-book"
        magnet="welcome-book"
        label="Download welcome book"
      />
      <PinterestPinButton toolSlug="welcome-book" description="Free Airbnb welcome book template — multi-page PDF" />
    </div>

    <AdSlot siteConfig={siteConfig} location="in-content" />

    <section class="mt-9 prose">
      <h2 class="font-serif text-h2 text-navy">A welcome book turns a stay into a host</h2>
      <p class="mt-3 text-body text-graphite leading-relaxed">
        The welcome book is the highest-leverage piece of guest collateral most hosts skip.
        It pre-empts 80% of the messages that arrive at 11pm on check-in night — wifi,
        coffee maker, parking — and doubles as the property's brand voice. The first
        thing guests touch when they walk in.
      </p>
    </section>

    <section class="mt-9">
      <h2 class="font-serif text-h2 text-navy">Five sections, each optional</h2>
      <ol class="mt-4 space-y-3 text-body text-graphite leading-relaxed list-decimal pl-5">
        <li><strong class="text-navy">Cover</strong> — property name, tagline, host signature.</li>
        <li><strong class="text-navy">Wi-Fi & access</strong> — high-contrast credential tile + door/garage codes.</li>
        <li><strong class="text-navy">Neighborhood favorites</strong> — local picks, one line each.</li>
        <li><strong class="text-navy">House tips</strong> — small instructions that prevent damage and confusion.</li>
        <li><strong class="text-navy">Emergency contacts</strong> — host, hospital, police.</li>
      </ol>
    </section>

    <RelatedPosts toolKey="welcome-book" />

    <EmailCaptureCard
      siteConfig={siteConfig}
      magnet="welcome-book"
      toolSlug="welcome-book"
      headline="Get the editable welcome book master template"
      blurb="Drop your email and we'll send the full editable Welcome Book — the version that comes with section presets and example copy."
      cta="Email me the master template"
    />

    <section class="mt-9">
      <h2 class="font-serif text-h2 text-navy">Frequently asked</h2>
      <dl class="mt-4 space-y-5">
        <div>
          <dt class="font-serif text-h3 text-navy">How many pages does it generate?</dt>
          <dd class="mt-1 text-body text-graphite leading-relaxed">
            1 (cover only) to 6 (all sections). Most hosts ship 4–5 pages.
          </dd>
        </div>
        <div>
          <dt class="font-serif text-h3 text-navy">Can I add photos?</dt>
          <dd class="mt-1 text-body text-graphite leading-relaxed">
            Not in this version. The Check-in Instructions generator supports image upload.
          </dd>
        </div>
        <div>
          <dt class="font-serif text-h3 text-navy">Can I remove the brand line at the bottom?</dt>
          <dd class="mt-1 text-body text-graphite leading-relaxed">
            Open the PDF in Preview, Acrobat, or Word and edit the footer. Direct opt-out is on the roadmap.
          </dd>
        </div>
      </dl>
    </section>

    <STRLedgerCTA siteConfig={siteConfig} tool="welcome-book" />

    <AdSlot siteConfig={siteConfig} location="footer" />

    <Sidebar siteConfig={siteConfig} current="welcome-book" />
  </article>

  <ClusterFunnelBlock siteConfig={siteConfig} currentCluster="guest-xp" />
</Layout>

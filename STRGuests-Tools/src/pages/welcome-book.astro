---
import Layout from '@/components/chrome/Layout.astro';
import Sidebar from '@/components/chrome/Sidebar.astro';
import ClusterFunnelBlock from '@/components/chrome/ClusterFunnelBlock.astro';
import AdSlot from '@/components/ads/AdSlot.astro';
import EmailCaptureCard from '@/components/funnel/EmailCaptureCard.astro';
import STRLedgerCTA from '@/components/funnel/STRLedgerCTA.astro';
import PdfDownloadButton from '@/components/generator/PdfDownloadButton.astro';
import WelcomeBookForm from '@/components/generator/WelcomeBookForm.tsx';
import { Content as ToolCopy } from '@/content/tools/welcome-book.mdx';
import { buildWebApplication, buildFAQPage } from '@/lib/seo';
import tools from '@/data/tools.json';

const tool = tools['welcome-book'];

const faqs = [
  {
    question: 'Can I add photos to the welcome book?',
    answer:
      'Not in v1. Photo uploads are on the roadmap. For now, generate the PDF here and drop photos in with any PDF editor before printing.',
  },
  {
    question: 'How long should an Airbnb welcome book be?',
    answer:
      "Six to ten pages is typical. Anything longer guests don't read. Cover, TOC, and emergency contacts are non-negotiable; everything else is value-add.",
  },
  {
    question: 'Can I print this and leave it in my rental?',
    answer:
      'Yes. The PDF is sized for US Letter and prints cleanly on home printers. Spiral binding at a print shop runs under $10.',
  },
  {
    question: 'Is my data stored or shared?',
    answer:
      'No. Generation is fully client-side. The PDF builds in your browser; nothing leaves your device.',
  },
];

const jsonLd = [
  buildWebApplication({
    name: 'Airbnb Welcome Book Builder',
    description:
      'Free Airbnb welcome book builder. Multi-page PDF with cover, sections, local picks, emergency contacts. Branded printable.',
    toolPath: tool.path,
  }),
  buildFAQPage(faqs),
];
---

<Layout
  title="Airbnb Welcome Book Builder — strguests.tools"
  description="Free Airbnb welcome book builder. Multi-page printable PDF with cover, host bio, Wi-Fi card, sections, local picks, and emergency contacts. Built in your browser."
  path="/welcome-book"
  jsonLd={jsonLd}
>
  <article class="generator-page bg-parchment">
    <div class="mx-auto max-w-6xl px-5 pt-9 pb-7 grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-9">
      <div class="min-w-0">
        <header>
          <h1 class="text-h1 font-serif text-navy leading-tight">
            Airbnb Welcome Book Builder<span class="period-gold">.</span>
          </h1>
          <p class="mt-3 text-lead text-ink-2 max-w-2xl">
            Multi-page printable guidebook PDF. Cover, sections, local picks, emergency contacts. Built in your browser.
          </p>
        </header>

        <div class="mt-7">
          <WelcomeBookForm client:load />
        </div>

        <PdfDownloadButton
          toolSlug="welcome-book"
          filename="welcome-book"
          magnet="welcome-book-pdf"
        />

        <AdSlot location="in-content" />

        <div class="prose mt-7 max-w-2xl">
          <ToolCopy />
        </div>

        <EmailCaptureCard
          magnet="strguests-newsletter"
          toolSlug="welcome-book"
        />

        <STRLedgerCTA tool="welcome-book" />

        <AdSlot location="footer" />
      </div>

      <Sidebar current="welcome-book" />
    </div>

    <ClusterFunnelBlock currentCluster="guest-xp" />
  </article>
</Layout>

<style>
  .prose :global(h2) { font-family: var(--font-display); font-size: var(--t-h2-size); color: var(--brand-navy); margin-top: 1.6rem; margin-bottom: 0.6rem; }
  .prose :global(h3) { font-family: var(--font-display); color: var(--brand-navy); margin-top: 1.2rem; margin-bottom: 0.4rem; font-size: var(--t-h3-size); }
  .prose :global(p) { margin-bottom: 0.9rem; line-height: 1.65; color: var(--ink-2); }
</style>

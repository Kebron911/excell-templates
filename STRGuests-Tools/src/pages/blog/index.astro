---
import Layout from '@/components/AppLayout.astro';
import ClusterFunnelBlock from '@str/ui-funnel/ClusterFunnelBlock.astro';
import EmailCaptureCard from '@str/ui-funnel/EmailCaptureCard.astro';
import STRLedgerCTA from '@str/ui-funnel/STRLedgerCTA.astro';
import { siteConfig } from '@/data/site.config';
import { getCollection } from 'astro:content';

const all = await getCollection('posts');
const posts = all
  .map((p: any) => ({
    slug: p.id.replace(/\.mdx$/, ''),
    ...p.data,
  }))
  .sort((a: { datePublished: string }, b: { datePublished: string }) =>
    a.datePublished < b.datePublished ? 1 : -1,
  );

const categoryLabels: Record<string, string> = {
  math: 'Math',
  operations: 'Operations',
  tax: 'Tax',
  'guest-xp': 'Guest XP',
  acquisition: 'Acquisition',
};

const formatDate = (iso: string) =>
  new Date(iso + 'T12:00:00Z').toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', timeZone: 'UTC' });
---

<Layout
  siteConfig={siteConfig}
  title="Blog — STR Guests Tools"
  description="Field-tested guides on the host-guest interface. House rules, welcome books, check-in flow, review responses, message templates — written by hosts for hosts."
  path="/blog"
>
  <section class="bg-parchment">
    <div class="mx-auto max-w-6xl px-5 pt-12 pb-9">
      <p class="label text-gold-deep">Field notes</p>
      <h1 class="mt-3 text-h1 font-serif text-navy max-w-3xl leading-tight">
        Reviews are the strategy<span class="period-gold">.</span>
      </h1>
      <p class="mt-4 text-lead text-ink-2 max-w-2xl">
        Practical writing on the parts of hosting guests actually feel — first messages, check-in clarity, the bad-review reply that lands. Each post pairs with one of the generators on this site.
      </p>
      <a
        href="/feed.xml"
        class="mt-5 inline-flex items-center gap-2 text-ui text-navy no-underline hover:text-navy-tint group"
      >
        Subscribe via RSS
        <span class="text-gold inline-block transition-transform duration-std group-hover:translate-x-0.5" aria-hidden="true">→</span>
      </a>
    </div>
  </section>

  <section class="bg-parchment-light border-t border-rule">
    <div class="mx-auto max-w-6xl px-5 py-9">
      <ul class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {posts.map((post: any) => {
          const thumbSrc = post.heroImage
            ? post.heroImage.replace(/\/hero\.webp$/, '/thumb.webp')
            : null;
          return (
          <li>
            <a
              href={`/blog/${post.slug}`}
              class="group block h-full rounded-md border border-rule bg-parchment no-underline hover:border-gold hover:shadow-card transition-all duration-std focus:outline-none focus:shadow-focus overflow-hidden"
            >
              {thumbSrc && (
                <div class="aspect-[1200/630] overflow-hidden bg-parchment-light border-b border-rule">
                  <img
                    src={thumbSrc}
                    alt={post.heroAlt ?? post.title}
                    width="600"
                    height="315"
                    loading="lazy"
                    decoding="async"
                    class="w-full h-full object-cover transition-transform duration-std group-hover:scale-[1.02]"
                  />
                </div>
              )}
              <div class="p-6">
                <div class="flex items-center gap-3 text-caption text-ink-3">
                  <span class="label text-gold-deep">{categoryLabels[post.category] ?? post.category}</span>
                  <span aria-hidden="true">·</span>
                  <time datetime={post.datePublished} class="font-mono">{formatDate(post.datePublished)}</time>
                  <span aria-hidden="true">·</span>
                  <span class="font-mono">{post.readMinutes} min read</span>
                </div>
                <p class="mt-3 font-serif text-h3 text-navy leading-snug group-hover:text-navy-tint">
                  {post.title}
                </p>
                <p class="mt-2 text-small text-ink-2 leading-snug">{post.description}</p>
                <p class="mt-4 text-caption text-gold-deep group-hover:text-gold flex items-center gap-1">
                  Read
                  <span class="inline-block transition-transform duration-std group-hover:translate-x-0.5" aria-hidden="true">→</span>
                </p>
              </div>
            </a>
          </li>
          );
        })}
      </ul>
    </div>
  </section>

  <section class="bg-parchment border-t border-rule">
    <div class="mx-auto max-w-6xl px-5 py-9">
      <EmailCaptureCard siteConfig={siteConfig} magnet="welcome-book-template" toolSlug="blog-index" />
    </div>
  </section>

  <section class="bg-parchment-light border-t border-rule">
    <div class="mx-auto max-w-6xl px-5 py-9">
      <STRLedgerCTA siteConfig={siteConfig} tool="welcome-book" />
    </div>
  </section>

  <ClusterFunnelBlock siteConfig={siteConfig} currentCluster="guest-xp" />
</Layout>

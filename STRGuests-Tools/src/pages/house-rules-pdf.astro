---
import Layout from '@/components/AppLayout.astro';
import Sidebar from '@str/ui-chrome/AppSidebar.astro';
import { sidebarItems } from '@/data/sidebar-items';
import AdSlot from '@str/ui-funnel/AdSlot.astro';
import EmailCaptureCard from '@str/ui-funnel/EmailCaptureCard.astro';
import STRLedgerCTA from '@str/ui-funnel/STRLedgerCTA.astro';
import RelatedPosts from '@/components/funnel/RelatedPosts.astro';
import PdfDownloadButton from '@/components/generator/PdfDownloadButton.astro';
import PinterestPinButton from '@/components/generator/PinterestPinButton.astro';
import ClusterFunnelBlock from '@str/ui-funnel/ClusterFunnelBlock.astro';
import HouseRulesGenerator from '@/components/generators/HouseRulesGenerator.tsx';
import { buildWebApplication, buildFAQPage } from '@str/seo';
import { siteConfig } from '@/data/site.config';
import tools from '@/data/tools.json';

const tool = tools['house-rules-pdf'];
const path = tool.path;

const webApp = buildWebApplication(siteConfig, {
  name: tool.name,
  description: tool.tagline,
  toolPath: path,
});
const faq = buildFAQPage([
  {
    question: 'Is the house rules PDF legally binding?',
    answer:
      "A house-rules PDF isn't a rental agreement. It's property-specific guidance that booking platforms surface during dispute resolution. For long-stay rentals, talk to a local attorney about a separate rental agreement.",
  },
  {
    question: 'Can I customize the PDF with my own logo?',
    answer:
      'Yes — open the downloaded PDF in Preview, Acrobat, or Word and add a logo before printing. Direct logo upload is on the roadmap.',
  },
  {
    question: 'Does it work on mobile?',
    answer:
      'The form works on phones, but the preview is easier to review on desktop. The PDF generates fine either way.',
  },
  {
    question: 'Is the PDF accessible to screen readers?',
    answer:
      'The PDF includes title and author metadata, and body text uses embedded Helvetica which screen readers handle. PDF/UA tagging is on the roadmap.',
  },
]);
---
<Layout
  siteConfig={siteConfig}
  title={`${tool.name} — strguests.tools`}
  description={tool.tagline}
  path={path}
  jsonLd={[webApp, faq]}
>
  <article class="generator-page mx-auto max-w-6xl px-5 py-8">
    <header>
      <p class="label text-[color:var(--accent-700)]">Free generator · No signup</p>
      <h1 class="mt-2 font-serif text-h1 text-navy">
        House Rules PDF Generator<span class="period-accent">.</span>
      </h1>
      <p class="mt-3 text-lead text-ink-2 max-w-2xl leading-snug">
        {tool.tagline} Pick from 22 presets or write your own. Generates entirely in
        your browser — nothing uploaded, nothing tracked.
      </p>
    </header>

    <section class="mt-7">
      <HouseRulesGenerator client:visible />
    </section>

    <div class="mt-5 flex flex-wrap gap-3">
      <PdfDownloadButton
        toolSlug="house-rules-pdf"
        filename="house-rules"
        magnet="house-rules-pdf"
        label="Download PDF"
      />
      <PinterestPinButton toolSlug="house-rules-pdf" description="Free Airbnb house rules PDF generator" />
    </div>

    <AdSlot siteConfig={siteConfig} location="in-content" />

    <section class="mt-9 prose">
      <h2 class="font-serif text-h2 text-navy">Why house rules belong in writing</h2>
      <p class="mt-3 text-body text-graphite leading-relaxed">
        A guest who breaks a rule "they didn't see" is a guest you can't easily charge for damage.
        Booking-platform dispute resolution favors hosts who can show that house rules were posted,
        signed, and visible inside the property. A framed copy on the fridge — or tucked into the
        welcome book — turns a vague expectation into a documented one.
      </p>
    </section>

    <section class="mt-9">
      <h2 class="font-serif text-h2 text-navy">How to use the printable</h2>
      <ul class="mt-4 space-y-3 text-body text-graphite leading-relaxed">
        <li><strong class="text-navy">Print one for inside the property.</strong> Frame it or magnet it to the fridge. Visibility is half the enforcement.</li>
        <li><strong class="text-navy">Send a digital copy with the booking confirmation.</strong> Most platforms let you attach a PDF in the pre-arrival message.</li>
        <li><strong class="text-navy">Update annually.</strong> Quiet hours, occupancy rules, and pet policies drift. Re-generate every January.</li>
        <li><strong class="text-navy">Don't legalize the language.</strong> "Please don't smoke" reads better than "smoking is strictly prohibited under penalty of forfeiture."</li>
      </ul>
    </section>

    <RelatedPosts toolKey="house-rules-pdf" />

    <EmailCaptureCard
      siteConfig={siteConfig}
      magnet="house-rules-pdf"
      toolSlug="house-rules-pdf"
      headline="Free Welcome Book master template — coming next"
      blurb="The next generator is the multi-page Welcome Book builder. Drop your email and we'll send the editable template the day it ships."
      cta="Email me when it ships"
    />

    <section class="mt-9">
      <h2 class="font-serif text-h2 text-navy">Frequently asked</h2>
      <dl class="mt-4 space-y-5">
        <div>
          <dt class="font-serif text-h3 text-navy">Is the PDF legally binding?</dt>
          <dd class="mt-1 text-body text-graphite leading-relaxed">
            Not by itself — it's property-specific guidance, not a rental agreement.
            For long-stay rentals, consult a local attorney about a separate contract.
          </dd>
        </div>
        <div>
          <dt class="font-serif text-h3 text-navy">Can I add my own logo?</dt>
          <dd class="mt-1 text-body text-graphite leading-relaxed">
            Open the downloaded PDF in Preview, Acrobat, or Word and add a logo
            before printing. Direct logo upload is on the roadmap.
          </dd>
        </div>
        <div>
          <dt class="font-serif text-h3 text-navy">Does it work on mobile?</dt>
          <dd class="mt-1 text-body text-graphite leading-relaxed">
            Yes — the form works on phones. The preview is easier on desktop.
          </dd>
        </div>
      </dl>
    </section>

    <STRLedgerCTA siteConfig={siteConfig} tool="house-rules-pdf" />

    <AdSlot siteConfig={siteConfig} location="footer" />

    <Sidebar siteConfig={siteConfig} items={sidebarItems} current="house-rules-pdf" />
  </article>

  <ClusterFunnelBlock siteConfig={siteConfig} currentCluster="guest-xp" />
</Layout>

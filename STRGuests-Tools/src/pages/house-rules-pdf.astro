---
import Layout from '@/components/chrome/Layout.astro';
import Sidebar from '@/components/chrome/Sidebar.astro';
import ClusterFunnelBlock from '@/components/chrome/ClusterFunnelBlock.astro';
import AdSlot from '@/components/ads/AdSlot.astro';
import EmailCaptureCard from '@/components/funnel/EmailCaptureCard.astro';
import STRLedgerCTA from '@/components/funnel/STRLedgerCTA.astro';
import PdfDownloadButton from '@/components/generator/PdfDownloadButton.astro';
import HouseRulesForm from '@/components/generator/HouseRulesForm.tsx';
import { Content as ToolCopy } from '@/content/tools/house-rules-pdf.mdx';
import { buildWebApplication, buildFAQPage } from '@/lib/seo';
import tools from '@/data/tools.json';

const tool = tools['house-rules-pdf'];

const faqs = [
  {
    question: 'Are house rules legally binding?',
    answer:
      "A signed house-rules sheet is evidence of agreement, but enforceability depends on your jurisdiction's short-term rental regulations and the booking platform's terms. This is not legal advice — consult a local attorney for binding agreements.",
  },
  {
    question: 'Does this work for VRBO and Booking.com too?',
    answer:
      'Yes. The PDF is platform-agnostic. Print it for in-property display, or attach to booking confirmations.',
  },
  {
    question: 'How many rules should I include?',
    answer:
      'Five to ten is usually enough. Guests skim, and density costs compliance. Lead with safety, then property protection, then preferences.',
  },
  {
    question: 'Will this capture my email when I download?',
    answer:
      'No. The PDF download is unconditional. We surface an optional newsletter signup afterward, but the file is yours either way.',
  },
];

const jsonLd = [
  buildWebApplication({
    name: 'Airbnb House Rules PDF Generator',
    description:
      'Free Airbnb house rules PDF generator. Branded printable PDF with checkboxes, check-in/out times, and signature line.',
    toolPath: tool.path,
  }),
  buildFAQPage(faqs),
];
---

<Layout
  title="Airbnb House Rules PDF Generator — strguests.tools"
  description="Free Airbnb house rules PDF generator. Branded printable, checkbox list, check-in/out times, optional signature line. Downloads instantly."
  path="/house-rules-pdf"
  jsonLd={jsonLd}
>
  <article class="generator-page bg-parchment">
    <div class="mx-auto max-w-6xl px-5 pt-9 pb-7 grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-9">
      <div class="min-w-0">
        <header>
          <h1 class="text-h1 font-serif text-navy leading-tight">
            Airbnb House Rules PDF<span class="period-gold">.</span>
          </h1>
          <p class="mt-3 text-lead text-ink-2 max-w-2xl">
            Branded printable rules in 60 seconds. Edit live, download instantly, no signup required.
          </p>
        </header>

        <div class="mt-7">
          <HouseRulesForm client:load />
        </div>

        <PdfDownloadButton
          toolSlug="house-rules-pdf"
          filename="house-rules"
          magnet="house-rules-pdf"
        />

        <AdSlot location="in-content" />

        <div class="prose mt-7 max-w-2xl">
          <ToolCopy />
        </div>

        <EmailCaptureCard
          magnet="strguests-newsletter"
          toolSlug="house-rules-pdf"
        />

        <STRLedgerCTA tool="house-rules-pdf" />

        <AdSlot location="footer" />
      </div>

      <Sidebar current="house-rules-pdf" />
    </div>

    <ClusterFunnelBlock currentCluster="guest-xp" />
  </article>
</Layout>

<style>
  .prose :global(h2) {
    font-family: var(--font-display);
    font-size: var(--t-h2-size);
    color: var(--brand-navy);
    margin-top: 1.6rem;
    margin-bottom: 0.6rem;
  }
  .prose :global(h3) {
    font-family: var(--font-display);
    color: var(--brand-navy);
    margin-top: 1.2rem;
    margin-bottom: 0.4rem;
    font-size: var(--t-h3-size);
  }
  .prose :global(p) {
    margin-bottom: 0.9rem;
    line-height: 1.65;
    color: var(--ink-2);
  }
</style>

---
import Layout from '@/components/chrome/Layout.astro';
import Sidebar from '@/components/chrome/Sidebar.astro';
import ClusterFunnelBlock from '@/components/chrome/ClusterFunnelBlock.astro';
import AdSlot from '@/components/ads/AdSlot.astro';
import EmailCaptureCard from '@/components/funnel/EmailCaptureCard.astro';
import STRLedgerCTA from '@/components/funnel/STRLedgerCTA.astro';
import PdfDownloadButton from '@/components/generator/PdfDownloadButton.astro';
import PinterestPinButton from '@/components/generator/PinterestPinButton.astro';
import CheckInForm from '@/components/generator/CheckInForm.tsx';
import { Content as ToolCopy } from '@/content/tools/check-in-instructions.mdx';
import { buildWebApplication, buildFAQPage } from '@/lib/seo';
import tools from '@/data/tools.json';

const tool = tools['check-in-instructions'];

const faqs = [
  {
    question: 'Are arrival photos uploaded to a server?',
    answer:
      'No. Photos are read in your browser via the FileReader API and embedded directly into the PDF. They never leave your device.',
  },
  {
    question: 'What photo formats are supported?',
    answer:
      'JPEG and PNG. HEIC files (typical iPhone exports) need to be converted first — most iOS apps will export to JPEG when saving.',
  },
  {
    question: 'How big can the PDF get?',
    answer:
      'Each photo adds 100KB–500KB. A typical check-in PDF with 5 steps and 2 photos lands around 1MB — email attachment-friendly.',
  },
  {
    question: 'Can this send the PDF to guests automatically?',
    answer:
      "No automation layer here. Save the PDF and attach it to your booking platform's pre-arrival message, or upload to your guidebook software.",
  },
];

const jsonLd = [
  buildWebApplication({
    name: 'Airbnb Check-in Instructions PDF Generator',
    description:
      'Free Airbnb check-in instructions PDF generator. Branded printable with door codes, parking, numbered steps, and optional photos.',
    toolPath: tool.path,
  }),
  buildFAQPage(faqs),
];
---

<Layout
  title="Airbnb Check-in Instructions PDF — strguests.tools"
  description="Free check-in instructions PDF generator. Door codes, parking, numbered arrival steps with photos, and Wi-Fi tail page. Photos stay in your browser."
  path="/check-in-instructions"
  jsonLd={jsonLd}
>
  <article class="generator-page bg-parchment">
    <div class="mx-auto max-w-6xl px-5 pt-9 pb-7 grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-9">
      <div class="min-w-0">
        <header>
          <h1 class="text-h1 font-serif text-navy leading-tight">
            Airbnb Check-in Instructions<span class="period-gold">.</span>
          </h1>
          <p class="mt-3 text-lead text-ink-2 max-w-2xl">
            Door code, parking, numbered arrival steps with photos, Wi-Fi tail page. Built in your browser.
          </p>
        </header>

        <div class="mt-7">
          <CheckInForm client:load />
        </div>

        <div class="flex flex-wrap gap-3 items-center">
          <PdfDownloadButton
            toolSlug="check-in-instructions"
            filename="check-in-instructions"
            magnet="check-in-pdf"
          />
          <PinterestPinButton
            toolSlug="check-in-instructions"
            description="Free Airbnb check-in instructions PDF. Door codes, parking, photos, Wi-Fi tail page. No signup. strguests.tools"
          />
        </div>

        <AdSlot location="in-content" />

        <div class="prose mt-7 max-w-2xl">
          <ToolCopy />
        </div>

        <EmailCaptureCard
          magnet="strguests-newsletter"
          toolSlug="check-in-instructions"
        />

        <STRLedgerCTA tool="check-in-instructions" />

        <AdSlot location="footer" />
      </div>

      <Sidebar current="check-in-instructions" />
    </div>

    <ClusterFunnelBlock currentCluster="guest-xp" />
  </article>
</Layout>

<style>
  .prose :global(h2) { font-family: var(--font-display); font-size: var(--t-h2-size); color: var(--brand-navy); margin-top: 1.6rem; margin-bottom: 0.6rem; }
  .prose :global(h3) { font-family: var(--font-display); color: var(--brand-navy); margin-top: 1.2rem; margin-bottom: 0.4rem; font-size: var(--t-h3-size); }
  .prose :global(p) { margin-bottom: 0.9rem; line-height: 1.65; color: var(--ink-2); }
</style>

---
// Wordmark — "STR Guests" as the main brand identity, "tools" as the small
// trailing category descriptor with a terracotta period accent. Single
// component so Header and Footer never drift apart and the OG image
// generator can import the same proportions.
//
// Treatment: "STR Guests" in Cormorant Garamond medium reads as
// editorial/hospitality-warm. Per cluster style guide §1, hierarchy is
// {Brand Name} main + .tld trailing — NOT eyebrow + main (rejected variant).
// Per strguests delta, the wordmark IS the most visible accent surface,
// so the terracotta has to read as a brand color at 28px serif weight,
// not just as a UI tint.

interface Props {
  /** Visual scale. */
  size?: 'sm' | 'md' | 'lg';
  /** Surface the wordmark sits on; controls 'STR Guests' color. */
  theme?: 'navy' | 'parchment';
  /** Render as a link to home (default true). When false, plain text. */
  asLink?: boolean;
  /** Optional href override (defaults to "/"). */
  href?: string;
  /** Class to extend the wrapping element. */
  class?: string;
}

const { size = 'md', theme = 'navy', asLink = true, href = '/', class: className = '' } = Astro.props;

const sizes = {
  sm: { main: 'text-[20px]', tail: 'text-[10px]', track: 'tracking-[0.28em]' },
  md: { main: 'text-[28px]', tail: 'text-[12px]', track: 'tracking-[0.28em]' },
  lg: { main: 'text-[40px]', tail: 'text-[14px]', track: 'tracking-[0.28em]' },
};

const themes = {
  navy:      { main: 'text-[color:var(--accent-700)]', tail: 'text-ink-3',           dot: 'text-[color:var(--accent-500)]' },
  parchment: { main: 'text-[color:var(--accent-500)]', tail: 'text-parchment opacity-70', dot: 'text-parchment' },
};

const s = sizes[size];
const t = themes[theme];

const Tag = asLink ? 'a' : 'span';
const linkProps = asLink
  ? { href, 'aria-label': 'STR Guests Tools — home', class: 'no-underline' }
  : {};
---
<Tag
  {...linkProps}
  class:list={[
    'inline-flex items-baseline gap-1',
    className,
  ]}
>
  <span
    class:list={[
      'font-serif font-medium leading-none whitespace-nowrap',
      s.main,
      t.main,
    ]}
  >
    STR Guests
  </span>
  <span
    class:list={[
      'font-sans uppercase font-semibold leading-none',
      s.tail,
      s.track,
    ]}
    aria-hidden="true"
  >
    <span class={t.dot}>.</span><span class={t.tail}>tools</span>
  </span>
</Tag>

---
import { loadCatalog, findTool, type Tool } from '@str/catalog';

interface Props {
  toolId: string;
  heading?: string;
  limit?: number;
}

const { toolId, heading = 'Related tools across the empire', limit = 4 } = Astro.props;

const { catalog } = loadCatalog();
const current = findTool(catalog, toolId);

const candidates: Tool[] = [];
if (current) {
  const ids = [...current.related, ...current.upsells];
  for (const id of ids) {
    const t = findTool(catalog, id);
    if (t && t.status === 'shipped' && t.site !== current.site) {
      if (!candidates.find((c) => c.id === t.id)) candidates.push(t);
    }
    if (candidates.length >= limit) break;
  }
}

const sitesById = new Map(catalog.sites.map((s) => [s.id, s] as const));
---

{candidates.length > 0 && (
  <section class="my-12">
    <h2 class="text-xl font-semibold mb-4">{heading}</h2>
    <ul class="grid sm:grid-cols-2 gap-3">
      {candidates.map((t) => {
        const site = sitesById.get(t.site)!;
        const url = `https://${site.domain}${t.path}`;
        return (
          <li class="border rounded-lg p-4 hover:shadow-md transition">
            <a
              href={url}
              data-event="upsell_clicked"
              data-tool-id={t.id}
              data-tool-site={t.site}
              class="block"
            >
              <div class="text-xs uppercase tracking-wide text-gray-500">{site.displayName}</div>
              <div class="font-medium mt-1">{t.shortTitle ?? t.title}</div>
              <p class="text-sm text-gray-600 mt-1 line-clamp-2">{t.description}</p>
            </a>
          </li>
        );
      })}
    </ul>
  </section>
)}

---
// AppSidebar — site-level Sidebar that shows shortName + tagline per item.
// Preserves the 2-line card style from the in-tree chrome/Sidebar.
// Replaces @str/ui-chrome/Sidebar for STRGuests-Tools pages.

import tools from '@/data/tools.json';
import type { SiteConfig } from '@str/seo';

interface Props {
  /** Key of the current tool — excluded from related links. */
  current: keyof typeof tools;
  /** Accepted for API compat with @str/ui-chrome/Sidebar; not used by this component. */
  siteConfig?: SiteConfig;
}

const { current } = Astro.props;
const others = Object.entries(tools).filter(([key]) => key !== current).slice(0, 6);
---
<aside class="related-generators" aria-label="Related generators">
  <p class="label text-navy">Related generators</p>

  <ul class="mt-4 space-y-3">
    {others.map(([_key, t]) => (
      <li>
        <a
          href={t.path}
          class="block group rounded-md border border-rule bg-parchment-light p-4 no-underline hover:border-[color:var(--accent-500)] hover:shadow-card transition-all duration-std"
        >
          <p class="text-ui text-navy group-hover:text-[color:var(--accent-700)] font-semibold">{t.shortName}</p>
          <p class="mt-1 text-caption text-ink-2 leading-snug">{t.tagline}</p>
        </a>
      </li>
    ))}
  </ul>
</aside>

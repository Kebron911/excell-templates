---
// AppLayout — thin wrapper around @str/ui-chrome/Layout that injects
// STRGuests-specific global styles via the head-styles slot.
// Import this instead of @str/ui-chrome/Layout.astro in all pages.

import '@/styles/global.css';
import '@/styles/print.css';
import PkgLayout from '@str/ui-chrome/Layout.astro';
import type { SiteConfig } from '@str/seo';

interface Props {
  siteConfig: SiteConfig;
  title: string;
  description: string;
  path: string;
  ogImage?: string;
  noIndex?: boolean;
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const { siteConfig, title, description, path, ogImage, noIndex, jsonLd } = Astro.props;
---
<PkgLayout
  siteConfig={siteConfig}
  title={title}
  description={description}
  path={path}
  ogImage={ogImage}
  noIndex={noIndex}
  jsonLd={jsonLd}
>
  <slot name="head-styles" slot="head-styles" />
  <slot name="head-extra" slot="head-extra" />
  <slot name="header-cta" slot="header-cta" />
  {/* FunnelBand: must be explicitly provided because the package Layout passes an
      empty named-slot forward to FunnelBand which suppresses its fallback content.
      We inject the identical HTML here so the "Built by The STR Ledger" band renders. */}
  <section class="funnel-band border-t border-rule bg-parchment-light" slot="funnel-banner-override">
    <div class="mx-auto max-w-6xl px-5 py-4 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
      <p class="text-small text-ink-2 leading-snug">
        <span class="label text-navy mr-2">Built by</span>
        <a
          href="https://thestrledger.com"
          class="font-serif text-h3 text-navy no-underline hover:text-navy-tint transition-colors duration-std"
        >
          The STR Ledger<span class="period-accent">.</span>
        </a>
        <span class="text-ink-2"> Excel templates and PDFs for short-term rental finance.</span>
      </p>
      <a
        href="https://thestrledger.com?utm_source=strguests-tools&utm_medium=funnel-band"
        class="text-ui text-navy no-underline whitespace-nowrap hover:text-[color:var(--accent-700)] group"
      >
        Visit The STR Ledger
        <span class="text-[color:var(--accent-500)] inline-block transition-transform duration-std group-hover:translate-x-0.5" aria-hidden="true"> →</span>
      </a>
    </div>
  </section>
  <slot name="footer-extra" slot="footer-extra" />
  <slot />
</PkgLayout>

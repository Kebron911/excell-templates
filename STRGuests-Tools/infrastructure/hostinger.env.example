# strguests.tools — Hostinger runtime env (Phase 6 Task 35)
#
# Copy this file to /home/<user>/strguests-api/.env on the Hostinger box.
# DO NOT commit a real .env. The file is read by pm2 / the Express process.
#
# Phase 6 launch posture: NO MySQL. Server boots, /api/health responds, every
# DB-backed route returns 503 rate_limit_unavailable until MySQL is provisioned
# (Phase 6.5 follow-up).

# ---- Server runtime ---------------------------------------------------------
NODE_ENV=production
PORT=3001

# ---- AI provider — leave blank for first-launch dark-mode -------------------
# Set ANTHROPIC_API_KEY once you've cleared the Anthropic quota check.
ANTHROPIC_API_KEY=
# Override the default model (claude-haiku-4-5) without touching code.
ANTHROPIC_MODEL=

# ---- Server secrets (REQUIRED before any verify-email or rate-limit hits) ---
# 32+ random bytes. Generate with: openssl rand -hex 32
EMAIL_VERIFY_SECRET=
# Mixed into sha256(IP). Same generator. Rotate sparingly.
IP_HASH_SALT=

# ---- MySQL — INTENTIONALLY ABSENT for the first launch ----------------------
# Leave the MYSQL_* vars unset. The rate-limit middleware will fail closed
# (503 rate_limit_unavailable) on every DB-backed call. /api/health stays up.
# Provision MySQL on Hostinger Business and add MYSQL_* in a follow-up deploy.
# MYSQL_HOST=
# MYSQL_PORT=3306
# MYSQL_USER=
# MYSQL_PASSWORD=
# MYSQL_DATABASE=strguests

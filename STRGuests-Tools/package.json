{
  "name": "strguests-tools",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && node ./scripts/build-pins.mjs && node ./scripts/build-og.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "typecheck": "astro check && tsc --noEmit && tsc -p server/tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:install": "playwright install --with-deps chromium",
    "lint": "eslint --ext .ts,.tsx,.astro src tests server",
    "server:dev": "tsx watch server/index.ts",
    "server:build": "tsc -p server/tsconfig.json",
    "server:start": "node server/dist/index.js",
    "db:migrate": "tsx server/db/migrate.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@astrojs/mdx": "^5.0.4",
    "@astrojs/react": "^5.0.4",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/tailwind": "^6.0.2",
    "@resvg/resvg-js": "^2.6.2",
    "astro": "^6.2.2",
    "astro-seo": "^0.8.4",
    "cookie": "^0.6.0",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "mysql2": "^3.10.0",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "satori": "^0.10.13",
    "sharp": "^0.33.4",
    "tailwindcss": "^3.4.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@types/cookie": "^0.6.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "eslint": "^8.57.0",
    "eslint-plugin-astro": "^1.2.3",
    "tsx": "^4.16.0",
    "typescript": "^5.5.3",
    "vitest": "^1.6.0"
  },
  "packageManager": "pnpm@9.6.0"
}

# strops.tools — environment variables
#
# Copy this file to `.env` and fill in real values for local dev.
# Production values are configured at the host (Hostinger / Vercel / etc).
# All keys are PUBLIC_ — exposed to the client. Server-only secrets must
# never be added here. Astro inlines anything starting with PUBLIC_ at
# build time (`import.meta.env.PUBLIC_*`).
#
# Behavior with each var unset:
#   - PUBLIC_GA4_ID unset      → GA4 snippet not emitted; trackEvent() is a silent no-op.
#   - PUBLIC_ESP_WEBHOOK unset → EmailCaptureCard logs the payload to console (no POST).
#   - PUBLIC_ADSENSE_*  unset  → AdSlot renders nothing (no script, no slot).

# Google Analytics 4 measurement ID (cluster-shared property w/ cross-domain linker).
# Format: G-XXXXXXXXXX. Single env-var swap pre-deploy ships analytics live.
PUBLIC_GA4_ID=G-XXXXXXXXXX

# ESP webhook endpoint for the EmailCaptureCard form (Buttondown / ConvertKit / Mailchimp / n8n).
# Receives JSON: { email, magnet, source, tool, utm_*, ts }. POST only.
PUBLIC_ESP_WEBHOOK=

# AdSense — gated, off by default until the site has traffic + content reviewed.
PUBLIC_ADSENSE_ENABLED=false
PUBLIC_ADSENSE_CLIENT=

---
// AffiliateCard — strops-novel. Single-vendor recommendation card. Reads as
// "we use this, here's why" — not as a paid placement. Inline FTC disclosure.
// Soft, after-value placement (no top-of-page banner — that's strbuyers' pattern).
//
// Click logs to GA4 only (no /api/click endpoint in strops; static-only site).

import affiliates from '@/data/affiliates.json';

interface Props {
  /** Tool slug — used to look up which vendor to surface. */
  tool: string;
  /** Optional vendor id override; otherwise uses first vendor in byTool list. */
  vendorId?: string;
  /** Optional override for the "We use this because..." line. */
  rationale?: string;
}

const { tool, vendorId, rationale } = Astro.props;

const byTool = affiliates.byTool as Record<string, string[]>;
const vendors = affiliates.vendors as Record<string, any>;

const id = vendorId ?? (byTool[tool] ?? [])[0];
const v = id ? vendors[id] : undefined;
---
{v && (
  <aside class="affiliate-card my-7 print:hidden" aria-label="Vendor recommendation">
    <a
      href={v.url}
      class="block group rounded-md border border-rule bg-parchment-light p-5 no-underline hover:border-[color:var(--accent-500)] hover:shadow-card transition-all duration-std"
      data-affiliate-card
      data-vendor={id}
      data-tool={tool}
      data-category={v.category}
      rel="sponsored noopener"
      target="_blank"
    >
      <p class="label text-[color:var(--accent-700)]">Vendor we use</p>
      <p class="mt-3 font-serif text-h3 text-navy group-hover:text-[color:var(--accent-700)] leading-snug">{v.name}</p>
      <p class="mt-2 text-small text-ink-2 leading-snug">{rationale ?? v.tagline}</p>
      <p class="mt-3 text-caption text-ink-3 italic leading-snug">{v.disclosure}</p>
      <p class="mt-3 text-caption text-[color:var(--accent-700)] flex items-center gap-1">
        Visit {v.name}
        <span class="inline-block transition-transform duration-std group-hover:translate-x-0.5" aria-hidden="true">→</span>
      </p>
    </a>
  </aside>
)}

<script>
  document.querySelectorAll<HTMLAnchorElement>('a[data-affiliate-card]').forEach((card) => {
    card.addEventListener('click', () => {
      (window as any).gtag?.('event', 'affiliate_click', {
        vendor: card.dataset.vendor,
        tool: card.dataset.tool,
        category: card.dataset.category,
      });
    });
  });
</script>

---
// PageHero — renders a 1200x630 WebP hero from /images/pages/<slug>/
// Generated by scripts/page-hero.mjs. Falls back to nothing if the file
// is missing (lets pages render before images are committed).
//
// Usage:
//   <PageHero slug="welcome-book" alt="Welcome Book Builder for short-term rental hosts" />

interface Props {
  slug: string;
  alt: string;
  /** Optional max-width tailwind class. Default matches the cluster page width. */
  maxWidth?: string;
  /** Optional eager/lazy loading override. Default: eager (above the fold). */
  loading?: 'eager' | 'lazy';
}

const { slug, alt, maxWidth = 'max-w-6xl', loading = 'eager' } = Astro.props;
const hero = `/images/pages/${slug}/hero.webp`;
const thumb = `/images/pages/${slug}/thumb.webp`;
---

<figure class:list={['mx-auto px-5 mt-5 mb-7', maxWidth]}>
  <picture>
    <source media="(min-width: 768px)" srcset={hero} type="image/webp" />
    <img
      src={thumb}
      alt={alt}
      width="1200"
      height="630"
      loading={loading}
      decoding="async"
      class="w-full h-auto rounded-md border border-rule"
    />
  </picture>
</figure>

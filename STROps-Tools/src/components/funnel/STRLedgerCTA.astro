---
// STRLedgerCTA — one per page, copy varies by tool, deep-links to the
// matching SKU on thestrledger.com with UTM tracking. strops.tools is the
// "running" stage — the natural funnel into The STR Ledger is for hosts who
// realize they need to track this stuff in a spreadsheet, not in their head.
//
// Per design spec: contextual cluster bridge. Below the fold, after value
// has been delivered. Single button, single link, no carousel.

interface Props {
  /** Tool slug (matches keys in src/data/tools.json). */
  tool: string;
  /** Override copy if needed. Defaults below. */
  headline?: string;
  blurb?: string;
  cta?: string;
  /** Override target SKU path if the default mapping isn't right. */
  skuPath?: string;
}

const { tool, headline, blurb, cta, skuPath } = Astro.props;

// Per-tool copy + STR Ledger SKU mapping. Editable here as catalog evolves.
const defaults: Record<string, { headline: string; blurb: string; cta: string; skuPath: string }> = {
  'turnover-scheduler': {
    headline: 'Track every turnover, every property, every month.',
    blurb: 'The STR Ledger Turnover Tracker logs cleaner cost, time, and notes per stay — so you see margin per turnover, not just an average.',
    cta: 'See the turnover tracker',
    skuPath: '/products/cleaning-cost-per-turnover',
  },
  'cleaner-dispatch': {
    headline: 'Track cleaner pay vs. cleaning fees collected.',
    blurb: 'The STR Ledger Cleaning Cost Tracker shows margin per turnover and where dispatch costs eat your fee math.',
    cta: 'See the cleaning tracker',
    skuPath: '/products/cleaning-cost-per-turnover',
  },
  'smart-lock-codes': {
    headline: 'Track key-code rotations against booking IDs.',
    blurb: 'The STR Ledger Operations Log keeps a paper trail of code rotations, lockouts, and access events — useful for both incidents and tax records.',
    cta: 'See the operations log',
    skuPath: '/products/operations-log',
  },
  'linen-par': {
    headline: 'Track linen replacement and laundry cost per turnover.',
    blurb: 'The STR Ledger Supplies Workbook reconciles par-level math against actual restock receipts so you stop guessing.',
    cta: 'See the supplies workbook',
    skuPath: '/products/supplies-workbook',
  },
  'restock-calculator': {
    headline: 'Reconcile restock spending against booking volume.',
    blurb: 'The STR Ledger Supplies Workbook tracks consumable costs per booking — so you see if your reorder rhythm matches your math.',
    cta: 'See the supplies workbook',
    skuPath: '/products/supplies-workbook',
  },
  'damage-cost-lookup': {
    headline: 'Track damage claims and replacement costs.',
    blurb: 'The STR Ledger Damage Log captures incident, claim status, payout, and replacement cost — the paper trail Airbnb Resolution Center expects.',
    cta: 'See the damage log',
    skuPath: '/products/damage-log',
  },
  'maintenance-schedule': {
    headline: 'Stop forgetting the HVAC service date.',
    blurb: 'The STR Ledger Maintenance Calendar tracks recurring tasks, vendor info, and last-done dates per property.',
    cta: 'See the maintenance calendar',
    skuPath: '/products/maintenance-calendar',
  },
};

const fallback = {
  headline: 'Track this for real in The STR Ledger.',
  blurb: 'Excel templates and PDFs that turn these tools into your monthly bookkeeping rhythm.',
  cta: 'Browse The STR Ledger',
  skuPath: '/',
};

const conf = defaults[tool] ?? fallback;
const finalHeadline = headline ?? conf.headline;
const finalBlurb = blurb ?? conf.blurb;
const finalCta = cta ?? conf.cta;
const finalSkuPath = skuPath ?? conf.skuPath;

const href = `https://thestrledger.com${finalSkuPath}?utm_source=strops-tools&utm_medium=cta&utm_content=${encodeURIComponent(tool)}`;
---
<aside class="str-ledger-cta my-7 print:hidden" aria-label="Related product on The STR Ledger">
  <div class="rounded-md surface-navy p-6">
    <p class="label text-accent-soft">From The STR Ledger</p>
    <p class="mt-3 font-serif text-h3 text-parchment max-w-2xl leading-snug">
      {finalHeadline}
    </p>
    <p class="mt-3 text-small text-parchment opacity-90 max-w-2xl leading-snug">
      {finalBlurb}
    </p>
    <a
      href={href}
      class="mt-5 inline-flex items-center gap-2 rounded-md bg-accent text-parchment px-5 py-2.5 text-ui no-underline hover:bg-accent-soft hover:text-navy transition-colors duration-std focus:outline-none focus:shadow-focus"
      data-str-ledger-cta
      data-tool={tool}
    >
      {finalCta}
      <span aria-hidden="true">→</span>
    </a>
  </div>
</aside>

<script>
  document.querySelectorAll<HTMLAnchorElement>('a[data-str-ledger-cta]').forEach((a) => {
    a.addEventListener('click', () => {
      (window as any).gtag?.('event', 'str_ledger_cta_clicked', {
        tool: a.dataset.tool,
      });
    });
  });
</script>

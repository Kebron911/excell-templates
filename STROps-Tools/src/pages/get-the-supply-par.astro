---
import Layout from '@/layouts/Layout.astro';
import tools from '@data/tools.json';

type ToolEntry = { title: string; magnet: string; blurb: string; affiliates: string[] };
const magnet = 'supply-par';
const file = '/pdf/supply-par-v0.pdf';
const title = 'STR Supply Par-Level Sheet (PDF)';
const blurb =
  "Per-bedroom par levels for sheets, towels, paper goods, kitchen consumables, and amenity restocks. Quietly answers the only question that matters on changeover day: do we have enough?";
const url = 'https://strops.tools/get-the-supply-par';
const ogImage = '/og/get-the-supply-par.png';

const pairs = Object.entries(tools as Record<string, ToolEntry>)
  .filter(([, t]) => t.magnet === magnet);
---
<Layout title={title} description={blurb} canonical={url} ogImage={ogImage}>
  <article class="prose mx-auto max-w-2xl px-6 py-12">
    <div class="text-label uppercase tracking-widest text-accent mb-2">Free download</div>
    <h1>{title}</h1>
    <p class="lead">{blurb}</p>

    {/* PAUSED — ESP webhook unset. Restore the original <form class="magnet-capture">
        block when the cluster lead-router (n8n) is live + tested. */}
    <div class="border border-rule bg-parchment-alt p-6 my-8">
      <p class="font-semibold text-navy mb-1">Email delivery is paused.</p>
      <p class="text-sm text-ink2">
        We're finishing the email pipeline this week. The stub preview below is the
        same file you'd receive — grab it directly, or email
        <a href="mailto:hello@thestrledger.com?subject=Send%20me%20the%20Supply%20Par%20Sheet" class="underline decoration-accent underline-offset-4">hello@thestrledger.com</a>
        if you want the polished version.
      </p>
    </div>

    <p>
      <a href={file} class="underline decoration-accent underline-offset-4" data-magnet={magnet}>
        Download stub preview &rarr;
      </a>
    </p>

    <h2 id="pairs">Tools that pair with this par sheet</h2>
    <ul>
      {pairs.map(([slug, t]) => (
        <li>
          <a href={`/${slug}`} class="font-semibold">{t.title}</a> — <span class="text-ink2">{t.blurb}</span>
        </li>
      ))}
    </ul>
  </article>

  <script>
    import { track } from '@lib/analytics';

    document.querySelectorAll<HTMLFormElement>('form.magnet-capture').forEach((form) => {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        const magnetName = form.getAttribute('data-magnet') || '';
        const emailInput = form.querySelector<HTMLInputElement>('input[name="email"]');
        const status = form.querySelector<HTMLElement>('.magnet-status');
        if (!emailInput || !emailInput.checkValidity()) {
          if (status) status.textContent = 'Please enter a valid email address.';
          return;
        }
        const espEndpoint = form.getAttribute('action') || '';
        track('magnet_captured', { magnet: magnetName, esp: espEndpoint ? 'configured' : 'stub' });

        if (espEndpoint) {
          fetch(espEndpoint, {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify({ email: emailInput.value, magnet: magnetName }),
          }).catch(() => { /* swallow */ });
        }
        if (status) status.textContent = 'Thanks — check your inbox. The stub preview is linked below in the meantime.';
        emailInput.value = '';
      });
    });
  </script>
</Layout>

---
import Layout from '@/layouts/Layout.astro';
import AppSidebar from '@str/ui-chrome/AppSidebar.astro';
import { siteConfig } from '@/data/site.config';
import { sidebarItems } from '@/data/sidebar-items';
import DamageCostLookup from '@components/calculators/DamageCostLookup.tsx';
import AdSlot from '@str/ui-funnel/AdSlot.astro';
import EmailCaptureCard from '@str/ui-funnel/EmailCaptureCard.astro';
import STRLedgerCTA from '@str/ui-funnel/STRLedgerCTA.astro';
import RelatedPosts from '@components/funnel/RelatedPosts.astro';
import { magnetCopyFor } from '@/data/magnet-copy';
import JsonLd from '@components/seo/JsonLd.astro';
import { buildWebApplication, buildFAQPage } from '@str/seo';

const url = 'https://strops.tools/damage-cost-lookup';
const magnetCopy = magnetCopyFor('maintenance-checklist');
const faqs = [
  { q: 'Where do these costs come from?', a: 'Hand-compiled from major retailer pricing snapshots. Always verify against current quotes for your market.' },
  { q: 'Are these wholesale or retail?', a: 'Retail mid-market — what you would pay walking into a Home Depot or ordering from Wayfair.' },
  { q: 'How often is the catalog updated?', a: 'Each item carries a "lastVerified" date. Major appliances and furniture are reviewed quarterly.' },
];
---
<Layout title="Airbnb Damage Cost Lookup — strops.tools" description="Replacement cost reference for common Airbnb furniture, electronics, and finishes." canonical={url} ogImage="/og/damage-cost-lookup.png">
  <Fragment slot="head">
    <JsonLd data={[
      buildWebApplication(siteConfig, { name: 'Airbnb Damage Cost Lookup', description: 'Replacement cost reference for common Airbnb items.', toolPath: '/damage-cost-lookup', applicationCategory: 'BusinessApplication' }),
      buildFAQPage(faqs.map(f => ({ question: f.q, answer: f.a }))),
    ]} />
  </Fragment>
  <div class="mx-auto max-w-6xl px-6 py-10 flex gap-10">
    <article class="flex-1 prose">
      <h1>Damage Cost Lookup</h1>
      <p class="lead">Search the replacement-cost catalog before you file the AirCover claim — know what you're asking for.</p>
      <DamageCostLookup client:visible />
      <AdSlot siteConfig={siteConfig} location="in-content" />
      <h2>How it works</h2>
      <p>Each row is a hand-compiled retail mid-market price range plus expected lifespan. Click any row to open the deep-dive page for that item with brand recommendations and how-to-replace guidance.</p>
      <RelatedPosts toolKey="damage-cost-lookup" variant="section" />
      <EmailCaptureCard siteConfig={siteConfig} magnet="maintenance-checklist" toolSlug="damage-cost-lookup" headline={magnetCopy.headline} blurb={magnetCopy.blurb} cta={magnetCopy.cta} />
      <h2>FAQ</h2>
      {faqs.map(f => <div><h3>{f.q}</h3><p>{f.a}</p></div>)}
      <STRLedgerCTA siteConfig={siteConfig} tool="damage-cost-lookup" />
      <AdSlot siteConfig={siteConfig} location="footer" />
    </article>
    <AppSidebar siteConfig={siteConfig} items={sidebarItems} current="damage-cost-lookup" />
  </div>
</Layout>

---
import Layout from '@/components/chrome/Layout.astro';
import ClusterFunnelBlock from '@/components/chrome/ClusterFunnelBlock.astro';
import AdSlot from '@/components/ads/AdSlot.astro';
import EmailCaptureCard from '@/components/funnel/EmailCaptureCard.astro';
import STRLedgerCTA from '@/components/funnel/STRLedgerCTA.astro';
import AffiliateCard from '@/components/affiliate/AffiliateCard.astro';
import tools from '@/data/tools.json';

const toolsList = Object.values(tools);
---

<Layout
  title="STR Ops Tools — Free tools for active short-term rental operators"
  description="Seven free operational tools for Airbnb and Vrbo hosts: turnover scheduler, cleaner dispatch, smart lock codes, linen par, restock, damage cost lookup, maintenance schedule. No signup, no popups."
  path="/"
>
  {/* Hero — short, single CTA: pick a tool. */}
  <section class="bg-parchment">
    <div class="mx-auto max-w-6xl px-5 pt-12 pb-9">
      <p class="label text-accent-deep">Built by The STR Ledger</p>
      <h1 class="mt-3 text-h1 font-serif text-navy max-w-3xl leading-tight">
        Free tools for short-term rental operators<span class="period-accent">.</span>
      </h1>
      <p class="mt-4 text-lead text-ink-2 max-w-2xl">
        Seven operational tools. PDF outputs. Zero pop-ups. No signup. Pick one below.
      </p>
    </div>
  </section>

  {/* Tool picker — page IS the menu. 3 cols at lg, 2 at sm, 1 below sm.
      Per Cluster Style Guide §4. */}
  <section class="bg-parchment-light border-t border-rule">
    <div class="mx-auto max-w-6xl px-5 py-9">
      <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {toolsList.map(t => (
          <li>
            <a
              href={t.path}
              class="group block h-full rounded-md border border-rule bg-parchment p-5 no-underline hover:border-accent hover:shadow-card transition-all duration-std focus:outline-none focus:shadow-focus"
            >
              <p class="font-serif text-h3 text-navy leading-snug">{t.shortName}</p>
              <p class="mt-2 text-small text-ink-2 leading-snug">{t.tagline}</p>
              <p class="mt-4 text-caption text-accent-deep group-hover:text-accent flex items-center gap-1">
                Open
                <span class="inline-block transition-transform duration-std group-hover:translate-x-0.5" aria-hidden="true">→</span>
              </p>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  {/* Why this exists — short, no fluff */}
  <section class="bg-parchment border-t border-rule">
    <div class="mx-auto max-w-6xl px-5 py-9 grid grid-cols-1 md:grid-cols-3 gap-7">
      <div>
        <p class="label text-accent-deep">Operational, not flashy</p>
        <p class="mt-3 font-serif text-h3 text-navy leading-snug">Tools, not theater.</p>
        <p class="mt-2 text-small text-ink-2 leading-snug">
          Built for hosts who need to ship a turnover schedule, not for SaaS landing pages with stock photos.
        </p>
      </div>
      <div>
        <p class="label text-accent-deep">Indexable & shareable</p>
        <p class="mt-3 font-serif text-h3 text-navy leading-snug">URL state, every input.</p>
        <p class="mt-2 text-small text-ink-2 leading-snug">
          Bookmark a turnover scenario, share dispatch with your cleaner, hand a maintenance schedule to your handyman.
        </p>
      </div>
      <div>
        <p class="label text-accent-deep">Print + PDF</p>
        <p class="mt-3 font-serif text-h3 text-navy leading-snug">For the laundry room wall.</p>
        <p class="mt-2 text-small text-ink-2 leading-snug">
          Cleaner SOPs and maintenance schedules ship as PDFs. Print them, tape them up, get on with running the property.
        </p>
      </div>
    </div>
  </section>

  <ClusterFunnelBlock currentCluster="operations" />

  {/* Phase 1 verification preview — collapsed details, removed when Phase 4
      ships the real landing. Per Cluster Style Guide §6. */}
  <section class="bg-parchment border-t border-rule">
    <div class="mx-auto max-w-6xl px-5 py-9">
      <details>
        <summary class="cursor-pointer">
          <span class="label text-accent-deep">Phase 1 preview</span>
          <span class="text-ui text-ink-2 ml-2">Show monetization primitives (AdSlot · EmailCaptureCard · STRLedgerCTA · AffiliateCard · AdSlot)</span>
        </summary>
        <div class="mt-5 space-y-5">
          <AdSlot location="in-content" />
          <EmailCaptureCard
            magnet="cleaner-sop-pdf"
            toolSlug="landing"
          />
          <STRLedgerCTA tool="turnover-scheduler" />
          <AffiliateCard vendor="august" tool="smart-lock-codes" />
          <AdSlot location="footer" />
        </div>
      </details>
    </div>
  </section>
</Layout>

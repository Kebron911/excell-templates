---
import Layout from '@/components/chrome/Layout.astro';
import ClusterFunnelBlock from '@/components/chrome/ClusterFunnelBlock.astro';
import AdSlot from '@/components/ads/AdSlot.astro';
import tools from '@/data/tools.json';

type Tool = {
  name: string;
  shortName: string;
  tagline: string;
  blurb: string;
  path: string;
  primaryKeyword: string;
  category: string;
  magnet: string;
  affiliates: string[];
};

const toolsList = Object.values(tools as Record<string, Tool>);

const magnets = [
  {
    href: '/cleaner-sop',
    title: 'STR Cleaner SOP',
    blurb: 'Printable turnover SOP for cleaning teams.',
  },
  {
    href: '/supply-par',
    title: 'Supply Par-Level Sheet',
    blurb: 'Linen + consumable par levels per property.',
  },
  {
    href: '/maintenance-checklist',
    title: 'Maintenance Checklist',
    blurb: 'Annual + seasonal recurring tasks for an STR.',
  },
];
---

<Layout
  title="strops.tools — free tools for active short-term rental operators"
  description="Seven free operational tools and three printable PDFs for short-term rental hosts running properties: turnover scheduler, cleaner dispatch, smart lock codes, linen par, restock, damage cost lookup, maintenance schedule. No signup, no popups."
  path="/"
>
  {/* Hero — short, no buttons. Tool grid below IS the menu (Cluster Style Guide §4). */}
  <section class="bg-parchment">
    <div class="mx-auto max-w-6xl px-5 pt-12 pb-9">
      <p class="label text-accent-deep">Built by The STR Ledger</p>
      <h1 class="mt-3 text-h1 font-serif text-navy max-w-3xl leading-tight">
        Free tools for active short-term rental operators<span class="period-accent">.</span>
      </h1>
      <p class="mt-4 text-lead text-ink-2 max-w-2xl">
        Seven operational tools. Three printable PDFs. URL-stateful, shareable, printable. No signup, no popups, no exit-intent. Pick one.
      </p>
    </div>
  </section>

  {/* 7-tool grid — page IS the menu. Per Cluster Style Guide §4. */}
  <section class="bg-parchment-light border-t border-rule">
    <div class="mx-auto max-w-6xl px-5 py-9">
      <p class="label text-accent-deep mb-4">Tools</p>
      <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {toolsList.map(t => (
          <li>
            <a
              href={t.path}
              class="group block h-full rounded-md border border-rule bg-parchment p-5 no-underline hover:border-accent hover:shadow-card transition-all duration-std focus:outline-none focus:shadow-focus"
            >
              <p class="font-serif text-h3 text-navy leading-snug">{t.shortName}</p>
              <p class="mt-2 text-small text-ink-2 leading-snug">{t.blurb}</p>
              <p class="mt-4 text-caption text-accent-deep group-hover:text-accent flex items-center gap-1">
                Open
                <span class="inline-block transition-transform duration-std group-hover:translate-x-0.5" aria-hidden="true">→</span>
              </p>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  {/* Lead magnet teaser strip — three PDFs. */}
  <section class="bg-parchment border-t border-rule">
    <div class="mx-auto max-w-6xl px-5 py-9">
      <p class="label text-accent-deep mb-2">Free downloads</p>
      <p class="font-serif text-h2 text-navy max-w-2xl leading-tight">
        Three printable PDFs for the laundry-room wall.
      </p>
      <p class="mt-3 text-small text-ink-2 max-w-2xl">
        Cleaner SOP, supply par-level sheet, maintenance checklist. Subscribe once; we'll email each PDF the day it ships. Preview releases available now.
      </p>
      <ul class="mt-6 grid grid-cols-1 md:grid-cols-3 gap-4">
        {magnets.map(m => (
          <li>
            <a
              href={m.href}
              class="group block h-full rounded-md border border-rule bg-parchment-light p-5 no-underline hover:border-accent hover:shadow-card transition-all duration-std focus:outline-none focus:shadow-focus"
            >
              <p class="font-serif text-h3 text-navy leading-snug">{m.title}</p>
              <p class="mt-2 text-small text-ink-2 leading-snug">{m.blurb}</p>
              <p class="mt-4 text-caption text-accent-deep group-hover:text-accent flex items-center gap-1">
                Get the PDF
                <span class="inline-block transition-transform duration-std group-hover:translate-x-0.5" aria-hidden="true">→</span>
              </p>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  {/* Why this exists — short, no fluff */}
  <section class="bg-parchment-light border-t border-rule">
    <div class="mx-auto max-w-6xl px-5 py-9 grid grid-cols-1 md:grid-cols-3 gap-7">
      <div>
        <p class="label text-accent-deep">Operational, not flashy</p>
        <p class="mt-3 font-serif text-h3 text-navy leading-snug">Tools, not theater.</p>
        <p class="mt-2 text-small text-ink-2 leading-snug">
          Built for hosts who need to ship a turnover schedule, not for SaaS landing pages with stock photos.
        </p>
      </div>
      <div>
        <p class="label text-accent-deep">Indexable & shareable</p>
        <p class="mt-3 font-serif text-h3 text-navy leading-snug">URL state, every input.</p>
        <p class="mt-2 text-small text-ink-2 leading-snug">
          Bookmark a turnover scenario, share dispatch with your cleaner, hand a maintenance schedule to your handyman.
        </p>
      </div>
      <div>
        <p class="label text-accent-deep">Print + PDF</p>
        <p class="mt-3 font-serif text-h3 text-navy leading-snug">For the laundry-room wall.</p>
        <p class="mt-2 text-small text-ink-2 leading-snug">
          Cleaner SOPs and maintenance schedules ship as PDFs. Print them, tape them up, get on with running the property.
        </p>
      </div>
    </div>
  </section>

  <ClusterFunnelBlock currentCluster="operations" />

  <div class="mx-auto max-w-6xl px-5">
    <AdSlot location="footer" />
  </div>
</Layout>

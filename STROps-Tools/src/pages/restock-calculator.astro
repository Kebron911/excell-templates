---
import Layout from '@/layouts/Layout.astro';
import AppSidebar from '@str/ui-chrome/AppSidebar.astro';
import { siteConfig } from '@/data/site.config';
import { sidebarItems } from '@/data/sidebar-items';
import RestockCalculator from '@components/calculators/RestockCalculator.tsx';
import AdSlot from '@str/ui-funnel/AdSlot.astro';
import EmailCaptureCard from '@str/ui-funnel/EmailCaptureCard.astro';
import STRLedgerCTA from '@str/ui-funnel/STRLedgerCTA.astro';
import RelatedPosts from '@components/funnel/RelatedPosts.astro';
import AffiliateCard from '@components/affiliate/AffiliateCard.astro';
import JsonLd from '@components/seo/JsonLd.astro';
import { buildWebApplication, buildFAQPage } from '@str/seo';
import affiliates from '@data/affiliates.json';

const url = 'https://strops.tools/restock-calculator';
const faqs = [
  { q: 'What does "per guest night" mean?', a: 'How many units one guest uses on a single night. 0.5 toilet paper rolls per guest-night ≈ a roll every two nights.' },
  { q: 'Are these realistic numbers?', a: 'They are starting points. Track actuals for one month and adjust per-property.' },
  { q: 'Can I add my own items?', a: 'Yes — paste any name + per-guest-night rate + average nights into the items textarea.' },
];
---
<Layout title="Airbnb Supply Restock Calculator — strops.tools" description="Project monthly and yearly consumable usage from booking volume." canonical={url} ogImage="/og/restock-calculator.png">
  <Fragment slot="head">
    <JsonLd data={[
      buildWebApplication(siteConfig, { name: 'Airbnb Supply Restock Calculator', description: 'Project consumable usage from booking volume and per-guest rates.', toolPath: '/restock-calculator', applicationCategory: 'BusinessApplication' }),
      buildFAQPage(faqs.map(f => ({ question: f.q, answer: f.a }))),
    ]} />
  </Fragment>
  <div class="mx-auto max-w-6xl px-6 py-10 flex gap-10">
    <article class="flex-1 prose">
      <h1>Supply Restock Calculator</h1>
      <p class="lead">Forecast monthly and yearly consumable use so you stop running out mid-stay.</p>
      <RestockCalculator client:visible />
      <AdSlot siteConfig={siteConfig} location="in-content" />
      <h2>How it works</h2>
      <p>Per-item usage = bookings/month × guests/stay × avg nights × per-guest-night rate. Multiply by 12 for the annual figure. The result is your purchasing baseline — adjust for the long tail (storage, gifts, breakage) per item.</p>
      <RelatedPosts toolKey="restock-calculator" variant="section" />
      <EmailCaptureCard siteConfig={siteConfig} magnet="supply-par" toolSlug="restock-calculator" />
      <h2>How to use this tool</h2>
      <ol>
        <li>Set your monthly booking count and average party size.</li>
        <li>List your consumables — one per line: <code>name,perGuestNight,avgNights</code>.</li>
        <li>Use the monthly figure as your minimum reorder threshold.</li>
      </ol>
      <h2>FAQ</h2>
      {faqs.map(f => <div><h3>{f.q}</h3><p>{f.a}</p></div>)}
      <STRLedgerCTA siteConfig={siteConfig} tool="restock-calculator" />
      <AffiliateCard {...(affiliates as any)['turno']} vendorId="turno" />
      <AdSlot siteConfig={siteConfig} location="footer" />
    </article>
    <AppSidebar siteConfig={siteConfig} items={sidebarItems} current="restock-calculator" />
  </div>
</Layout>

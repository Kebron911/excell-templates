---
import Layout from '@/components/chrome/Layout.astro';
import ClusterFunnelBlock from '@/components/chrome/ClusterFunnelBlock.astro';
import EmailCaptureCard from '@/components/funnel/EmailCaptureCard.astro';
import AdSlot from '@/components/ads/AdSlot.astro';
---

<Layout
  title="STR Supply Par-Level Sheet — printable PDF for linens, towels, consumables"
  description="Free supply par-level reference sheet for short-term rental hosts. Sheet sets, towel sets, toiletries, paper goods — what to stock per property to never run out. Printable PDF."
  path="/supply-par"
>
  <article class="bg-parchment">
    <div class="mx-auto max-w-3xl px-5 pt-12 pb-9 prose">
      <p class="label text-accent-deep">Free PDF · STR Supply Par-Level Sheet</p>
      <h1 class="mt-3 text-h1 font-serif text-navy leading-tight">
        Linen and consumable par levels you can hang in the laundry room<span class="period-accent">.</span>
      </h1>
      <p class="mt-4 text-lead text-ink-2">
        One printable page that tells your cleaner exactly how many sheet sets, towel sets, toiletries, and paper goods to keep on hand — by property, by bed mix, by booking volume.
      </p>

      <h2>What's in it</h2>
      <ul>
        <li><strong>Linen par by bed</strong> — three full sets per king + queen, scaled by turn rate. Sheet sets, pillowcases, mattress protectors.</li>
        <li><strong>Towel par by bath</strong> — bath, hand, washcloth, pool/beach if applicable.</li>
        <li><strong>Toiletries</strong> — shampoo / conditioner / body wash refill cadence, soap rotation, TP and tissue minimums.</li>
        <li><strong>Pantry restock</strong> — coffee, tea, sweetener, dish soap, sponges, paper towels, trash bags.</li>
        <li><strong>"Reorder when below" thresholds</strong> — printable as a wall-mounted reference so cleaners flag low stock before it's a problem.</li>
        <li><strong>Per-month restock calendar</strong> — bookings × consumable burn rate = a month-by-month reorder list.</li>
      </ul>

      <h2>Why operators care</h2>
      <p>
        Running out of clean sheets between turnovers is one of the fastest ways to land a bad review. The par sheet eliminates the math during a busy week — the answer is on the wall, not in the host's head.
      </p>
      <p>
        The form below puts you on the list for v1. The preview release is linked below if you want to see the layout first.
      </p>
    </div>

    <div class="mx-auto max-w-3xl px-5">
      <EmailCaptureCard
        magnet="supply-par-pdf"
        toolSlug="supply-par"
        headline="Get the Supply Par-Level Sheet when v1 ships"
        blurb="One email when the full PDF is ready. No newsletter spam."
        cta="Send me the PDF"
      />
    </div>

    <div class="mx-auto max-w-3xl px-5 prose">
      <h2>Preview release (stub PDF)</h2>
      <p>
        Want to see the layout before you subscribe? Download the preview release — abbreviated content, full format.
      </p>
      <p>
        <a
          href="/pdf/supply-par-v0.pdf"
          class="font-mono no-underline border border-rule bg-parchment-light hover:border-accent rounded-md px-4 py-2 inline-block text-navy"
          download
        >
          Download Supply-Par-preview.pdf →
        </a>
      </p>

      <h2>Pairs well with</h2>
      <ul>
        <li><a href="/linen-par">Linen par calculator</a> — tune sheet/towel set counts for your specific king/queen mix.</li>
        <li><a href="/restock-calculator">Restock calculator</a> — booking volume × consumable burn rate = when to reorder.</li>
      </ul>
    </div>

    <div class="mx-auto max-w-3xl px-5">
      <AdSlot location="footer" />
    </div>

    <ClusterFunnelBlock currentCluster="operations" />
  </article>
</Layout>

<style>
  .prose :global(h2) { font-family: var(--font-display); font-size: var(--t-h2-size); color: var(--brand-navy); margin-top: var(--sp-7); margin-bottom: var(--sp-3); line-height: 1.1; }
  .prose :global(p) { color: var(--fg-1); margin-bottom: var(--sp-3); line-height: 1.6; }
  .prose :global(ul) { margin: var(--sp-3) 0 var(--sp-4); padding-left: var(--sp-5); }
  .prose :global(li) { margin-bottom: var(--sp-2); line-height: 1.55; }
  .prose :global(strong) { color: var(--brand-navy); font-weight: 600; }
  .prose :global(a) { color: var(--brand-navy); text-decoration: underline; text-decoration-color: var(--brand-gold); text-underline-offset: 3px; }
</style>

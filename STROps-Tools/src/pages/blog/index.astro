---
import Layout from '@/layouts/Layout.astro';
import JsonLd from '@components/seo/JsonLd.astro';
import { buildOrganization } from '@str/seo';
import { siteConfig } from '@/data/site.config';
import { getCollection } from 'astro:content';

const all = await getCollection('posts');
const posts = all
  .map((p) => ({
    slug: p.id.replace(/\.mdx?$/, ''),
    ...p.data,
  }))
  .sort((a, b) => (a.datePublished < b.datePublished ? 1 : -1));

const categoryLabels: Record<string, string> = {
  operations: 'Operations',
  turnover: 'Turnover',
  cleaning: 'Cleaning',
  access: 'Access',
  supply: 'Supply',
  maintenance: 'Maintenance',
  damage: 'Damage',
};

const formatDate = (iso: string) =>
  new Date(iso + 'T12:00:00Z').toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
    timeZone: 'UTC',
  });

const url = 'https://strops.tools/blog';
const description =
  'Field notes on running short-term rentals. Turnover math, cleaner SOPs, smart-lock workflows, supply pars, replacement cost, and maintenance cadence — written for hosts who already operate.';

const blogLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'strops.tools — Operations Notebook',
  url,
  description,
  publisher: buildOrganization(siteConfig),
  blogPost: posts.map((p) => ({
    '@type': 'BlogPosting',
    headline: p.title,
    url: `https://strops.tools/blog/${p.slug}`,
    datePublished: p.datePublished,
    dateModified: p.dateModified ?? p.datePublished,
    author: { '@type': 'Person', name: p.author },
  })),
};
---
<Layout
  title="Blog — strops.tools"
  description={description}
  canonical={url}
  ogImage="/og/blog.png"
>
  <Fragment slot="head">
    <JsonLd data={[buildOrganization(siteConfig), blogLd]} />
    <link rel="alternate" type="application/rss+xml" title="strops.tools" href="/feed.xml" />
  </Fragment>

  <section class="mx-auto max-w-5xl px-6 py-16">
    <div class="text-label uppercase tracking-widest text-accent mb-3">Operations notebook</div>
    <h1 class="display text-5xl mb-3 leading-tight">
      Operations, written down<span class="period-gold">.</span>
    </h1>
    <p class="lead text-xl text-ink2 max-w-2xl">
      Tight turnovers, cleaner accountability, rolling lock codes, par levels, replacement
      costs. Each post pairs with one of the tools on this site, so you can read the
      reasoning, then run the math.
    </p>
    <a
      href="/feed.xml"
      class="mt-5 inline-flex items-center gap-2 text-sm text-ink2 no-underline hover:text-ink group"
    >
      Subscribe via RSS
      <span
        class="text-accent inline-block transition-transform duration-200 group-hover:translate-x-0.5"
        aria-hidden="true"
      >→</span>
    </a>
  </section>

  <section class="border-t border-rule bg-parchment-alt">
    <div class="mx-auto max-w-5xl px-6 py-12">
      {posts.length === 0 ? (
        <p class="text-ink2">No posts yet — check back soon.</p>
      ) : (
        <ul class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {posts.map((post) => (
            <li>
              <a
                href={`/blog/${post.slug}`}
                class="group block h-full border border-rule bg-parchment p-6 no-underline hover:border-accent transition-colors duration-200"
              >
                <div class="flex items-center gap-3 text-xs text-ink3">
                  <span class="text-label uppercase tracking-widest text-accent">
                    {categoryLabels[post.category] ?? post.category}
                  </span>
                  <span aria-hidden="true">·</span>
                  <time datetime={post.datePublished} class="font-mono">
                    {formatDate(post.datePublished)}
                  </time>
                  <span aria-hidden="true">·</span>
                  <span class="font-mono">{post.readMinutes} min</span>
                </div>
                <p class="mt-3 font-semibold text-lg text-navy leading-snug">
                  {post.title}
                </p>
                <p class="mt-2 text-sm text-ink2 leading-snug">{post.description}</p>
                <p class="mt-4 text-xs text-accent flex items-center gap-1">
                  Read
                  <span
                    class="inline-block transition-transform duration-200 group-hover:translate-x-0.5"
                    aria-hidden="true"
                  >→</span>
                </p>
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>
</Layout>

<style>
  .text-navy { color: var(--brand-navy); }
</style>

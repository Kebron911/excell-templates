---
import '@/styles/global.css';
import Header from '@components/chrome/Header.astro';
import Footer from '@components/chrome/Footer.astro';
import FunnelBand from '@components/chrome/FunnelBand.astro';
import ClusterFunnelBlock from '@components/funnel/ClusterFunnelBlock.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  showCluster?: boolean;
}
const { title, description, canonical, ogImage = '/og/default.png', showCluster = true } = Astro.props;
const url = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const ga4Id = import.meta.env.PUBLIC_GA4_ID;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="canonical" href={url} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="alternate" type="application/rss+xml" title="STR Ops Tools — Blog" href="/feed.xml" />
    {ga4Id && (
      <>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`}></script>
        <script is:inline define:vars={{ ga4Id }}>
          window.dataLayer = window.dataLayer || [];
          window.gtag = function () { window.dataLayer.push(arguments); };
          gtag('js', new Date());
          gtag('config', ga4Id, {
            linker: {
              domains: [
                'strops.tools',
                'strguests.tools',
                'strhost.tools',
                'strbuyers.tools',
                'thestrledger.com',
              ],
            },
          });
        </script>
      </>
    )}
    <slot name="head" />
  </head>
  <body>
    <Header />
    <main id="main"><slot /></main>
    {showCluster && <ClusterFunnelBlock currentCluster="operations" />}
    <FunnelBand />
    <Footer />
  </body>
</html>

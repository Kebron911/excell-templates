# =============================================================================
# STR Empire — Single Root Env File
# =============================================================================
#
# This is the ONE file you edit. Run `pnpm sync:env` after changing values
# (pnpm install also runs it as a postinstall hook). The script regenerates
# every subproject's .env.local from this file using env.config.json.
#
# Copy this file to `.env` (no .example) and fill in values.
#
# CONVENTION:
#   - Shared keys (one value, multiple projects): no prefix
#   - Per-project keys: prefixed with the project name
#       STRLAWS_*, STRGUESTS_*, STRBUYERS_*, STRLISTINGAUDIT_*,
#       STRMANUALS_*, STROPS_*, EMPIRE_CONSOLE_*
#
# DO NOT COMMIT .env (only this .example). The check happens in pre-commit.
# =============================================================================


# ---------- SHARED: AI providers ----------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
FIRECRAWL_API_KEY=

# ---------- SHARED: Email + marketing ----------
RESEND_API_KEY=
RESEND_FROM_EMAIL=alerts@strlaws.com
INFLUENCERSOFT_API_KEY=
INFLUENCERSOFT_BASE_URL=https://kebron.influencersoft.com

# ---------- SHARED: Billing (Stripe account is one; webhooks are per-project) ----------
STRIPE_SECRET_KEY=

# ---------- SHARED: Database (one Hostinger MySQL; database name is per-project) ----------
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=

# ---------- SHARED: Crypto secrets ----------
IP_HASH_SALT=
EMAIL_VERIFY_SECRET=
SLACK_WEBHOOK_URL=

# ---------- SHARED: Apify (listing scraping) ----------
APIFY_TOKEN=

# ---------- SHARED: n8n (one self-hosted instance) ----------
N8N_BASE_URL=
N8N_API_KEY=

# ---------- SHARED: Etsy (one shop) ----------
ETSY_API_KEY=
ETSY_OAUTH_SECRET=
ETSY_SHOP_ID=
ETSY_ACCESS_TOKEN=
ETSY_REFRESH_TOKEN=
ETSY_TOKEN_EXPIRES_AT=


# =============================================================================
# PER-PROJECT KEYS
# =============================================================================

# ---------- STRLaws (strlaws.com) ----------
STRLAWS_MYSQL_DATABASE=strlaws
STRLAWS_STRIPE_WEBHOOK_SECRET=
STRLAWS_STRIPE_PRICE_ID_MONTHLY=
STRLAWS_STRIPE_PRICE_ID_ANNUAL=
STRLAWS_INFLUENCERSOFT_LIST_ID_ALERTS=
STRLAWS_ADMIN_TOKEN=
STRLAWS_PUBLIC_GA4_ID=
STRLAWS_PUBLIC_SITE_URL=https://strlaws.com

# ---------- STRGuests-Tools (strguests.tools) ----------
STRGUESTS_MYSQL_DATABASE=strguests
STRGUESTS_PUBLIC_ESP_WEBHOOK=
STRGUESTS_PUBLIC_API_BASE=
STRGUESTS_PUBLIC_ADSENSE_ENABLED=false
STRGUESTS_PUBLIC_ADSENSE_CLIENT=
STRGUESTS_PUBLIC_GA4_ID=

# ---------- STRBuyers-Tools (strbuyers.tools) ----------
STRBUYERS_MYSQL_DATABASE=strbuyers
STRBUYERS_PORT=3003
STRBUYERS_CORS_ORIGIN=
STRBUYERS_PUBLIC_ESP_WEBHOOK=

# ---------- STRListingAudit-Tools (listingaudit.tools) ----------
STRLISTINGAUDIT_MYSQL_DATABASE=strlistingaudit
STRLISTINGAUDIT_APIFY_AIRBNB_ACTOR=
STRLISTINGAUDIT_ADMIN_TOKEN=
STRLISTINGAUDIT_EMAIL_PROVIDER=resend
STRLISTINGAUDIT_PUBLIC_ESP_WEBHOOK=
STRLISTINGAUDIT_PUBLIC_GA4_ID=

# ---------- STRManuals/site (strmanuals.com) ----------
STRMANUALS_SITE=https://strmanuals.com
STRMANUALS_STRIPE_SECRET=
STRMANUALS_STRIPE_WEBHOOK_SECRET=
STRMANUALS_STRIPE_PRICE_BUNDLE=
STRMANUALS_STRIPE_PRICE_TAX_01=
STRMANUALS_STRIPE_PRICE_TAX_02=
STRMANUALS_STRIPE_PRICE_REV_01=
STRMANUALS_STRIPE_PRICE_REV_02=
STRMANUALS_STRIPE_PRICE_LGL_01=
STRMANUALS_STRIPE_LINK_TAX_01=
STRMANUALS_STRIPE_LINK_TAX_02=
STRMANUALS_STRIPE_LINK_REV_01=
STRMANUALS_STRIPE_LINK_REV_02=
STRMANUALS_STRIPE_LINK_LGL_01=
STRMANUALS_STRIPE_LINK_BUNDLE=
STRMANUALS_DOWNLOAD_HMAC_SECRET=
STRMANUALS_PUBLIC_N8N_WEBHOOK_BASE=
STRMANUALS_DOWNLOAD_HASH=

# ---------- STROps-Tools (strops.tools) ----------
STROPS_PUBLIC_ADSENSE_ENABLED=false
STROPS_PUBLIC_ADSENSE_CLIENT=
STROPS_PUBLIC_ESP_ENDPOINT=

# ---------- Empire console ----------
EMPIRE_CONSOLE_PUBLIC_CONSOLE_BASE_URL=

# --- PinForge ---
OPENAI_API_KEY=sk-replace-me
OPENAI_MODEL=gpt-4o-mini
N8N_BASE_URL=https://n8n.example.com
N8N_PIN_KEY=replace-me
UNSPLASH_ACCESS_KEY=replace-me
PINFORGE_OUTPUT_DIR=./dist/pins
PINFORGE_JOBS_DIR=./dist/jobs
PINFORGE_QUEUE_CONCURRENCY=3
PINFORGE_QUEUE_INTERVAL_CAP=10
PINFORGE_QUEUE_INTERVAL_MS=60000
PINFORGE_N8N_TIMEOUT_MS=60000

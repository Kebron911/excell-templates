# strmanuals.com — environment variables
# Copy to .env and fill in real values for local dev. Production lives in Hostinger env.

# === Site ===
SITE=http://localhost:4321
# In production: SITE=https://strmanuals.com

# === Stripe ===
STRIPE_SECRET=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — create in Stripe Dashboard, paste here
STRIPE_PRICE_TAX_01=price_...
STRIPE_PRICE_TAX_02=price_...
STRIPE_PRICE_REV_01=price_...
STRIPE_PRICE_REV_02=price_...
STRIPE_PRICE_LGL_01=price_...
STRIPE_PRICE_BUNDLE=price_...

# === Download token signing ===
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DOWNLOAD_HMAC_SECRET=replace-with-32-byte-hex

# === n8n (cluster integration) ===
N8N_WEBHOOK_URL=https://n8n.thestrledger.com
N8N_WEBHOOK_AUTH=
# N8N_WEBHOOK_AUTH is the Bearer token n8n expects on inbound webhooks (optional;
# leave empty if n8n uses a query-string secret per workflow instead)

# === Analytics ===
# GA4 measurement ID for the strmanuals web stream (unset for local dev)
PUBLIC_GA4_ID=

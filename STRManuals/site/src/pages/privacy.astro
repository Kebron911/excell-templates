---
import Base from '../layouts/Base.astro';
---
<Base title="Privacy">
  <section class="container-page py-20">
    <div class="max-w-2xl mx-auto measure">
      <p class="eyebrow mb-6">Policy</p>
      <h1 class="mb-10">Privacy.</h1>

      <p class="mb-6">
        We collect your email at checkout (for receipts and download links) and
        your card details via Stripe. We never see or store card numbers — Stripe
        handles all of it.
      </p>
      <p class="mb-6">
        If you sign up for the email list, we send you the free PDF and one
        manual preview every other week. Unsubscribe in one click; we don't make
        you log in or fill anything out.
      </p>
      <p class="mb-6">
        Analytics is privacy-friendly Plausible — no cookies, no fingerprinting,
        no data sold. We see aggregate traffic, not who you are.
      </p>
      <p class="mb-6">
        PDFs are watermarked with your email and order ID. This is the only place
        your email appears on the file itself.
      </p>
      <p class="mb-6" style="color: var(--color-mute);">
        Questions? Email <a href="mailto:hello@strmanuals.com" class="underline">hello@strmanuals.com</a>.
      </p>
    </div>
  </section>
</Base>

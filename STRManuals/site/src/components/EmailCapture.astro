---
interface Props {
  heading?: string;
  subhead?: string;
  cta?: string;
  variant?: 'block' | 'inline';
  /** n8n webhook path (under PUBLIC_N8N_WEBHOOK_BASE). Default = the tax-loophole lead magnet (W08). */
  webhookPath?: string;
}
const {
  heading = 'Free: The STR Tax Loophole Explainer',
  subhead = "The 8-page primer pulled from chapter 1 of the playbook. We'll send one new manual preview every other week.",
  cta = 'Send me the PDF',
  variant = 'block',
  webhookPath = '/webhook/lead-magnet-strmanuals-tax-explainer',
} = Astro.props;

// Path B: form posts directly to n8n (same pattern as /free). PUBLIC_-prefixed
// env is inlined at build time. Build hard-fails below if missing.
const N8N_BASE = import.meta.env.PUBLIC_N8N_WEBHOOK_BASE ?? '';
if (!N8N_BASE && import.meta.env.PROD) {
  throw new Error('EmailCapture: PUBLIC_N8N_WEBHOOK_BASE is required in production builds');
}
const formAction = N8N_BASE
  ? `${N8N_BASE.replace(/\/$/, '')}${webhookPath}`
  : '#';
---
<section
  class={variant === 'block' ? 'container-page py-16' : ''}
>
  <div
    class="p-10 md:p-12"
    style="background: var(--color-paper-2); border: 1px solid var(--color-rule);"
  >
    <p class="eyebrow mb-3">Free PDF</p>
    <h2 class="mb-3" style="font-size: 2rem;">{heading}</h2>
    <p class="measure mb-6" style="color: var(--color-mute);">{subhead}</p>
    {/* PAUSED — n8n W08 lead-magnet workflow not active; PDF not yet on /dl/.
        Revert this stub when STR_StrManuals_LeadMagnet_Tax is live + PDF deployed. */}
    <div class="max-w-2xl" style="border: 1px solid var(--color-rule); padding: 14px 16px; border-radius: 6px;">
      <p class="font-medium" style="margin-bottom: 4px;">Email delivery is paused.</p>
      <p class="text-sm" style="color: var(--color-mute); margin: 0;">
        We're wiring email delivery this week so nothing gets dropped. Bookmark the page,
        or email
        <a href="mailto:hello@thestrledger.com?subject=Send%20me%20the%20tax%20explainer">hello@thestrledger.com</a>
        and we'll send it manually.
      </p>
    </div>
  </div>
</section>

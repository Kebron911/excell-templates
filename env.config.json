{
  "$schema": "./env.config.schema.json",
  "_doc": [
    "Central env mapping. Edits ONLY happen to .env at repo root.",
    "Run `pnpm sync:env` (or just `pnpm install`) to fan-out per-project .env.local files.",
    "",
    "Each entry maps a project (workspace directory) to the keys it needs.",
    "Three rename forms:",
    "  1) \"FOO\"                       — copy root FOO into project FOO",
    "  2) {from: \"X_FOO\", to: \"FOO\"} — rename project-prefixed root key to local name",
    "  3) {literal: \"FOO=bar\"}        — hardcode (rare; usually for dev defaults)"
  ],
  "shared": [
    "ANTHROPIC_API_KEY",
    "OPENAI_API_KEY",
    "GEMINI_API_KEY",
    "STRIPE_SECRET_KEY",
    "RESEND_API_KEY",
    "RESEND_FROM_EMAIL",
    "INFLUENCERSOFT_API_KEY",
    "INFLUENCERSOFT_BASE_URL",
    "FIRECRAWL_API_KEY",
    "MYSQL_HOST",
    "MYSQL_PORT",
    "MYSQL_USER",
    "MYSQL_PASSWORD",
    "IP_HASH_SALT",
    "EMAIL_VERIFY_SECRET",
    "SLACK_WEBHOOK_URL",
    "APIFY_TOKEN",
    "N8N_BASE_URL",
    "N8N_API_KEY",
    "ETSY_API_KEY",
    "ETSY_OAUTH_SECRET",
    "ETSY_SHOP_ID",
    "ETSY_ACCESS_TOKEN",
    "ETSY_REFRESH_TOKEN",
    "ETSY_TOKEN_EXPIRES_AT"
  ],
  "projects": {
    "STRLaws": {
      "include": [
        { "from": "STRLAWS_MYSQL_DATABASE", "to": "MYSQL_DATABASE" },
        { "from": "STRLAWS_STRIPE_WEBHOOK_SECRET", "to": "STRIPE_WEBHOOK_SECRET" },
        { "from": "STRLAWS_STRIPE_PRICE_ID_MONTHLY", "to": "STRIPE_PRICE_ID_MONTHLY" },
        { "from": "STRLAWS_STRIPE_PRICE_ID_ANNUAL", "to": "STRIPE_PRICE_ID_ANNUAL" },
        { "from": "STRLAWS_INFLUENCERSOFT_LIST_ID_ALERTS", "to": "INFLUENCERSOFT_LIST_ID_ALERTS" },
        { "from": "STRLAWS_ADMIN_TOKEN", "to": "ADMIN_TOKEN" },
        { "from": "STRLAWS_PUBLIC_GA4_ID", "to": "PUBLIC_GA4_ID" },
        { "from": "STRLAWS_PUBLIC_SITE_URL", "to": "PUBLIC_SITE_URL" },
        { "literal": "PORT=3001" },
        { "literal": "DB_HOST=$MYSQL_HOST" },
        { "literal": "DB_PORT=$MYSQL_PORT" },
        { "literal": "DB_USER=$MYSQL_USER" },
        { "literal": "DB_PASSWORD=$MYSQL_PASSWORD" },
        { "literal": "DB_NAME=$MYSQL_DATABASE" }
      ]
    },
    "STRGuests-Tools": {
      "include": [
        { "from": "STRGUESTS_MYSQL_DATABASE", "to": "MYSQL_DATABASE" },
        { "from": "STRGUESTS_PUBLIC_ESP_WEBHOOK", "to": "PUBLIC_ESP_WEBHOOK" },
        { "from": "STRGUESTS_PUBLIC_API_BASE", "to": "PUBLIC_API_BASE" },
        { "from": "STRGUESTS_PUBLIC_ADSENSE_ENABLED", "to": "PUBLIC_ADSENSE_ENABLED" },
        { "from": "STRGUESTS_PUBLIC_ADSENSE_CLIENT", "to": "PUBLIC_ADSENSE_CLIENT" },
        { "from": "STRGUESTS_PUBLIC_GA4_ID", "to": "PUBLIC_GA4_ID" }
      ]
    },
    "STRBuyers-Tools": {
      "include": [
        { "from": "STRBUYERS_MYSQL_DATABASE", "to": "DB_NAME" },
        { "from": "STRBUYERS_PORT", "to": "PORT" },
        { "from": "STRBUYERS_CORS_ORIGIN", "to": "CORS_ORIGIN" },
        { "from": "STRBUYERS_PUBLIC_ESP_WEBHOOK", "to": "PUBLIC_ESP_WEBHOOK" },
        { "literal": "DB_HOST=$MYSQL_HOST" },
        { "literal": "DB_PORT=$MYSQL_PORT" },
        { "literal": "DB_USER=$MYSQL_USER" },
        { "literal": "DB_PASS=$MYSQL_PASSWORD" }
      ]
    },
    "STRListingAudit-Tools": {
      "include": [
        { "from": "STRLISTINGAUDIT_MYSQL_DATABASE", "to": "MYSQL_DATABASE" },
        { "from": "STRLISTINGAUDIT_APIFY_AIRBNB_ACTOR", "to": "APIFY_AIRBNB_ACTOR" },
        { "from": "STRLISTINGAUDIT_ADMIN_TOKEN", "to": "ADMIN_TOKEN" },
        { "from": "STRLISTINGAUDIT_EMAIL_PROVIDER", "to": "EMAIL_PROVIDER" },
        { "from": "STRLISTINGAUDIT_PUBLIC_ESP_WEBHOOK", "to": "PUBLIC_ESP_WEBHOOK" },
        { "from": "STRLISTINGAUDIT_PUBLIC_GA4_ID", "to": "PUBLIC_GA4_ID" },
        { "literal": "PORT=3002" }
      ]
    },
    "STRManuals/site": {
      "include": [
        { "from": "STRMANUALS_SITE", "to": "SITE" },
        { "from": "STRMANUALS_STRIPE_SECRET", "to": "STRIPE_SECRET" },
        { "from": "STRMANUALS_STRIPE_WEBHOOK_SECRET", "to": "STRIPE_WEBHOOK_SECRET" },
        { "from": "STRMANUALS_STRIPE_PRICE_BUNDLE", "to": "STRIPE_PRICE_BUNDLE" },
        { "from": "STRMANUALS_STRIPE_PRICE_TAX_01", "to": "STRIPE_PRICE_TAX_01" },
        { "from": "STRMANUALS_STRIPE_PRICE_TAX_02", "to": "STRIPE_PRICE_TAX_02" },
        { "from": "STRMANUALS_STRIPE_PRICE_REV_01", "to": "STRIPE_PRICE_REV_01" },
        { "from": "STRMANUALS_STRIPE_PRICE_REV_02", "to": "STRIPE_PRICE_REV_02" },
        { "from": "STRMANUALS_STRIPE_PRICE_LGL_01", "to": "STRIPE_PRICE_LGL_01" },
        { "from": "STRMANUALS_STRIPE_LINK_TAX_01", "to": "STRIPE_LINK_TAX_01" },
        { "from": "STRMANUALS_STRIPE_LINK_TAX_02", "to": "STRIPE_LINK_TAX_02" },
        { "from": "STRMANUALS_STRIPE_LINK_REV_01", "to": "STRIPE_LINK_REV_01" },
        { "from": "STRMANUALS_STRIPE_LINK_REV_02", "to": "STRIPE_LINK_REV_02" },
        { "from": "STRMANUALS_STRIPE_LINK_LGL_01", "to": "STRIPE_LINK_LGL_01" },
        { "from": "STRMANUALS_STRIPE_LINK_BUNDLE", "to": "STRIPE_LINK_BUNDLE" },
        { "from": "STRMANUALS_DOWNLOAD_HMAC_SECRET", "to": "DOWNLOAD_HMAC_SECRET" },
        { "from": "STRMANUALS_PUBLIC_N8N_WEBHOOK_BASE", "to": "PUBLIC_N8N_WEBHOOK_BASE" },
        { "from": "STRMANUALS_DOWNLOAD_HASH", "to": "STRMANUALS_DOWNLOAD_HASH" }
      ]
    },
    "STROps-Tools": {
      "include": [
        { "from": "STROPS_PUBLIC_ADSENSE_ENABLED", "to": "PUBLIC_ADSENSE_ENABLED" },
        { "from": "STROPS_PUBLIC_ADSENSE_CLIENT", "to": "PUBLIC_ADSENSE_CLIENT" },
        { "from": "STROPS_PUBLIC_ESP_ENDPOINT", "to": "PUBLIC_ESP_ENDPOINT" }
      ]
    },
    "STRHost-Tools": {
      "include": []
    },
    "STRLedger": {
      "include": []
    },
    "tools/empire-console": {
      "include": [
        { "from": "EMPIRE_CONSOLE_PUBLIC_CONSOLE_BASE_URL", "to": "PUBLIC_CONSOLE_BASE_URL" }
      ]
    }
  }
}
